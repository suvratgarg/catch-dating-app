{
  "name": "catch-web-workspace",
  "private": true,
  "type": "module",
  "workspaces": [
    "admin",
    "website"
  ],
  "scripts": {
    "web:admin:dev": "npm --workspace catch-admin run dev",
    "web:admin:build": "npm --workspace catch-admin run build",
    "web:admin:check:boundaries": "npm --workspace catch-admin run check:boundaries",
    "web:admin:typecheck": "npm --workspace catch-admin run typecheck",
    "web:marketing:dev": "npm --workspace catch-marketing run dev",
    "web:marketing:build": "npm --workspace catch-marketing run build",
    "web:marketing:typecheck": "npm --workspace catch-marketing run typecheck",
    "web:build": "npm run web:marketing:build && npm run web:admin:build",
    "web:typecheck": "npm run web:marketing:typecheck && npm run web:admin:typecheck",
    "web:tokens": "dart run tool/design_tokens.dart",
    "web:tokens:check": "dart run tool/design_tokens.dart --check",
    "design:components:check": "node tool/design/check_component_contracts.mjs",
    "design:widgets:classify": "node tool/design/generate_widget_classification.mjs",
    "design:widgets:check": "node tool/design/check_widget_classification.mjs",
    "design:widgets:variants": "node tool/design/generate_widget_variant_inventory.mjs",
    "design:widgets:variants:check": "node tool/design/generate_widget_variant_inventory.mjs --check",
    "design:parity:check": "node tool/design/check_design_parity.mjs --check"
  },
  "devDependencies": {
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "4.61.1"
  }
}
