{
  "name": "catch-web-workspace",
  "private": true,
  "type": "module",
  "workspaces": [
    "admin",
    "website"
  ],
  "scripts": {
    "web:admin:dev": "npm --workspace catch-admin run dev",
    "web:admin:build": "npm --workspace catch-admin run build",
    "web:admin:typecheck": "npm --workspace catch-admin run typecheck",
    "web:marketing:dev": "npm --workspace catch-marketing run dev",
    "web:marketing:build": "npm --workspace catch-marketing run build",
    "web:marketing:typecheck": "npm --workspace catch-marketing run typecheck",
    "web:build": "npm run web:marketing:build && npm run web:admin:build",
    "web:typecheck": "npm run web:marketing:typecheck && npm run web:admin:typecheck",
    "web:tokens": "dart run tool/design_tokens.dart",
    "web:tokens:check": "dart run tool/design_tokens.dart --check"
  }
}
