    {
      "id": "APP-TARGET-IOS-GITHUB-CUTOVER-001",
      "status": "blocked_external",
      "reason": "GitHub Actions is the canonical iOS owner, but cutover remains externally unproven until both role uploads process and both legacy Xcode Cloud workflows are disabled.",
      "externalPrerequisites": [
        "process a GitHub-uploaded Consumer TestFlight build",
        "process a GitHub-uploaded Host TestFlight build",
        "disable the app-scoped Consumer and Host workflows whose exact App Store Connect API name is Default",
        "select and record the intended Consumer and Host internal TestFlight groups"
      ],
      "githubBuildNumberNamespace": "<UTC YYYYMMDD><8-digit GitHub run><2-digit attempt>",
      "removalProof": [
        "consumer-prod/Release-prod archive and processed build",
        "host-prod/Release-host-prod archive",
        "com.catchdates.host processed build",
        "processing receipts bound to one Mobile Internal Release run",
        "both legacy Xcode Cloud workflows disabled",
        "tester-group assignments"
      ]
    },
    {
      "id": "APP-TARGET-ANDROID-PLAY-001",
      "status": "blocked_external",
      "reason": "The unified workflow, Android Publisher API, dedicated zero-project-role service account, and prod-mobile OIDC binding are ready, but Play internal upload stays disabled until both Play app records grant app-scoped testing-track access.",
      "externalPrerequisites": [
        "create com.catchdates.app and com.catchdates.host Play records",
        "enroll both apps in Play App Signing",
        "grant GOOGLE_PLAY_SERVICE_ACCOUNT_EMAIL release access to both apps",
        "configure both internal tester lists",
        "dispatch probe_play_access for both qa tracks and keep the edit uncommitted",
        "set GOOGLE_PLAY_UPLOAD_ENABLED=true only after both authenticated access probes pass"
      ],
      "playTrack": "qa",
      "removalProof": [
        "consumer signed AAB processed on Play internal testing",
        "host signed AAB processed on Play internal testing",
        "Play signing fingerprints registered with Firebase and App Check",
        "both internal builds installed and launched"
