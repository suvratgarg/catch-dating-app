{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://catch.app/tool/organizer_intake/schemas/organizer_curation_decisions.schema.json",
  "title": "OrganizerCurationDecisionBatch",
  "description": "Manual QA curation decisions that resolve duplicate organizer candidates, false-positive surfaces, and split-required surfaces before review artifacts are generated.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "curationBatchId", "decidedAt", "reviewer", "operations"],
  "properties": {
    "schemaVersion": {"const": 1},
    "curationBatchId": {"$ref": "#/definitions/slug"},
    "decidedAt": {"type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$"},
    "reviewer": {"type": "string", "minLength": 1, "maxLength": 120},
    "operations": {
      "type": "array",
      "items": {
        "oneOf": [
          {"$ref": "#/definitions/attachSurface"},
          {"$ref": "#/definitions/mergeEntity"},
          {"$ref": "#/definitions/suppressEntity"},
          {"$ref": "#/definitions/surfaceDecision"},
          {"$ref": "#/definitions/splitSurface"}
        ]
      }
    }
  },
  "definitions": {
    "slug": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "reason": {
      "type": "string",
      "minLength": 1,
      "maxLength": 500
    },
    "urlOrNull": {
      "anyOf": [
        {"type": "string", "format": "uri"},
        {"type": "null"}
      ]
    },
    "attachSurface": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "entityId", "sourceCandidateId", "surface", "reason"],
      "properties": {
        "type": {"const": "attach_surface"},
        "entityId": {"$ref": "#/definitions/slug"},
        "sourceCandidateId": {"type": "string", "minLength": 1, "maxLength": 240},
        "surface": {"$ref": "#/definitions/surface"},
        "reason": {"$ref": "#/definitions/reason"}
      }
    },
    "mergeEntity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "sourceEntityId", "targetEntityId", "reason"],
      "properties": {
        "type": {"const": "merge_entity"},
        "sourceEntityId": {"$ref": "#/definitions/slug"},
        "targetEntityId": {"$ref": "#/definitions/slug"},
        "reason": {"$ref": "#/definitions/reason"}
      }
    },
    "suppressEntity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "entityId", "reason"],
      "properties": {
        "type": {"const": "suppress_entity"},
        "entityId": {"$ref": "#/definitions/slug"},
        "reason": {"$ref": "#/definitions/reason"}
      }
    },
    "surfaceDecision": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "entityId", "surfaceId", "decision", "reason"],
      "properties": {
        "type": {"const": "surface_decision"},
        "entityId": {"$ref": "#/definitions/slug"},
        "surfaceId": {"$ref": "#/definitions/slug"},
        "decision": {
          "type": "string",
          "enum": [
            "accept_primary",
            "accept_secondary",
            "reject_wrong_entity",
            "mark_ambiguous",
            "mark_historical"
          ]
        },
        "reason": {"$ref": "#/definitions/reason"}
      }
    },
    "splitSurface": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "entityId", "surfaceId", "newEntityId", "reason"],
      "properties": {
        "type": {"const": "split_surface"},
        "entityId": {"$ref": "#/definitions/slug"},
        "surfaceId": {"$ref": "#/definitions/slug"},
        "newEntityId": {"$ref": "#/definitions/slug"},
        "reason": {"$ref": "#/definitions/reason"}
      }
    },
    "surface": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "surfaceId",
        "platform",
        "surfaceKind",
        "url",
        "normalizedKey",
        "role",
        "status",
        "confidence",
        "crawl",
        "evidenceRefs",
        "notes"
      ],
      "properties": {
        "surfaceId": {"$ref": "#/definitions/slug"},
        "platform": {
          "type": "string",
          "enum": [
            "bookMyShow",
            "district",
            "instagram",
            "linkedin",
            "luma",
            "news",
            "officialWebsite",
            "partiful",
            "sortMyScene",
            "userReport",
            "other"
          ]
        },
        "surfaceKind": {
          "type": "string",
          "enum": [
            "eventListing",
            "eventCalendar",
            "organizerProfile",
            "personProfile",
            "press",
            "socialProfile",
            "website",
            "wrongEntity"
          ]
        },
        "url": {"$ref": "#/definitions/urlOrNull"},
        "normalizedKey": {"type": ["string", "null"], "maxLength": 240},
        "role": {
          "type": "string",
          "enum": ["primary", "secondary", "backup", "historical", "ambiguous", "rejected"]
        },
        "status": {
          "type": "string",
          "enum": ["active", "candidate", "ambiguous", "historical", "rejected"]
        },
        "confidence": {
          "type": "object",
          "additionalProperties": false,
          "required": ["entityMatch", "ownership", "city"],
          "properties": {
            "entityMatch": {"type": "string", "enum": ["low", "medium", "high"]},
            "ownership": {"type": "string", "enum": ["low", "medium", "high"]},
            "city": {"type": "string", "enum": ["low", "medium", "high"]}
          }
        },
        "crawl": {
          "type": "object",
          "additionalProperties": false,
          "required": ["eventDiscoveryStatus", "policy", "supportsEventExtraction"],
          "properties": {
            "eventDiscoveryStatus": {
              "type": "string",
              "enum": ["disabled", "candidate", "approved", "paused"]
            },
            "policy": {"type": "string", "enum": ["manualOnly", "blocked", "apiPreferred"]},
            "supportsEventExtraction": {"type": "boolean"}
          }
        },
        "evidenceRefs": {
          "type": "array",
          "items": {"$ref": "#/definitions/evidenceRef"}
        },
        "notes": {"type": "string", "maxLength": 500}
      }
    },
    "evidenceRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "ref", "description"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["hostDiscoveryRun", "seedClub", "userReportedSearchResult", "manualNote"]
        },
        "ref": {"type": ["string", "null"], "maxLength": 240},
        "description": {"type": "string", "minLength": 1, "maxLength": 400}
      }
    }
  }
}
