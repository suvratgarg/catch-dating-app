{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://catch.app/tool/organizer_intake/schemas/organizer_intake_batch.schema.json",
  "title": "OrganizerIntakeBatch",
  "description": "Private organizer intake batch. This is not the public website listing schema and should not be imported directly into Firestore.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "batchId", "createdAt", "promotionPolicy", "entities"],
  "properties": {
    "schemaVersion": {"const": 1},
    "batchId": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"},
    "createdAt": {"type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$"},
    "promotionPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "policyVersion",
        "publicPromotionDefault",
        "indexingDefault",
        "appVisibilityDefault",
        "crawlDefault"
      ],
      "properties": {
        "policyVersion": {"type": "string", "minLength": 1, "maxLength": 80},
        "publicPromotionDefault": {
          "type": "string",
          "enum": ["manual_admin_review_required"]
        },
        "indexingDefault": {
          "type": "string",
          "enum": ["admin_public_approval_sets_index_follow"]
        },
        "appVisibilityDefault": {
          "type": "string",
          "enum": ["hidden_until_claimed_or_app_approved"]
        },
        "crawlDefault": {
          "type": "string",
          "enum": ["manual_only_disabled"]
        }
      }
    },
    "entities": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/definitions/entity"}
    }
  },
  "definitions": {
    "slug": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "urlOrNull": {
      "anyOf": [
        {"type": "string", "format": "uri"},
        {"type": "null"}
      ]
    },
    "entity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "entityId",
        "displayName",
        "canonicalSlug",
        "aliases",
        "entityKind",
        "priority",
        "reviewStatus",
        "relationshipToCatch",
        "activityDefaults",
        "geographicScope",
        "publicListingIntent",
        "publicDraft",
        "surfaces",
        "dedupeHints",
        "reviewNotes"
      ],
      "properties": {
        "entityId": {"$ref": "#/definitions/slug"},
        "displayName": {"type": "string", "minLength": 1, "maxLength": 160},
        "canonicalSlug": {"$ref": "#/definitions/slug"},
        "aliases": {
          "type": "array",
          "uniqueItems": true,
          "items": {"type": "string", "minLength": 1, "maxLength": 160}
        },
        "entityKind": {
          "type": "string",
          "enum": [
            "brand",
            "clubCommunity",
            "creatorCommunity",
            "eventOrganizer",
            "individual",
            "venue"
          ]
        },
        "priority": {"type": "string", "enum": ["p0", "p1", "p2", "p3"]},
        "reviewStatus": {
          "type": "string",
          "enum": [
            "candidate",
            "needs_admin_review",
            "needs_more_evidence",
            "approved_public",
            "published",
            "claimed",
            "suppressed"
          ]
        },
        "relationshipToCatch": {
          "type": "string",
          "enum": ["unclaimed", "claimPending", "claimed", "internalOnly"]
        },
        "activityDefaults": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "primaryActivityKind",
            "supportedActivityKinds",
            "confidence",
            "derivedFromSurfaceIds"
          ],
          "properties": {
            "primaryActivityKind": {"type": ["string", "null"], "maxLength": 80},
            "supportedActivityKinds": {
              "type": "array",
              "uniqueItems": true,
              "items": {"type": "string", "minLength": 1, "maxLength": 80}
            },
            "confidence": {"type": "string", "enum": ["low", "medium", "high"]},
            "derivedFromSurfaceIds": {
              "type": "array",
              "uniqueItems": true,
              "items": {"$ref": "#/definitions/slug"}
            }
          }
        },
        "geographicScope": {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "primaryMarketSlug", "markets", "countryCodes"],
          "properties": {
            "kind": {
              "type": "string",
              "enum": ["city", "multiCity", "national", "global", "remote"]
            },
            "primaryMarketSlug": {"type": ["string", "null"], "maxLength": 80},
            "markets": {
              "type": "array",
              "items": {"$ref": "#/definitions/market"}
            },
            "countryCodes": {
              "type": "array",
              "minItems": 1,
              "uniqueItems": true,
              "items": {"type": "string", "pattern": "^[A-Z]{2}$"}
            }
          }
        },
        "publicListingIntent": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "canonicalPath",
            "legacyPaths",
            "pageMode",
            "indexOnAdminApproval",
            "appVisibilityOnAdminApproval"
          ],
          "properties": {
            "canonicalPath": {"type": "string", "pattern": "^/organizers/[a-z0-9/-]+/$"},
            "legacyPaths": {
              "type": "array",
              "uniqueItems": true,
              "items": {"type": "string", "pattern": "^/organizers/[a-z0-9/-]+/$"}
            },
            "pageMode": {"type": "string", "enum": ["singleEntity"]},
            "indexOnAdminApproval": {"type": "boolean"},
            "appVisibilityOnAdminApproval": {
              "type": "string",
              "enum": ["hidden", "discoverable"]
            }
          }
        },
        "publicDraft": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "headline",
            "summary",
            "sourceSummary",
            "formats",
            "missingEvidence"
          ],
          "properties": {
            "headline": {"type": ["string", "null"], "maxLength": 160},
            "summary": {"type": ["string", "null"], "maxLength": 800},
            "sourceSummary": {"type": ["string", "null"], "maxLength": 800},
            "formats": {
              "type": "array",
              "maxItems": 12,
              "items": {"type": "string", "minLength": 1, "maxLength": 80}
            },
            "missingEvidence": {
              "type": "array",
              "maxItems": 20,
              "items": {"type": "string", "minLength": 1, "maxLength": 240}
            }
          }
        },
        "surfaces": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/definitions/surface"}
        },
        "dedupeHints": {
          "type": "array",
          "items": {"$ref": "#/definitions/dedupeHint"}
        },
        "reviewNotes": {
          "type": "array",
          "items": {"type": "string", "minLength": 1, "maxLength": 500}
        }
      }
    },
    "market": {
      "type": "object",
      "additionalProperties": false,
      "required": ["marketSlug", "displayName", "countryCode", "eventFilter"],
      "properties": {
        "marketSlug": {"$ref": "#/definitions/slug"},
        "displayName": {"type": "string", "minLength": 1, "maxLength": 120},
        "countryCode": {"type": "string", "pattern": "^[A-Z]{2}$"},
        "eventFilter": {
          "type": "object",
          "additionalProperties": false,
          "required": ["mode", "citySlug"],
          "properties": {
            "mode": {"type": "string", "enum": ["eventCity"]},
            "citySlug": {"$ref": "#/definitions/slug"}
          }
        }
      }
    },
    "surface": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "surfaceId",
        "platform",
        "surfaceKind",
        "url",
        "normalizedKey",
        "role",
        "status",
        "confidence",
        "crawl",
        "evidenceRefs",
        "notes"
      ],
      "properties": {
        "surfaceId": {"$ref": "#/definitions/slug"},
        "platform": {
          "type": "string",
          "enum": [
            "bookMyShow",
            "district",
            "instagram",
            "linkedin",
            "luma",
            "news",
            "officialWebsite",
            "partiful",
            "sortMyScene",
            "userReport",
            "other"
          ]
        },
        "surfaceKind": {
          "type": "string",
          "enum": [
            "eventListing",
            "eventCalendar",
            "organizerProfile",
            "personProfile",
            "press",
            "socialProfile",
            "website",
            "wrongEntity"
          ]
        },
        "url": {"$ref": "#/definitions/urlOrNull"},
        "normalizedKey": {"type": ["string", "null"], "maxLength": 240},
        "role": {
          "type": "string",
          "enum": ["primary", "secondary", "backup", "historical", "ambiguous", "rejected"]
        },
        "status": {
          "type": "string",
          "enum": ["active", "candidate", "ambiguous", "historical", "rejected"]
        },
        "confidence": {
          "type": "object",
          "additionalProperties": false,
          "required": ["entityMatch", "ownership", "city"],
          "properties": {
            "entityMatch": {"type": "string", "enum": ["low", "medium", "high"]},
            "ownership": {"type": "string", "enum": ["low", "medium", "high"]},
            "city": {"type": "string", "enum": ["low", "medium", "high"]}
          }
        },
        "crawl": {
          "type": "object",
          "additionalProperties": false,
          "required": ["eventDiscoveryStatus", "policy", "supportsEventExtraction"],
          "properties": {
            "eventDiscoveryStatus": {
              "type": "string",
              "enum": ["disabled", "candidate", "approved", "paused"]
            },
            "policy": {"type": "string", "enum": ["manualOnly", "blocked", "apiPreferred"]},
            "supportsEventExtraction": {"type": "boolean"}
          }
        },
        "evidenceRefs": {
          "type": "array",
          "items": {"$ref": "#/definitions/evidenceRef"}
        },
        "notes": {"type": "string", "maxLength": 500}
      }
    },
    "evidenceRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "ref", "description"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["hostDiscoveryRun", "seedClub", "userReportedSearchResult", "manualNote"]
        },
        "ref": {"type": ["string", "null"], "maxLength": 240},
        "description": {"type": "string", "minLength": 1, "maxLength": 400}
      }
    },
    "dedupeHint": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "value", "strength"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["legacyClubId", "canonicalPath", "platformId", "normalizedName", "manual"]
        },
        "value": {"type": "string", "minLength": 1, "maxLength": 240},
        "strength": {"type": "string", "enum": ["weak", "medium", "strong"]}
      }
    }
  }
}
