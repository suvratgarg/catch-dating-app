{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://catch.app/tool/organizer_intake/schemas/organizer_search_result_batches.schema.json",
  "title": "OrganizerSearchResultBatch",
  "description": "Private captured search-result batch. This is raw evidence and must be normalized and reviewed before it can affect public listings.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "batchId", "createdAt", "source", "query", "queryIntent", "results"],
  "properties": {
    "schemaVersion": {"const": 1},
    "batchId": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"},
    "createdAt": {"type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$"},
    "source": {
      "type": "string",
      "enum": ["manual_google_search", "manual_web_search", "serp_api", "custom_scraper", "fixture"]
    },
    "query": {"type": "string", "minLength": 1, "maxLength": 500},
    "queryIntent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["entityHint", "marketSlug", "activityKind"],
      "properties": {
        "entityHint": {"type": ["string", "null"], "maxLength": 160},
        "marketSlug": {"type": ["string", "null"], "maxLength": 80},
        "activityKind": {"type": ["string", "null"], "maxLength": 80}
      }
    },
    "captureContext": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "candidateId",
        "categoryId",
        "city",
        "citySlug",
        "planKind",
        "providerResultCount",
        "resultFingerprint",
        "runKey",
        "sourcePlanFile"
      ],
      "properties": {
        "candidateId": {"type": ["string", "null"], "maxLength": 120},
        "categoryId": {"type": ["string", "null"], "maxLength": 120},
        "city": {"type": ["string", "null"], "maxLength": 120},
        "citySlug": {"type": ["string", "null"], "maxLength": 80},
        "planKind": {"type": ["string", "null"], "maxLength": 80},
        "providerResultCount": {"type": "integer", "minimum": 0},
        "resultFingerprint": {"type": ["string", "null"], "maxLength": 80},
        "runKey": {"type": "string", "minLength": 1, "maxLength": 500},
        "sourcePlanFile": {"type": "string", "minLength": 1, "maxLength": 240}
      }
    },
    "results": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/definitions/result"}
    },
    "notes": {"type": ["string", "null"], "maxLength": 1000}
  },
  "definitions": {
    "result": {
      "type": "object",
      "additionalProperties": false,
      "required": ["resultId", "rank", "title", "url", "snippet", "observedAt"],
      "properties": {
        "resultId": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"},
        "rank": {"type": "integer", "minimum": 1},
        "title": {"type": "string", "minLength": 1, "maxLength": 300},
        "url": {"type": "string", "format": "uri"},
        "snippet": {"type": ["string", "null"], "maxLength": 1000},
        "observedAt": {"type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$"}
      }
    }
  }
}
