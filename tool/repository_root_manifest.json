{
  "version": "1.1.2",
  "updated": "2026-07-21",
  "ownerVocabulary": [
    "agent_operating_model",
    "app_platform",
    "backend_platform",
    "content_system",
    "design_system",
    "documentation",
    "operations_platform",
    "release_engineering",
    "repository_tooling",
    "web_platform"
  ],
  "prohibitedRootEntries": [".audit_work", "catch-dating-app", "codex_audit"],
  "entries": [
    {"names": [".git", ".claude", ".env", ".env.local"], "kind": "protected-local", "expectation": "ignored-or-unmanaged", "owner": "repository_tooling", "recovery": "Do not delete automatically; restore or recreate from the owning local tool."},
    {"names": [".editorconfig", ".env.example", ".github", "AGENTS.md", "analysis_options.yaml", "build.yaml", "dart_test.yaml", "l10n.yaml", "package-lock.json", "package.json", "pubspec.lock", "pubspec.yaml"], "kind": "config", "expectation": "tracked", "owner": "repository_tooling", "recovery": "Restore from Git."},
    {"names": [".firebaserc", "firebase.json", "firestore.indexes.json", "firestore.rules", "storage.rules"], "kind": "config", "expectation": "tracked", "owner": "backend_platform", "recovery": "Restore from Git."},
    {"names": [".gitignore", ".metadata"], "kind": "config", "expectation": "tracked", "owner": "app_platform", "recovery": "Restore from Git."},
    {"names": ["CLAUDE.md", "PROJECT_CONTEXT.md", "README.md", "TESTS.md"], "kind": "documentation", "expectation": "tracked", "owner": "documentation", "recovery": "Restore from Git."},
    {"names": ["admin", "website"], "kind": "source", "expectation": "tracked", "owner": "web_platform", "recovery": "Restore from Git and reinstall dependencies."},
    {"names": ["packages"], "kind": "source", "expectation": "tracked", "owner": "repository_tooling", "consumer": "package.json", "recovery": "Restore from Git and reinstall the owning Dart or npm workspace dependencies."},
    {"names": ["functions", "contracts", "analytics"], "kind": "source", "expectation": "tracked", "owner": "backend_platform", "recovery": "Restore from Git and regenerate contract outputs when required."},
    {"names": ["firebase", "extensions"], "kind": "config", "expectation": "tracked", "owner": "backend_platform", "consumer": "firebase.json", "recovery": "Restore from Git and validate the selected Firebase environment."},
    {"names": ["operations"], "kind": "source", "expectation": "tracked", "owner": "operations_platform", "consumer": "docs/operations_platform.md", "recovery": "Restore from Git and run npm --prefix operations test."},
    {"names": ["android", "ios", "macos", "web", "lib", "assets", "integration_test", "test"], "kind": "source", "expectation": "tracked", "owner": "app_platform", "recovery": "Restore from Git and run flutter pub get."},
    {"names": ["copy"], "kind": "source", "expectation": "tracked", "owner": "content_system", "consumer": "docs/app_architecture.md", "recovery": "Restore from Git and run the owning copy generator."},
    {"names": ["design", "widgetbook"], "kind": "source", "expectation": "tracked", "owner": "design_system", "consumer": "docs/design_parity/README.md", "recovery": "Restore from Git and run the owning design or Widgetbook generator."},
    {"names": ["docs"], "kind": "documentation", "expectation": "tracked", "owner": "documentation", "consumer": "docs/README.md", "recovery": "Restore from Git and refresh governed documentation registries when required."},
    {"names": ["tool"], "kind": "source", "expectation": "tracked", "owner": "repository_tooling", "consumer": "tool/tools_manifest.json", "recovery": "Restore from Git and run the tool-manifest and readiness checks."},
    {"names": ["artifacts"], "kind": "curated-artifact", "expectation": "tracked", "owner": "design_system", "consumer": "artifacts/README.md", "recovery": "Regenerate from the source capture workflow documented in artifacts/README.md."},
    {"names": ["design_context_pack"], "kind": "curated-artifact", "expectation": "tracked", "owner": "design_system", "consumer": "design_context_pack/MANIFEST.json", "recovery": "Restore from Git."},
    {"names": [".dart_tool", ".firebase", ".flutter-plugins-dependencies", "build", "coverage", "node_modules"], "kind": "generated-cache", "expectation": "ignored", "owner": "repository_tooling", "recovery": "Run flutter pub get, npm ci, or the relevant build command.", "cleanable": true, "scope": "all-regenerable"},
    {"names": [".idea"], "kind": "generated-cache", "expectation": "ignored", "owner": "app_platform", "recovery": "Reopen the project in the IDE.", "cleanable": true, "scope": "ide"},
    {"names": [".DS_Store"], "kind": "generated-cache", "expectation": "ignored", "owner": "repository_tooling", "recovery": "Regenerated by Finder if needed.", "cleanable": true, "scope": "ide"}
  ],
  "relationships": [
    {
      "id": "flutter-app",
      "owner": "app_platform",
      "sources": ["lib/**", "assets/**", "android/**", "ios/**", "macos/**", "web/**", "pubspec.yaml", "pubspec.lock", "analysis_options.yaml", "build.yaml", "l10n.yaml"],
      "generatedOutputs": ["lib/l10n/**", "lib/core/schema_contracts/generated/**"],
      "consumers": ["test/**", "integration_test/**"],
      "checks": ["meta:test-inventory", "design:tokens", "design:parity-gate"],
      "ciWorkflows": [".github/workflows/flutter-ci.yml", ".github/workflows/visual-integration-ci.yml"]
    },
    {
      "id": "backend-contracts",
      "owner": "backend_platform",
      "sources": ["contracts/**", "functions/**", "firebase/**", "extensions/**", "analytics/**", "firebase.json", ".firebaserc", "firestore.indexes.json", "firestore.rules", "storage.rules"],
      "generatedOutputs": ["functions/src/shared/generated/**", "lib/core/schema_contracts/generated/**", "tool/contracts/generated/**", "admin/src/generated/**"],
      "consumers": ["lib/**", "admin/**", "website/**", "operations/**"],
      "checks": ["contracts:validate-schemas", "contracts:generate-schemas", "contracts:generate-domain-classes"],
      "ciWorkflows": [".github/workflows/contracts-ci.yml", ".github/workflows/functions-ci.yml", ".github/workflows/firestore-rules-ci.yml"]
    },
    {
      "id": "react-surfaces",
      "owner": "web_platform",
      "sources": ["admin/**", "website/**", "packages/web-ui/**", "packages/web-config/**", "design/admin/**", "design/website/**", "design/web-ui/**"],
      "generatedOutputs": ["admin/src/generated/**", "website/src/generated/**", "packages/web-config/generated/**"],
      "consumers": ["firebase.json", "artifacts/marketing/**"],
      "checks": ["web:react-architecture-boundaries", "web:shared-ui-adoption"],
      "ciWorkflows": [".github/workflows/react-surface-validation.yml", ".github/workflows/admin-website.yml", ".github/workflows/marketing-website.yml"]
    },
    {
      "id": "design-system",
      "owner": "design_system",
      "sources": ["design/**", "lib/core/theme/**", "lib/core/widgets/**", "widgetbook/**", "packages/catch_ui_lints/**", "packages/phosphor_flutter/**"],
      "generatedOutputs": ["design_context_pack/**", "docs/design_parity/**", "docs/audit_registry/widget_*.json", "widgetbook/lib/main.directories.g.dart"],
      "consumers": ["lib/**", "admin/**", "website/**", "test/design/**", "test/goldens/**", "artifacts/**"],
      "checks": ["design:tokens", "design:parity-gate", "design:public-surface-behavior", "design:flutter-field-surface-inventory", "design:widgetbook-contract-refs", "design:widgetbook-coverage", "lint:catch-ui-plugin-smoke"],
      "ciWorkflows": [".github/workflows/flutter-ci.yml", ".github/workflows/tools-ci.yml", ".github/workflows/visual-integration-ci.yml"]
    },
    {
      "id": "operations-platform",
      "owner": "operations_platform",
      "sources": ["operations/**", "contracts/operations/**", "tool/organizer_intake/**", "tool/host_discovery/**", "tool/marketing/event_guide/**"],
      "generatedOutputs": ["operations/.state/**", "tool/organizer_intake/generated/**"],
      "consumers": ["functions/src/operations/**", "functions/scripts/operations/**", "admin/src/shared/operations/**", "admin/src/features/intake/operations/**"],
      "checks": ["operations:boundaries", "operations:workflow-manifest"],
      "ciWorkflows": [".github/workflows/tools-ci.yml", ".github/workflows/functions-ci.yml"]
    },
    {
      "id": "content-system",
      "owner": "content_system",
      "sources": ["copy/**", "lib/l10n/app_en.arb"],
      "generatedOutputs": ["lib/l10n/generated/**", "lib/l10n/generated/structured_domain_copy.g.dart", "functions/src/shared/generated/notificationCopyEn.ts", "ios/Runner/en.lproj/InfoPlist.strings"],
      "consumers": ["lib/**", "functions/**", "ios/**", "website/**"],
      "checks": ["meta:test-inventory"],
      "ciWorkflows": [".github/workflows/flutter-ci.yml", ".github/workflows/functions-ci.yml"]
    },
    {
      "id": "repository-control",
      "owner": "repository_tooling",
      "sources": [".github/**", "tool/**", "docs/**", "AGENTS.md", "CLAUDE.md", "PROJECT_CONTEXT.md", "README.md", "TESTS.md", "package.json", "package-lock.json", "dart_test.yaml", ".editorconfig", ".env.example", ".gitignore", ".metadata"],
      "generatedOutputs": ["docs/audit_registry/**", "TESTS.md"],
      "consumers": ["operations/**", "widgetbook/**", "integration_test/**", "test/**"],
      "checks": ["meta:repository-root-hygiene", "meta:enforcement-integrity", "meta:test-inventory", "agent:readiness", "docs:version-monotonic"],
      "ciWorkflows": [".github/workflows/tools-ci.yml", ".github/workflows/visual-integration-ci.yml"]
    }
  ],
  "auditPolicies": [
    {"pattern": "design/visual_baselines/**", "review": "aggregate", "kind": "generated_evidence", "owner": "design_system"},
    {"pattern": "android/app/src/*/res/**", "review": "aggregate", "kind": "platform_scaffold", "owner": "app_platform"},
    {"pattern": "ios/Runner/Assets.xcassets/**", "review": "aggregate", "kind": "platform_scaffold", "owner": "app_platform"},
    {"pattern": "macos/Runner/Assets.xcassets/**", "review": "aggregate", "kind": "platform_scaffold", "owner": "app_platform"},
    {"pattern": "web/icons/**", "review": "aggregate", "kind": "platform_scaffold", "owner": "app_platform"},
    {"pattern": "packages/phosphor_flutter/**", "review": "aggregate", "kind": "vendored_package", "owner": "repository_tooling"}
  ],
  "patterns": [
    {"pattern": "flutter_*.log", "kind": "generated-evidence", "expectation": "ignored", "owner": "app_platform", "recovery": "Re-run the Flutter command that emitted the log.", "cleanable": true, "scope": "logs"},
    {"pattern": "firestore-debug.log", "kind": "generated-evidence", "expectation": "ignored", "owner": "backend_platform", "recovery": "Re-run the Firestore emulator.", "cleanable": true, "scope": "logs"},
    {"pattern": "firebase-export-*", "kind": "generated-evidence", "expectation": "ignored", "owner": "backend_platform", "recovery": "Export emulator data again.", "cleanable": true, "scope": "evidence"},
    {"pattern": "emulator-data", "kind": "generated-evidence", "expectation": "ignored", "owner": "backend_platform", "recovery": "Export emulator data again.", "cleanable": true, "scope": "evidence"},
    {"pattern": "*.iml", "kind": "generated-cache", "expectation": "ignored", "owner": "app_platform", "recovery": "Reopen the project in the IDE.", "cleanable": true, "scope": "ide"}
  ],
  "cleanupTargets": [
    {"path": "build", "scope": "flutter", "reason": "Flutter build output"},
    {"path": ".dart_tool", "scope": "flutter", "reason": "Dart package and build cache"},
    {"path": ".flutter-plugins-dependencies", "scope": "flutter", "reason": "Generated Flutter plugin metadata"},
    {"path": "coverage", "scope": "flutter", "reason": "Generated test coverage"},
    {"path": "ios/Pods", "scope": "native", "reason": "CocoaPods dependencies"},
    {"path": "ios/.symlinks", "scope": "native", "reason": "Generated Flutter iOS links"},
    {"path": "macos/Pods", "scope": "native", "reason": "CocoaPods dependencies"},
    {"path": "macos/Flutter/ephemeral", "scope": "native", "reason": "Generated Flutter macOS files"},
    {"path": "android/.gradle", "scope": "native", "reason": "Gradle project cache"},
    {"path": "node_modules", "scope": "node", "reason": "Root npm dependencies"},
    {"path": "admin/node_modules", "scope": "node", "reason": "Admin npm dependencies"},
    {"path": "website/node_modules", "scope": "node", "reason": "Marketing npm dependencies"},
    {"path": "functions/node_modules", "scope": "node", "reason": "Functions npm dependencies"},
    {"path": "admin/dist", "scope": "node", "reason": "Admin build output"},
    {"path": "website/dist", "scope": "node", "reason": "Marketing build output"},
    {"path": "functions/lib", "scope": "node", "reason": "Compiled Functions output"},
    {"path": "widgetbook/.dart_tool", "scope": "flutter", "reason": "Widgetbook Dart package and build cache"},
    {"path": "widgetbook/build", "scope": "flutter", "reason": "Widgetbook build output"},
    {"path": "codex_audit", "scope": "evidence", "reason": "Retired root audit residue"},
    {"path": ".audit_work", "scope": "evidence", "reason": "Temporary audit workspace"},
    {"path": "test/goldens/failures", "scope": "evidence", "reason": "Failed golden diff output", "retentionDays": 14},
    {"path": "docs/visual_references", "scope": "evidence", "reason": "Review evidence older than retention", "retentionDays": 14, "contentsOnly": true},
    {"path": "tool/organizer_intake/raw_artifacts", "scope": "evidence", "reason": "Raw intake evidence older than retention", "retentionDays": 14, "contentsOnly": true}
  ],
  "protectedPaths": [".git", ".claude", ".env", ".env.local", "firebase", "tool/env", "tool/ci/toolchain.env"]
}
