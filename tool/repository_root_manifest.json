{
  "version": "1.0.1",
  "updated": "2026-07-12",
  "ownerVocabulary": [
    "agent_operating_model",
    "app_platform",
    "backend_platform",
    "design_system",
    "documentation",
    "operations_platform",
    "release_engineering",
    "repository_tooling",
    "web_platform"
  ],
  "prohibitedRootEntries": [".audit_work", "catch-dating-app", "codex_audit"],
  "entries": [
    {"names": [".git", ".claude", ".env", ".env.local"], "kind": "protected-local", "expectation": "ignored-or-unmanaged", "owner": "repository_tooling", "recovery": "Do not delete automatically; restore or recreate from the owning local tool."},
    {"names": [".editorconfig", ".env.example", ".github", "AGENTS.md", "analysis_options.yaml", "build.yaml", "dart_test.yaml", "l10n.yaml", "package-lock.json", "package.json", "pubspec.lock", "pubspec.yaml"], "kind": "config", "expectation": "tracked", "owner": "repository_tooling", "recovery": "Restore from Git."},
    {"names": [".firebaserc", "firebase.json", "firestore.indexes.json", "firestore.rules", "storage.rules"], "kind": "config", "expectation": "tracked", "owner": "backend_platform", "recovery": "Restore from Git."},
    {"names": [".gitignore", ".metadata"], "kind": "config", "expectation": "tracked", "owner": "app_platform", "recovery": "Restore from Git."},
    {"names": ["CLAUDE.md", "PROJECT_CONTEXT.md", "README.md", "TESTS.md", "design-qa.md"], "kind": "documentation", "expectation": "tracked", "owner": "documentation", "recovery": "Restore from Git."},
    {"names": ["admin", "website", "packages"], "kind": "source", "expectation": "tracked", "owner": "web_platform", "recovery": "Restore from Git and reinstall dependencies."},
    {"names": ["functions", "firebase", "contracts", "analytics"], "kind": "source", "expectation": "tracked", "owner": "backend_platform", "recovery": "Restore from Git and regenerate contract outputs when required."},
    {"names": ["operations"], "kind": "source", "expectation": "tracked", "owner": "operations_platform", "consumer": "docs/operations_platform.md", "recovery": "Restore from Git and run npm --prefix operations test."},
    {"names": ["android", "ios", "macos", "web", "lib", "assets", "integration_test", "test"], "kind": "source", "expectation": "tracked", "owner": "app_platform", "recovery": "Restore from Git and run flutter pub get."},
    {"names": ["copy", "design", "docs", "extensions", "tool", "widgetbook"], "kind": "source", "expectation": "tracked", "owner": "repository_tooling", "recovery": "Restore from Git and run the owning generator if documented."},
    {"names": ["artifacts"], "kind": "curated-artifact", "expectation": "tracked", "owner": "design_system", "consumer": "artifacts/README.md", "recovery": "Regenerate from the source capture workflow documented in artifacts/README.md."},
    {"names": ["design_context_pack"], "kind": "curated-artifact", "expectation": "tracked", "owner": "design_system", "consumer": "design_context_pack/MANIFEST.json", "recovery": "Restore from Git."},
    {"names": [".dart_tool", ".firebase", ".flutter-plugins-dependencies", "build", "coverage", "node_modules"], "kind": "generated-cache", "expectation": "ignored", "owner": "repository_tooling", "recovery": "Run flutter pub get, npm ci, or the relevant build command.", "cleanable": true, "scope": "all-regenerable"},
    {"names": [".idea"], "kind": "generated-cache", "expectation": "ignored", "owner": "app_platform", "recovery": "Reopen the project in the IDE.", "cleanable": true, "scope": "ide"},
    {"names": [".DS_Store"], "kind": "generated-cache", "expectation": "ignored", "owner": "repository_tooling", "recovery": "Regenerated by Finder if needed.", "cleanable": true, "scope": "ide"}
  ],
  "patterns": [
    {"pattern": "flutter_*.log", "kind": "generated-evidence", "expectation": "ignored", "owner": "app_platform", "recovery": "Re-run the Flutter command that emitted the log.", "cleanable": true, "scope": "logs"},
    {"pattern": "firestore-debug.log", "kind": "generated-evidence", "expectation": "ignored", "owner": "backend_platform", "recovery": "Re-run the Firestore emulator.", "cleanable": true, "scope": "logs"},
    {"pattern": "firebase-export-*", "kind": "generated-evidence", "expectation": "ignored", "owner": "backend_platform", "recovery": "Export emulator data again.", "cleanable": true, "scope": "evidence"},
    {"pattern": "emulator-data", "kind": "generated-evidence", "expectation": "ignored", "owner": "backend_platform", "recovery": "Export emulator data again.", "cleanable": true, "scope": "evidence"},
    {"pattern": "*.iml", "kind": "generated-cache", "expectation": "ignored", "owner": "app_platform", "recovery": "Reopen the project in the IDE.", "cleanable": true, "scope": "ide"}
  ],
  "cleanupTargets": [
    {"path": "build", "scope": "flutter", "reason": "Flutter build output"},
    {"path": ".dart_tool", "scope": "flutter", "reason": "Dart package and build cache"},
    {"path": ".flutter-plugins-dependencies", "scope": "flutter", "reason": "Generated Flutter plugin metadata"},
    {"path": "coverage", "scope": "flutter", "reason": "Generated test coverage"},
    {"path": "ios/Pods", "scope": "native", "reason": "CocoaPods dependencies"},
    {"path": "ios/.symlinks", "scope": "native", "reason": "Generated Flutter iOS links"},
    {"path": "macos/Pods", "scope": "native", "reason": "CocoaPods dependencies"},
    {"path": "macos/Flutter/ephemeral", "scope": "native", "reason": "Generated Flutter macOS files"},
    {"path": "android/.gradle", "scope": "native", "reason": "Gradle project cache"},
    {"path": "node_modules", "scope": "node", "reason": "Root npm dependencies"},
    {"path": "admin/node_modules", "scope": "node", "reason": "Admin npm dependencies"},
    {"path": "website/node_modules", "scope": "node", "reason": "Marketing npm dependencies"},
    {"path": "functions/node_modules", "scope": "node", "reason": "Functions npm dependencies"},
    {"path": "admin/dist", "scope": "node", "reason": "Admin build output"},
    {"path": "website/dist", "scope": "node", "reason": "Marketing build output"},
    {"path": "functions/lib", "scope": "node", "reason": "Compiled Functions output"},
    {"path": "codex_audit", "scope": "evidence", "reason": "Retired root audit residue"},
    {"path": ".audit_work", "scope": "evidence", "reason": "Temporary audit workspace"},
    {"path": "test/goldens/failures", "scope": "evidence", "reason": "Failed golden diff output", "retentionDays": 14},
    {"path": "docs/visual_references", "scope": "evidence", "reason": "Review evidence older than retention", "retentionDays": 14, "contentsOnly": true},
    {"path": "tool/organizer_intake/raw_artifacts", "scope": "evidence", "reason": "Raw intake evidence older than retention", "retentionDays": 14, "contentsOnly": true}
  ],
  "protectedPaths": [".git", ".claude", ".env", ".env.local", "firebase", "tool/env", "tool/ci/toolchain.env"]
}
