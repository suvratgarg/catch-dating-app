      "rulesTestFile": "functions/test/firestore.rules.test.cjs",
      "owner": "document id must equal Firebase Auth uid for client writes",
      "read": "owner only; app-facing user discovery reads publicProfiles",
      "write": "owner initial create; profile edits via updateUserProfile; narrow runtime direct updates only",
