        "diet",
        "children",
        "paceMinSecsPerKm",
        "paceMaxSecsPerKm",
        "preferredDistances",
        "runningReasons",
        "preferredRunTimes",
        "languages"
      ],
      "internalDemoFields": [
        "synthetic",
        "seedPrefix",
        "scenario",
        "demoOps",
        "demoOpsId",
        "demoOpsCommand"
      ],
      "exportedFunctions": [
        "syncPublicProfile"
      ]
    },
    {
      "id": "runClubs",
