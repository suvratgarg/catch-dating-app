        "setRunClubNotificationPreference",
        "syncRunClubMemberStats",
        "requestAccountDeletion"
      ],
      "migrationNotes": [
        "Owns run-club membership state; parent runClubs documents retain only memberCount as a trigger-recomputed aggregate.",
        "pushNotificationsEnabled is the per-club bell opt-in for FCM only; active membership still receives durable Activity updates."
      ]
