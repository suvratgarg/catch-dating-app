      "typescriptInterface": "PublicProfileDoc",
      "dartModel": "lib/public_profile/domain/public_profile.dart",
      "owner": "syncPublicProfile trigger",
      "read": "authenticated users, except deleted or blocked relationships",
      "write": "server only",
      "triggerOwnedFields": [
        "name",
        "age",
        "gender",
        "profilePrompts",
        "photoUrls",
        "photoThumbnailUrls",
        "photoPrompts",
        "profilePhotos",
        "city",
        "height",
        "occupation",
        "company",
        "education",
        "religion",
        "relationshipGoal",
        "drinking",
        "smoking",
