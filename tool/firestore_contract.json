        "fcmToken"
      ],
      "callableOwnedFields": [],
      "serverOwnedFields": [
        "deleted",
        "deletedAt"
      ],
      "internalDemoFields": [
        "synthetic",
        "seedPrefix",
        "scenario",
        "demoOps",
        "demoOpsId",
        "demoOpsCommand"
      ],
      "exportedFunctions": [
        "updateUserProfile",
        "requestAccountDeletion"
      ],
      "operations": [
        {
          "id": "owner_initial_create",
          "type": "directCreate",
          "owner": "authenticated owner",
          "allowedFields": [
            "name",
            "firstName",
            "lastName",
            "displayName",
            "dateOfBirth",
            "gender",
            "phoneNumber",
            "profileComplete",
            "email",
            "instagramHandle",
            "profilePrompts",
            "photoUrls",
            "photoThumbnailUrls",
            "photoPrompts",
            "profilePhotos",
            "city",
            "latitude",
            "longitude",
            "interestedInGenders",
            "minAgePreference",
            "maxAgePreference",
            "height",
            "occupation",
            "company",
            "education",
            "religion",
            "languages",
            "relationshipGoal",
            "drinking",
            "smoking",
            "workout",
            "diet",
            "children",
            "paceMinSecsPerKm",
            "paceMaxSecsPerKm",
            "preferredDistances",
            "runningReasons",
            "preferredRunTimes",
            "prefsNewCatches",
            "prefsMessages",
            "prefsEventReminders",
            "prefsRunStatusUpdates",
            "prefsClubUpdates",
            "prefsWeeklyDigest",
            "prefsShowOnMap"
          ],
          "deniedFields": [
            "fcmToken",
            "deleted",
            "deletedAt"
          ],
          "rulesTestNames": [
            "allows owners to create the current UserProfile schema without legacy sexualOrientation"
          ]
        },
        {
          "id": "owner_profile_patch",
          "type": "callable",
          "owner": "authenticated owner",
          "function": "updateUserProfile",
          "allowedFields": [
            "name",
            "displayName",
            "dateOfBirth",
            "gender",
            "phoneNumber",
            "profileComplete",
            "email",
            "instagramHandle",
            "profilePrompts",
            "photoUrls",
            "photoThumbnailUrls",
            "photoPrompts",
            "profilePhotos",
            "city",
            "latitude",
            "longitude",
            "interestedInGenders",
            "minAgePreference",
            "maxAgePreference",
            "height",
            "occupation",
            "company",
            "education",
            "religion",
            "languages",
            "relationshipGoal",
            "drinking",
            "smoking",
            "workout",
            "diet",
            "children",
            "paceMinSecsPerKm",
            "paceMaxSecsPerKm",
            "preferredDistances",
            "runningReasons",
            "preferredRunTimes",
            "prefsNewCatches",
            "prefsMessages",
            "prefsEventReminders",
            "prefsRunStatusUpdates",
            "prefsClubUpdates",
            "prefsWeeklyDigest",
            "prefsShowOnMap"
          ]
        },
        {
          "id": "runtime_direct_updates",
          "type": "directUpdate",
          "owner": "authenticated owner",
          "allowedFields": [
            "fcmToken"
          ],
          "deniedFields": [
            "deleted",
            "deletedAt"
          ],
          "rulesTestNames": [
            "denies direct profile edits but allows runtime FCM token updates"
          ]
        }
      ],
      "migrationNotes": [
        "Rules, Functions profile updates, and the generated Dart/TypeScript contract no longer allow new sexualOrientation writes.",
        "firstName and lastName are private identity fields initialized during onboarding; displayName is the editable public name written by the updateUserProfile callable.",
        "Legacy bio text now migrates into structured profilePrompts; new prompt text is stored in profilePrompts and optional photo captions are stored in photoPrompts.",
        "Global notification category preferences live on users/{uid}; per-club push opt-in lives on clubMemberships/{clubId_uid}.",
        "Event-club membership and saved-event state live in edge collections, not profile arrays."
      ]
    },
    {
      "id": "onboarding_drafts",
      "path": "onboarding_drafts/{uid}",
      "rulesMatch": "/onboarding_drafts/{uid}",
      "dartModel": "lib/onboarding/domain/onboarding_draft.dart",
      "rulesTestFile": "functions/test/firestore.rules.test.cjs",
      "owner": "document id must equal Firebase Auth uid",
      "read": "owner only",
      "write": "owner only; intentionally extensible draft payload",
      "extensible": true,
      "clientWritableFields": [
        "step",
        "draftVersion",
        "firstName",
        "lastName",
        "dateOfBirth",
        "phoneNumber",
        "countryCode",
        "gender",
        "interestedInGenders",
        "instagramHandle",
        "profilePrompts"
      ],
      "requiredFields": [
        "step"
      ],
      "operations": [
        {
          "id": "owner_draft_write",
          "type": "directCreateOrUpdate",
          "owner": "authenticated owner",
          "rulesMustContain": [
            "hasValidOnboardingDraftShape"
          ],
          "rulesTestNames": [
            "allows only the owner to read, write, and delete their draft"
          ]
        }
      ],
      "migrationNotes": [
        "The rules intentionally validate only step for owner-private draft routing; the draft payload can evolve without a rules deploy."
      ]
    },
