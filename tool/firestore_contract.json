      "path": "config/cities",
      "rulesMatch": "/config/cities",
      "owner": "public read, server/admin write",
      "read": "any user, authenticated or not",
      "write": "server/admin only",
      "serverOwnedFields": ["cityNames"],
      "migrationNotes": ["Rules fall back to the hard-coded city enum when this document is absent."]
