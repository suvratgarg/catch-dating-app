{
  "schemaVersion": 2,
  "description": "Canonical Firestore ownership contract for Dart models, Functions TypeScript types, Firestore rules, and client mutation boundaries.",
  "collections": [
    {
      "id": "config_cities",
      "path": "config/cities",
      "rulesMatch": "/config/cities",
      "owner": "public read, server/admin write",
      "read": "any user, authenticated or not",
      "write": "server/admin only",
      "serverOwnedFields": [
        "cityNames",
        "cities"
      ],
      "migrationNotes": [
        "Rules fall back to the hard-coded city enum when this document is absent."
      ]
    },
    {
      "id": "users",
      "path": "users/{uid}",
      "rulesMatch": "/users/{uid}",
      "typescriptInterface": "UserProfileDoc",
      "dartModel": "lib/user_profile/domain/user_profile.dart",
      "rulesTestFile": "functions/test/firestore.rules.test.cjs",
      "owner": "document id must equal Firebase Auth uid for client writes",
      "read": "owner only; app-facing user discovery reads publicProfiles",
      "write": "owner initial create; profile edits via updateUserProfile; narrow runtime direct updates only",
      "clientWritableFields": [
        "name",
        "firstName",
        "lastName",
        "displayName",
        "dateOfBirth",
        "gender",
        "phoneNumber",
        "profileComplete",
        "email",
        "instagramHandle",
        "profilePrompts",
        "photoUrls",
        "photoThumbnailUrls",
        "photoPrompts",
        "profilePhotos",
        "city",
        "latitude",
        "longitude",
        "interestedInGenders",
        "minAgePreference",
        "maxAgePreference",
        "height",
        "occupation",
        "company",
        "education",
        "religion",
        "languages",
        "relationshipGoal",
        "drinking",
        "smoking",
        "workout",
        "diet",
        "children",
        "paceMinSecsPerKm",
        "paceMaxSecsPerKm",
        "preferredDistances",
        "runningReasons",
        "preferredRunTimes",
        "prefsNewCatches",
        "prefsMessages",
        "prefsRunReminders",
        "prefsRunStatusUpdates",
        "prefsClubUpdates",
        "prefsWeeklyDigest",
        "prefsShowOnMap"
      ],
      "clientRuntimeWritableFields": [
        "fcmToken"
      ],
      "callableOwnedFields": [],
      "serverOwnedFields": [
        "deleted",
        "deletedAt"
      ],
      "internalDemoFields": [
        "synthetic",
        "seedPrefix",
        "scenario",
        "demoOps",
        "demoOpsId",
        "demoOpsCommand"
      ],
      "exportedFunctions": [
        "updateUserProfile",
        "requestAccountDeletion"
      ],
      "operations": [
        {
          "id": "owner_initial_create",
          "type": "directCreate",
          "owner": "authenticated owner",
          "allowedFields": [
            "name",
            "firstName",
            "lastName",
            "displayName",
            "dateOfBirth",
            "gender",
            "phoneNumber",
            "profileComplete",
            "email",
            "instagramHandle",
            "profilePrompts",
            "photoUrls",
            "photoThumbnailUrls",
            "photoPrompts",
            "profilePhotos",
            "city",
            "latitude",
            "longitude",
            "interestedInGenders",
            "minAgePreference",
            "maxAgePreference",
            "height",
            "occupation",
            "company",
            "education",
            "religion",
            "languages",
            "relationshipGoal",
            "drinking",
            "smoking",
            "workout",
            "diet",
            "children",
            "paceMinSecsPerKm",
            "paceMaxSecsPerKm",
            "preferredDistances",
            "runningReasons",
            "preferredRunTimes",
            "prefsNewCatches",
            "prefsMessages",
            "prefsRunReminders",
            "prefsRunStatusUpdates",
            "prefsClubUpdates",
            "prefsWeeklyDigest",
            "prefsShowOnMap"
          ],
          "deniedFields": [
            "fcmToken",
            "deleted",
            "deletedAt"
          ],
          "rulesTestNames": [
            "allows owners to create the current UserProfile schema without legacy sexualOrientation"
          ]
        },
        {
          "id": "owner_profile_patch",
          "type": "callable",
          "owner": "authenticated owner",
          "function": "updateUserProfile",
          "allowedFields": [
            "name",
            "displayName",
            "dateOfBirth",
            "gender",
            "phoneNumber",
            "profileComplete",
            "email",
            "instagramHandle",
            "profilePrompts",
            "photoUrls",
            "photoThumbnailUrls",
            "photoPrompts",
            "profilePhotos",
            "city",
            "latitude",
            "longitude",
            "interestedInGenders",
            "minAgePreference",
            "maxAgePreference",
            "height",
            "occupation",
            "company",
            "education",
            "religion",
            "languages",
            "relationshipGoal",
            "drinking",
            "smoking",
            "workout",
            "diet",
            "children",
            "paceMinSecsPerKm",
            "paceMaxSecsPerKm",
            "preferredDistances",
            "runningReasons",
            "preferredRunTimes",
            "prefsNewCatches",
            "prefsMessages",
            "prefsRunReminders",
            "prefsRunStatusUpdates",
            "prefsClubUpdates",
            "prefsWeeklyDigest",
            "prefsShowOnMap"
          ]
        },
        {
          "id": "runtime_direct_updates",
          "type": "directUpdate",
          "owner": "authenticated owner",
          "allowedFields": [
            "fcmToken"
          ],
          "deniedFields": [
            "deleted",
            "deletedAt"
          ],
          "rulesTestNames": [
            "denies direct profile edits but allows runtime FCM token updates"
          ]
        }
      ],
      "migrationNotes": [
        "Rules, Functions profile updates, and the generated Dart/TypeScript contract no longer allow new sexualOrientation writes.",
        "firstName and lastName are private identity fields initialized during onboarding; displayName is the editable public name written by the updateUserProfile callable.",
        "Legacy bio text now migrates into structured profilePrompts; new prompt text is stored in profilePrompts and optional photo captions are stored in photoPrompts.",
        "Global notification category preferences live on users/{uid}; per-club push opt-in lives on runClubMemberships/{clubId_uid}.",
        "Run-club membership and saved-run state live in edge collections, not profile arrays."
      ]
    },
    {
      "id": "onboarding_drafts",
      "path": "onboarding_drafts/{uid}",
      "rulesMatch": "/onboarding_drafts/{uid}",
      "dartModel": "lib/onboarding/domain/onboarding_draft.dart",
      "rulesTestFile": "functions/test/firestore.rules.test.cjs",
      "owner": "document id must equal Firebase Auth uid",
      "read": "owner only",
      "write": "owner only; intentionally extensible draft payload",
      "extensible": true,
      "clientWritableFields": [
        "step",
        "draftVersion",
        "firstName",
        "lastName",
        "dateOfBirth",
        "phoneNumber",
        "countryCode",
        "gender",
        "interestedInGenders",
        "instagramHandle",
        "profilePrompts"
      ],
      "requiredFields": [
        "step"
      ],
      "operations": [
        {
          "id": "owner_draft_write",
          "type": "directCreateOrUpdate",
          "owner": "authenticated owner",
          "rulesMustContain": [
            "hasValidOnboardingDraftShape"
          ],
          "rulesTestNames": [
            "allows only the owner to read, write, and delete their draft"
          ]
        }
      ],
      "migrationNotes": [
        "The rules intentionally validate only step for owner-private draft routing; the draft payload can evolve without a rules deploy."
      ]
    },
    {
      "id": "publicProfiles",
      "path": "publicProfiles/{uid}",
