{
  "schemaVersion": 2,
  "description": "Canonical Firestore ownership contract for Dart models, Functions TypeScript types, Firestore rules, and client mutation boundaries.",
  "collections": [
    {
      "id": "config_cities",
      "path": "config/cities",
      "rulesMatch": "/config/cities",
      "owner": "public read, server/admin write",
      "read": "any user, authenticated or not",
      "write": "server/admin only",
      "migrationNotes": [
        "Rules fall back to the hard-coded city enum when this document is absent."
      ]
    },
    {
      "id": "users",
      "path": "users/{uid}",
      "rulesMatch": "/users/{uid}",
      "typescriptInterface": "UserProfileDocument",
      "dartModel": "lib/user_profile/domain/user_profile.dart",
      "rulesTestFile": "functions/test/firestore.rules.test.cjs",
      "owner": "document id must equal Firebase Auth uid for client writes",
      "read": "owner only; app-facing user discovery reads publicProfiles",
      "write": "owner initial create; profile edits via updateUserProfile; narrow runtime direct updates only",
      "exportedFunctions": [
        "updateUserProfile",
        "requestAccountDeletion"
      ],
      "operations": [
        {
          "id": "owner_initial_create",
          "type": "directCreate",
          "owner": "authenticated owner",
          "allowedFields": [
            "name",
            "firstName",
            "lastName",
            "displayName",
            "dateOfBirth",
            "gender",
            "phoneNumber",
            "profileComplete",
            "email",
            "instagramHandle",
            "profilePrompts",
            "profilePhotos",
            "city",
            "latitude",
            "longitude",
            "interestedInGenders",
            "minAgePreference",
            "maxAgePreference",
            "height",
            "occupation",
            "company",
            "education",
            "religion",
            "languages",
            "relationshipGoal",
            "drinking",
            "smoking",
            "workout",
            "diet",
            "children",
            "activityPreferences",
            "prefsNewCatches",
            "prefsMessages",
            "prefsEventReminders",
            "prefsRunStatusUpdates",
            "prefsClubUpdates",
            "prefsWeeklyDigest",
            "prefsShowOnMap"
          ],
          "deniedFields": [
            "fcmToken",
            "deleted",
            "deletedAt"
          ],
          "rulesTestNames": [
            "allows owners to create the current UserProfile schema without legacy sexualOrientation"
          ]
        },
        {
          "id": "owner_profile_patch",
          "type": "callable",
          "owner": "authenticated owner",
          "function": "updateUserProfile",
          "payloadSchemaRef": "contracts/patches/update_user_profile.schema.json",
          "strictAllowedFieldsMatch": true,
          "allowedFields": [
            "name",
            "displayName",
            "dateOfBirth",
            "gender",
            "phoneNumber",
            "profileComplete",
            "email",
            "instagramHandle",
            "profilePrompts",
            "profilePhotos",
            "city",
            "latitude",
            "longitude",
            "interestedInGenders",
            "minAgePreference",
            "maxAgePreference",
            "height",
            "occupation",
            "company",
            "education",
            "religion",
            "languages",
            "relationshipGoal",
            "drinking",
            "smoking",
            "workout",
            "diet",
            "children",
            "activityPreferences",
            "prefsNewCatches",
            "prefsMessages",
            "prefsEventReminders",
            "prefsRunStatusUpdates",
            "prefsClubUpdates",
            "prefsWeeklyDigest",
            "prefsShowOnMap"
          ]
        },
        {
          "id": "runtime_direct_updates",
          "type": "directUpdate",
          "owner": "authenticated owner",
          "allowedFields": [
            "fcmToken"
          ],
          "deniedFields": [
            "deleted",
            "deletedAt"
          ],
          "rulesTestNames": [
            "denies direct profile edits but allows runtime FCM token updates"
          ]
        }
      ],
      "migrationNotes": [
        "Rules, Functions profile updates, and the generated Dart/TypeScript contract no longer allow new sexualOrientation writes.",
        "firstName and lastName are private identity fields initialized during onboarding; displayName is the editable public name written by the updateUserProfile callable.",
        "Legacy bio text now migrates into structured profilePrompts; new prompt text is stored in profilePrompts and photo prompt selections live inside profilePhotos.prompt.",
        "Global notification category preferences live on users/{uid}; per-club push opt-in lives on clubMemberships/{clubId_uid}.",
        "Event-club membership and saved-event state live in edge collections, not profile arrays."
      ]
    },
    {
      "id": "onboarding_drafts",
      "path": "onboarding_drafts/{uid}",
      "rulesMatch": "/onboarding_drafts/{uid}",
      "dartModel": "lib/onboarding/domain/onboarding_draft.dart",
      "rulesTestFile": "functions/test/firestore.rules.test.cjs",
      "owner": "document id must equal Firebase Auth uid",
      "read": "owner only",
      "write": "owner only; intentionally extensible draft payload",
      "extensible": true,
      "requiredFields": [
        "step"
      ],
      "operations": [
        {
          "id": "owner_draft_write",
          "type": "directCreateOrUpdate",
          "owner": "authenticated owner",
          "rulesMustContain": [
            "hasValidOnboardingDraftShape"
          ],
          "rulesTestNames": [
            "allows only the owner to read, write, and delete their draft"
          ]
        }
      ],
      "migrationNotes": [
        "The rules intentionally validate only step for owner-private draft routing; the draft payload can evolve without a rules deploy."
      ]
    },
    {
      "id": "publicProfiles",
      "path": "publicProfiles/{uid}",
      "rulesMatch": "/publicProfiles/{uid}",
      "typescriptInterface": "PublicProfileDocument",
      "dartModel": "lib/public_profile/domain/public_profile.dart",
      "owner": "syncPublicProfile trigger",
      "read": "authenticated users, except deleted or blocked relationships",
      "write": "server only",
      "exportedFunctions": [
        "syncPublicProfile"
      ]
    },
    {
      "id": "hostProfiles",
      "path": "hostProfiles/{uid}",
      "rulesMatch": "/hostProfiles/{uid}",
      "typescriptInterface": "HostProfileDocument",
      "dartModel": "lib/hosts/domain/host_profile.dart",
      "owner": "professional host identity owned by the authenticated host; seeded and projected by club/profile functions",
      "read": "public",
      "write": "authenticated owner direct create/update; server functions may seed and project host display data",
      "exportedFunctions": [
        "syncHostProfile",
        "createClub",
        "addClubHost",
        "removeClubHost",
        "transferClubOwnership"
      ],
      "operations": [
        {
          "id": "owner_profile_write",
          "type": "directCreateOrUpdate",
          "owner": "authenticated owner",
          "rulesMustContain": [
            "isValidHostProfile"
          ]
        },
        {
          "id": "host_profile_projection",
          "type": "triggerProjection",
          "owner": "syncHostProfile trigger",
          "function": "syncHostProfile"
        }
      ],
      "migrationNotes": [
        "Host professional identity is intentionally separate from users/{uid} dating profile data and publicProfiles/{uid}.",
        "Club creation and team-management callables may seed missing hostProfiles/{uid} documents from professional host snapshots."
      ]
    },
    {
      "id": "clubs",
      "path": "clubs/{clubId}",
      "rulesMatch": "/clubs/{clubId}",
      "typescriptInterface": "ClubDocument",
      "dartModel": "lib/clubs/domain/club.dart",
      "rulesTestFile": "functions/test/firestore.rules.test.cjs",
      "owner": "club create/update/membership lifecycle is callable-owned; aggregate and next-event projections are trigger-owned",
      "read": "public",
      "write": "all club writes are callable-owned; direct client writes are denied",
      "exportedFunctions": [
        "createClub",
        "updateClub",
        "createClubPost",
        "joinClub",
        "leaveClub",
        "archiveClub",
        "deleteClub",
        "syncClubMemberStats",
        "syncClubNextEvent",
        "syncClubReviewStats"
      ],
      "migrationNotes": [
        "archiveClub marks clubs archived when history exists.",
        "deleteClub hard-deletes only never-used clubs with no events, payments, reviews, or non-host members.",
        "Organizer posts live under clubs/{clubId}/posts/{postId} and are created only by createClubPost.",
        "memberCount is recomputed from active clubMemberships by syncClubMemberStats.",
        "nextEventAt and nextEventLabel are recomputed from active future events by syncClubNextEvent."
      ]
    },
    {
      "id": "club_posts",
      "path": "clubs/{clubId}/posts/{postId}",
      "rulesMatch": "/clubs/{clubId}/posts/{postId}",
      "typescriptInterface": "ClubPostDocument",
      "rulesTestFile": "functions/test/firestore.rules.test.cjs",
      "owner": "createClubPost callable",
      "read": "authenticated users",
      "write": "server only",
      "exportedFunctions": [
        "createClubPost"
      ],
      "operations": [
        {
          "id": "host_create_post",
          "type": "callable",
          "owner": "club owner or host",
          "function": "createClubPost",
          "payloadSchemaRef": "contracts/callables/create_club_post_payload.schema.json"
        }
      ],
      "migrationNotes": [
        "V1 post audience is followers only.",
        "The createClubPost callable enforces max 3 active posts per club per rolling 7 days."
      ]
    },
    {
      "id": "clubMemberships",
      "path": "clubMemberships/{membershipId}",
      "rulesMatch": "/clubMemberships/{membershipId}",
      "typescriptInterface": "ClubMembershipDocument",
      "dartModel": "lib/clubs/domain/club_membership.dart",
      "rulesTestFile": "functions/test/firestore.rules.test.cjs",
      "owner": "club membership callables; syncClubMemberStats derives parent count",
      "read": "active memberships visible to authenticated users; historical memberships visible to the member",
      "write": "server only",
      "exportedFunctions": [
        "createClub",
        "joinClub",
        "leaveClub",
        "setClubNotificationPreference",
        "syncClubMemberStats",
        "requestAccountDeletion"
      ],
      "migrationNotes": [
        "Owns club membership state; parent clubs documents retain only memberCount as a trigger-recomputed aggregate.",
        "pushNotificationsEnabled is the per-club bell opt-in for FCM only; active membership still receives durable Activity updates."
      ]
    },
    {
      "id": "clubHostClaims",
      "path": "clubHostClaims/{uid}",
      "rulesMatch": "/clubHostClaims/{uid}",
      "rulesTestFile": "functions/test/firestore.rules.test.cjs",
      "owner": "createClub callable",
      "read": "server only",
      "write": "server only",
      "exportedFunctions": [
        "createClub"
      ],
      "migrationNotes": [
        "One document per host UID enforces the product rule that a user can host at most one club.",
        "Existing beta data should be backfilled with a host claim or reset before relying on this invariant in production."
      ]
    },
    {
      "id": "events",
      "path": "events/{eventId}",
      "rulesMatch": "/events/{eventId}",
      "typescriptInterface": "EventDocument",
      "dartModel": "lib/events/domain/event.dart",
      "rulesTestFile": "functions/test/firestore.rules.test.cjs",
      "owner": "host creates and edits events through callables; booking, attendance, waitlist joins, and gender counts are backend-owned",
      "read": "public",
      "write": "all event writes are callable-owned; direct client writes are denied",
      "exportedFunctions": [
        "createEvent",
        "updateEvent",
        "cancelEvent",
        "deleteEvent",
        "signUpForFreeEvent",
        "cancelEventSignUp",
        "joinEventWaitlist",
        "leaveEventWaitlist",
        "markEventAttendance",
        "selfCheckInAttendance",
        "verifyRazorpayPayment"
      ],
      "operations": [
        {
          "id": "host_create",
          "type": "callable",
          "owner": "club host",
          "function": "createEvent",
          "payloadSchemaRef": "contracts/callables/create_event_payload.schema.json",
          "allowedFields": [
            "clubId",
            "startTime",
            "endTime",
            "meetingPoint",
            "meetingLocation",
            "startingPointLat",
            "startingPointLng",
            "locationDetails",
            "photoUrl",
            "distanceKm",
            "pace",
            "capacityLimit",
            "description",
            "priceInPaise",
            "bookedCount",
            "checkedInCount",
            "waitlistedCount",
            "status",
            "cancelledAt",
            "cancellationReason",
            "constraints",
            "genderCounts"
          ]
        },
        {
          "id": "host_detail_update",
          "type": "callable",
          "owner": "club host",
          "function": "updateEvent",
          "payloadSchemaRef": "contracts/callables/update_event_payload.schema.json",
          "allowedFields": [
            "startTime",
            "endTime",
            "meetingPoint",
            "meetingLocation",
            "startingPointLat",
            "startingPointLng",
            "locationDetails",
            "photoUrl",
            "distanceKm",
            "pace",
            "description"
          ],
          "deniedFields": [
            "clubId",
            "capacityLimit",
            "priceInPaise",
            "constraints",
            "bookedCount",
            "checkedInCount",
            "waitlistedCount",
            "genderCounts",
            "status",
            "cancelledAt",
            "cancellationReason"
          ],
          "rulesTestNames": [
            "denies direct event creates because creation is callable-owned",
            "denies direct host event detail edits because updates are callable-owned",
            "denies hosts changing booking-sensitive or ownership event fields"
          ]
        },
        {
          "id": "host_cancel",
          "type": "callable",
          "owner": "club host",
          "function": "cancelEvent",
          "payloadSchemaRef": "contracts/callables/cancel_event_payload.schema.json",
          "allowedFields": [
            "status",
            "cancelledAt",
            "cancellationReason"
          ]
        },
        {
          "id": "host_delete_unused",
          "type": "callable",
          "owner": "club host",
          "function": "deleteEvent",
          "payloadSchemaRef": "contracts/callables/delete_event_payload.schema.json",
          "allowedFields": [],
          "preconditions": [
            "no eventParticipations for eventId",
            "no payments for eventId",
            "no reviews for eventId"
          ]
        },
        {
          "id": "waitlist_self_leave",
          "type": "callable",
          "owner": "waitlisted authenticated user",
          "function": "leaveEventWaitlist",
          "payloadSchemaRef": "contracts/callables/event_id_payload.schema.json",
          "allowedFields": [
            "waitlistedCount"
          ],
          "rulesTestNames": [
            "denies direct event aggregate rewrites because roster actions are callable-owned"
          ]
        },
        {
          "id": "booking_workflows",
          "type": "callable",
          "owner": "authenticated user or host depending on callable",
          "allowedFields": [
            "bookedCount",
            "checkedInCount",
            "waitlistedCount",
            "genderCounts"
          ]
        }
      ],
      "embeddedTypes": [
        {
          "typescriptInterface": "EventConstraints",
          "propertyPath": "constraints"
        }
      ],
      "migrationNotes": [
        "cancelEvent handles events with history.",
        "deleteEvent hard-deletes only unused hosted events with no participations, payments, or reviews."
      ]
    },
    {
      "id": "eventParticipations",
      "path": "eventParticipations/{participationId}",
      "rulesMatch": "/eventParticipations/{participationId}",
      "typescriptInterface": "EventParticipationDocument",
      "dartModel": "lib/events/domain/event_participation.dart",
      "rulesTestFile": "functions/test/firestore.rules.test.cjs",
      "owner": "booking, waitlist, attendance, cancellation, and account-deletion callables",
      "read": "participant, club host, or authenticated users for attended edges",
      "write": "server only",
      "exportedFunctions": [
        "signUpForFreeEvent",
        "verifyRazorpayPayment",
        "cancelEventSignUp",
        "joinEventWaitlist",
        "leaveEventWaitlist",
        "createEventWaitlistOffers",
        "acceptEventWaitlistOffer",
        "declineEventWaitlistOffer",
        "markEventAttendance",
        "selfCheckInAttendance",
        "requestAccountDeletion"
      ],
      "migrationNotes": [
        "Owns signed-up, waitlisted, attended, cancelled, and deleted event roster state; events documents retain only callable-owned aggregate counts."
      ]
    },
    {
      "id": "eventBroadcasts",
      "path": "eventBroadcasts/{broadcastId}",
      "rulesMatch": "/eventBroadcasts/{broadcastId}",
      "typescriptInterface": "EventBroadcastDocument",
      "dartModel": null,
      "rulesTestFile": "functions/test/firestore.rules.test.cjs",
      "owner": "sendEventBroadcast callable and account-deletion cleanup",
      "read": "server/admin only; clients receive only the sanitized callable response",
      "write": "server only",
      "exportedFunctions": [
        "sendEventBroadcast",
        "requestAccountDeletion"
      ],
      "operations": [
        {
          "id": "host_send_event_broadcast",
          "type": "callable",
          "owner": "authenticated current host for the event",
          "function": "sendEventBroadcast",
          "payloadSchemaRef": "contracts/callables/send_event_broadcast_payload.schema.json",
          "rulesTestNames": [
            "keeps event broadcast delivery receipts server-only"
          ]
        },
        {
          "id": "account_deletion_cleanup",
          "type": "callable",
          "owner": "authenticated account owner",
          "function": "requestAccountDeletion"
        }
      ],
      "migrationNotes": [
        "The receipt freezes the server-resolved audience and per-delivery evidence; direct client reads and writes are denied.",
        "Requires a Firestore TTL policy on expiresAt.",
        "Account deletion deletes authored receipts and removes recipient identifiers and delivery evidence."
      ]
    },
    {
      "id": "eventWaitlistOffers",
      "path": "eventWaitlistOffers/{offerId}",
      "rulesMatch": "/eventWaitlistOffers/{offerId}",
      "typescriptInterface": "EventWaitlistOfferDocument",
      "dartModel": null,
      "rulesTestFile": "functions/test/firestore.rules.test.cjs",
      "owner": "waitlist offer callables and expiry scheduler",
      "read": "offered attendee or club host",
      "write": "server only",
      "exportedFunctions": [
        "createEventWaitlistOffers",
        "acceptEventWaitlistOffer",
        "declineEventWaitlistOffer",
        "expireEventWaitlistOffers"
      ],
      "migrationNotes": [
        "The offer document is the durable audit object; eventParticipations mirrors the current offer state for cheap roster and attendee CTA reads."
      ]
    },
    {
      "id": "eventInviteLinks",
      "path": "eventInviteLinks/{inviteLinkId}",
      "rulesMatch": "/eventInviteLinks/{inviteLinkId}",
      "typescriptInterface": "EventInviteLinkDocument",
      "dartModel": "lib/events/domain/event_invite_link.dart",
      "rulesTestFile": "functions/test/firestore.rules.test.cjs",
      "owner": "event invite link callables and event-success scorecard recomputation",
      "read": "club host only",
      "write": "server only",
      "exportedFunctions": [
        "createEventInviteLink",
        "disableEventInviteLink",
        "recordEventInviteLinkOpen",
        "onEventInviteLinkWritten",
        "onEventParticipationWritten",
        "onPaymentWritten",
        "onEventWaitlistOfferWritten",
        "onSwipeCreated",
        "onMessageCreated"
      ],
      "migrationNotes": [
        "Named host links track opens, requests, confirmations, payments, check-ins, matches, and chat starts without erasing disabled-link history."
      ]
    },
    {
      "id": "clubScheduleLocks",
      "path": "clubScheduleLocks/{lockId}",
      "rulesMatch": "/clubScheduleLocks/{lockId}",
      "owner": "event scheduling callables",
      "read": "server/admin only",
      "write": "server only",
      "exportedFunctions": [
        "createEvent",
        "updateEvent",
        "cancelEvent",
        "deleteEvent"
      ],
      "migrationNotes": [
        "Server-owned minute-bucket lock documents prevent overlapping active events for a club.",
        "Demo seeding writes these only when --include-schedule-locks is explicitly provided."
      ]
    },
    {
      "id": "userEventScheduleLocks",
      "path": "userEventScheduleLocks/{lockId}",
      "rulesMatch": "/userEventScheduleLocks/{lockId}",
      "owner": "event booking and waitlist callables",
      "read": "server/admin only",
      "write": "server only",
      "exportedFunctions": [
        "signUpForFreeEvent",
        "verifyRazorpayPayment",
        "cancelEventSignUp",
        "joinEventWaitlist",
        "leaveEventWaitlist"
      ],
      "migrationNotes": [
        "Server-owned minute-bucket lock documents prevent users from signing up or waitlisting for overlapping events.",
        "Demo seeding writes these only when --include-schedule-locks is explicitly provided."
      ]
    },
    {
      "id": "savedEvents",
      "path": "savedEvents/{savedEventId}",
      "rulesMatch": "/savedEvents/{savedEventId}",
      "typescriptInterface": "SavedEventDocument",
      "dartModel": "lib/events/domain/saved_event.dart",
      "rulesTestFile": "functions/test/firestore.rules.test.cjs",
      "owner": "authenticated owner",
      "read": "owner only",
      "write": "owner direct create/delete only",
      "operations": [
        {
          "id": "owner_save_run",
          "type": "directCreate",
          "owner": "authenticated owner",
          "allowedFields": [
            "uid",
            "eventId",
            "savedAt"
          ]
        },
        {
          "id": "owner_unsave_run",
          "type": "directDelete",
          "owner": "authenticated owner"
        }
      ],
      "migrationNotes": [
        "Owns saved-event state; users documents do not keep a saved-event projection. Current unsave is a hard delete."
      ]
    },
    {
      "id": "payments",
      "path": "payments/{paymentId}",
      "rulesMatch": "/payments/{paymentId}",
      "typescriptInterface": "PaymentDocument",
      "dartModel": "lib/payments/domain/payment.dart",
      "owner": "payments callables",
      "read": "payment owner only",
      "write": "server only",
      "exportedFunctions": [
        "createRazorpayOrder",
        "verifyRazorpayPayment"
      ]
    },
    {
      "id": "reviews",
      "path": "reviews/{reviewId}",
      "rulesMatch": "/reviews/{reviewId}",
      "typescriptInterface": "ReviewDocument",
      "dartModel": "lib/reviews/domain/review.dart",
      "rulesTestFile": "functions/test/firestore.rules.test.cjs",
      "owner": "review mutations are callable-owned; aggregate stats are trigger-owned",
      "read": "authenticated users",
      "write": "all review writes are callable-owned; direct client writes are denied",
      "exportedFunctions": [
        "createEventReview",
        "updateEventReview",
        "deleteEventReview",
        "syncClubReviewStats"
      ],
      "operations": [
        {
          "id": "attended_run_review_create",
          "type": "callable",
          "owner": "createEventReview",
          "function": "createEventReview",
          "payloadSchemaRef": "contracts/callables/create_event_review_payload.schema.json",
          "strictAllowedFieldsMatch": true,
          "allowedFields": [
            "clubId",
            "eventId",
            "rating",
            "comment"
          ],
          "pathDataFields": [
            "eventId",
            "reviewerUserId"
          ],
          "rulesMustContain": [
            "allow write: if false"
          ],
          "rulesTestNames": [
            "denies direct review writes because reviews are callable-owned"
          ]
        },
        {
          "id": "author_content_update",
          "type": "callable",
          "owner": "updateEventReview",
          "function": "updateEventReview",
          "payloadSchemaRef": "contracts/callables/update_event_review_payload.schema.json",
          "strictAllowedFieldsMatch": true,
          "allowedFields": [
            "rating",
            "comment"
          ],
          "deniedFields": [
            "clubId",
            "eventId",
            "reviewerUserId",
            "reviewerName",
            "createdAt"
          ],
          "rulesTestNames": [
            "denies direct review writes because reviews are callable-owned"
          ]
        },
        {
          "id": "author_review_delete",
          "type": "callable",
          "owner": "deleteEventReview",
          "function": "deleteEventReview",
          "payloadSchemaRef": "contracts/callables/delete_event_review_payload.schema.json",
          "rulesTestNames": [
            "denies direct review writes because reviews are callable-owned"
          ]
        }
      ],
      "migrationNotes": [
        "Existing club-level/random-id reviews should be migrated or archived before enforcing this in production. The app should write event-scoped reviews through callables only."
      ]
    },
    {
      "id": "profileDecisions",
      "path": "profileDecisions/{userId}/outgoing/{targetId}",
      "rulesMatch": "/profileDecisions/{userId}/outgoing/{targetId}",
      "typescriptInterface": "SwipeDocument",
      "dartModel": "lib/swipes/domain/swipe.dart",
      "rulesTestFile": "functions/test/firestore.rules.test.cjs",
      "owner": "swiper owns outgoing swipe create",
      "read": "swiper only",
      "write": "swiper create only",
      "exportedFunctions": [
        "onSwipeCreated"
      ],
      "operations": [
        {
          "id": "owner_outgoing_create",
          "type": "directCreate",
          "owner": "authenticated swiper",
          "allowedFields": [
            "swiperId",
            "targetId",
            "eventId",
            "direction",
            "reactionTargetId",
            "reactionTargetType",
            "reactionTargetLabel",
            "reactionTargetPreview",
            "comment",
            "createdAt"
          ],
