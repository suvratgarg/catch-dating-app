{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Catch Marketing Ops Bridge",
  "type": "object",
  "required": [
    "schemaVersion",
    "program",
    "city",
    "weekStart",
    "weekEnd",
    "summary",
    "sourceProfiles",
    "queryTemplates",
    "runPlan",
    "sourceResults",
    "eventCandidates",
    "recommendationSets",
    "contentDrafts",
    "guardrails",
    "commands"
  ],
  "properties": {
    "schemaVersion": {"const": 1},
    "program": {"type": "string"},
    "generatedAt": {"type": "string"},
    "city": {
      "type": "object",
      "required": ["id", "label", "timezone"],
      "properties": {
        "id": {"type": "string"},
        "label": {"type": "string"},
        "timezone": {"type": "string"}
      }
    },
    "weekStart": {"type": "string"},
    "weekEnd": {"type": "string"},
    "summary": {"type": "object"},
    "sourceProfiles": {"type": "array"},
    "queryTemplates": {"type": "array"},
    "runPlan": {"type": "object"},
    "sourceResults": {"type": "array"},
    "eventCandidates": {"type": "array"},
    "recommendationSets": {"type": "array"},
    "contentDrafts": {"type": "array"},
    "guardrails": {"type": "array", "items": {"type": "string"}},
    "commands": {"type": "object"}
  }
}
