{
  "$schema": "../schemas/marketing_ops_config.schema.json",
  "program": "catch-event-guide-marketing-ops",
  "city": {
    "id": "mumbai",
    "label": "Mumbai",
    "timezone": "Asia/Kolkata",
    "aliases": ["bombay"]
  },
  "cadence": {
    "publishDay": "Monday",
    "lookaheadDays": 7,
    "weeklyLabel": "This Week"
  },
  "contentStrategy": {
    "recommendedDefaultTone": "singles-friendly",
    "toneVariants": ["singles-friendly", "singles-social"],
    "ctaPriority": ["app_waitlist", "host_submission"],
    "copyGuardrails": [
      "Do not imply a third-party event is hosted by Catch.",
      "Do not imply an event is singles-only unless the source says so.",
      "Use singles-friendly for low-pressure, solo-attendable events.",
      "Every event needs source evidence before public publishing.",
      "Prefer useful specifics over hype."
    ],
    "categoryMixTargets": {
      "food_drink": 2,
      "culture": 2,
      "active": 1,
      "learning": 1,
      "nightlife": 1
    }
  },
  "ctas": {
    "app_waitlist": {
      "label": "Join the Catch waitlist",
      "destination": "TBD",
      "purpose": "user acquisition"
    },
    "host_submission": {
      "label": "Submit a host event",
      "destination": "TBD",
      "purpose": "host acquisition"
    }
  },
  "sourceProfiles": [
    {
      "id": "manual-instagram-reference-list",
      "label": "Instagram reference list",
      "type": "manual_reference_only",
      "status": "enabled",
      "cadence": "weekly",
      "riskLevel": "medium",
      "allowedUse": "Use user-provided URLs or manually reviewed posts as editorial leads only. Do not scrape Instagram.",
      "items": [
        {
          "label": "Mumbai Foodie",
          "url": "https://www.instagram.com/mumbaifoodie/"
        },
        {
          "label": "Servd India",
          "url": "https://www.instagram.com/servd.india/"
        },
        {
          "label": "Paperboard Magazine",
          "url": "https://www.instagram.com/paperboard.mag/"
        },
        {
          "label": "Conde Nast Traveller India",
          "url": "https://www.instagram.com/cntravellerindia/"
        }
      ]
    },
    {
      "id": "open-web-event-platforms",
      "label": "Open web event platforms",
      "type": "source_url_list",
      "status": "needs_verification",
      "cadence": "weekly",
      "riskLevel": "medium",
      "allowedUse": "Fetch only if permitted by source terms and robots policy; otherwise use manual review.",
      "items": [
        {
          "label": "BookMyShow Mumbai events",
          "url": "https://in.bookmyshow.com/explore/events-mumbai"
        },
        {
          "label": "Luma Mumbai discovery",
          "url": "https://lu.ma/mumbai"
        },
        {
          "label": "District Mumbai",
          "url": "https://www.district.in/events/mumbai"
        }
      ]
    },
    {
      "id": "host-submission-inbox",
      "label": "Catch host submissions",
      "type": "future_form_feed",
      "status": "planned",
      "cadence": "continuous",
      "riskLevel": "low",
      "allowedUse": "Catch-owned host submissions can become the highest trust source once the form exists."
    }
  ],
  "queryTemplates": [
    {
      "id": "city-events-week",
      "template": "events in {city} this week",
      "intent": "broad event discovery",
      "priority": 1
    },
    {
      "id": "city-things-to-do-week",
      "template": "things to do in {city} this week",
      "intent": "editorial guides and listings",
      "priority": 1
    },
    {
      "id": "city-events-month",
      "template": "events in {city} this month",
      "intent": "longer-running exhibitions and festivals",
      "priority": 2
    },
    {
      "id": "city-singles-mixers-week",
      "template": "singles mixers in {city} this week",
      "intent": "explicit singles-led events",
      "priority": 1
    },
    {
      "id": "city-singles-events-week",
      "template": "singles events in {city} this week",
      "intent": "dating-led or singles-led events",
      "priority": 1
    },
    {
      "id": "city-solo-friendly-week",
      "template": "events to attend solo in {city} this week",
      "intent": "singles-friendly and solo-attendable events",
      "priority": 2
    },
    {
      "id": "city-workshops-social-weekend",
      "template": "{city} workshops social events this weekend",
      "intent": "structured conversation and learning",
      "priority": 2
    },
    {
      "id": "city-community-open-mic-quiz",
      "template": "{city} quiz night open mic community events this week",
      "intent": "low-pressure conversation",
      "priority": 3
    }
  ],
  "rankingWeights": {
    "dateRelevance": 1.5,
    "soloFriendliness": 1.4,
    "conversationPotential": 1.3,
    "sourceTrust": 1.2,
    "visualPotential": 0.8,
    "activityFit": 1.0
  },
  "penalties": {
    "requiresVerification": -1.5,
    "missingPrice": -0.4,
    "missingSourceUrl": -1.0,
    "nonCity": -5.0
  },
  "limits": {
    "sourceResults": 40,
    "candidatePool": 25,
    "recommendationSlots": 7
  }
}
