{
  "$schema": "./primitives.contract.schema.json",
  "version": 2,
  "surface": "weekly_event_guide_instagram_carousel",
  "policy": {
    "mode": "reference_only",
    "rule": "This contract must reference existing Catch assets, text styles, tokens, and component primitives. It must not recreate logos, text styles, icons, badges, chips, or buttons."
  },
  "canvas": {
    "platform": "instagram_carousel",
    "width": 1080,
    "height": 1350,
    "aspectRatio": "4:5",
    "safeInsetPolicy": "define in renderer, not here"
  },
  "logo": {
    "requiredWordmark": "Catch _",
    "sourceStatus": "missing_source",
    "sourceAsset": null,
    "sourceComponent": null,
    "rule": "Do not synthesize this with text. Rendering is blocked until the real Catch _ logo asset or component is referenced."
  },
  "typography": {
    "rule": "Use Catch text style roles directly. Do not copy numeric style values into this contract.",
    "roleReferences": {
      "headline": {
        "file": "lib/core/theme/catch_text_styles.dart",
        "symbol": "CatchTextStyles.eventTitle"
      },
      "displayHeadline": {
        "file": "lib/core/theme/catch_text_styles.dart",
        "symbol": "CatchTextStyles.display"
      },
      "label": {
        "file": "lib/core/theme/catch_text_styles.dart",
        "symbol": "CatchTextStyles.kicker"
      },
      "metadata": {
        "file": "lib/core/theme/catch_text_styles.dart",
        "symbol": "CatchTextStyles.monoLabel"
      },
      "badge": {
        "file": "lib/core/theme/catch_text_styles.dart",
        "symbol": "CatchTextStyles.badge"
      },
      "body": {
        "file": "lib/core/theme/catch_text_styles.dart",
        "symbol": "CatchTextStyles.bodyM"
      },
      "button": {
        "file": "lib/core/theme/catch_text_styles.dart",
        "symbol": "CatchTextStyles.buttonMd"
      }
    },
    "fontRegistryReference": {
      "file": "lib/core/theme/catch_fonts.dart",
      "symbols": [
        "CatchFonts.voice",
        "CatchFonts.head",
        "CatchFonts.sans",
        "CatchFonts.mono"
      ]
    }
  },
  "colors": {
    "rule": "Use token references only. Do not duplicate hex values in templates.",
    "tokenSource": "design/tokens/catch.tokens.json",
    "themeReferences": [
      "theme.light.color.bg",
      "theme.light.color.surface",
      "theme.light.color.raised",
      "theme.light.color.ink",
      "theme.light.color.ink2",
      "theme.light.color.ink3",
      "theme.light.color.line",
      "theme.light.color.line2"
    ],
    "activityReferences": [
      "activity.dinner.accent",
      "activity.pubQuiz.accent",
      "activity.socialRun.accent",
      "activity.singlesMixer.accent",
      "activity.openActivity.accent"
    ]
  },
  "components": {
    "rule": "Use component contracts and runtime primitives. Do not redraw with local CSS/SVG shapes.",
    "references": [
      {
        "contractId": "catch.badge",
        "componentRegistry": "design/components/catch.components.json",
        "runtimeFile": "lib/core/widgets/catch_badge.dart",
        "runtimeSymbol": "CatchBadge"
      },
      {
        "contractId": "catch.chip",
        "componentRegistry": "design/components/catch.components.json",
        "runtimeFile": "lib/core/widgets/catch_chip.dart",
        "runtimeSymbol": "CatchChip"
      },
      {
        "contractId": "catch.button",
        "componentRegistry": "design/components/catch.components.json",
        "runtimeFile": "lib/core/widgets/catch_button.dart",
        "runtimeSymbol": "CatchButton"
      }
    ]
  },
  "carouselSpecificPrimitives": {
    "rule": "New carousel wrappers may compose existing references, but may not define new visual language.",
    "allowed": [
      "CarouselFrame",
      "CarouselLogoSlot",
      "CarouselEventMetadata",
      "CarouselReviewBadge",
      "CarouselCtaStack"
    ],
    "blockedUntilLogoSourceExists": true
  }
}
