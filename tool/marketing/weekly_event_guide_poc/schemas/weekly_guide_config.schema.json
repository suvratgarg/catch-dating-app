{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Catch weekly event guide config",
  "type": "object",
  "required": [
    "program",
    "city",
    "cadence",
    "contentStrategy",
    "ctas",
    "sources",
    "weeklySearches",
    "rankingWeights",
    "limits"
  ],
  "properties": {
    "program": {
      "type": "string"
    },
    "city": {
      "type": "object",
      "required": [
        "id",
        "label",
        "timezone"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "label": {
          "type": "string"
        },
        "timezone": {
          "type": "string"
        }
      }
    },
    "cadence": {
      "type": "object"
    },
    "contentStrategy": {
      "type": "object"
    },
    "ctas": {
      "type": "object"
    },
    "sources": {
      "type": "array"
    },
    "weeklySearches": {
      "type": "array"
    },
    "rankingWeights": {
      "type": "object"
    },
    "limits": {
      "type": "object"
    }
  }
}
