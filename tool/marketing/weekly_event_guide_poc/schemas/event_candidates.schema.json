{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Catch weekly event guide candidates",
  "type": "object",
  "required": [
    "city",
    "week",
    "events"
  ],
  "properties": {
    "city": {
      "type": "string"
    },
    "week": {
      "type": "string"
    },
    "events": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "title",
          "category",
          "neighborhood",
          "startDate",
          "reviewState",
          "requiresVerification",
          "explicitSinglesEvent",
          "whySinglesFriendly",
          "scores"
        ]
      }
    }
  }
}
