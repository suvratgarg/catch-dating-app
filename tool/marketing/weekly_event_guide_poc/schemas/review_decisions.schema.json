{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Catch weekly event guide review decisions",
  "type": "object",
  "required": [
    "city",
    "week",
    "decisions"
  ],
  "properties": {
    "city": {
      "type": "string"
    },
    "week": {
      "type": "string"
    },
    "decisions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "eventId",
          "reviewState"
        ],
        "properties": {
          "eventId": {
            "type": "string"
          },
          "reviewState": {
            "type": "string",
            "enum": [
              "draft",
              "needs_changes",
              "approved",
              "rejected"
            ]
          },
          "editorNotes": {
            "type": "string"
          }
        }
      }
    }
  }
}
