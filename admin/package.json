{
  "name": "catch-admin",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "npm run check:boundaries && npm run typecheck && vite build && npm run check:bundle-budget",
    "check:boundaries": "node ../tool/admin/check_import_boundaries.mjs",
    "check:bundle-budget": "node scripts/checkBundleBudget.mjs --check",
    "check:storybook-bundle-budget": "node scripts/checkStorybookBundleBudget.mjs --check",
    "check:callable-validators": "node scripts/generateCallableValidators.mjs --check",
    "check:query-state": "node ../tool/web/check_react_query_state.mjs --check --surface admin",
    "check:class-names": "node ../tool/web/check_react_classname_boundaries.mjs --check --surface admin",
    "check:ui-components": "node ../tool/web/check_react_component_governance.mjs --check --surface admin",
    "check:component-registry": "node ../tool/web/check_admin_components.mjs --check",
    "check:feature-ui-size": "node ../tool/web/check_admin_feature_ui_size.mjs --check",
    "check:ui-primitives": "node ../tool/web/check_react_ui_primitives.mjs --check --surface admin",
    "generate:callable-validators": "node scripts/generateCallableValidators.mjs",
    "preview": "vite preview --host 127.0.0.1",
    "storybook": "HOME=/tmp/catch-admin-storybook-home STORYBOOK_DISABLE_TELEMETRY=1 storybook dev -p 6007 --host 127.0.0.1 --disable-telemetry",
    "build:storybook": "HOME=/tmp/catch-admin-storybook-home STORYBOOK_DISABLE_TELEMETRY=1 storybook build --disable-telemetry && npm run check:storybook-bundle-budget",
    "test:visual": "node ../tool/web/check_storybook_visuals.mjs --surface admin --check",
    "test": "vitest run --project=unit",
    "test:coverage": "vitest run --project=unit --coverage",
    "test:storybook:a11y": "STORYBOOK_DISABLE_TELEMETRY=1 vitest run --project=storybook",
    "test:watch": "vitest --project=unit",
    "pretypecheck": "npm run check:callable-validators",
    "typecheck": "npm run check:ui-primitives && npm run check:class-names && npm run check:ui-components && npm run check:feature-exports && npm run check:component-registry && npm run check:feature-ui-size && npm run check:query-state && tsc -p tsconfig.json --noEmit --pretty false && tsc -p tsconfig.node.json --noEmit --pretty false",
    "check:feature-exports": "node ../tool/web/check_admin_feature_exports.mjs --check"
  },
  "dependencies": {
    "@catch/web-ui": "0.1.0",
    "@tanstack/react-query": "^5.101.2",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "firebase": "^12.6.0",
    "lucide-react": "^1.17.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router": "^8.1.0"
  },
  "devDependencies": {
    "@storybook/addon-a11y": "^10.4.6",
    "@storybook/addon-vitest": "^10.4.6",
    "@storybook/react-vite": "^10.4.6",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/browser-playwright": "^4.1.10",
    "@vitest/coverage-v8": "^4.1.10",
    "jsdom": "^28.1.0",
    "playwright": "^1.61.1",
    "storybook": "^10.4.6",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.10"
  }
}
