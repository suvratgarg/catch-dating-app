{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Catch marketing website metadata content",
  "type": "object",
  "required": ["$schema", "routes", "listing", "event"],
  "additionalProperties": false,
  "properties": {
    "$schema": {"const": "./meta.schema.json"},
    "routes": {
      "type": "object",
      "required": ["home", "host", "organizers", "claim", "privacy", "terms", "help", "not_found"],
      "additionalProperties": false,
      "properties": {
        "home": {"$ref": "#/$defs/staticMeta"},
        "host": {"$ref": "#/$defs/staticMeta"},
        "organizers": {"$ref": "#/$defs/staticMeta"},
        "claim": {"$ref": "#/$defs/staticMeta"},
        "privacy": {"$ref": "#/$defs/staticMeta"},
        "terms": {"$ref": "#/$defs/staticMeta"},
        "help": {"$ref": "#/$defs/staticMeta"},
        "not_found": {"$ref": "#/$defs/staticMeta"}
      }
    },
    "listing": {
      "type": "object",
      "required": ["titleTemplate", "staticLabels"],
      "additionalProperties": false,
      "properties": {
        "titleTemplate": {
          "type": "string",
          "allOf": [
            {"pattern": "\\{name\\}"},
            {"pattern": "\\{city\\}"}
          ]
        },
        "staticLabels": {
          "type": "object",
          "required": [
            "profileEyebrow",
            "formatsHeading",
            "factsHeading",
            "sourcesHeading",
            "lastVerifiedPrefix",
            "notRecorded",
            "homeBreadcrumb",
            "organizersBreadcrumb"
          ],
          "additionalProperties": false,
          "properties": {
            "profileEyebrow": {"type": "string", "minLength": 1},
            "formatsHeading": {"type": "string", "minLength": 1},
            "factsHeading": {"type": "string", "minLength": 1},
            "sourcesHeading": {"type": "string", "minLength": 1},
            "lastVerifiedPrefix": {"type": "string", "minLength": 1},
            "notRecorded": {"type": "string", "minLength": 1},
            "homeBreadcrumb": {"type": "string", "minLength": 1},
            "organizersBreadcrumb": {"type": "string", "minLength": 1}
          }
        }
      }
    },
    "event": {
      "type": "object",
      "required": [
        "titleTemplate",
        "catchTwitterTemplate",
        "externalTwitterTemplate",
        "staticLabels"
      ],
      "additionalProperties": false,
      "properties": {
        "titleTemplate": {
          "type": "string",
          "allOf": [
            {"pattern": "\\{title\\}"},
            {"pattern": "\\{city\\}"}
          ]
        },
        "catchTwitterTemplate": {
          "type": "string",
          "allOf": [
            {"pattern": "\\{title\\}"},
            {"pattern": "\\{organizer\\}"}
          ]
        },
        "externalTwitterTemplate": {
          "type": "string",
          "allOf": [
            {"pattern": "\\{title\\}"},
            {"pattern": "\\{source\\}"}
          ]
        },
        "staticLabels": {
          "type": "object",
          "required": [
            "eventEyebrow",
            "hostedByPrefix",
            "scheduleHeading",
            "locationLabel",
            "priceLabel",
            "sourceLabel",
            "reviewsHeading",
            "lastReviewedPrefix",
            "homeBreadcrumb",
            "organizersBreadcrumb"
          ],
          "additionalProperties": false,
          "properties": {
            "eventEyebrow": {"type": "string", "minLength": 1},
            "hostedByPrefix": {"type": "string", "minLength": 1},
            "scheduleHeading": {"type": "string", "minLength": 1},
            "locationLabel": {"type": "string", "minLength": 1},
            "priceLabel": {"type": "string", "minLength": 1},
            "sourceLabel": {"type": "string", "minLength": 1},
            "reviewsHeading": {"type": "string", "minLength": 1},
            "lastReviewedPrefix": {"type": "string", "minLength": 1},
            "homeBreadcrumb": {"type": "string", "minLength": 1},
            "organizersBreadcrumb": {"type": "string", "minLength": 1}
          }
        }
      }
    }
  },
  "$defs": {
    "staticMeta": {
      "type": "object",
      "required": ["title", "description", "canonicalPath", "twitterDescription"],
      "additionalProperties": false,
      "properties": {
        "title": {"type": "string", "minLength": 1},
        "description": {"type": "string", "minLength": 1},
        "canonicalPath": {"type": "string", "pattern": "^/(?:.*?/)?$"},
        "twitterDescription": {"type": "string", "minLength": 1},
        "robots": {"const": "noindex, follow"}
      }
    }
  }
}
