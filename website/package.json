{
  "name": "catch-marketing",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "generate:organizer-listings": "node scripts/generateOrganizerListings.mjs",
    "generate:organizer-listings:demo": "node scripts/generateOrganizerListings.mjs --include-demo --output src/generated/hostListings.demo.json",
    "check:organizer-listings": "node scripts/generateOrganizerListings.mjs --check && node scripts/generateOrganizerListings.mjs --include-demo --output src/generated/hostListings.demo.json --check",
    "check:routes": "node ../tool/marketing/check_website_routes.mjs --check",
    "check:components": "node ../tool/marketing/check_website_components.mjs --check",
    "check:architecture": "node ../tool/web/check_react_architecture_boundaries.mjs --check --surface website",
    "check:copy": "node ../tool/web/check_website_copy_ownership.mjs --check",
    "check:analytics-contract": "node --experimental-strip-types --test scripts/analyticsContract.test.mjs",
    "check:a11y-debt": "node scripts/checkStorybookA11yDebt.mjs",
    "check:event-eligibility": "node --experimental-strip-types --test scripts/homeEventEligibility.test.mjs",
    "check:market-pack": "node --experimental-strip-types --test scripts/marketPack.test.mjs",
    "check:published-legal-content": "node --experimental-strip-types --test scripts/ownerGatedContent.test.mjs",
    "check:postbuild-contract": "node --test scripts/postbuild.test.mjs",
    "check:import-boundaries": "node ../tool/web/check_website_import_boundaries.mjs",
    "check:query-state": "node ../tool/web/check_react_query_state.mjs --check --surface website",
    "check:ui-primitives": "node ../tool/web/check_react_ui_primitives.mjs --check --surface website",
    "check:class-names": "node ../tool/web/check_react_classname_boundaries.mjs --check --surface website",
    "check:ui-components": "node ../tool/web/check_react_component_governance.mjs --check --surface website",
    "pretypecheck": "npm run check:organizer-listings && npm run check:routes && npm run check:components && npm run check:architecture && npm run check:copy && npm run check:market-pack && npm run check:event-eligibility && npm run check:analytics-contract && npm run check:a11y-debt && npm run check:published-legal-content && npm run check:postbuild-contract && npm run check:import-boundaries && npm run check:ui-primitives && npm run check:class-names && npm run check:ui-components && npm run check:query-state",
    "dev": "vite --host 127.0.0.1",
    "build": "npm run typecheck && vite build && node scripts/postbuild.mjs",
    "preview": "vite preview --host 127.0.0.1",
    "storybook": "HOME=/tmp/catch-storybook-home STORYBOOK_DISABLE_TELEMETRY=1 storybook dev -p 6006 --host 127.0.0.1 --disable-telemetry",
    "build:storybook": "HOME=/tmp/catch-storybook-home STORYBOOK_DISABLE_TELEMETRY=1 storybook build --disable-telemetry",
    "test:visual": "node ../tool/web/check_storybook_visuals.mjs --surface website --check && node ../tool/web/check_storybook_visuals.mjs --surface webui --check",
    "test:storybook:a11y": "STORYBOOK_DISABLE_TELEMETRY=1 vitest run --project=storybook",
    "test:unit": "vitest run --project=unit",
    "test:unit:coverage": "vitest run --project=unit --coverage",
    "typecheck": "tsc -p tsconfig.json --noEmit --pretty false && tsc -p tsconfig.node.json --noEmit --pretty false"
  },
  "dependencies": {
    "@catch/web-ui": "0.1.0",
    "@tanstack/react-query": "^5.101.2",
    "firebase": "^12.14.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router": "^8.1.0"
  },
  "devDependencies": {
    "@storybook/addon-a11y": "^10.4.6",
    "@storybook/addon-vitest": "^10.4.6",
    "@storybook/react-vite": "^10.4.6",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/browser-playwright": "^4.1.10",
    "@vitest/coverage-v8": "^4.1.10",
    "playwright": "^1.61.1",
    "storybook": "^10.4.6",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.10"
  }
}
