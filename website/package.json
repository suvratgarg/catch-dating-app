{
  "name": "catch-marketing",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "generate:organizer-listings": "node scripts/generateOrganizerListings.mjs",
    "check:organizer-listings": "node scripts/generateOrganizerListings.mjs --check",
    "check:routes": "node ../tool/marketing/check_website_routes.mjs --check",
    "check:components": "node ../tool/marketing/check_website_components.mjs --check",
    "pretypecheck": "npm run check:organizer-listings && npm run check:routes && npm run check:components",
    "dev": "vite --host 127.0.0.1",
    "build": "npm run typecheck && vite build && node scripts/postbuild.mjs",
    "preview": "vite preview --host 127.0.0.1",
    "storybook": "HOME=/tmp/catch-storybook-home STORYBOOK_DISABLE_TELEMETRY=1 storybook dev -p 6006 --host 127.0.0.1 --disable-telemetry",
    "build:storybook": "HOME=/tmp/catch-storybook-home STORYBOOK_DISABLE_TELEMETRY=1 storybook build --disable-telemetry",
    "typecheck": "tsc -p tsconfig.json --noEmit --pretty false && tsc -p tsconfig.node.json --noEmit --pretty false"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.101.2",
    "firebase": "^12.14.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router": "^8.1.0"
  },
  "devDependencies": {
    "@storybook/addon-a11y": "^10.4.6",
    "@storybook/react-vite": "^10.4.6",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "storybook": "^10.4.6",
    "typescript": "^6.0.3",
    "vite": "^8.0.16"
  }
}
