VITE_GTM_ID=GTM-XXXXXXX
VITE_WEBSITE_APPCHECK_SITE_KEY=
# Keep both URLs empty in prelaunch mode. Change the mode to live only when both
# official product listings exist, then provide their exact HTTPS URLs.
