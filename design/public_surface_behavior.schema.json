{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://catch.app/schemas/public_surface_behavior.schema.json",
  "title": "Catch public surface behavior contract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "version",
    "updated",
    "purpose",
    "coveragePolicy",
    "inventorySources",
    "compositions",
    "dimensions",
    "dispositions",
    "surfaces",
    "proofHarnesses",
    "absentSurfaces"
  ],
  "properties": {
    "$schema": {
      "const": "./public_surface_behavior.schema.json"
    },
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "updated": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
    },
    "purpose": {
      "type": "string",
      "minLength": 1
    },
    "coveragePolicy": {
      "type": "string",
      "minLength": 1
    },
    "inventorySources": {
      "type": "object",
      "additionalProperties": false,
      "required": ["appRoutes", "appScreens", "websiteRoutes"],
      "properties": {
        "appRoutes": {"$ref": "#/$defs/repoPath"},
        "appScreens": {"$ref": "#/$defs/repoPath"},
        "websiteRoutes": {"$ref": "#/$defs/repoPath"}
      }
    },
    "compositions": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/composition"}
    },
    "dimensions": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/dimension"}
    },
    "dispositions": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/disposition"}
    },
    "surfaces": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/surface"}
    },
    "proofHarnesses": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/proofHarness"}
    },
    "absentSurfaces": {
      "type": "array",
      "items": {"$ref": "#/$defs/absentSurface"}
    }
  },
  "$defs": {
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-zA-Z0-9]*(?:[._-][a-zA-Z0-9]+)*$"
    },
    "repoPath": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$)).+$"
    },
    "stringSet": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "contains"],
      "properties": {
        "path": {"$ref": "#/$defs/repoPath"},
        "contains": {
          "allOf": [
            {"$ref": "#/$defs/stringSet"},
            {"minItems": 1}
          ]
        }
      }
    },
    "composition": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "kind", "appliesToSurfaceIds", "evidence", "notes"],
      "properties": {
        "id": {"$ref": "#/$defs/id"},
        "kind": {
          "enum": ["orthogonalStateContract", "resolver"]
        },
        "appliesToSurfaceIds": {
          "allOf": [
            {"$ref": "#/$defs/stringSet"},
            {"minItems": 1}
          ]
        },
        "evidence": {"$ref": "#/$defs/evidence"},
        "notes": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "jsonPointerSource": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "path", "pointer", "match"],
      "properties": {
        "kind": {"const": "jsonPointer"},
        "path": {"$ref": "#/$defs/repoPath"},
        "pointer": {
          "type": "string",
          "pattern": "^/"
        },
        "match": {"const": "exact"}
      }
    },
    "dartEnumSource": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "path", "symbol", "match"],
      "properties": {
        "kind": {"const": "dartEnum"},
        "path": {"$ref": "#/$defs/repoPath"},
        "symbol": {
          "type": "string",
          "pattern": "^[A-Za-z][A-Za-z0-9_]*$"
        },
        "match": {"const": "exact"}
      }
    },
    "dimension": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "description", "values"],
      "properties": {
        "id": {"$ref": "#/$defs/id"},
        "description": {
          "type": "string",
          "minLength": 1
        },
        "values": {
          "allOf": [
            {"$ref": "#/$defs/stringSet"},
            {"minItems": 1}
          ]
        },
        "source": {
          "oneOf": [
            {"$ref": "#/$defs/jsonPointerSource"},
            {"$ref": "#/$defs/dartEnumSource"}
          ]
        }
      }
    },
    "disposition": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "presence",
        "availability",
        "execution",
        "description"
      ],
      "properties": {
        "id": {"$ref": "#/$defs/id"},
        "presence": {
          "enum": ["visible", "hidden"]
        },
        "availability": {
          "enum": ["enabled", "disabled", "notApplicable"]
        },
        "execution": {
          "enum": [
            "none",
            "native",
            "web",
            "external",
            "local",
            "signInGate",
          "profileGate",
          "redirectSignIn",
          "redirectLoading",
          "redirectProfile",
          "redirectResume"
          ]
        },
        "description": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "element": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "kind", "description"],
      "properties": {
        "id": {"$ref": "#/$defs/id"},
        "kind": {
          "enum": ["content", "badge", "action", "routeGuard"]
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "constantDisposition": {"$ref": "#/$defs/id"},
        "constantRationale": {"type": "string", "minLength": 1}
      }
    },
    "expectation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["disposition"],
      "properties": {
        "disposition": {"$ref": "#/$defs/id"},
        "variant": {
          "type": "string",
          "minLength": 1
        },
        "target": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "configuration": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "values",
        "expectations",
        "implementationStatus",
        "proofHarnessIds"
      ],
      "properties": {
        "id": {"$ref": "#/$defs/id"},
        "values": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": {
            "type": "string",
            "minLength": 1
          }
        },
        "expectations": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": {"$ref": "#/$defs/expectation"}
        },
        "implementationStatus": {
          "enum": ["specified", "implemented", "verified"]
        },
        "proofHarnessIds": {
          "allOf": [
            {"$ref": "#/$defs/stringSet"},
            {"minItems": 1}
          ]
        },
        "notes": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "excludedDecisionValues": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "surface": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "platform",
        "coverageKind",
        "coverageRationale",
        "routeIds",
        "decisionDimensions",
        "excludedDecisionValues",
        "invariantDimensions",
        "compositionIds",
        "elements",
        "configurations",
        "evidence"
      ],
      "properties": {
        "id": {"$ref": "#/$defs/id"},
        "platform": {
          "enum": ["app", "web"]
        },
        "coverageKind": {
          "enum": ["matrix", "routeGuard"]
        },
        "coverageRationale": {
          "type": "string",
          "minLength": 1
        },
        "routeIds": {
          "allOf": [
            {"$ref": "#/$defs/stringSet"},
            {"minItems": 1}
          ]
        },
        "screenIds": {"$ref": "#/$defs/stringSet"},
        "decisionDimensions": {
          "allOf": [
            {"$ref": "#/$defs/stringSet"},
            {"minItems": 1}
          ]
        },
        "excludedDecisionValues": {
          "$ref": "#/$defs/excludedDecisionValues"
        },
        "invariantDimensions": {"$ref": "#/$defs/stringSet"},
        "compositionIds": {"$ref": "#/$defs/stringSet"},
        "elements": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/element"}
        },
        "configurations": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/configuration"}
        },
        "evidence": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/evidence"}
        }
      }
    },
    "proofHarness": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "platform",
        "status",
        "path",
        "contains",
        "surfaceIds",
        "configurationIds",
        "verificationMode"
      ],
      "properties": {
        "id": {"$ref": "#/$defs/id"},
        "platform": {
          "enum": ["app", "web"]
        },
        "status": {
          "enum": ["existing", "planned"]
        },
        "path": {"$ref": "#/$defs/repoPath"},
        "contains": {
          "allOf": [
            {"$ref": "#/$defs/stringSet"},
            {"minItems": 1}
          ]
        },
        "surfaceIds": {
          "allOf": [
            {"$ref": "#/$defs/stringSet"},
            {"minItems": 1}
          ]
        },
        "configurationIds": {
          "allOf": [
            {"$ref": "#/$defs/stringSet"},
            {"minItems": 1}
          ]
        },
        "verificationMode": {
          "const": "dynamicMatrixEnumeration"
        }
      }
    },
    "absentSurface": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "platform",
        "checkedInventory",
        "forbiddenRouteIds",
        "counterpartSurfaceId",
        "reason"
      ],
      "properties": {
        "id": {"$ref": "#/$defs/id"},
        "platform": {
          "enum": ["app", "web"]
        },
        "checkedInventory": {
          "enum": ["appRoutes", "websiteRoutes"]
        },
        "forbiddenRouteIds": {
          "allOf": [
            {"$ref": "#/$defs/stringSet"},
            {"minItems": 1}
          ]
        },
        "counterpartSurfaceId": {"$ref": "#/$defs/id"},
        "reason": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
