{
  "$schema": "./website.routes.schema.json",
  "version": 9,
  "updated": "2026-07-22",
  "owner": "marketing_website",
  "sourceOfTruth": {
    "architecture": "docs/web_surface_architecture.md",
    "positioning": "docs/marketing_landing_page_research.md",
    "media": "docs/marketing_app_media_pipeline.md",
    "runtimeShell": "website/src/app/App.tsx",
    "runtimeRouter": "website/src/app/routeRegistry.ts",
    "metadataRuntime": "website/src/app/pageMeta.ts",
    "metadataContent": "website/src/content/meta.json",
    "metadataSchema": "website/src/content/meta.schema.json",
    "staticOutput": "website/scripts/postbuild.mjs",
    "hostingConfig": "firebase.json",
    "generatedListings": "website/src/generated/hostListings.json"
  },
  "routes": [
    {
      "id": "home",
      "kind": "static",
      "path": "/",
      "pageKey": "home",
      "source": "website/src/features/home/HomePage.tsx",
      "metaKey": "home",
      "staticOutput": "postbuild",
      "indexing": "index",
      "sitemap": "included",
      "notes": "Primary member and public discovery entrypoint. Pilot launch metadata and runtime market content name Mumbai and Indore as the only live cities.",
      "review": {
        "priority": "p0",
        "status": "ready",
        "viewports": ["desktop", "mobile"],
        "states": ["default", "app-download-pending", "waitlist-form"],
        "stateCoverage": {
          "storybook": ["default"],
          "manual": ["app-download-pending", "waitlist-form"]
        }
      }
    },
    {
      "id": "host",
      "kind": "static",
      "path": "/host/",
      "pageKey": "host",
      "source": "website/src/features/host/HostPage.tsx",
      "metaKey": "host",
      "staticOutput": "postbuild",
      "indexing": "index",
      "sitemap": "included",
      "notes": "Canonical public host acquisition page. Legacy /host/preview and nested paths redirect permanently to /host/.",
      "review": {
        "priority": "p0",
        "status": "ready",
        "viewports": ["desktop", "mobile"],
        "states": ["default", "founding-host-offer", "host-application", "capture-placeholders"],
        "stateCoverage": {
          "storybook": ["default"],
          "manual": ["founding-host-offer", "host-application", "capture-placeholders"]
        }
      }
    },
    {
      "id": "organizer_search",
      "kind": "static",
      "path": "/organizers/",
      "pageKey": "organizers",
      "source": "website/src/features/organizers/OrganizerSearchPage.tsx",
      "metaKey": "organizers",
      "staticOutput": "postbuild",
      "indexing": "noindex-follow",
      "sitemap": "excluded",
      "notes": "Search surface for generated organizer profiles; deliberately noindex until public inventory quality is stronger.",
      "review": {
        "priority": "p0",
        "status": "ready",
        "viewports": ["desktop", "mobile"],
        "states": ["default", "filtered", "empty-results", "saved-organizers"],
        "stateCoverage": {
          "storybook": ["default"],
          "manual": ["filtered", "empty-results", "saved-organizers"]
        }
      }
    },
    {
      "id": "claim",
      "kind": "static",
      "path": "/claim/",
      "pageKey": "claim",
      "source": "website/src/features/claims/ClaimPage.tsx",
      "metaKey": "claim",
      "staticOutput": "postbuild",
      "indexing": "noindex-follow",
      "sitemap": "excluded",
      "notes": "Claim landing route with static noindex output. Firebase Hosting serves nested claim lookup URLs through /claim/index.html.",
      "review": {
        "priority": "p0",
        "status": "ready",
        "viewports": ["desktop", "mobile"],
        "states": ["default", "not-found", "pending-claim", "already-claimed", "claim-unavailable"],
        "stateCoverage": {
          "storybook": ["default"],
          "manual": ["not-found", "pending-claim", "already-claimed", "claim-unavailable"]
        }
      }
    },
    {
      "id": "claim_lookup",
      "kind": "clientDynamic",
      "pathPattern": "/claim/:listing/",
      "pageKey": "claim",
      "source": "website/src/features/claims/ClaimPage.tsx",
      "metaKey": "claim",
      "staticOutput": "spa-rewrite",
      "indexing": "noindex-follow",
      "sitemap": "excluded",
      "notes": "Client lookup variant parsed by getClaimListingLookupFromLocation; Firebase Hosting rewrites /claim/** to the static /claim/index.html shell.",
      "review": {
        "priority": "p1",
        "status": "manual",
        "viewports": ["desktop", "mobile"],
        "states": ["known-listing", "not-found", "pending-claim", "claim-unavailable"],
        "stateCoverage": {
          "storybook": [],
          "manual": ["known-listing", "not-found", "pending-claim", "claim-unavailable"]
        }
      }
    },
    {
      "id": "privacy",
      "kind": "static",
      "path": "/privacy/",
      "pageKey": "privacy",
      "source": "website/src/features/legal/LegalPage.tsx",
      "metaKey": "privacy",
      "staticOutput": "postbuild",
      "indexing": "index",
      "sitemap": "included",
      "notes": "Published privacy policy with confirmed operator, contact, grievance, data-use, rights, retention, safety, and public-source listing terms.",
      "review": {
        "priority": "p0",
        "status": "ready",
        "viewports": ["desktop", "mobile"],
        "states": ["published"],
        "stateCoverage": {"storybook": ["published"], "manual": []}
      }
    },
    {
      "id": "terms",
      "kind": "static",
      "path": "/terms/",
      "pageKey": "terms",
      "source": "website/src/features/legal/LegalPage.tsx",
      "metaKey": "terms",
      "staticOutput": "postbuild",
      "indexing": "index",
      "sitemap": "included",
      "notes": "Published terms for the website-first pilot, external events, public-source listings, accounts, conduct, safety, and governing law.",
      "review": {
        "priority": "p0",
        "status": "ready",
        "viewports": ["desktop", "mobile"],
        "states": ["published"],
        "stateCoverage": {"storybook": ["published"], "manual": []}
      }
    },
    {
      "id": "help",
      "kind": "static",
      "path": "/help/",
      "pageKey": "help",
      "source": "website/src/features/legal/LegalPage.tsx",
      "metaKey": "help",
      "staticOutput": "postbuild",
      "indexing": "index",
      "sitemap": "included",
      "notes": "Published account, privacy, listing, event, safety, website, correction, claim, and takedown support route.",
      "review": {
        "priority": "p0",
        "status": "ready",
        "viewports": ["desktop", "mobile"],
        "states": ["published"],
        "stateCoverage": {"storybook": ["published"], "manual": []}
      }
    },
    {
      "id": "not_found",
      "kind": "static",
      "path": "/404/",
      "pageKey": "not_found",
      "source": "website/src/features/notFound/NotFoundPage.tsx",
      "metaKey": "not_found",
      "staticOutput": "postbuild",
      "httpStatus": 404,
      "indexing": "noindex-follow",
      "sitemap": "excluded",
      "notes": "Unknown direct routes are served through the generated root 404.html with HTTP 404; client-side unknown routes render the same noindex not-found page.",
      "review": {
        "priority": "p1",
        "status": "ready",
        "viewports": ["desktop", "mobile"],
        "states": ["unknown-route", "missing-organizer-listing"],
        "stateCoverage": {
          "storybook": ["unknown-route"],
          "manual": ["missing-organizer-listing"]
        }
      }
    },
    {
      "id": "organizer_listing_canonical",
      "kind": "generatedFamily",
      "pathPatterns": ["/organizers/:slug/", "/organizers/:citySlug/:slug/"],
      "pageKey": "listing",
      "source": "website/src/features/organizers/HostListingPage.tsx",
      "metaFactory": "pageMetaForListing",
      "staticOutput": "generated-postbuild",
      "indexing": "listing-controlled",
      "sitemap": "listing-controlled",
      "notes": "Generated canonical organizer profile routes from website/src/generated/hostListings.json. The deployable projection includes only organizers with at least one market whose status is live in the active market pack; waitlist-market records remain available to review tooling and Storybook but cannot enter static output, search, or sitemap. Postbuild emits crawlable semantic profile content, Organization JSON-LD, canonical metadata, and lastVerifiedAt sitemap dates before React starts.",
      "review": {
        "priority": "p0",
        "status": "ready",
        "viewports": ["desktop", "mobile"],
        "states": ["indexable", "noindex", "public-api-disabled", "external-events", "claim-cta"],
        "stateCoverage": {
          "storybook": ["claim-cta"],
          "manual": ["indexable", "noindex", "public-api-disabled", "external-events"]
        }
      }
    },
    {
      "id": "organizer_listing_legacy",
      "kind": "generatedFamily",
      "pathPattern": "hostListing.legacyPaths[]",
      "pageKey": "listing",
      "source": "website/src/features/organizers/HostListingPage.tsx",
      "metaFactory": "pageMetaForListing",
      "staticOutput": "generated-postbuild",
      "indexing": "noindex-follow",
      "sitemap": "excluded",
      "notes": "Generated legacy organizer routes must preserve canonical URL and noindex after hydration.",
      "review": {
        "priority": "p0",
        "status": "manual",
        "viewports": ["desktop"],
        "states": ["legacy-noindex", "canonical-preserved"],
        "stateCoverage": {
          "storybook": [],
          "manual": ["legacy-noindex", "canonical-preserved"]
        }
      }
    }
  ],
  "redirects": [
    {
      "source": "/host/preview",
      "destination": "/host/",
      "status": 301,
      "preserveQuery": true
    },
    {
      "source": "/host/preview/**",
      "destination": "/host/",
      "status": 301,
      "preserveQuery": true
    }
  ]
}
