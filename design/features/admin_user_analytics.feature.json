{
  "$schema": "./feature_contract.schema.json",
  "version": 2,
  "updated": "2026-07-23",
  "id": "feature.admin_user_analytics",
  "name": "Admin User Analytics",
  "owner": "admin_console",
  "status": "pilot",
  "description": "Orchestrates exact-uid aggregate member analytics lookup with validated time scope, honest empty and partial reports, and actionable retry states.",
  "surfaces": [
    {
      "id": "admin_web",
      "runtime": "react_admin",
      "authority": {"registry": "admin_routes", "id": "route_user_analytics"},
      "actionScope": {
        "included": "Submitting one normalized uid and analytics range, retrying the same read after a missing, forbidden, or failed result, and freezing the complete Admin workspace while that submitted query is pending.",
        "excluded": [
          "Uid, range, date, and granularity edits remain validated query form data.",
          "The report is aggregate and read-only; it does not expose event-member detail or mutate member state."
        ]
      },
      "bindings": {
        "previewSources": ["admin/src/stories/AdminRoutes.stories.tsx"],
        "actionOwners": [
          {"id": "controller", "language": "typescript", "file": "admin/src/features/users/controllers/useUserAnalyticsController.ts", "symbol": "useUserAnalyticsController"}
        ],
        "componentContracts": ["route_user_analytics"],
        "dataContracts": [
          "contracts/callables/user_analytics_query_payload.schema.json",
          "contracts/callable_responses/user_analytics_response.schema.json"
        ],
        "runtimeContracts": [
          {"kind": "admin_callable", "registry": "admin/src/generated/validators/adminCallableValidators.ts", "callable": "adminGetUserAnalytics", "requestValidation": "strict_schema", "responseValidation": "strict_schema"}
        ],
        "testEvidence": {
          "aggregate-report": [
            "admin/src/features/users/controllers/useUserAnalyticsController.test.tsx",
            "admin/src/shared/pendingOperation.test.tsx"
          ]
        }
      },
      "dimensions": {
        "view": {"default": "idle", "values": ["idle", "invalid", "loading", "ready", "partial", "empty", "missing", "forbidden", "error"]}
      },
      "actions": [
        {
          "id": "load_user_analytics",
          "owner": "controller",
          "codeValue": "load",
          "cardinality": "singleton",
          "scopeKeys": ["reviewerUid", "targetUid", "queryPayloadVersion"],
          "outcomes": [
            {"kind": "surface_state", "stateIds": ["aggregate-report"]},
            {"kind": "side_effect", "id": "admin.user_analytics_loaded"}
          ],
          "description": "Validates and loads one aggregate user-analytics report for the submitted uid and range snapshot."
        }
      ],
      "scenarios": [
        {
          "id": "aggregate_report",
          "stateId": "aggregate-report",
          "dimensions": {},
          "actionCases": [
            {"id": "idle_valid", "enabledActions": ["load_user_analytics"]},
            {"id": "invalid_scope", "dimensions": {"view": "invalid"}, "disabledActions": ["load_user_analytics"]},
            {"id": "loading_frozen_query", "dimensions": {"view": "loading"}, "disabledActions": ["load_user_analytics"]},
            {"id": "ready", "dimensions": {"view": "ready"}, "enabledActions": ["load_user_analytics"]},
            {"id": "partial", "dimensions": {"view": "partial"}, "enabledActions": ["load_user_analytics"]},
            {"id": "empty", "dimensions": {"view": "empty"}, "enabledActions": ["load_user_analytics"]},
            {"id": "missing", "dimensions": {"view": "missing"}, "enabledActions": ["load_user_analytics"]},
            {"id": "forbidden", "dimensions": {"view": "forbidden"}, "enabledActions": ["load_user_analytics"]},
            {"id": "error", "dimensions": {"view": "error"}, "enabledActions": ["load_user_analytics"]}
          ]
        }
      ],
      "requiredEvidence": {"captures": false, "previews": true, "tests": true}
    }
  ]
}
