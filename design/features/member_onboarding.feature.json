{
  "$schema": "./feature_contract.schema.json",
  "version": 2,
  "updated": "2026-07-23",
  "id": "feature.member_onboarding",
  "name": "Member Onboarding",
  "owner": "onboarding",
  "status": "pilot",
  "description": "Orchestrates the logged-out Start welcome projection, standard booking-identity onboarding, social-profile completion, run-preference completion, draft resumption, photo/profile decisions, and route handoff.",
  "surfaces": [
    {
      "id": "consumer_flutter",
      "runtime": "flutter",
      "authority": {"registry": "flutter_screens", "id": "screen.onboarding.flow"},
      "actionScope": {
        "included": "Welcome choices; step-back navigation; date, gender, interest, Instagram, photo, prompt, and running-preference decisions; booking-identity save; social-profile completion; and run-preference completion.",
        "excluded": [
          "Raw name, phone, Instagram-handle, and prompt-answer character entry remains form data governed by field formatters, validators, and profile data contracts rather than separately cardinalized keystrokes.",
          "Initial entry-mode resolution, draft hydration, best-effort draft persistence/deletion, provider invalidation, and router resume redirects are lifecycle effects rather than user actions.",
          "Photo picking/cropping inside ProfilePhotoEditor retains that child workflow's ownership; this feature owns opening the editor plus direct delete/reorder actions."
        ]
      },
      "bindings": {
        "previewSources": ["widgetbook/lib/onboarding/onboarding_use_cases.dart"],
        "actionOwners": [
          {
            "id": "welcome_page",
            "language": "dart",
            "file": "lib/onboarding/presentation/pages/welcome_page.dart",
            "symbol": "WelcomePage"
          },
          {
            "id": "flow_controller",
            "language": "dart",
            "file": "lib/onboarding/presentation/onboarding_controller.dart",
            "symbol": "OnboardingController"
          },
          {
            "id": "name_dob_page",
            "language": "dart",
            "file": "lib/onboarding/presentation/pages/name_dob_page.dart",
            "symbol": "NameDobPage"
          },
          {
            "id": "gender_page",
            "language": "dart",
            "file": "lib/onboarding/presentation/pages/gender_interest_page.dart",
            "symbol": "GenderInterestPage"
          },
          {
            "id": "photos_page",
            "language": "dart",
            "file": "lib/onboarding/presentation/pages/photos_page.dart",
            "symbol": "PhotosPage"
          },
          {
            "id": "photo_controller",
            "language": "dart",
            "file": "lib/image_uploads/shared/photo_upload_controller.dart",
            "symbol": "PhotoUploadController"
          },
          {
            "id": "prompts_page",
            "language": "dart",
            "file": "lib/onboarding/presentation/pages/profile_prompts_page.dart",
            "symbol": "ProfilePromptsPage"
          },
          {
            "id": "running_page",
            "language": "dart",
            "file": "lib/onboarding/presentation/pages/running_prefs_page.dart",
            "symbol": "RunningPrefsPage"
          }
        ],
        "componentContracts": [
          "catch.button",
          "catch.error_banner",
          "catch.field",
          "catch.range_slider",
          "catch.section"
        ],
        "dataContracts": [
          "contracts/catalogs/profile_photo_policy.json",
          "contracts/embedded/profile_photo.schema.json",
          "contracts/firestore/onboarding_drafts.schema.json",
          "contracts/firestore/users.schema.json",
          "contracts/patches/update_user_profile.schema.json",
          "contracts/storage/profile_photo_thumbnails.schema.json",
          "contracts/storage/profile_photos.schema.json"
        ]
      },
      "dimensions": {
        "entry": {"default": "standard", "values": ["standard", "profile_completion", "run_preferences"]},
        "step": {"default": "welcome", "values": ["welcome", "name_dob", "gender_interest", "instagram", "photos", "prompts", "running_prefs"]},
        "reachability": {"default": "reachable", "values": ["reachable", "orphaned"]},
        "draft": {"default": "none", "values": ["none", "resumed"]},
        "content": {"default": "ready", "values": ["ready", "validation", "empty", "partial", "complete"]},
        "media": {"default": "insufficient", "values": ["insufficient", "minimum_ready", "surplus_ready", "minimum_uploading", "surplus_uploading", "error"]},
        "mutation": {"default": "idle", "values": ["idle", "pending", "error", "settled"]},
        "accessibility": {"default": "standard", "values": ["standard", "text_scale_2", "reduced_motion"]}
      },
      "actions": [
        {
          "id": "skip_welcome_intro",
          "owner": "welcome_page",
          "codeValue": "_skip",
          "cardinality": "singleton",
          "scopeKeys": ["routeInstanceId", "welcomeAnimationVersion"],
          "outcomes": [{"kind": "surface_state", "stateIds": ["welcome_entry"]}],
          "description": "Skips the welcome reel and reveals its calls to action."
        },
        {
          "id": "continue_with_phone",
          "owner": "welcome_page",
          "codeValue": "_authLocation",
          "cardinality": "singleton",
          "scopeKeys": ["routeInstanceId", "resumeDestination"],
          "outcomes": [{"kind": "route", "authority": {"registry": "flutter_screens", "id": "screen.auth.phone_entry"}}],
          "description": "Opens shared Phone Authentication while preserving the sanitized return destination."
        },
        {
          "id": "explore_public_events",
          "owner": "welcome_page",
          "codeValue": "exploreScreen",
          "cardinality": "singleton",
          "scopeKeys": ["routeInstanceId"],
          "outcomes": [{"kind": "route", "authority": {"registry": "flutter_screens", "id": "screen.explore.discovery"}}],
          "description": "Leaves onboarding for guest-readable organizer and event discovery."
        },
        {
          "id": "previous_onboarding_step",
          "owner": "flow_controller",
          "codeValue": "goToStep",
          "cardinality": "unbounded",
          "scopeKeys": ["routeInstanceId", "entryMode", "currentStep"],
          "outcomes": [{"kind": "surface_state", "stateIds": ["name_dob_step", "gender_interest_step", "instagram_step", "photos_photo_gate", "prompts_step"]}],
          "description": "Moves to the previous step without crossing the active entry mode's minimum back boundary."
        },
        {
          "id": "select_date_of_birth",
          "owner": "name_dob_page",
          "codeValue": "_pickDate",
          "cardinality": "unbounded",
          "scopeKeys": ["routeInstanceId", "selectedDate"],
          "outcomes": [{"kind": "surface_state", "stateIds": ["name_dob_step", "required_field_errors"]}],
          "description": "Selects a date of birth within the validated adult date range."
        },
        {
          "id": "continue_identity_details",
          "owner": "flow_controller",
          "codeValue": "advanceToGenderInterest",
          "cardinality": "singleton",
          "scopeKeys": ["viewerUid", "identityDraftSignature"],
          "outcomes": [{"kind": "surface_state", "stateIds": ["required_field_errors", "gender_interest_step", "saved_draft"]}],
          "description": "Validates name, date of birth, and verified phone fields, saves the draft, and advances to identity preferences."
        },
        {
          "id": "select_gender",
          "owner": "gender_page",
          "codeValue": "onGenderChanged",
          "cardinality": "domain_bounded",
          "scopeKeys": ["routeInstanceId", "gender"],
          "outcomes": [{"kind": "surface_state", "stateIds": ["gender_interest_step", "required_field_errors", "save_profile_mutation"]}],
          "description": "Selects one gender from the finite profile gender domain."
        },
        {
          "id": "select_interested_genders",
          "owner": "gender_page",
          "codeValue": "onInterestedInChanged",
          "cardinality": "domain_bounded",
          "scopeKeys": ["routeInstanceId", "interestSet"],
          "outcomes": [{"kind": "surface_state", "stateIds": ["gender_interest_step", "required_field_errors", "save_profile_mutation"]}],
          "description": "Selects a non-empty subset of the finite profile gender domain."
        },
        {
          "id": "save_booking_identity",
          "owner": "flow_controller",
          "codeValue": "saveProfile",
          "cardinality": "singleton",
          "scopeKeys": ["viewerUid", "identityDraftSignature"],
          "outcomes": [
            {"kind": "surface_state", "stateIds": ["required_field_errors", "save_profile_mutation"]},
            {"kind": "side_effect", "id": "member.booking_identity.saved"}
          ],
          "description": "Persists the required booking identity, clears its draft, and lets the router resume the pending destination."
        },
        {
          "id": "continue_with_instagram",
          "owner": "flow_controller",
          "codeValue": "advanceToPhotos",
          "cardinality": "singleton",
          "scopeKeys": ["viewerUid", "instagramDraftSignature"],
          "outcomes": [{"kind": "surface_state", "stateIds": ["photos_photo_gate", "saved_draft"]}],
          "description": "Normalizes the optional Instagram handle, saves the draft, and advances to photos when the orphaned Instagram step is manually reached."
        },
        {
          "id": "skip_instagram",
          "owner": "flow_controller",
          "codeValue": "advanceToPhotos",
          "cardinality": "singleton",
          "scopeKeys": ["viewerUid", "instagramStepInstanceId"],
          "outcomes": [{"kind": "surface_state", "stateIds": ["photos_photo_gate", "saved_draft"]}],
          "description": "Clears the optional Instagram handle and advances to photos when the orphaned Instagram step is manually reached."
        },
        {
          "id": "open_profile_photo_editor",
          "owner": "photos_page",
          "codeValue": "openProfilePhotoEditor",
          "cardinality": "unbounded",
          "scopeKeys": ["viewerUid", "photoSlotIndex", "photoVersion"],
          "outcomes": [{"kind": "side_effect", "id": "profile_photo_editor.opened"}],
          "description": "Opens the shared photo editor for an empty or populated onboarding photo slot."
        },
        {
          "id": "delete_profile_photo",
          "owner": "photo_controller",
          "codeValue": "deletePhoto",
          "cardinality": "singleton",
          "scopeKeys": ["viewerUid", "photoId", "photoVersion"],
          "outcomes": [{"kind": "surface_state", "stateIds": ["photos_photo_gate"]}],
          "description": "Deletes one profile photo while preserving the minimum-photo policy."
        },
        {
          "id": "reorder_profile_photo",
          "owner": "photo_controller",
          "codeValue": "reorderPhoto",
          "cardinality": "unbounded",
          "scopeKeys": ["viewerUid", "photoId", "targetIndex"],
          "outcomes": [{"kind": "surface_state", "stateIds": ["photos_photo_gate"]}],
          "description": "Reorders profile photos and therefore changes their presentation order."
        },
        {
          "id": "continue_from_photos",
          "owner": "flow_controller",
          "codeValue": "goToStepAndSaveDraft",
          "cardinality": "singleton",
          "scopeKeys": ["viewerUid", "photoSetVersion"],
          "outcomes": [{"kind": "surface_state", "stateIds": ["prompts_step", "saved_draft"]}],
          "description": "Advances after the minimum photo count is met and all uploads have settled."
        },
        {
          "id": "select_profile_prompt",
          "owner": "prompts_page",
          "codeValue": "_selectPrompt",
          "cardinality": "domain_bounded",
          "scopeKeys": ["routeInstanceId", "promptSlot", "promptId"],
          "outcomes": [{"kind": "surface_state", "stateIds": ["prompts_step", "complete_mutation"]}],
          "description": "Selects a unique prompt from the finite prompt catalog for one answer slot."
        },
        {
          "id": "complete_social_profile",
          "owner": "flow_controller",
          "codeValue": "completeSocialProfile",
          "cardinality": "singleton",
          "scopeKeys": ["viewerUid", "promptAnswersSignature"],
          "outcomes": [
            {"kind": "surface_state", "stateIds": ["prompts_step", "complete_mutation"]},
            {"kind": "side_effect", "id": "member.social_profile.completed"}
          ],
          "description": "Persists three completed prompt answers, marks the social profile complete, clears its draft, and resumes the pending route."
        },
        {
          "id": "adjust_running_pace",
          "owner": "running_page",
          "codeValue": "onPaceChanged",
          "cardinality": "unbounded",
          "scopeKeys": ["routeInstanceId", "paceRange"],
          "outcomes": [{"kind": "surface_state", "stateIds": ["running_prefs_step", "complete_mutation"]}],
          "description": "Adjusts the bounded preferred pace range."
        },
        {
          "id": "select_preferred_distances",
          "owner": "running_page",
          "codeValue": "onDistancesChanged",
          "cardinality": "domain_bounded",
          "scopeKeys": ["routeInstanceId", "distanceSet"],
          "outcomes": [{"kind": "surface_state", "stateIds": ["running_prefs_step", "complete_mutation"]}],
          "description": "Selects an optional subset of supported preferred distances."
        },
        {
          "id": "select_running_reasons",
          "owner": "running_page",
          "codeValue": "onReasonsChanged",
          "cardinality": "domain_bounded",
          "scopeKeys": ["routeInstanceId", "reasonSet"],
          "outcomes": [{"kind": "surface_state", "stateIds": ["running_prefs_step", "complete_mutation"]}],
          "description": "Selects an optional subset of supported running reasons."
        },
        {
          "id": "select_preferred_run_times",
          "owner": "running_page",
          "codeValue": "onRunTimesChanged",
          "cardinality": "domain_bounded",
          "scopeKeys": ["routeInstanceId", "runTimeSet"],
          "outcomes": [{"kind": "surface_state", "stateIds": ["running_prefs_step", "complete_mutation"]}],
          "description": "Selects an optional subset of supported run times."
        },
        {
          "id": "complete_run_preferences",
          "owner": "flow_controller",
          "codeValue": "completeRunPreferences",
          "cardinality": "singleton",
          "scopeKeys": ["viewerUid", "runPreferencesSignature"],
          "outcomes": [
            {"kind": "surface_state", "stateIds": ["running_prefs_step", "complete_mutation"]},
            {"kind": "side_effect", "id": "member.run_preferences.completed"}
          ],
          "description": "Persists the current run-preference version, clears its draft, and resumes the pending route."
        }
      ],
      "stateIds": [
        "welcome_entry",
        "name_dob_step",
        "gender_interest_step",
        "instagram_step",
        "photos_photo_gate",
        "prompts_step",
        "running_prefs_step",
        "required_field_errors",
        "saved_draft",
        "save_profile_mutation",
        "complete_mutation",
        "text_scale_2",
        "reduced_motion"
      ],
      "scenarioDefaults": {"dimensions": {}, "actionCases": [{"id": "default"}]},
      "scenarioOverrides": {
        "welcome_entry": {
          "actionCases": [{"id": "welcome", "enabledActions": ["skip_welcome_intro", "continue_with_phone", "explore_public_events"]}]
        },
        "name_dob_step": {
          "dimensions": {"step": "name_dob"},
          "actionCases": [{"id": "identity", "enabledActions": ["select_date_of_birth", "continue_identity_details"]}]
        },
        "gender_interest_step": {
          "dimensions": {"step": "gender_interest"},
          "actionCases": [
            {
              "id": "identity_preferences",
              "enabledActions": ["previous_onboarding_step", "select_gender", "select_interested_genders", "save_booking_identity"]
            }
          ]
        },
        "instagram_step": {
          "dimensions": {"step": "instagram", "reachability": "orphaned"},
          "actionCases": [
            {
              "id": "manually_seeded_only",
              "enabledActions": ["previous_onboarding_step", "continue_with_instagram", "skip_instagram"]
            }
          ]
        },
        "photos_photo_gate": {
          "dimensions": {"entry": "profile_completion", "step": "photos"},
          "actionCases": [
            {
              "id": "insufficient",
              "dimensions": {"media": "insufficient"},
              "enabledActions": ["open_profile_photo_editor"],
              "disabledActions": ["continue_from_photos", "delete_profile_photo", "reorder_profile_photo"]
            },
            {
              "id": "minimum_ready",
              "dimensions": {"media": "minimum_ready"},
              "enabledActions": ["open_profile_photo_editor", "reorder_profile_photo", "continue_from_photos"],
              "disabledActions": ["delete_profile_photo"]
            },
            {
              "id": "surplus_ready",
              "dimensions": {"media": "surplus_ready"},
              "enabledActions": ["open_profile_photo_editor", "delete_profile_photo", "reorder_profile_photo", "continue_from_photos"]
            },
            {
              "id": "minimum_uploading",
              "dimensions": {"media": "minimum_uploading"},
              "enabledActions": ["open_profile_photo_editor"],
              "disabledActions": ["delete_profile_photo", "reorder_profile_photo", "continue_from_photos"]
            },
            {
              "id": "surplus_uploading",
              "dimensions": {"media": "surplus_uploading"},
              "enabledActions": ["open_profile_photo_editor", "delete_profile_photo"],
              "disabledActions": ["reorder_profile_photo", "continue_from_photos"]
            },
            {
              "id": "upload_error",
              "dimensions": {"media": "error"},
              "enabledActions": ["open_profile_photo_editor"],
              "disabledActions": ["delete_profile_photo", "reorder_profile_photo", "continue_from_photos"]
            },
            {
              "id": "legacy_instagram_entry",
              "dimensions": {"entry": "standard"},
              "enabledActions": ["previous_onboarding_step", "open_profile_photo_editor"]
            }
          ]
        },
        "prompts_step": {
          "dimensions": {"entry": "profile_completion", "step": "prompts"},
          "actionCases": [
            {
              "id": "empty",
              "dimensions": {"content": "empty"},
              "enabledActions": ["previous_onboarding_step", "select_profile_prompt"],
              "disabledActions": ["complete_social_profile"]
            },
            {
              "id": "partial",
              "dimensions": {"content": "partial"},
              "enabledActions": ["previous_onboarding_step", "select_profile_prompt"],
              "disabledActions": ["complete_social_profile"]
            },
            {
              "id": "complete",
              "dimensions": {"content": "complete"},
              "enabledActions": ["previous_onboarding_step", "select_profile_prompt", "complete_social_profile"]
            }
          ]
        },
        "running_prefs_step": {
          "dimensions": {"step": "running_prefs"},
          "actionCases": [
            {
              "id": "run_preferences_entry",
              "dimensions": {"entry": "run_preferences"},
              "enabledActions": ["adjust_running_pace", "select_preferred_distances", "select_running_reasons", "select_preferred_run_times", "complete_run_preferences"]
            },
            {
              "id": "legacy_flow_entry",
              "dimensions": {"entry": "standard"},
              "enabledActions": ["previous_onboarding_step", "adjust_running_pace", "select_preferred_distances", "select_running_reasons", "select_preferred_run_times", "complete_run_preferences"]
            }
          ]
        },
        "required_field_errors": {
          "dimensions": {"content": "validation"},
          "actionCases": [
            {
              "id": "name_dob",
              "dimensions": {"step": "name_dob"},
              "enabledActions": ["select_date_of_birth", "continue_identity_details"]
            },
            {
              "id": "gender_interest",
              "dimensions": {"step": "gender_interest"},
              "enabledActions": ["previous_onboarding_step", "select_gender", "select_interested_genders", "save_booking_identity"]
            }
          ]
        },
        "saved_draft": {
          "dimensions": {"draft": "resumed"},
          "actionCases": [
            {
              "id": "name_dob_resume",
              "dimensions": {"step": "name_dob"},
              "enabledActions": ["select_date_of_birth", "continue_identity_details"]
            },
            {
              "id": "gender_resume",
              "dimensions": {"step": "gender_interest"},
              "enabledActions": ["previous_onboarding_step", "select_gender", "select_interested_genders", "save_booking_identity"]
            }
          ]
        },
        "save_profile_mutation": {
          "dimensions": {"step": "gender_interest"},
          "actionCases": [
            {
              "id": "frozen_identity_snapshot",
              "dimensions": {"mutation": "pending"},
              "disabledActions": ["previous_onboarding_step", "select_gender", "select_interested_genders", "save_booking_identity"]
            },
            {
              "id": "error",
              "dimensions": {"mutation": "error"},
              "enabledActions": ["previous_onboarding_step", "select_gender", "select_interested_genders", "save_booking_identity"]
            }
          ]
        },
        "complete_mutation": {
          "actionCases": [
            {
              "id": "frozen_prompts_snapshot",
              "dimensions": {"entry": "profile_completion", "step": "prompts", "mutation": "pending"},
              "disabledActions": ["previous_onboarding_step", "select_profile_prompt", "complete_social_profile"]
            },
            {
              "id": "prompts_error",
              "dimensions": {"entry": "profile_completion", "step": "prompts", "mutation": "error"},
              "enabledActions": ["previous_onboarding_step", "select_profile_prompt", "complete_social_profile"]
            },
            {
              "id": "frozen_run_preferences_snapshot",
              "dimensions": {"entry": "run_preferences", "step": "running_prefs", "mutation": "pending"},
              "disabledActions": ["adjust_running_pace", "select_preferred_distances", "select_running_reasons", "select_preferred_run_times", "complete_run_preferences"]
            },
            {
              "id": "running_error",
              "dimensions": {"entry": "run_preferences", "step": "running_prefs", "mutation": "error"},
              "enabledActions": ["adjust_running_pace", "select_preferred_distances", "select_running_reasons", "select_preferred_run_times", "complete_run_preferences"]
            }
          ]
        },
        "text_scale_2": {"dimensions": {"accessibility": "text_scale_2"}},
        "reduced_motion": {"dimensions": {"accessibility": "reduced_motion"}}
      },
      "requiredEvidence": {"captures": true, "previews": true, "tests": true},
      "evidenceExceptions": [
        {
          "stateIds": ["instagram_step", "prompts_step", "text_scale_2", "reduced_motion"],
          "evidence": ["tests"],
          "debtId": "FEATURE-CONTRACT-MIGRATION-001",
          "reason": "These deterministic onboarding states have registered capture and Widgetbook evidence but no focused state-level test recorded by the screen authority."
        }
      ]
    },
    {
      "id": "start_flutter",
      "runtime": "flutter",
      "authority": {"registry": "flutter_screens", "id": "screen.start.welcome"},
      "actionScope": {
        "included": "Skipping the animated welcome reel, continuing to shared phone authentication, and entering guest-readable Explore.",
        "excluded": [
          "Automatic reel completion and immediate landing for capture or reduced-motion mode are animation lifecycle transitions, not user actions.",
          "Welcome-impression and CTA analytics remain action side effects rather than separately cardinalized actions.",
          "Phone Authentication and Explore own all behavior after their route handoffs."
        ]
      },
      "bindings": {
        "previewSources": ["widgetbook/lib/onboarding/onboarding_use_cases.dart"],
        "actionOwners": [
          {
            "id": "welcome_page",
            "language": "dart",
            "file": "lib/onboarding/presentation/pages/welcome_page.dart",
            "symbol": "WelcomePage"
          }
        ],
        "componentContracts": ["catch.button", "catch.surface"],
        "dataContracts": []
      },
      "dimensions": {
        "motion": {"default": "animated", "values": ["animated", "landed", "reduced_motion"]},
        "accessibility": {"default": "standard", "values": ["standard", "text_scale_2"]},
        "theme": {"default": "fixed_dark", "values": ["fixed_dark"]}
      },
      "actions": [
        {
          "id": "skip_welcome_intro",
          "owner": "welcome_page",
          "codeValue": "_skip",
          "cardinality": "singleton",
          "scopeKeys": ["routeInstanceId", "welcomeAnimationVersion"],
          "outcomes": [{"kind": "surface_state", "stateIds": ["landed_direct"]}],
          "description": "Skips the active object reel and begins the landed CTA reveal."
        },
        {
          "id": "continue_with_phone",
          "owner": "welcome_page",
          "codeValue": "_authLocation",
          "cardinality": "singleton",
          "scopeKeys": ["routeInstanceId", "resumeDestination"],
          "outcomes": [{"kind": "route", "authority": {"registry": "flutter_screens", "id": "screen.auth.phone_entry"}}],
          "description": "Opens shared Phone Authentication while preserving the current Start location as the sanitized return destination."
        },
        {
          "id": "explore_public_events",
          "owner": "welcome_page",
          "codeValue": "exploreScreen",
          "cardinality": "singleton",
          "scopeKeys": ["routeInstanceId"],
          "outcomes": [{"kind": "route", "authority": {"registry": "flutter_screens", "id": "screen.explore.discovery"}}],
          "description": "Leaves the Start route for guest-readable organizer and event discovery."
        }
      ],
      "stateIds": [
        "animated_reel",
        "landed_direct",
        "cta_navigation",
        "reduced_motion",
        "text_scale_2",
        "light_dark"
      ],
      "scenarioDefaults": {"dimensions": {}, "actionCases": [{"id": "default"}]},
      "scenarioOverrides": {
        "animated_reel": {
          "actionCases": [
            {
              "id": "reel_playing",
              "enabledActions": ["skip_welcome_intro"],
              "disabledActions": ["continue_with_phone", "explore_public_events"]
            }
