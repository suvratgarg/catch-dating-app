{
  "$schema": "./feature_contract.schema.json",
  "version": 2,
  "updated": "2026-07-23",
  "id": "feature.host_acquisition",
  "name": "Host Acquisition",
  "owner": "marketing_website",
  "status": "pilot",
  "description": "Orchestrates the public Host product narrative, interactive operating previews, founding-host application, and post-submission organizer and claim handoffs.",
  "surfaces": [
    {
      "id": "marketing_web",
      "runtime": "react_marketing",
      "authority": {"registry": "marketing_routes", "id": "host"},
      "actionScope": {
        "included": "Opening the application, operating the create-event and Playbook previews, expanding the comparison, navigating the application, choosing bounded format/module decisions, submitting the host packet, and following post-submission routes.",
        "excluded": [
          "Site-header anchors, consent choices, static FAQ/trust content, and capture rendering retain shared shell or presentation ownership.",
          "Host application text and select field edits remain form data governed by the application model rather than separate feature actions.",
          "The /api/join-waitlist host-application payload and response have no shared schema; WEB-LEAD-API-CONTRACT-001 tracks the missing data-contract boundary."
        ]
      },
      "bindings": {
        "previewSources": [
          "website/src/stories/HostSections.stories.tsx",
          "website/src/stories/MarketingRoutes.stories.tsx"
        ],
        "actionOwners": [
          {
            "id": "host_sections",
            "language": "typescript",
            "file": "website/src/features/host/sections/HostPageSections.tsx",
            "symbol": "HostHeroSection"
          },
          {
            "id": "create_walkthrough",
            "language": "typescript",
            "file": "website/src/features/host/sections/CreateEventWalkthrough.tsx",
            "symbol": "CreateEventWalkthrough"
          },
          {
            "id": "playbook",
            "language": "typescript",
            "file": "website/src/features/host/sections/PlaybookShowcase.tsx",
            "symbol": "PlaybookShowcase"
          },
          {
            "id": "comparison",
            "language": "typescript",
            "file": "website/src/features/host/sections/HostComparisonSection.tsx",
            "symbol": "HostComparisonSection"
          },
          {
            "id": "application_controller",
            "language": "typescript",
            "file": "website/src/features/host/application/useHostApplicationController.ts",
            "symbol": "useHostApplicationController"
          },
          {
            "id": "application_flow",
            "language": "typescript",
            "file": "website/src/features/host/application/HostApplicationFlow.tsx",
            "symbol": "HostApplicationFlow"
          }
        ],
        "componentContracts": [
          "route_host",
          "host_application_flow",
          "host_create_event_walkthrough",
          "host_playbook_showcase",
          "host_comparison_section"
        ],
        "dataContracts": [],
        "testEvidence": {
          "host-application": [
            "website/src/features/host/application/applicationModel.test.ts",
            "website/src/features/host/application/useHostApplicationController.test.tsx"
          ]
        }
      },
      "dimensions": {
        "presentation": {"default": "default", "values": ["default", "offer", "application", "capture_placeholders"]},
        "application_step": {"default": "profile", "values": ["profile", "event", "policy", "success", "review", "submitted"]},
        "application_mutation": {"default": "idle", "values": ["idle", "pending", "failed", "success"]},
        "preview": {"default": "idle", "values": ["idle", "create_step_selected", "playbook_stage_selected", "module_expanded", "comparison_expanded"]}
      },
      "actions": [
        {
          "id": "open_host_application",
          "owner": "host_sections",
          "codeValue": "trackCtaClick",
          "cardinality": "unbounded",
          "scopeKeys": ["routeInstanceId", "placement"],
          "outcomes": [
            {"kind": "surface_state", "stateIds": ["host-application"]},
            {"kind": "side_effect", "id": "analytics.host_application_opened"}
          ],
          "description": "Moves to the founding-host application section and records the CTA placement."
        },
        {
          "id": "select_create_walkthrough_step",
          "owner": "create_walkthrough",
          "codeValue": "setActiveStep",
          "cardinality": "unbounded",
          "scopeKeys": ["routeInstanceId", "walkthroughStepId"],
          "outcomes": [{"kind": "surface_state", "stateIds": ["default", "capture-placeholders"]}],
          "description": "Selects a bounded create-event demonstration step and its matching capture or fallback."
        },
        {
          "id": "select_playbook_stage",
          "owner": "playbook",
          "codeValue": "setStage",
          "cardinality": "unbounded",
          "scopeKeys": ["routeInstanceId", "playbookStageId"],
          "outcomes": [{"kind": "surface_state", "stateIds": ["default", "capture-placeholders"]}],
          "description": "Selects the activity, after, or debrief Playbook stage and its corresponding capture."
        },
        {
          "id": "expand_playbook_module",
          "owner": "playbook",
          "codeValue": "trackMarketingEvent",
          "cardinality": "unbounded",
          "scopeKeys": ["routeInstanceId", "moduleId"],
          "outcomes": [{"kind": "side_effect", "id": "analytics.playbook_module_expanded"}],
          "description": "Expands one Playbook module and records its module and lifecycle-stage identity."
        },
        {
          "id": "toggle_host_comparison",
          "owner": "comparison",
          "codeValue": "setOpen",
          "cardinality": "unbounded",
          "scopeKeys": ["routeInstanceId", "comparisonVersion"],
          "outcomes": [{"kind": "surface_state", "stateIds": ["default"]}],
          "description": "Shows or hides the full Host comparison table and scrolls the expanded table into view."
        },
        {
          "id": "go_to_application_step",
          "owner": "application_controller",
          "codeValue": "goToStep",
          "cardinality": "unbounded",
          "scopeKeys": ["formInstanceId", "stepId"],
          "outcomes": [{"kind": "surface_state", "stateIds": ["host-application"]}],
          "description": "Moves to a selected application step while no application submission is pending."
        },
        {
          "id": "continue_application",
          "owner": "application_controller",
          "codeValue": "goNext",
          "cardinality": "unbounded",
          "scopeKeys": ["formInstanceId", "draftVersion", "stepId"],
          "outcomes": [{"kind": "surface_state", "stateIds": ["host-application"]}],
          "description": "Validates the current application stage and advances to the next bounded step."
        },
        {
          "id": "back_application",
          "owner": "application_controller",
          "codeValue": "goBack",
          "cardinality": "unbounded",
          "scopeKeys": ["formInstanceId", "stepId"],
          "outcomes": [{"kind": "surface_state", "stateIds": ["host-application"]}],
          "description": "Returns to the previous application stage while no application submission is pending."
        },
        {
          "id": "toggle_application_choice",
          "owner": "application_controller",
          "codeValue": "toggleDraftList",
          "cardinality": "unbounded",
          "scopeKeys": ["formInstanceId", "choiceDomain", "choiceValue", "draftVersion"],
          "outcomes": [{"kind": "surface_state", "stateIds": ["host-application"]}],
          "description": "Adds or removes a bounded event-format or Event Success module choice from the local application draft."
        },
        {
          "id": "submit_host_application",
          "owner": "application_controller",
          "codeValue": "handleSubmit",
          "cardinality": "singleton",
          "scopeKeys": ["formInstanceId", "submissionVersion"],
          "outcomes": [
            {"kind": "surface_state", "stateIds": ["host-application"]},
            {"kind": "side_effect", "id": "marketing.host_application_submitted"}
          ],
          "description": "Validates and submits one normalized host operating packet, then renders success or actionable failure status."
        },
        {
          "id": "open_organizer_search_after_submit",
          "owner": "application_flow",
          "codeValue": "ButtonLink",
          "cardinality": "unbounded",
          "scopeKeys": ["routeInstanceId", "submissionVersion"],
          "outcomes": [{"kind": "route", "authority": {"registry": "marketing_routes", "id": "organizer_search"}}],
          "description": "Opens the public organizer directory from the submitted application confirmation."
        },
        {
          "id": "open_claim_after_submit",
          "owner": "application_flow",
          "codeValue": "ButtonLink",
          "cardinality": "unbounded",
          "scopeKeys": ["routeInstanceId", "submissionVersion"],
          "outcomes": [{"kind": "route", "authority": {"registry": "marketing_routes", "id": "claim"}}],
          "description": "Opens the organizer claim workflow from the submitted application confirmation."
        }
      ],
      "scenarios": [
        {
          "id": "default",
          "stateId": "default",
          "dimensions": {},
          "actionCases": [{
            "id": "interactive_brochure",
            "enabledActions": ["open_host_application", "select_create_walkthrough_step", "select_playbook_stage", "expand_playbook_module", "toggle_host_comparison"]
          }]
        },
        {
          "id": "founding_host_offer",
          "stateId": "founding-host-offer",
          "dimensions": {"presentation": "offer"},
          "actionCases": [{
            "id": "offer_visible",
            "enabledActions": ["open_host_application", "select_create_walkthrough_step", "select_playbook_stage", "expand_playbook_module", "toggle_host_comparison"]
          }]
        },
        {
          "id": "host_application",
          "stateId": "host-application",
          "dimensions": {"presentation": "application"},
          "actionCases": [
            {
              "id": "profile_or_form_step",
              "enabledActions": ["go_to_application_step", "continue_application", "back_application", "toggle_application_choice"]
            },
            {
              "id": "review_ready",
              "dimensions": {"application_step": "review"},
              "enabledActions": ["go_to_application_step", "back_application", "toggle_application_choice", "submit_host_application"]
            },
            {
              "id": "submission_pending_frozen_snapshot",
              "dimensions": {"application_step": "review", "application_mutation": "pending"},
              "disabledActions": ["go_to_application_step", "continue_application", "back_application", "toggle_application_choice", "submit_host_application"]
            },
            {
              "id": "submission_failed",
              "dimensions": {"application_step": "review", "application_mutation": "failed"},
              "enabledActions": ["go_to_application_step", "back_application", "toggle_application_choice", "submit_host_application"]
            },
            {
              "id": "submitted",
              "dimensions": {"application_step": "submitted", "application_mutation": "success"},
              "enabledActions": ["open_organizer_search_after_submit", "open_claim_after_submit"]
            }
          ]
        },
        {
          "id": "capture_placeholders",
          "stateId": "capture-placeholders",
          "dimensions": {"presentation": "capture_placeholders"},
          "actionCases": [{
            "id": "fallback_captures",
            "enabledActions": ["open_host_application", "select_create_walkthrough_step", "select_playbook_stage", "expand_playbook_module", "toggle_host_comparison"]
          }]
        }
      ],
      "requiredEvidence": {"captures": false, "previews": true, "tests": true},
      "evidenceExceptions": [
        {
          "stateIds": ["default", "founding-host-offer", "capture-placeholders"],
          "evidence": ["tests"],
          "debtId": "FEATURE-CONTRACT-MIGRATION-001",
          "reason": "These route-level narrative and capture-fallback states have registered route/section Storybook evidence but no focused interaction test registered for their Host section composition."
        }
      ]
    }
  ]
}
