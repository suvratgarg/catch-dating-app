{
  "$schema": "./feature_contract.schema.json",
  "version": 2,
  "updated": "2026-07-23",
  "id": "feature.host_inbox",
  "name": "Host Inbox",
  "owner": "hosts",
  "status": "pilot",
  "description": "Orchestrates the host event-inquiry inbox across event and general scope, booked and prospective audiences, search, conversation routing, and authorized event broadcasts.",
  "surfaces": [
    {
      "id": "host_flutter",
      "runtime": "flutter",
      "authority": {"registry": "flutter_screens", "id": "screen.host.inbox"},
      "actionScope": {
        "included": "Host Inbox retry, search, event/general scope, booked/prospective audience selection, conversation routing, and event-broadcast audience, template, composer, and send lifecycle.",
        "excluded": [
          "Raw broadcast body edits are form data; the contract cardinalizes template/audience decisions and the send mutation instead of individual keystrokes.",
          "Conversation thread behavior and safety actions retain the shared chat-thread contract."
        ]
      },
      "bindings": {
        "previewSources": ["widgetbook/lib/hosts/host_inbox_use_cases.dart"],
        "actionOwners": [
          {"id": "inbox_screen", "language": "dart", "file": "lib/hosts/presentation/inbox/host_inbox_screen.dart", "symbol": "HostInboxScreen"},
          {"id": "search_header", "language": "dart", "file": "lib/chats/presentation/inbox/chats_search_header_controller.dart", "symbol": "ChatsSearchHeaderController"},
          {"id": "search_query", "language": "dart", "file": "lib/chats/presentation/inbox/chats_list_view_model.dart", "symbol": "ChatSearchQuery"},
          {"id": "broadcast_composer", "language": "dart", "file": "lib/hosts/presentation/inbox/host_broadcast_composer_sheet.dart", "symbol": "HostBroadcastComposerSheet"},
          {"id": "broadcast_controller", "language": "dart", "file": "lib/hosts/presentation/inbox/host_inbox_broadcast_controller.dart", "symbol": "HostInboxBroadcastController"}
        ],
        "componentContracts": ["catch.button", "catch.empty_state", "catch.error_state", "catch.field", "catch.menu", "catch.option_card", "catch.option_group", "catch.person_row", "catch.search_field", "catch.surface", "catch.top_bar"],
        "dataContracts": [
          "contracts/callable_responses/send_event_broadcast_response.schema.json",
          "contracts/callables/send_event_broadcast_payload.schema.json",
          "contracts/firestore/clubs.schema.json",
          "contracts/firestore/event_broadcasts.schema.json",
          "contracts/firestore/event_participations.schema.json",
          "contracts/firestore/events.schema.json",
          "contracts/firestore/matches.schema.json"
        ]
      },
      "dimensions": {
        "load": {"default": "ready", "values": ["ready", "loading", "error", "offline"]},
        "scope": {"default": "event", "values": ["event", "general"]},
        "segment": {"default": "booked", "values": ["booked", "prospective"]},
        "content": {"default": "populated", "values": ["populated", "empty", "new_inquiry"]},
        "search": {"default": "collapsed", "values": ["collapsed", "active", "filtering", "empty"]},
        "profile": {"default": "ready", "values": ["ready", "loading"]},
        "broadcast": {"default": "idle", "values": ["idle", "composer", "pending", "error"]},
        "accessibility": {"default": "standard", "values": ["standard", "text_scale_2", "reduced_motion"]},
        "theme": {"default": "standard", "values": ["standard", "light_dark"]}
      },
      "actions": [
        {
          "id": "retry_inbox",
          "owner": "inbox_screen",
          "codeValue": "_retry",
          "cardinality": "singleton",
          "scopeKeys": ["viewerUid", "routeInstanceId", "failureStateVersion"],
          "outcomes": [{"kind": "surface_state", "stateIds": ["uid_loading_or_missing", "matches_loading", "matches_error", "populated_queries", "empty_host_queries", "offline"]}],
          "description": "Invalidates the failed identity, conversation, and hosted-organizer sources for the current inbox."
        },
        {
          "id": "toggle_search",
          "owner": "search_header",
          "codeValue": "setExpanded",
          "cardinality": "unbounded",
          "scopeKeys": ["routeInstanceId", "searchSessionVersion"],
          "outcomes": [{"kind": "surface_state", "stateIds": ["search_collapsed", "search_active"]}],
          "description": "Opens or collapses the inbox search field while preserving non-empty search text."
        },
        {
          "id": "search_inquiries",
          "owner": "search_query",
          "codeValue": "setQuery",
          "cardinality": "unbounded",
          "scopeKeys": ["viewerUid", "routeInstanceId", "query"],
          "outcomes": [{"kind": "surface_state", "stateIds": ["host_query_filtering", "search_active", "search_empty", "populated_queries"]}],
          "description": "Filters the selected event or general inquiry rows by participant name."
        },
        {
          "id": "select_scope",
          "owner": "inbox_screen",
          "codeValue": "_selectScope",
          "cardinality": "unbounded",
          "scopeKeys": ["viewerUid", "routeInstanceId", "eventId"],
          "outcomes": [{"kind": "surface_state", "stateIds": ["populated_queries", "prospective_queries", "general_queries", "roster_without_threads", "empty_host_queries"]}],
          "description": "Selects an event-scoped inbox or the explicit General inquiry scope and synchronizes it to the route."
        },
        {
          "id": "select_audience_segment",
          "owner": "inbox_screen",
          "codeValue": "HostInboxAudienceSegment",
          "cardinality": "unbounded",
          "scopeKeys": ["viewerUid", "eventId", "segment"],
          "outcomes": [{"kind": "surface_state", "stateIds": ["populated_queries", "prospective_queries", "roster_without_threads"]}],
          "description": "Switches an event inbox between Booked and Prospective inquiry rows."
        },
        {
          "id": "open_conversation",
          "owner": "inbox_screen",
          "codeValue": "_openThread",
          "cardinality": "unbounded",
          "scopeKeys": ["viewerUid", "matchId"],
          "outcomes": [{"kind": "route", "authority": {"registry": "flutter_screens", "id": "screen.host.chat"}}],
          "description": "Opens the selected host inquiry in the shared chat thread route."
        },
        {
          "id": "open_broadcast_composer",
          "owner": "inbox_screen",
          "codeValue": "_openBroadcast",
          "cardinality": "singleton",
          "scopeKeys": ["viewerUid", "eventId", "segment", "audienceVersion"],
          "outcomes": [{"kind": "surface_state", "stateIds": ["broadcast_composer_lifecycle"]}],
          "description": "Opens the authorized broadcast composer for a non-empty event audience."
        },
        {
          "id": "select_broadcast_audience",
          "owner": "broadcast_composer",
          "codeValue": "_selectAudience",
          "cardinality": "unbounded",
          "scopeKeys": ["viewerUid", "eventId", "audience", "requestId"],
          "outcomes": [{"kind": "surface_state", "stateIds": ["broadcast_composer_lifecycle"]}],
          "description": "Selects Booked, Prospective, or Everyone and rotates the idempotency request id."
        },
        {
          "id": "select_broadcast_template",
          "owner": "broadcast_composer",
          "codeValue": "_selectTemplate",
          "cardinality": "unbounded",
          "scopeKeys": ["viewerUid", "eventId", "template", "requestId"],
          "outcomes": [{"kind": "surface_state", "stateIds": ["broadcast_composer_lifecycle"]}],
          "description": "Seeds one reviewed broadcast template and rotates the idempotency request id."
        },
        {
          "id": "send_broadcast",
          "owner": "broadcast_controller",
          "codeValue": "send",
          "cardinality": "singleton",
          "scopeKeys": ["viewerUid", "eventId", "audience", "requestId"],
          "outcomes": [
            {"kind": "surface_state", "stateIds": ["broadcast_composer_lifecycle", "offline"]},
            {"kind": "side_effect", "id": "host_inbox.event_broadcast_sent"}
          ],
          "description": "Sends one idempotent event broadcast to the selected roster-derived audience and reports partial push delivery honestly."
        }
      ],
      "stateIds": ["uid_loading_or_missing", "matches_loading", "matches_error", "empty_host_queries", "host_query_filtering", "populated_queries", "host_header", "prospective_queries", "general_queries", "roster_without_threads", "broadcast_composer_lifecycle", "search_collapsed", "search_active", "search_empty", "new_inquiry_without_messages", "conversation_rows", "unread_rows", "host_inquiry_avatar_shape", "profile_loading_fallback", "duplicate_match_collapse", "route_to_host_chat", "offline", "text_scale_2", "reduced_motion", "light_dark"],
      "scenarioDefaults": {"dimensions": {}, "actionCases": [{"id": "default"}]},
      "scenarioOverrides": {
        "uid_loading_or_missing": {"dimensions": {"load": "loading"}},
        "matches_loading": {"dimensions": {"load": "loading"}},
        "matches_error": {"dimensions": {"load": "error"}, "actionCases": [{"id": "recovery", "enabledActions": ["retry_inbox"]}]},
        "empty_host_queries": {"dimensions": {"content": "empty"}, "actionCases": [{"id": "empty", "enabledActions": ["toggle_search", "select_scope", "select_audience_segment"]}]},
        "host_query_filtering": {"dimensions": {"search": "filtering"}, "actionCases": [{"id": "filter", "enabledActions": ["toggle_search", "search_inquiries", "open_conversation"]}]},
        "populated_queries": {"actionCases": [{"id": "inbox", "enabledActions": ["toggle_search", "search_inquiries", "select_scope", "select_audience_segment", "open_conversation", "open_broadcast_composer"]}]},
        "host_header": {"actionCases": [{"id": "header", "enabledActions": ["toggle_search", "search_inquiries"]}]},
        "prospective_queries": {"dimensions": {"segment": "prospective"}, "actionCases": [{"id": "prospective", "enabledActions": ["toggle_search", "search_inquiries", "select_scope", "select_audience_segment", "open_conversation", "open_broadcast_composer"]}]},
        "general_queries": {"dimensions": {"scope": "general"}, "actionCases": [{"id": "general", "enabledActions": ["toggle_search", "search_inquiries", "select_scope", "open_conversation"]}]},
        "roster_without_threads": {"dimensions": {"content": "empty"}, "actionCases": [{"id": "broadcast_only", "enabledActions": ["select_scope", "select_audience_segment", "open_broadcast_composer"]}]},
        "broadcast_composer_lifecycle": {"dimensions": {"broadcast": "composer"}, "actionCases": [
          {"id": "ready", "enabledActions": ["select_broadcast_audience", "select_broadcast_template", "send_broadcast"]},
          {"id": "sending_disabled", "enabledActions": ["select_broadcast_audience", "select_broadcast_template"], "disabledActions": ["send_broadcast"]},
          {"id": "pending", "disabledActions": ["select_broadcast_audience", "select_broadcast_template", "send_broadcast"]},
          {"id": "error", "enabledActions": ["select_broadcast_audience", "select_broadcast_template", "send_broadcast"]}
        ]},
        "search_collapsed": {"actionCases": [{"id": "open", "enabledActions": ["toggle_search"]}]},
        "search_active": {"dimensions": {"search": "active"}, "actionCases": [{"id": "search", "enabledActions": ["toggle_search", "search_inquiries"]}]},
        "search_empty": {"dimensions": {"content": "empty", "search": "empty"}, "actionCases": [{"id": "clear", "enabledActions": ["toggle_search", "search_inquiries"]}]},
        "new_inquiry_without_messages": {"dimensions": {"content": "new_inquiry"}, "actionCases": [{"id": "new", "enabledActions": ["open_conversation"]}]},
        "conversation_rows": {"actionCases": [{"id": "rows", "enabledActions": ["open_conversation"]}]},
        "unread_rows": {"actionCases": [{"id": "unread", "enabledActions": ["open_conversation"]}]},
        "host_inquiry_avatar_shape": {"actionCases": [{"id": "avatar", "enabledActions": ["open_conversation"]}]},
        "profile_loading_fallback": {"dimensions": {"profile": "loading"}, "actionCases": [{"id": "fallback", "enabledActions": ["open_conversation"]}]},
        "duplicate_match_collapse": {"actionCases": [{"id": "deduped", "enabledActions": ["open_conversation"]}]},
        "route_to_host_chat": {"actionCases": [{"id": "route", "enabledActions": ["open_conversation"]}]},
        "offline": {"dimensions": {"load": "offline"}, "actionCases": [{"id": "retry", "enabledActions": ["retry_inbox", "send_broadcast"]}]},
        "text_scale_2": {"dimensions": {"accessibility": "text_scale_2"}},
        "reduced_motion": {"dimensions": {"accessibility": "reduced_motion"}},
        "light_dark": {"dimensions": {"theme": "light_dark"}}
      },
      "requiredEvidence": {"captures": true, "previews": true, "tests": true},
      "evidenceExceptions": [
        {
          "stateIds": ["host_query_filtering", "profile_loading_fallback", "duplicate_match_collapse", "route_to_host_chat"],
          "evidence": ["captures"],
          "debtId": "FEATURE-CONTRACT-MIGRATION-001",
          "reason": "These Host Inbox interaction states have focused tests and the shared production-screen preview but no standalone deterministic capture registered yet."
        },
        {
          "stateIds": ["empty_host_queries", "new_inquiry_without_messages", "host_inquiry_avatar_shape", "profile_loading_fallback", "offline", "text_scale_2", "reduced_motion", "light_dark"],
          "evidence": ["tests"],
          "debtId": "FEATURE-CONTRACT-MIGRATION-001",
          "reason": "These registered Host Inbox states have deterministic capture and preview evidence but no focused state-level automated test attached to the authority yet."
        }
      ]
    }
  ]
}
