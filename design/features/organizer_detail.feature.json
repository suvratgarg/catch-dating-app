{
  "$schema": "./feature_contract.schema.json",
  "version": 2,
  "updated": "2026-07-23",
  "id": "feature.organizer_detail",
  "name": "Organizer Detail",
  "owner": "organizers",
  "status": "pilot",
  "description": "Orchestrates one public organizer identity across consumer Flutter, host Flutter, and marketing-web projections while preserving surface-specific membership, navigation, claim, review, and indexing behavior.",
  "surfaces": [
    {
      "id": "consumer_flutter",
      "runtime": "flutter",
      "authority": {
        "registry": "flutter_screens",
        "id": "screen.club.detail"
      },
      "actionScope": {
        "included": "Consumer organizer-detail retry, membership, notification, share, schedule, host-contact, and host-profile actions owned by the shared Club Detail route and its controllers.",
        "excluded": [
          "Review creation and response behavior retains the shared review-section owner; embedded read-only previews suppress route actions; Host operational controls remain outside this public profile route."
        ]
      },
      "bindings": {
        "previewSources": [
          "widgetbook/lib/clubs/club_detail_use_cases.dart"
        ],
        "actionOwners": [
          {
            "id": "route_screen",
            "language": "dart",
            "file": "lib/clubs/presentation/detail/club_detail_screen.dart",
            "symbol": "ClubDetailScreen"
          },
          {
            "id": "membership",
            "language": "dart",
            "file": "lib/clubs/presentation/detail/club_membership_controller.dart",
            "symbol": "ClubMembershipController"
          },
          {
            "id": "membership_dock",
            "language": "dart",
            "file": "lib/clubs/presentation/detail/widgets/club_detail_dock.dart",
            "symbol": "ClubMembershipDock"
          },
          {
            "id": "host_contact",
            "language": "dart",
            "file": "lib/clubs/presentation/detail/club_host_contact_controller.dart",
            "symbol": "ClubHostContactController"
          }
        ],
        "componentContracts": [
          "catch.button",
          "catch.chip",
          "catch.event_card",
          "catch.icon_button",
          "catch.surface",
          "catch.top_bar"
        ],
        "dataContracts": [
          "contracts/callables/club_membership_payload.schema.json",
          "contracts/callables/set_club_notification_preference_payload.schema.json",
          "contracts/callables/start_club_host_conversation_payload.schema.json",
          "contracts/firestore/club_memberships.schema.json",
          "contracts/firestore/clubs.schema.json",
          "contracts/firestore/events.schema.json",
          "contracts/firestore/organizers.schema.json"
        ]
      },
      "dimensions": {
        "load": {
          "default": "ready",
          "values": [
            "ready",
            "loading",
            "not_found",
            "error",
            "offline"
          ]
        },
        "viewer": {
          "default": "member",
          "values": [
            "guest",
            "visitor",
            "member",
            "host"
          ]
        },
        "schedule": {
          "default": "populated",
          "values": [
            "populated",
            "empty"
          ]
        },
        "membership_mutation": {
          "default": "idle",
          "values": [
            "idle",
            "pending",
            "failed"
          ]
        },
        "accessibility": {
          "default": "standard",
          "values": [
            "standard",
            "text_scale_2",
            "reduced_motion"
          ]
        }
      },
      "actions": [
        {
          "id": "retry_detail",
          "owner": "route_screen",
          "codeValue": "invalidate",
          "cardinality": "singleton",
          "scopeKeys": [
            "routeInstanceId",
            "clubId",
            "failureStateVersion"
          ],
          "outcomes": [
            {
              "kind": "surface_state",
              "stateIds": [
                "loading",
                "member_default",
                "visitor_not_member",
                "guest_join",
                "host_public_view"
              ]
            }
          ],
          "description": "Invalidates the organizer-detail view model once for the current failed load state."
        },
        {
          "id": "sign_in_to_join",
          "owner": "membership_dock",
          "codeValue": "go",
          "cardinality": "singleton",
          "scopeKeys": [
            "routeInstanceId",
            "clubId",
            "viewerSessionId"
          ],
          "outcomes": [
            {
              "kind": "route",
              "authority": {
                "registry": "flutter_screens",
                "id": "screen.auth.phone_entry"
              }
            }
          ],
          "description": "Routes a signed-out viewer to authentication while preserving the organizer-detail return path."
        },
        {
          "id": "join_organizer",
          "owner": "membership",
          "codeValue": "join",
          "cardinality": "singleton",
          "scopeKeys": [
            "viewerUid",
            "clubId",
            "membershipVersion"
          ],
          "outcomes": [
            {
              "kind": "surface_state",
              "stateIds": [
                "join_leave_pending",
                "member_default",
                "join_leave_failed"
              ]
            },
            {
              "kind": "side_effect",
              "id": "organizer.membership_joined"
            }
          ],
          "description": "Creates the current viewer's organizer membership once for the active membership version."
        },
        {
          "id": "leave_organizer",
          "owner": "membership",
          "codeValue": "leave",
          "cardinality": "singleton",
          "scopeKeys": [
            "viewerUid",
            "clubId",
            "membershipVersion"
          ],
          "outcomes": [
            {
              "kind": "surface_state",
              "stateIds": [
                "join_leave_pending",
                "visitor_not_member",
                "join_leave_failed"
              ]
            },
            {
              "kind": "side_effect",
              "id": "organizer.membership_left"
            }
          ],
          "description": "Removes the current viewer's organizer membership once for the active membership version."
        },
        {
          "id": "toggle_notifications",
          "owner": "membership",
          "codeValue": "setPushNotifications",
          "cardinality": "singleton",
          "scopeKeys": [
            "viewerUid",
            "clubId",
            "notificationPreferenceVersion"
          ],
          "outcomes": [
            {
              "kind": "side_effect",
              "id": "organizer.notification_preference_updated"
            }
          ],
          "description": "Toggles organizer push notifications once for the current membership preference version."
        },
        {
          "id": "share_organizer",
          "owner": "route_screen",
          "codeValue": "showClubShareCardSheet",
          "cardinality": "unbounded",
          "scopeKeys": [
            "routeInstanceId",
            "clubId",
            "shareAttemptId"
          ],
          "outcomes": [
            {
              "kind": "side_effect",
              "id": "organizer.share_sheet_opened"
            }
          ],
          "description": "Opens the organizer share-card sheet for the current profile."
        },
        {
          "id": "open_event",
          "owner": "route_screen",
          "codeValue": "onEventSelected",
          "cardinality": "unbounded",
          "scopeKeys": [
            "routeInstanceId",
            "clubId",
            "eventId"
          ],
          "outcomes": [
            {
              "kind": "route",
              "authority": {
                "registry": "flutter_screens",
                "id": "screen.event.detail"
              }
            }
          ],
          "description": "Routes a selected upcoming organizer event to consumer Event Detail."
        },
        {
          "id": "open_host_profile",
          "owner": "route_screen",
          "codeValue": "onViewHostProfile",
          "cardinality": "unbounded",
          "scopeKeys": [
            "routeInstanceId",
            "clubId",
            "hostUid"
          ],
          "outcomes": [
            {
              "kind": "route",
              "authority": {
                "registry": "flutter_screens",
                "id": "screen.profile.public"
              }
            }
          ],
          "description": "Routes a selected organizer host identity to Public Profile."
        },
        {
          "id": "message_host",
          "owner": "host_contact",
          "codeValue": "startConversation",
          "cardinality": "singleton",
          "scopeKeys": [
            "viewerUid",
            "clubId",
            "hostUid"
          ],
          "outcomes": [
            {
              "kind": "route",
              "authority": {
                "registry": "flutter_screens",
                "id": "screen.matches.chat"
              }
            },
            {
              "kind": "side_effect",
              "id": "organizer.host_conversation_started"
            }
          ],
          "description": "Starts or resolves the viewer-host conversation once and opens its member chat."
        },
        {
          "id": "open_contact",
          "owner": "route_screen",
          "codeValue": "openClubContact",
          "cardinality": "unbounded",
          "scopeKeys": [
            "routeInstanceId",
            "clubId",
            "contactKind"
          ],
          "outcomes": [
            {
              "kind": "side_effect",
              "id": "organizer.contact_link_opened"
            }
          ],
          "description": "Opens a typed organizer Instagram, phone, or email contact target."
        }
      ],
      "stateIds": [
        "loading",
        "not_found",
        "fatal_error",
        "member_default",
        "visitor_not_member",
        "guest_join",
        "host_public_view",
        "empty_schedule",
        "join_leave_pending",
        "join_leave_failed",
        "offline",
        "text_scale_2",
        "reduced_motion"
      ],
      "scenarioDefaults": {
        "dimensions": {},
        "actionCases": [
          {
            "id": "default"
          }
        ]
      },
      "scenarioOverrides": {
        "loading": {
          "dimensions": {
            "load": "loading"
          }
        },
        "not_found": {
          "dimensions": {
            "load": "not_found"
          }
        },
