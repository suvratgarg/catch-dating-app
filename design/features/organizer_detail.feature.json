        "empty_schedule": {
          "dimensions": {
            "schedule": "empty"
          },
          "actionCases": [
            {
              "id": "member_without_events",
              "enabledActions": [
                "leave_organizer",
                "toggle_notifications",
                "share_organizer",
                "open_host_profile",
                "message_host",
                "open_contact"
              ]
            }
          ]
        },
        "join_leave_pending": {
          "dimensions": {
            "membership_mutation": "pending"
          },
          "actionCases": [
            {
              "id": "join_pending",
              "dimensions": {
                "viewer": "visitor"
              },
              "disabledActions": [
                "join_organizer"
              ]
            },
            {
              "id": "leave_pending",
              "dimensions": {
                "viewer": "member"
              },
              "disabledActions": [
                "leave_organizer",
                "toggle_notifications"
              ]
            }
          ]
        },
        "join_leave_failed": {
          "dimensions": {
            "membership_mutation": "failed"
          },
          "actionCases": [
            {
              "id": "join_failed",
              "dimensions": {
                "viewer": "visitor"
              },
              "enabledActions": [
                "join_organizer"
              ]
            },
            {
              "id": "leave_failed",
              "dimensions": {
                "viewer": "member"
              },
              "enabledActions": [
                "leave_organizer"
              ]
            }
          ]
        },
        "offline": {
          "dimensions": {
            "load": "offline"
          },
          "actionCases": [
            {
              "id": "retryable",
              "enabledActions": [
                "retry_detail"
              ]
            }
          ]
        },
        "text_scale_2": {
          "dimensions": {
            "accessibility": "text_scale_2"
          },
          "actionCases": [
            {
              "id": "member",
              "enabledActions": [
                "leave_organizer",
                "toggle_notifications",
                "share_organizer",
                "open_event",
                "open_host_profile",
                "message_host",
                "open_contact"
              ]
            }
          ]
        },
        "reduced_motion": {
          "dimensions": {
            "accessibility": "reduced_motion"
          },
          "actionCases": [
            {
              "id": "member",
              "enabledActions": [
                "leave_organizer",
                "toggle_notifications",
                "share_organizer",
                "open_event",
                "open_host_profile",
                "message_host",
                "open_contact"
              ]
            }
          ]
