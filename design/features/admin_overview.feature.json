{
  "$schema": "./feature_contract.schema.json",
  "version": 2,
  "updated": "2026-07-23",
  "id": "feature.admin_overview",
  "name": "Admin Overview",
  "owner": "admin_console",
  "status": "pilot",
  "description": "Orchestrates the read-only owner digest, role-checked queue routing, scoped Host Analytics controls, and the live lazy controller wrapper as one administrative overview feature.",
  "surfaces": [
    {
      "id": "admin_overview",
      "runtime": "react_admin",
      "authority": {"registry": "admin_routes", "id": "route_overview"},
      "actionScope": {
        "included": "Refreshing queue and analytics evidence, clearing optional analytics entity scope, and opening the role-checked workflow that owns a queue row.",
        "excluded": [
          "Range, granularity, date, organizer, and event inputs remain analytics query data.",
          "Headline metrics and queue rows retain their own source scope; analytics filters apply only to the analysis section below.",
          "The Overview is a read-only router and does not resolve queue items or alter metrics."
        ]
      },
      "bindings": {
        "previewSources": ["admin/src/stories/AdminRoutes.stories.tsx"],
        "actionOwners": [
          {"id": "controller", "language": "typescript", "file": "admin/src/features/overview/controllers/useOverviewController.ts", "symbol": "useOverviewController"},
          {"id": "screen", "language": "typescript", "file": "admin/src/features/overview/ui/OverviewScreen.tsx", "symbol": "OverviewScreen"}
        ],
        "componentContracts": ["route_overview"],
        "dataContracts": [
          "contracts/callables/host_analytics_query_payload.schema.json",
          "contracts/callable_responses/host_analytics_response.schema.json"
        ],
        "runtimeContracts": [
          {"kind": "admin_callable", "registry": "admin/src/generated/validators/adminCallableValidators.ts", "callable": "adminGetOverview", "requestValidation": "structural_object", "responseValidation": "structural_object"},
          {"kind": "admin_callable", "registry": "admin/src/generated/validators/adminCallableValidators.ts", "callable": "adminGetHostAnalytics", "requestValidation": "strict_schema", "responseValidation": "strict_schema"}
        ],
        "testEvidence": {
          "default": ["admin/src/features/overview/controllers/useOverviewController.test.tsx"],
          "analytics-controls": ["admin/src/features/overview/controllers/useOverviewController.test.tsx"],
          "queue-router": ["admin/src/features/overview/controllers/useOverviewController.test.tsx"],
          "metric-ownership": ["admin/src/features/overview/controllers/useOverviewController.test.tsx"],
          "scoped-analytics": ["admin/src/features/overview/controllers/useOverviewController.test.tsx"]
        }
      },
      "dimensions": {
        "overview_source": {"default": "ready", "values": ["ready", "loading", "failed"]},
        "analytics_source": {"default": "ready", "values": ["ready", "loading", "failed", "role_restricted"]},
        "analytics_scope": {"default": "global", "values": ["global", "organizer", "event"]}
      },
      "actions": [
        {"id": "refresh_admin_overview", "owner": "controller", "codeValue": "refresh", "cardinality": "singleton", "scopeKeys": ["adminSessionId", "overviewVersion", "analyticsVersion"], "outcomes": [{"kind": "surface_state", "stateIds": ["default", "analytics-controls", "metric-ownership", "scoped-analytics"]}], "description": "Refetches Overview and, when role-allowed, Host Analytics together."},
        {"id": "refresh_overview_queues", "owner": "controller", "codeValue": "refreshOverview", "cardinality": "singleton", "scopeKeys": ["adminSessionId", "overviewVersion"], "outcomes": [{"kind": "surface_state", "stateIds": ["default", "analytics-controls", "queue-router", "metric-ownership", "scoped-analytics"]}], "description": "Refetches only current headline metrics and queue digests without changing the analytics projection."},
        {"id": "refresh_overview_analytics", "owner": "controller", "codeValue": "refreshAnalytics", "cardinality": "singleton", "scopeKeys": ["adminSessionId", "analyticsPayloadVersion"], "outcomes": [{"kind": "surface_state", "stateIds": ["analytics-controls", "scoped-analytics"]}], "description": "Refetches only the role-checked analytics payload."},
        {"id": "clear_overview_analytics_scope", "owner": "controller", "codeValue": "clearAnalyticsScope", "cardinality": "singleton", "scopeKeys": ["adminSessionId", "analyticsPayloadVersion"], "outcomes": [{"kind": "surface_state", "stateIds": ["analytics-controls", "scoped-analytics"]}], "description": "Clears organizer and event scope while preserving the selected range and granularity."},
        {"id": "open_overview_queue_owner", "owner": "screen", "codeValue": "onOpenQueue", "cardinality": "unbounded", "scopeKeys": ["adminSessionId", "destination", "targetPath"], "outcomes": [{"kind": "side_effect", "id": "admin.queue_owner_opened"}], "description": "Routes a digest or queue row to its role-checked owning workflow."
        }
      ],
      "scenarios": [
        {"id": "default", "stateId": "default", "dimensions": {}, "actionCases": [{"id": "complete_digest", "enabledActions": ["refresh_admin_overview", "refresh_overview_queues", "open_overview_queue_owner"]}, {"id": "overview_loading", "dimensions": {"overview_source": "loading"}, "disabledActions": ["refresh_admin_overview", "refresh_overview_queues", "open_overview_queue_owner"]}]},
        {"id": "analytics_controls", "stateId": "analytics-controls", "dimensions": {}, "actionCases": [{"id": "analytics_ready", "enabledActions": ["refresh_admin_overview", "refresh_overview_analytics", "clear_overview_analytics_scope"]}, {"id": "analytics_loading", "dimensions": {"analytics_source": "loading"}, "disabledActions": ["refresh_admin_overview", "refresh_overview_analytics"]}, {"id": "analytics_restricted", "dimensions": {"analytics_source": "role_restricted"}, "enabledActions": ["refresh_overview_queues"], "disabledActions": ["refresh_overview_analytics"]}]},
        {"id": "queue_router", "stateId": "queue-router", "dimensions": {}, "actionCases": [{"id": "owner_routes", "enabledActions": ["refresh_overview_queues", "open_overview_queue_owner"]}]},
        {"id": "metric_ownership", "stateId": "metric-ownership", "dimensions": {}, "actionCases": [{"id": "source_scoped_metrics", "enabledActions": ["refresh_admin_overview", "refresh_overview_queues", "open_overview_queue_owner"]}]},
        {"id": "scoped_analytics", "stateId": "scoped-analytics", "dimensions": {"analytics_scope": "organizer"}, "actionCases": [{"id": "organizer_or_event_scope", "enabledActions": ["refresh_admin_overview", "refresh_overview_analytics", "clear_overview_analytics_scope"]}]}
      ],
      "requiredEvidence": {"captures": false, "previews": true, "tests": true}
    },
    {
      "id": "admin_overview_live_controller",
      "runtime": "react_admin",
      "authority": {"registry": "admin_routes", "id": "route_overview_live_controller"},
      "actionScope": {
        "included": "Owning the live query and role seam for the prop-driven Overview actions.",
        "excluded": [
          "Deterministic visual state remains on the prop-driven route_overview projection.",
          "The lazy boundary contributes no independent product goal or state vocabulary beyond loading the same feature."
        ]
      },
      "bindings": {
        "previewSources": [],
        "actionOwners": [
          {"id": "controller", "language": "typescript", "file": "admin/src/features/overview/controllers/useOverviewController.ts", "symbol": "useOverviewController"},
          {"id": "route", "language": "typescript", "file": "admin/src/features/overview/ui/OverviewRouteScreen.tsx", "symbol": "OverviewRouteScreen"}
        ],
        "componentContracts": ["route_overview_live_controller"],
        "dataContracts": [
          "contracts/callables/host_analytics_query_payload.schema.json",
          "contracts/callable_responses/host_analytics_response.schema.json"
        ],
        "runtimeContracts": [
          {"kind": "admin_callable", "registry": "admin/src/generated/validators/adminCallableValidators.ts", "callable": "adminGetOverview", "requestValidation": "structural_object", "responseValidation": "structural_object"},
          {"kind": "admin_callable", "registry": "admin/src/generated/validators/adminCallableValidators.ts", "callable": "adminGetHostAnalytics", "requestValidation": "strict_schema", "responseValidation": "strict_schema"}
        ],
        "testEvidence": {
          "live-query-wrapper": ["admin/src/features/overview/controllers/useOverviewController.test.tsx"],
          "route-lazy-boundary": ["admin/src/features/overview/controllers/useOverviewController.test.tsx"]
        }
      },
      "dimensions": {
        "boundary": {"default": "resolved", "values": ["resolved", "loading"]}
      },
      "actions": [
        {"id": "refresh_admin_overview", "owner": "controller", "codeValue": "refresh", "cardinality": "singleton", "scopeKeys": ["adminSessionId", "overviewVersion", "analyticsVersion"], "outcomes": [{"kind": "surface_state", "stateIds": ["live-query-wrapper"]}], "description": "Refetches both live Overview sources through the controller seam."},
        {"id": "refresh_overview_queues", "owner": "controller", "codeValue": "refreshOverview", "cardinality": "singleton", "scopeKeys": ["adminSessionId", "overviewVersion"], "outcomes": [{"kind": "surface_state", "stateIds": ["live-query-wrapper"]}], "description": "Refetches the live queue snapshot."},
        {"id": "refresh_overview_analytics", "owner": "controller", "codeValue": "refreshAnalytics", "cardinality": "singleton", "scopeKeys": ["adminSessionId", "analyticsPayloadVersion"], "outcomes": [{"kind": "surface_state", "stateIds": ["live-query-wrapper"]}], "description": "Refetches the live role-checked analytics query."},
        {"id": "clear_overview_analytics_scope", "owner": "controller", "codeValue": "clearAnalyticsScope", "cardinality": "singleton", "scopeKeys": ["adminSessionId", "analyticsPayloadVersion"], "outcomes": [{"kind": "surface_state", "stateIds": ["live-query-wrapper"]}], "description": "Clears live organizer and event analytics scope."},
        {"id": "open_overview_queue_owner", "owner": "route", "codeValue": "onOpenQueue", "cardinality": "unbounded", "scopeKeys": ["adminSessionId", "destination", "targetPath"], "outcomes": [{"kind": "side_effect", "id": "admin.queue_owner_opened"}], "description": "Forwards queue routing to the owning app route."
        }
      ],
      "scenarios": [
        {"id": "live_query_wrapper", "stateId": "live-query-wrapper", "dimensions": {}, "actionCases": [{"id": "resolved", "enabledActions": ["refresh_admin_overview", "refresh_overview_queues", "refresh_overview_analytics", "clear_overview_analytics_scope", "open_overview_queue_owner"]}]},
        {"id": "route_lazy_boundary", "stateId": "route-lazy-boundary", "dimensions": {"boundary": "loading"}, "actionCases": [{"id": "lazy_loading"}]}
      ],
      "requiredEvidence": {"captures": false, "previews": false, "tests": true}
    }
  ]
}
