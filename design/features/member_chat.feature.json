    {
      "id": "host_flutter",
      "runtime": "flutter",
      "authority": {"registry": "flutter_screens", "id": "screen.host.chat"},
      "actionScope": {
        "included": "Host-inquiry authentication, match, and message recovery; host identity policy; text and image delivery; profile/share capability policy; and report/block safety actions.",
        "excluded": [
          "Automatic read-marker decisions and scroll coordination remain lifecycle effects owned by their controllers rather than user actions.",
          "Suvbot and member-only profile/share behavior remain in the consumer projection; event-context enrichment failures stay non-primary."
        ]
      },
      "bindings": {
        "previewSources": ["widgetbook/lib/matches/matches_chat_use_cases.dart"],
        "actionOwners": [
          {"id": "chat_screen", "language": "dart", "file": "lib/chats/presentation/chat_screen.dart", "symbol": "ChatScreen"},
          {"id": "retry_controller", "language": "dart", "file": "lib/chats/presentation/chat_retry_controller.dart", "symbol": "ChatRetryController"},
          {"id": "chat_mutations", "language": "dart", "file": "lib/chats/presentation/chat_controller.dart", "symbol": "ChatController"},
          {"id": "thread_actions", "language": "dart", "file": "lib/chats/presentation/chat_thread_action_controller.dart", "symbol": "ChatThreadActionController"}
        ],
        "componentContracts": ["catch.button", "catch.error_state", "catch.field", "catch.icon_button", "catch.surface", "catch.top_bar"],
        "dataContracts": [
          "contracts/callables/block_user_payload.schema.json",
          "contracts/callables/report_user_payload.schema.json",
          "contracts/client_writes/create_chat_message.schema.json",
          "contracts/client_writes/reset_match_unread_count.schema.json",
          "contracts/firestore/chat_messages.schema.json",
          "contracts/firestore/clubs.schema.json",
          "contracts/firestore/events.schema.json",
          "contracts/firestore/matches.schema.json",
          "contracts/firestore/public_profiles.schema.json",
          "contracts/storage/match_chat_images.schema.json"
        ]
      },
      "dimensions": {
        "route": {"default": "ready", "values": ["ready", "loading", "error", "not_found"]},
        "messages": {"default": "ready", "values": ["ready", "loading", "error", "empty"]},
        "access": {"default": "host_inquiry", "values": ["host_inquiry", "profile_disabled", "share_disabled", "blocked"]},
        "context": {"default": "event", "values": ["event", "event_fallback"]},
        "mutation": {"default": "idle", "values": ["idle", "send_pending", "image_pending", "report_pending", "block_pending", "failed"]},
        "composer": {"default": "enabled", "values": ["enabled", "disabled", "keyboard_open"]},
        "connectivity": {"default": "online", "values": ["online", "offline"]},
        "accessibility": {"default": "standard", "values": ["standard", "text_scale_2", "reduced_motion"]},
        "theme": {"default": "standard", "values": ["standard", "light_dark"]}
      },
      "actions": [
        {
          "id": "retry_auth",
          "owner": "chat_screen",
          "codeValue": "uidProvider",
          "cardinality": "singleton",
          "scopeKeys": ["routeInstanceId", "authSessionId", "failureStateVersion"],
          "outcomes": [{"kind": "surface_state", "stateIds": ["host_inquiry_identity", "offline"]}],
          "description": "Retries the route-level signed-in viewer dependency."
        },
        {
          "id": "retry_match",
          "owner": "retry_controller",
          "codeValue": "reloadMatch",
          "cardinality": "singleton",
          "scopeKeys": ["viewerUid", "matchId", "failureStateVersion"],
          "outcomes": [{"kind": "surface_state", "stateIds": ["match_loading", "match_error", "match_not_found", "host_inquiry_identity"]}],
          "description": "Invalidates only the failed match stream for the current host inquiry."
        },
        {
          "id": "retry_messages",
          "owner": "retry_controller",
          "codeValue": "reloadMessages",
          "cardinality": "singleton",
          "scopeKeys": ["viewerUid", "matchId", "failureStateVersion"],
          "outcomes": [{"kind": "surface_state", "stateIds": ["messages_loading", "messages_error", "empty_thread", "populated_thread", "offline"]}],
          "description": "Invalidates only the failed conversation-message stream."
        },
        {
          "id": "send_message",
          "owner": "chat_mutations",
          "codeValue": "sendMessage",
          "cardinality": "unbounded",
          "scopeKeys": ["viewerUid", "matchId", "clientMessageId"],
          "outcomes": [
            {"kind": "surface_state", "stateIds": ["send_message_pending", "send_failure", "populated_thread", "offline"]},
            {"kind": "side_effect", "id": "host_chat.create_text_message"}
          ],
          "description": "Creates one text message in the host inquiry conversation."
        },
        {
          "id": "send_image",
          "owner": "chat_mutations",
          "codeValue": "sendImage",
          "cardinality": "unbounded",
          "scopeKeys": ["viewerUid", "matchId", "messageId", "storagePath"],
          "outcomes": [
            {"kind": "surface_state", "stateIds": ["send_image_pending", "mutation_error_listener", "populated_thread", "offline"]},
            {"kind": "side_effect", "id": "host_chat.upload_and_create_image_message"}
          ],
          "description": "Uploads an image and writes its message, deleting an orphaned upload if the message write fails."
        },
        {
          "id": "open_profile",
          "owner": "thread_actions",
          "codeValue": "profileNavigationRequest",
          "cardinality": "unbounded",
          "scopeKeys": ["viewerUid", "matchId", "targetUid"],
          "outcomes": [{"kind": "route", "authority": {"registry": "flutter_screens", "id": "screen.profile.public"}}],
          "description": "Represents profile navigation capability; host-inquiry identity policy intentionally disables it."
        },
        {
          "id": "share_card",
          "owner": "thread_actions",
          "codeValue": "runThreadAction",
          "cardinality": "unbounded",
          "scopeKeys": ["viewerUid", "matchId", "messageSnapshotVersion"],
          "outcomes": [{"kind": "side_effect", "id": "host_chat.share_card"}],
          "description": "Represents share-card capability; host-inquiry identity policy intentionally disables it."
        },
        {
          "id": "report_user",
          "owner": "chat_mutations",
          "codeValue": "reportUser",
          "cardinality": "unbounded",
          "scopeKeys": ["viewerUid", "matchId", "targetUid", "reportAttemptId"],
          "outcomes": [
            {"kind": "surface_state", "stateIds": ["report_user_mutation", "mutation_error_listener"]},
            {"kind": "side_effect", "id": "host_chat.report_user"}
          ],
          "description": "Submits one host-chat safety report for the inquiry participant."
        },
        {
          "id": "block_user",
          "owner": "chat_mutations",
          "codeValue": "blockUser",
          "cardinality": "singleton",
          "scopeKeys": ["viewerUid", "targetUid", "relationshipVersion"],
          "outcomes": [
            {"kind": "surface_state", "stateIds": ["block_user_mutation", "blocked_chat", "mutation_error_listener"]},
            {"kind": "side_effect", "id": "host_chat.block_user_and_close"}
          ],
          "description": "Confirms and blocks the inquiry participant once for the current viewer-target relationship, then closes the thread."
        }
