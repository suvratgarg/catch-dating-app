{
  "$schema": "./feature_contract.schema.json",
  "version": 2,
  "updated": "2026-07-23",
  "id": "feature.admin_finance_ops",
  "name": "Admin Finance Operations",
  "owner": "admin_console",
  "status": "pilot",
  "description": "Orchestrates read-only finance issue triage across overview and Host Analytics evidence, with exact issue detail and source-specific recovery.",
  "surfaces": [
    {
      "id": "admin_web",
      "runtime": "react_admin",
      "authority": {"registry": "admin_routes", "id": "route_finance_ops"},
      "actionScope": {
        "included": "Selecting an issue, returning to the register, refreshing both finance sources, and retrying one failed source.",
        "excluded": [
          "Search and issue-kind filters remain local register state.",
          "The route presents reconciliation evidence and ownership guidance; it performs no refund, payout, booking, or payment mutation.",
          "Overview retains structural-object validation while Host Analytics has strict request and response schemas."
        ]
      },
      "bindings": {
        "previewSources": ["admin/src/stories/AdminRoutes.stories.tsx"],
        "actionOwners": [
          {"id": "controller", "language": "typescript", "file": "admin/src/features/finance/controllers/useFinanceOpsController.ts", "symbol": "useFinanceOpsController"},
          {"id": "screen", "language": "typescript", "file": "admin/src/features/finance/ui/FinanceOpsScreen.tsx", "symbol": "FinanceOpsWorkspace"}
        ],
        "componentContracts": ["route_finance_ops"],
        "dataContracts": [
          "contracts/callables/host_analytics_query_payload.schema.json",
          "contracts/callable_responses/host_analytics_response.schema.json"
        ],
        "runtimeContracts": [
          {"kind": "admin_callable", "registry": "admin/src/generated/validators/adminCallableValidators.ts", "callable": "adminGetOverview", "requestValidation": "strict_schema", "responseValidation": "strict_schema"},
          {"kind": "admin_callable", "registry": "admin/src/generated/validators/adminCallableValidators.ts", "callable": "adminGetHostAnalytics", "requestValidation": "strict_schema", "responseValidation": "strict_schema"}
        ],
        "testEvidence": {
          "issue-detail": ["admin/src/features/finance/controllers/useFinanceOpsController.test.tsx"]
        }
      },
      "dimensions": {
        "view": {"default": "register", "values": ["register", "detail", "unavailable"]},
        "source_health": {"default": "complete", "values": ["complete", "loading", "partial", "unavailable"]}
      },
      "actions": [
        {"id": "select_finance_issue", "owner": "controller", "codeValue": "select", "cardinality": "unbounded", "scopeKeys": ["adminSessionId", "issueId"], "outcomes": [{"kind": "surface_state", "stateIds": ["issue-detail"]}], "description": "Opens one derived finance issue and its source-labelled reconciliation view."},
        {"id": "back_to_finance_register", "owner": "screen", "codeValue": "onBackToList", "cardinality": "unbounded", "scopeKeys": ["adminSessionId", "issueId"], "outcomes": [{"kind": "surface_state", "stateIds": ["issue-detail"]}], "description": "Returns from issue detail to the finance register."},
        {"id": "refresh_finance_sources", "owner": "controller", "codeValue": "refresh", "cardinality": "singleton", "scopeKeys": ["adminSessionId", "sourceSnapshotVersion"], "outcomes": [{"kind": "surface_state", "stateIds": ["issue-detail"]}], "description": "Refetches Overview and Host Analytics while accepting a usable partial result."},
        {"id": "retry_finance_source", "owner": "controller", "codeValue": "retrySource", "cardinality": "domain_bounded", "scopeKeys": ["adminSessionId", "sourceId", "attempt"], "outcomes": [{"kind": "surface_state", "stateIds": ["issue-detail"]}], "description": "Retries one failed finance evidence source without hiding the other source state."}
      ],
      "scenarios": [
        {
          "id": "issue_detail",
          "stateId": "issue-detail",
          "dimensions": {},
          "actionCases": [
            {"id": "register_complete", "enabledActions": ["select_finance_issue", "refresh_finance_sources"]},
            {"id": "register_loading", "dimensions": {"source_health": "loading"}, "disabledActions": ["select_finance_issue", "refresh_finance_sources"]},
            {"id": "register_partial", "dimensions": {"source_health": "partial"}, "enabledActions": ["select_finance_issue", "refresh_finance_sources", "retry_finance_source"]},
            {"id": "all_sources_unavailable", "dimensions": {"view": "unavailable", "source_health": "unavailable"}, "enabledActions": ["refresh_finance_sources", "retry_finance_source"]},
            {"id": "issue_detail", "dimensions": {"view": "detail"}, "enabledActions": ["back_to_finance_register", "refresh_finance_sources"]},
            {"id": "issue_unavailable", "dimensions": {"view": "unavailable"}, "enabledActions": ["back_to_finance_register", "refresh_finance_sources", "retry_finance_source"]}
          ]
        }
      ],
      "requiredEvidence": {"captures": false, "previews": true, "tests": true}
    }
  ]
}
