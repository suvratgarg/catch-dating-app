{
  "$schema": "./feature_contract.schema.json",
  "version": 2,
  "updated": "2026-07-23",
  "id": "feature.matches_list",
  "name": "Matches List",
  "owner": "chats",
  "status": "pilot",
  "description": "Orchestrates the consumer list of new matches and conversations, including search filtering, duplicate collapse, unread presentation, and chat entry.",
  "surfaces": [
    {
      "id": "consumer_flutter",
      "runtime": "flutter",
      "authority": {
        "registry": "flutter_screens",
        "id": "screen.matches.list"
      },
      "actionScope": {
        "included": "Consumer thread selection and query-owned search updates.",
        "excluded": [
          "Host-only filters and broadcast composition belong to feature.host_inbox; match-celebration timing remains an animation/controller concern."
        ]
      },
      "bindings": {
        "previewSources": [
          "widgetbook/lib/matches/matches_chat_use_cases.dart"
        ],
        "actionOwners": [
          {
            "id": "list_route",
            "language": "dart",
            "file": "lib/chats/presentation/inbox/chat_inbox_screen.dart",
            "symbol": "ChatsListScreen"
          },
          {
            "id": "search_query",
            "language": "dart",
            "file": "lib/chats/presentation/inbox/chats_list_view_model.dart",
            "symbol": "ChatSearchQuery"
          }
        ],
        "componentContracts": [
          "catch.badge",
          "catch.button",
          "catch.field",
          "catch.option_group",
          "catch.surface",
          "catch.top_bar"
        ],
        "dataContracts": [
          "contracts/client_writes/reset_match_unread_count.schema.json",
          "contracts/firestore/matches.schema.json",
          "contracts/firestore/public_profiles.schema.json"
        ]
      },
      "dimensions": {
        "load": {
          "default": "ready",
          "values": [
            "ready",
            "loading",
            "error",
            "offline"
          ]
        },
        "content": {
          "default": "threads",
          "values": [
            "threads",
            "new_matches",
            "empty",
            "duplicate_collapsed"
          ]
        },
        "search": {
          "default": "closed",
          "values": [
            "closed",
            "open",
            "no_results"
          ]
        },
        "read_state": {
          "default": "mixed",
          "values": [
            "mixed",
            "unread"
          ]
        },
        "overlay": {
          "default": "none",
          "values": [
            "none",
            "match_celebration"
          ]
        },
        "accessibility": {
          "default": "standard",
          "values": [
            "standard",
            "text_scale_2",
            "reduced_motion"
          ]
        },
        "theme": {
          "default": "standard",
          "values": [
            "standard",
            "light_dark"
          ]
        }
      },
      "actions": [
        {
          "id": "open_thread",
          "owner": "list_route",
          "codeValue": "_openChatThread",
          "cardinality": "domain_bounded",
          "scopeKeys": [
            "viewerUid",
            "matchId",
            "visibleThreadVersion"
          ],
          "outcomes": [
            {
              "kind": "route",
              "authority": {
                "registry": "flutter_screens",
                "id": "screen.matches.chat"
              }
            }
          ],
          "description": "Opens one visible match or conversation thread."
        },
        {
          "id": "update_search",
          "owner": "search_query",
          "codeValue": "setQuery",
          "cardinality": "unbounded",
          "scopeKeys": [
            "viewerUid",
            "routeInstanceId",
            "queryVersion"
          ],
          "outcomes": [
            {
              "kind": "surface_state",
              "stateIds": [
                "populated_threads",
                "search_open",
                "search_empty",
                "no_matches_empty"
              ]
            }
          ],
          "description": "Updates or clears the persistent consumer chat query and recomputes visible threads."
        }
      ],
      "stateIds": [
        "uid_or_matches_loading",
        "matches_error",
        "populated_threads",
        "new_matches",
        "search_open",
        "search_empty",
        "no_matches_empty",
        "duplicate_collapsed",
        "unread_state",
        "match_celebration",
        "offline",
        "text_scale_2",
        "reduced_motion",
        "light_dark"
      ],
      "scenarioDefaults": {
        "dimensions": {},
        "actionCases": [
          {
            "id": "default"
          }
        ]
      },
      "scenarioOverrides": {
        "uid_or_matches_loading": {
          "dimensions": {
            "load": "loading"
          }
        },
        "matches_error": {
          "dimensions": {
            "load": "error"
          }
        },
        "populated_threads": {
          "actionCases": [
            {
              "id": "threads",
              "enabledActions": [
                "open_thread",
                "update_search"
              ]
            }
          ]
        },
        "new_matches": {
          "dimensions": {
            "content": "new_matches"
          },
          "actionCases": [
            {
              "id": "new_matches",
              "enabledActions": [
                "open_thread",
                "update_search"
              ]
            }
          ]
        },
        "search_open": {
          "dimensions": {
            "search": "open"
          },
          "actionCases": [
            {
              "id": "searching",
              "enabledActions": [
                "open_thread",
                "update_search"
              ]
            }
          ]
        },
        "search_empty": {
          "dimensions": {
            "content": "empty",
            "search": "no_results"
          },
          "actionCases": [
            {
              "id": "search_recovery",
              "enabledActions": [
                "update_search"
              ]
            }
          ]
        },
        "no_matches_empty": {
          "dimensions": {
            "content": "empty"
          }
        },
        "duplicate_collapsed": {
          "dimensions": {
            "content": "duplicate_collapsed"
          },
          "actionCases": [
            {
              "id": "collapsed_threads",
              "enabledActions": [
                "open_thread",
                "update_search"
              ]
            }
          ]
        },
        "unread_state": {
          "dimensions": {
            "read_state": "unread"
          },
          "actionCases": [
            {
              "id": "unread_threads",
              "enabledActions": [
                "open_thread",
                "update_search"
              ]
            }
          ]
        },
        "match_celebration": {
          "dimensions": {
            "overlay": "match_celebration"
          }
        },
        "offline": {
          "dimensions": {
            "load": "offline"
          }
        },
        "text_scale_2": {
          "dimensions": {
            "accessibility": "text_scale_2"
          },
          "actionCases": [
            {
              "id": "threads",
              "enabledActions": [
                "open_thread",
                "update_search"
              ]
            }
          ]
        },
        "reduced_motion": {
          "dimensions": {
            "accessibility": "reduced_motion"
          },
          "actionCases": [
            {
              "id": "threads",
              "enabledActions": [
                "open_thread",
                "update_search"
              ]
            }
          ]
        },
        "light_dark": {
          "dimensions": {
            "theme": "light_dark"
          },
          "actionCases": [
            {
              "id": "threads",
              "enabledActions": [
                "open_thread",
                "update_search"
              ]
            }
          ]
        }
      },
      "requiredEvidence": {
        "captures": true,
        "previews": true,
        "tests": true
      },
      "evidenceExceptions": [
        {
          "stateIds": [
            "uid_or_matches_loading",
            "matches_error",
            "match_celebration",
            "offline",
            "text_scale_2",
            "reduced_motion",
            "light_dark"
          ],
          "evidence": [
            "tests"
          ],
          "debtId": "FEATURE-CONTRACT-MIGRATION-001",
          "reason": "The route registry has capture and Widgetbook evidence for these variants but does not yet attach focused behavior tests to each state."
        }
      ]
    }
  ]
}
