{
  "$schema": "./feature_contract.schema.json",
  "version": 2,
  "updated": "2026-07-23",
  "id": "feature.admin_safety_triage",
  "name": "Admin Safety Triage",
  "owner": "admin_console",
  "status": "pilot",
  "description": "Orchestrates capped safety queue inspection, encoded detail routing, assignment, audited review or dismissal, and explicitly scoped queue-health analytics.",
  "surfaces": [
    {
      "id": "admin_web",
      "runtime": "react_admin",
      "authority": {"registry": "admin_routes", "id": "route_safety_triage"},
      "actionScope": {
        "included": "Filtering the bounded queue, opening one exact target path, returning to the queue, refreshing evidence, assigning an owner, recording review or dismissal, and freezing the complete Admin workspace during either write.",
        "excluded": [
          "Free-text search and assignment/decision note edits remain local query or form data.",
          "Priority and age analytics describe only capped returned preview rows; aggregate open counts remain separately labelled."
        ]
      },
      "bindings": {
        "previewSources": ["admin/src/stories/AdminRoutes.stories.tsx"],
        "actionOwners": [
          {"id": "controller", "language": "typescript", "file": "admin/src/features/safety/controllers/useSafetyTriageController.ts", "symbol": "useSafetyTriageController"},
          {"id": "screen", "language": "typescript", "file": "admin/src/features/safety/ui/SafetyTriageScreen.tsx", "symbol": "SafetyTriageWorkspace"}
        ],
        "componentContracts": ["route_safety_triage"],
        "dataContracts": [],
        "runtimeContracts": [
          {"kind": "admin_callable", "registry": "admin/src/generated/validators/adminCallableValidators.ts", "callable": "adminGetOverview", "requestValidation": "structural_object", "responseValidation": "structural_object"},
          {"kind": "admin_callable", "registry": "admin/src/generated/validators/adminCallableValidators.ts", "callable": "adminGetSafetyTriageDetails", "requestValidation": "structural_object", "responseValidation": "structural_object"},
          {"kind": "admin_callable", "registry": "admin/src/generated/validators/adminCallableValidators.ts", "callable": "adminAssignSafetyTriageItem", "requestValidation": "structural_object", "responseValidation": "structural_object"},
          {"kind": "admin_callable", "registry": "admin/src/generated/validators/adminCallableValidators.ts", "callable": "adminDecideSafetyTriageItem", "requestValidation": "structural_object", "responseValidation": "structural_object"}
        ],
        "testEvidence": {
          "directory": ["admin/src/features/safety/controllers/useSafetyTriageController.test.tsx"],
          "filters": ["admin/src/features/safety/controllers/useSafetyTriageController.test.tsx"],
          "open-action": [
            "admin/src/features/safety/controllers/useSafetyTriageController.test.tsx",
            "admin/src/shared/pendingOperation.test.tsx"
          ],
          "queue-health": ["admin/src/features/safety/controllers/useSafetyTriageController.test.tsx"],
          "honest-preview-analytics": [
            "admin/src/features/safety/controllers/useSafetyTriageController.test.tsx",
            "admin/src/features/safety/controllers/safetyTriageAnalytics.test.ts"
          ]
        }
      },
      "dimensions": {
        "view": {"default": "directory", "values": ["directory", "detail", "unavailable"]},
        "assignment": {"default": "idle", "values": ["idle", "pending", "failed", "success"]},
        "decision": {"default": "idle", "values": ["idle", "pending", "failed", "success"]}
      },
      "actions": [
        {"id": "filter_safety_queue", "owner": "controller", "codeValue": "setQueueFilter", "cardinality": "domain_bounded", "scopeKeys": ["adminSessionId", "queueKind"], "outcomes": [{"kind": "surface_state", "stateIds": ["filters", "queue-health", "honest-preview-analytics"]}], "description": "Filters the returned preview among report, moderation, event, or all queue kinds."},
        {"id": "select_safety_item", "owner": "controller", "codeValue": "select", "cardinality": "unbounded", "scopeKeys": ["adminSessionId", "targetPath"], "outcomes": [{"kind": "surface_state", "stateIds": ["open-action"]}], "description": "Opens a separate encoded target-path detail route for one returned safety item."},
        {"id": "back_to_safety_queue", "owner": "screen", "codeValue": "onBackToList", "cardinality": "unbounded", "scopeKeys": ["adminSessionId", "targetPath"], "outcomes": [{"kind": "surface_state", "stateIds": ["directory"]}], "description": "Returns from safety detail to the queue route."},
        {"id": "refresh_safety_queue", "owner": "controller", "codeValue": "refresh", "cardinality": "singleton", "scopeKeys": ["adminSessionId", "queueSnapshotVersion"], "outcomes": [{"kind": "surface_state", "stateIds": ["directory", "queue-health"]}], "description": "Refetches the capped safety queue and aggregate counts."},
        {"id": "assign_safety_item", "owner": "controller", "codeValue": "assign", "cardinality": "singleton", "scopeKeys": ["reviewerUid", "targetPath", "assignmentVersion"], "outcomes": [{"kind": "surface_state", "stateIds": ["open-action"]}, {"kind": "side_effect", "id": "admin.safety_assignment_saved"}], "description": "Assigns or clears the current owner with an audited note."},
        {"id": "decide_safety_item", "owner": "controller", "codeValue": "decide", "cardinality": "singleton", "scopeKeys": ["reviewerUid", "targetPath", "decisionVersion"], "outcomes": [{"kind": "surface_state", "stateIds": ["directory", "open-action"]}, {"kind": "side_effect", "id": "admin.safety_decision_recorded"}], "description": "Records review or dismissal and removes the resolved item from the local queue."
        }
      ],
      "scenarios": [
        {"id": "directory", "stateId": "directory", "dimensions": {}, "actionCases": [{"id": "ready", "enabledActions": ["filter_safety_queue", "select_safety_item", "refresh_safety_queue"]}]},
        {"id": "filters", "stateId": "filters", "dimensions": {}, "actionCases": [{"id": "bounded_filters", "enabledActions": ["filter_safety_queue", "select_safety_item", "refresh_safety_queue"]}]},
        {
          "id": "open_action",
          "stateId": "open-action",
          "dimensions": {"view": "detail"},
          "actionCases": [
            {"id": "detail_ready", "enabledActions": ["back_to_safety_queue", "assign_safety_item", "decide_safety_item"]},
            {"id": "assignment_pending_frozen_workspace", "dimensions": {"assignment": "pending"}, "disabledActions": ["back_to_safety_queue", "assign_safety_item", "decide_safety_item"]},
            {"id": "decision_pending_frozen_workspace", "dimensions": {"decision": "pending"}, "disabledActions": ["back_to_safety_queue", "assign_safety_item", "decide_safety_item"]},
            {"id": "detail_unavailable", "dimensions": {"view": "unavailable"}, "enabledActions": ["back_to_safety_queue"]}
          ]
        },
        {"id": "queue_health", "stateId": "queue-health", "dimensions": {}, "actionCases": [{"id": "aggregate_health", "enabledActions": ["filter_safety_queue", "select_safety_item", "refresh_safety_queue"]}]},
        {"id": "honest_preview_analytics", "stateId": "honest-preview-analytics", "dimensions": {}, "actionCases": [{"id": "capped_preview", "enabledActions": ["filter_safety_queue", "select_safety_item"]}]}
      ],
      "requiredEvidence": {"captures": false, "previews": true, "tests": true}
    }
  ]
}
