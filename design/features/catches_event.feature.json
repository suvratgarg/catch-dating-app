{
  "$schema": "./feature_contract.schema.json",
  "version": 2,
  "updated": "2026-07-23",
  "id": "feature.catches_event",
  "name": "Catches Event Deck",
  "owner": "swipes",
  "status": "pilot",
  "description": "Orchestrates the event-scoped post-attendance profile queue, pass and reaction mutations, access boundaries, and deck navigation.",
  "surfaces": [
    {
      "id": "consumer_flutter",
      "runtime": "flutter",
      "authority": {
        "registry": "flutter_screens",
        "id": "screen.catches.event"
      },
      "actionScope": {
        "included": "Pass and reaction decisions plus deck-owned navigation to filters and the Catches hub.",
        "excluded": [
          "Profile content rendering, reaction-target enumeration, queue loading, eligibility policy, and empty-state copy retain their existing domain and presentation owners."
        ]
      },
      "bindings": {
        "previewSources": [
          "widgetbook/lib/catches/catches_use_cases.dart"
        ],
        "actionOwners": [
          {
            "id": "queue",
            "language": "dart",
            "file": "lib/swipes/presentation/swipe_queue_controller.dart",
            "symbol": "SwipeQueueNotifier"
          },
          {
            "id": "deck_route",
            "language": "dart",
            "file": "lib/swipes/presentation/swipe_screen.dart",
            "symbol": "SwipeScreen"
          }
        ],
        "componentContracts": [
          "catch.button",
          "catch.field",
          "catch.icon_button",
          "catch.surface"
        ],
        "dataContracts": [
          "contracts/client_writes/create_profile_decision.schema.json",
          "contracts/firestore/event_participations.schema.json",
          "contracts/firestore/events.schema.json",
          "contracts/firestore/public_profiles.schema.json",
          "contracts/firestore/swipes.schema.json"
        ]
      },
      "dimensions": {
        "load": {
          "default": "ready",
          "values": [
            "ready",
            "loading",
            "error",
            "offline",
            "cached_offline"
          ]
        },
        "content": {
          "default": "profile",
          "values": [
            "profile",
            "empty",
            "missing_event"
          ]
        },
        "access": {
          "default": "eligible",
          "values": [
            "eligible",
            "signed_out",
            "event_in_progress",
            "did_not_attend",
            "window_closed"
          ]
        },
        "mutation": {
          "default": "idle",
          "values": [
            "idle",
            "pass_pending",
            "reaction_pending",
            "duplicate_pending",
            "failed"
          ]
        },
        "accessibility": {
          "default": "standard",
          "values": [
            "standard",
            "text_scale_2",
            "reduced_motion"
          ]
        },
        "theme": {
          "default": "standard",
          "values": [
            "standard",
            "light_dark"
          ]
        }
      },
      "actions": [
        {
          "id": "pass_profile",
          "owner": "queue",
          "codeValue": "swipe",
          "cardinality": "domain_bounded",
          "scopeKeys": [
            "viewerUid",
            "eventId",
            "targetUid",
            "queueVersion"
          ],
          "outcomes": [
            {
              "kind": "surface_state",
              "stateIds": [
                "active_profile",
                "empty_queue",
                "pass_mutation",
                "write_failure"
              ]
            },
            {
              "kind": "side_effect",
              "id": "swipes.record_pass"
            }
          ],
          "description": "Records one pass decision for the current event and target profile, then advances the queue."
        },
        {
          "id": "react_to_profile",
          "owner": "queue",
          "codeValue": "swipe",
          "cardinality": "domain_bounded",
          "scopeKeys": [
            "viewerUid",
            "eventId",
            "targetUid",
            "reactionTargetId",
            "queueVersion"
          ],
          "outcomes": [
            {
              "kind": "surface_state",
              "stateIds": [
                "active_profile",
                "empty_queue",
                "reaction_mutation",
                "write_failure"
              ]
            },
            {
              "kind": "side_effect",
              "id": "swipes.record_reaction"
            }
          ],
          "description": "Records one like reaction, optional profile target, and optional comment for the current event candidate."
        },
        {
          "id": "open_filters",
          "owner": "deck_route",
          "codeValue": "onFilters",
          "cardinality": "unbounded",
          "scopeKeys": [
            "viewerUid",
            "eventId",
            "routeInstanceId"
          ],
          "outcomes": [
            {
              "kind": "route",
              "authority": {
                "registry": "flutter_screens",
                "id": "screen.filters.preferences"
              }
            }
          ],
          "description": "Opens matching preferences from an eligible event deck."
        },
        {
          "id": "back_to_catches",
          "owner": "deck_route",
          "codeValue": "onBack",
          "cardinality": "singleton",
          "scopeKeys": [
            "routeInstanceId",
            "eventId"
          ],
          "outcomes": [
            {
              "kind": "route",
              "authority": {
                "registry": "flutter_screens",
                "id": "screen.catches.hub"
              }
            }
          ],
          "description": "Exits the current event deck to the preceding route or canonical Catches hub fallback."
        }
      ],
      "stateIds": [
        "queue_loading",
        "queue_error",
        "active_profile",
        "pass_mutation",
        "reaction_mutation",
        "duplicate_pending",
        "write_failure",
        "empty_queue",
        "event_missing",
        "sign_in_required",
        "event_in_progress",
        "did_not_attend",
        "window_closed",
        "offline",
        "cached_offline",
        "filters_action",
        "text_scale_2",
        "reduced_motion",
        "light_dark"
      ],
      "scenarioDefaults": {
        "dimensions": {},
        "actionCases": [
          {
            "id": "default"
          }
        ]
      },
      "scenarioOverrides": {
        "queue_loading": {
          "dimensions": {
            "load": "loading"
          }
        },
        "queue_error": {
          "dimensions": {
            "load": "error"
          }
        },
        "active_profile": {
          "actionCases": [
            {
              "id": "eligible_profile",
              "enabledActions": [
                "pass_profile",
                "react_to_profile",
                "open_filters",
                "back_to_catches"
              ]
            }
          ]
        },
        "pass_mutation": {
          "dimensions": {
            "mutation": "pass_pending"
          },
          "actionCases": [
            {
              "id": "pass_pending",
              "enabledActions": [
                "open_filters",
                "back_to_catches"
              ],
              "disabledActions": [
                "pass_profile",
                "react_to_profile"
              ]
            }
          ]
        },
        "reaction_mutation": {
          "dimensions": {
            "mutation": "reaction_pending"
          },
          "actionCases": [
            {
              "id": "reaction_pending",
              "enabledActions": [
                "open_filters",
                "back_to_catches"
              ],
              "disabledActions": [
                "pass_profile",
                "react_to_profile"
              ]
            }
          ]
        },
        "duplicate_pending": {
          "dimensions": {
            "mutation": "duplicate_pending"
          },
          "actionCases": [
            {
              "id": "write_guarded",
              "enabledActions": [
                "open_filters",
                "back_to_catches"
              ],
              "disabledActions": [
                "pass_profile",
                "react_to_profile"
              ]
            }
          ]
        },
        "write_failure": {
          "dimensions": {
            "mutation": "failed"
          },
          "actionCases": [
            {
              "id": "retryable_profile",
              "enabledActions": [
                "pass_profile",
                "react_to_profile",
                "open_filters",
                "back_to_catches"
              ]
            }
          ]
        },
        "empty_queue": {
          "dimensions": {
            "content": "empty"
          }
        },
        "event_missing": {
          "dimensions": {
            "content": "missing_event"
          }
        },
        "sign_in_required": {
          "dimensions": {
            "access": "signed_out"
          }
        },
        "event_in_progress": {
          "dimensions": {
            "access": "event_in_progress"
          }
        },
        "did_not_attend": {
          "dimensions": {
            "access": "did_not_attend"
          }
        },
        "window_closed": {
          "dimensions": {
            "access": "window_closed"
          }
        },
        "offline": {
          "dimensions": {
            "load": "offline"
          }
        },
        "cached_offline": {
          "dimensions": {
            "load": "cached_offline"
          },
          "actionCases": [
            {
              "id": "cached_profile",
              "enabledActions": [
                "pass_profile",
                "react_to_profile",
                "open_filters",
                "back_to_catches"
              ]
            }
          ]
        },
        "filters_action": {
          "actionCases": [
            {
              "id": "eligible_profile",
              "enabledActions": [
                "pass_profile",
                "react_to_profile",
                "open_filters",
                "back_to_catches"
              ]
            }
          ]
        },
        "text_scale_2": {
          "dimensions": {
            "accessibility": "text_scale_2"
          },
          "actionCases": [
            {
              "id": "eligible_profile",
              "enabledActions": [
                "pass_profile",
                "react_to_profile",
                "open_filters",
                "back_to_catches"
              ]
            }
          ]
        },
        "reduced_motion": {
          "dimensions": {
            "accessibility": "reduced_motion"
          },
          "actionCases": [
            {
              "id": "eligible_profile",
              "enabledActions": [
                "pass_profile",
                "react_to_profile",
                "open_filters",
                "back_to_catches"
              ]
            }
          ]
        },
        "light_dark": {
          "dimensions": {
            "theme": "light_dark"
          },
          "actionCases": [
            {
              "id": "eligible_profile",
              "enabledActions": [
                "pass_profile",
                "react_to_profile",
                "open_filters",
                "back_to_catches"
              ]
            }
          ]
        }
      },
      "requiredEvidence": {
        "captures": true,
        "previews": true,
        "tests": true
      },
      "evidenceExceptions": [
        {
          "stateIds": [
            "active_profile",
            "sign_in_required",
            "filters_action",
            "text_scale_2",
            "reduced_motion",
            "light_dark"
          ],
          "evidence": [
            "tests"
          ],
          "debtId": "FEATURE-CONTRACT-MIGRATION-001",
          "reason": "These states are captured and previewed, but the screen authority does not yet register focused automated proof for each variant."
        }
      ]
    }
  ]
}
