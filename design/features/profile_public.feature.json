{
  "$schema": "./feature_contract.schema.json",
  "version": 2,
  "updated": "2026-07-23",
  "id": "feature.profile_public",
  "name": "Public Profile",
  "owner": "public_profile",
  "status": "pilot",
  "description": "Orchestrates a viewer-aware public member profile, initial-profile fallback, unavailable and offline states, and report or block safety actions.",
  "surfaces": [
    {
      "id": "consumer_flutter",
      "runtime": "flutter",
      "authority": {
        "registry": "flutter_screens",
        "id": "screen.profile.public"
      },
      "actionScope": {
        "included": "Viewer-target report and block mutations from the public-profile safety menu.",
        "excluded": [
          "Top-bar back navigation, overflow-menu disclosure, profile rendering, compatibility explanation, and viewer-context projection remain screen or domain concerns."
        ]
      },
      "bindings": {
        "previewSources": [
          "widgetbook/lib/profiles/profile_use_cases.dart"
        ],
        "actionOwners": [
          {
            "id": "safety",
            "language": "dart",
            "file": "lib/public_profile/presentation/public_profile_controller.dart",
            "symbol": "PublicProfileController"
          }
        ],
        "componentContracts": [
          "catch.button",
          "catch.icon_button",
          "catch.surface",
          "catch.top_bar"
        ],
        "dataContracts": [
          "contracts/callables/block_user_payload.schema.json",
          "contracts/callables/report_user_payload.schema.json",
          "contracts/firestore/blocks.schema.json",
          "contracts/firestore/public_profiles.schema.json",
          "contracts/firestore/reports.schema.json",
          "contracts/firestore/users.schema.json"
        ]
      },
      "dimensions": {
        "load": {
          "default": "ready",
          "values": [
            "ready",
            "loading",
            "initial_fallback",
            "error",
            "offline",
            "unavailable"
          ]
        },
        "relationship": {
          "default": "other_member",
          "values": [
            "other_member",
            "own_profile",
            "no_viewer"
          ]
        },
        "safety_ui": {
          "default": "closed",
          "values": [
            "closed",
            "report_sheet",
            "block_confirmation"
          ]
        },
        "mutation": {
          "default": "idle",
          "values": [
            "idle",
            "pending",
            "settled"
          ]
        },
        "accessibility": {
          "default": "standard",
          "values": [
            "standard",
            "text_scale_2",
            "reduced_motion"
          ]
        },
        "theme": {
          "default": "standard",
          "values": [
            "standard",
            "light_dark"
          ]
        }
      },
      "actions": [
        {
          "id": "report_member",
          "owner": "safety",
          "codeValue": "reportUser",
          "cardinality": "unbounded",
          "scopeKeys": [
            "viewerUid",
            "targetUid",
            "reasonCode",
            "reportAttemptId"
          ],
          "outcomes": [
            {
              "kind": "surface_state",
              "stateIds": [
                "report_sheet",
                "report_mutation"
              ]
            },
            {
              "kind": "side_effect",
              "id": "safety.report_member_from_profile"
            }
          ],
          "description": "Submits one reason-coded safety report for the viewed member and exposes pending plus settled feedback."
        },
        {
          "id": "block_member",
          "owner": "safety",
          "codeValue": "blockUser",
          "cardinality": "singleton",
          "scopeKeys": [
            "viewerUid",
            "targetUid",
            "relationshipVersion"
          ],
          "outcomes": [
            {
              "kind": "surface_state",
              "stateIds": [
                "block_confirmation",
                "block_mutation"
              ]
            },
            {
              "kind": "side_effect",
              "id": "safety.block_member_from_profile"
            }
          ],
          "description": "Blocks the viewed member once for the active viewer-target relationship after confirmation."
        }
      ],
      "stateIds": [
        "loading_without_initial_profile",
        "loading_with_initial_profile",
        "load_error",
        "profile_unavailable",
        "public_profile",
        "viewer_context",
        "report_sheet",
        "block_confirmation",
        "report_mutation",
        "block_mutation",
        "offline",
        "text_scale_2",
        "reduced_motion",
        "light_dark"
      ],
      "scenarioDefaults": {
        "dimensions": {},
        "actionCases": [
          {
            "id": "default"
          }
        ]
      },
      "scenarioOverrides": {
        "loading_without_initial_profile": {
          "dimensions": {
            "load": "loading"
          }
        },
        "loading_with_initial_profile": {
          "dimensions": {
            "load": "initial_fallback"
          }
        },
        "load_error": {
          "dimensions": {
            "load": "error"
          }
        },
        "profile_unavailable": {
          "dimensions": {
            "load": "unavailable"
          }
        },
        "public_profile": {
          "actionCases": [
            {
              "id": "other_member",
              "enabledActions": [
                "report_member",
                "block_member"
              ]
            }
          ]
        },
        "viewer_context": {
          "actionCases": [
            {
              "id": "other_member",
              "dimensions": {
                "relationship": "other_member"
              },
              "enabledActions": [
                "report_member",
                "block_member"
              ]
            },
            {
              "id": "own_profile",
              "dimensions": {
                "relationship": "own_profile"
              }
            },
            {
              "id": "no_viewer",
              "dimensions": {
                "relationship": "no_viewer"
              }
            }
          ]
        },
        "report_sheet": {
          "dimensions": {
            "safety_ui": "report_sheet"
          },
          "actionCases": [
            {
              "id": "reason_selection",
              "enabledActions": [
                "report_member"
              ]
            }
          ]
        },
        "block_confirmation": {
          "dimensions": {
            "safety_ui": "block_confirmation"
          },
          "actionCases": [
            {
              "id": "confirmation",
              "enabledActions": [
                "block_member"
              ]
            }
          ]
        },
        "report_mutation": {
          "actionCases": [
            {
              "id": "pending",
              "dimensions": {
                "mutation": "pending"
              },
              "disabledActions": [
                "report_member"
              ]
            },
            {
              "id": "settled",
              "dimensions": {
                "mutation": "settled"
              },
              "enabledActions": [
                "report_member"
              ]
            }
          ]
        },
        "block_mutation": {
          "actionCases": [
            {
              "id": "pending",
              "dimensions": {
                "mutation": "pending"
              },
              "disabledActions": [
                "block_member"
              ]
            }
          ]
        },
        "offline": {
          "dimensions": {
            "load": "offline"
          }
        },
        "text_scale_2": {
          "dimensions": {
            "accessibility": "text_scale_2"
          },
          "actionCases": [
            {
              "id": "other_member",
              "enabledActions": [
                "report_member",
                "block_member"
              ]
            }
          ]
        },
        "reduced_motion": {
          "dimensions": {
            "accessibility": "reduced_motion"
          },
          "actionCases": [
            {
              "id": "other_member",
              "enabledActions": [
                "report_member",
                "block_member"
              ]
            }
          ]
        },
        "light_dark": {
          "dimensions": {
            "theme": "light_dark"
          },
          "actionCases": [
            {
              "id": "other_member",
              "enabledActions": [
                "report_member",
                "block_member"
              ]
            }
          ]
        }
      },
      "requiredEvidence": {
        "captures": true,
        "previews": true,
        "tests": true
      },
      "evidenceExceptions": [
        {
          "stateIds": [
            "loading_without_initial_profile",
            "loading_with_initial_profile",
            "block_confirmation",
            "offline",
            "text_scale_2",
            "reduced_motion",
            "light_dark"
          ],
          "evidence": [
            "tests"
          ],
          "debtId": "FEATURE-CONTRACT-MIGRATION-001",
          "reason": "These public-profile states have deterministic captures and previews but no focused state-level test registered by the screen authority."
        }
      ]
    }
  ]
}
