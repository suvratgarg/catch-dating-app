{
  "$schema": "./feature_contract.schema.json",
  "version": 2,
  "updated": "2026-07-23",
  "id": "feature.event_planning",
  "name": "Event Planning",
  "owner": "events",
  "status": "pilot",
  "description": "Orchestrates the merged joined-and-saved Calendar agenda plus the saved-only route projection, their date/list recovery states, and Event Detail handoffs.",
  "surfaces": [
    {
      "id": "calendar_flutter",
      "runtime": "flutter",
      "authority": {"registry": "flutter_screens", "id": "screen.calendar.home"},
      "actionScope": {
        "included": "Retrying identity, planned-event, and organizer-name loads; selecting a date; jumping to today; expanding or collapsing the calendar header; and opening one planned event.",
        "excluded": [
          "Merging, deduplicating, sorting, status labeling, summary derivation, and organizer-name lookup are read-model projection behavior rather than user actions.",
          "Automatic selected-day scrolling and scroll-driven header collapse are lifecycle consequences of date/header decisions, not separate actions.",
          "Booking, cancellation, save, and unsave actions retain Event Detail ownership."
        ]
      },
      "bindings": {
        "previewSources": ["widgetbook/lib/utility/p3_utility_use_cases.dart"],
        "actionOwners": [
          {
            "id": "calendar_screen",
            "language": "dart",
            "file": "lib/events/presentation/calendar/calendar_screen.dart",
            "symbol": "CalendarScreen"
          }
        ],
        "componentContracts": ["catch.badge", "catch.button", "catch.empty_state", "catch.error_state", "catch.surface", "catch.top_bar"],
        "dataContracts": [
          "contracts/firestore/clubs.schema.json",
          "contracts/firestore/event_participations.schema.json",
          "contracts/firestore/events.schema.json",
          "contracts/firestore/saved_events.schema.json"
        ]
      },
      "dimensions": {
        "data": {"default": "ready", "values": ["missing", "loading", "error", "ready"]},
        "agenda": {"default": "ready", "values": ["empty", "ready", "lookup_loading", "lookup_error"]},
        "header": {"default": "collapsed", "values": ["collapsed", "expanded"]},
        "failure_source": {"default": "none", "values": ["none", "identity", "event_streams", "club_names"]},
        "accessibility": {"default": "standard", "values": ["standard", "text_scale_2", "reduced_motion"]}
      },
      "actions": [
        {
          "id": "retry_identity",
          "owner": "calendar_screen",
          "codeValue": "uidProvider",
          "cardinality": "singleton",
          "scopeKeys": ["routeInstanceId", "identityLoadGeneration"],
          "outcomes": [{"kind": "surface_state", "stateIds": ["events_loading", "events_error", "uid_missing"]}],
          "description": "Invalidates the current identity lookup after an authentication-provider failure."
        },
        {
          "id": "retry_planned_events",
          "owner": "calendar_screen",
          "codeValue": "invalidate",
          "cardinality": "singleton",
          "scopeKeys": ["viewerUid", "eventLoadGeneration"],
          "outcomes": [{"kind": "surface_state", "stateIds": ["events_loading", "events_error", "planned_events", "empty_calendar"]}],
          "description": "Invalidates both joined-event and saved-event streams so the merged agenda reloads coherently."
        },
        {
          "id": "retry_club_names",
          "owner": "calendar_screen",
          "codeValue": "clubNameLookupProvider",
          "cardinality": "singleton",
          "scopeKeys": ["clubIdSet", "lookupGeneration"],
          "outcomes": [{"kind": "surface_state", "stateIds": ["club_names_loading_error", "planned_events"]}],
          "description": "Retries the secondary organizer-name lookup without discarding the already loaded event agenda."
        },
        {
          "id": "select_calendar_date",
          "owner": "calendar_screen",
          "codeValue": "_selectDate",
          "cardinality": "unbounded",
          "scopeKeys": ["routeInstanceId", "selectedDate"],
          "outcomes": [{"kind": "surface_state", "stateIds": ["planned_events", "empty_calendar", "expanded_month_header"]}],
          "description": "Selects one visible date and reveals the corresponding agenda day when present."
        },
        {
          "id": "jump_to_today",
          "owner": "calendar_screen",
          "codeValue": "_selectDate",
          "cardinality": "singleton",
          "scopeKeys": ["routeInstanceId", "referenceToday"],
          "outcomes": [{"kind": "surface_state", "stateIds": ["planned_events", "empty_calendar", "expanded_month_header"]}],
          "description": "Uses the persistent Today action to restore the reference date selection."
        },
        {
          "id": "set_calendar_header_expanded",
          "owner": "calendar_screen",
          "codeValue": "_setCalendarExpanded",
          "cardinality": "domain_bounded",
          "scopeKeys": ["routeInstanceId", "expanded"],
          "outcomes": [{"kind": "surface_state", "stateIds": ["planned_events", "empty_calendar", "expanded_month_header"]}],
          "description": "Expands or collapses the bounded week-strip versus month-grid header mode."
        },
        {
          "id": "open_planned_event",
          "owner": "calendar_screen",
          "codeValue": "_openEventDetail",
          "cardinality": "unbounded",
          "scopeKeys": ["routeInstanceId", "eventId"],
          "outcomes": [{"kind": "route", "authority": {"registry": "flutter_screens", "id": "screen.event.detail"}}],
          "description": "Opens Event Detail for one joined or saved agenda row."
        }
      ],
      "stateIds": [
        "uid_missing",
        "events_loading",
        "events_error",
        "planned_events",
        "empty_calendar",
        "club_names_loading_error",
        "expanded_month_header",
        "event_detail_navigation",
        "text_scale_2",
        "reduced_motion"
      ],
      "scenarioDefaults": {"dimensions": {}, "actionCases": [{"id": "default"}]},
      "scenarioOverrides": {
        "uid_missing": {
          "dimensions": {"data": "missing", "agenda": "empty"},
          "actionCases": [{"id": "signed_out_empty_agenda", "enabledActions": ["select_calendar_date", "jump_to_today", "set_calendar_header_expanded"]}]
        },
        "events_loading": {
          "dimensions": {"data": "loading"},
          "actionCases": [{"id": "provider_loading", "enabledActions": ["jump_to_today"]}]
        },
        "events_error": {
          "dimensions": {"data": "error"},
          "actionCases": [
            {"id": "identity_error", "dimensions": {"failure_source": "identity"}, "enabledActions": ["retry_identity", "jump_to_today"]},
            {"id": "event_stream_error", "dimensions": {"failure_source": "event_streams"}, "enabledActions": ["retry_planned_events", "jump_to_today"]}
          ]
        },
        "planned_events": {
          "actionCases": [{"id": "merged_agenda", "enabledActions": ["select_calendar_date", "jump_to_today", "set_calendar_header_expanded", "open_planned_event"]}]
        },
        "empty_calendar": {
          "dimensions": {"agenda": "empty"},
          "actionCases": [{"id": "no_plans", "enabledActions": ["select_calendar_date", "jump_to_today", "set_calendar_header_expanded"]}]
        },
        "club_names_loading_error": {
          "actionCases": [
            {"id": "lookup_loading", "dimensions": {"agenda": "lookup_loading"}, "enabledActions": ["select_calendar_date", "jump_to_today", "set_calendar_header_expanded"]},
            {"id": "lookup_error", "dimensions": {"agenda": "lookup_error", "failure_source": "club_names"}, "enabledActions": ["retry_club_names", "select_calendar_date", "jump_to_today", "set_calendar_header_expanded"]}
          ]
        },
        "expanded_month_header": {
          "dimensions": {"header": "expanded"},
          "actionCases": [{"id": "month_grid", "enabledActions": ["select_calendar_date", "jump_to_today", "set_calendar_header_expanded", "open_planned_event"]}]
        },
        "event_detail_navigation": {
          "actionCases": [{"id": "select_row", "enabledActions": ["select_calendar_date", "jump_to_today", "set_calendar_header_expanded", "open_planned_event"]}]
        },
        "text_scale_2": {
          "dimensions": {"accessibility": "text_scale_2"},
          "actionCases": [{"id": "scaled_agenda", "enabledActions": ["select_calendar_date", "jump_to_today", "set_calendar_header_expanded", "open_planned_event"]}]
        },
        "reduced_motion": {
          "dimensions": {"accessibility": "reduced_motion"},
          "actionCases": [{"id": "motion_reduced", "enabledActions": ["select_calendar_date", "jump_to_today", "set_calendar_header_expanded", "open_planned_event"]}]
        }
      },
      "requiredEvidence": {"captures": true, "previews": true, "tests": true},
      "evidenceExceptions": [
        {
          "stateIds": ["text_scale_2", "reduced_motion"],
          "evidence": ["tests"],
          "debtId": "FEATURE-CONTRACT-MIGRATION-001",
          "reason": "These Calendar states have deterministic captures and Widgetbook evidence but no focused state-level test recorded by the screen authority."
        },
        {
          "stateIds": ["event_detail_navigation"],
          "evidence": ["captures"],
          "debtId": "FEATURE-CONTRACT-MIGRATION-001",
          "reason": "Calendar event navigation is focused-test and Widgetbook proven, but the route authority does not register a dedicated post-selection capture."
        }
      ]
    },
    {
      "id": "saved_events_flutter",
      "runtime": "flutter",
      "authority": {"registry": "flutter_screens", "id": "screen.saved_events.list"},
      "actionScope": {
        "included": "Closing the standalone route, retrying identity, saved-event, and organizer-name loads, and opening one saved event.",
        "excluded": [
          "Saved-event ordering, past/saved status labeling, missing-document omission, and organizer-name projection are read-model behavior rather than user actions.",
          "The route intentionally exposes no save or unsave mutation; those decisions retain Event Detail ownership.",
          "System back gestures are the platform equivalent of the declared close action, not an additional feature action."
        ]
      },
      "bindings": {
        "previewSources": ["widgetbook/lib/events/event_detail_use_cases.dart"],
        "actionOwners": [
          {
            "id": "saved_events_screen",
            "language": "dart",
            "file": "lib/events/presentation/saved_events_screen.dart",
            "symbol": "SavedEventsScreen"
          }
        ],
        "componentContracts": ["catch.empty_state", "catch.error_state", "catch.surface", "catch.top_bar"],
        "dataContracts": [
          "contracts/firestore/clubs.schema.json",
          "contracts/firestore/events.schema.json",
          "contracts/firestore/saved_events.schema.json"
        ]
      },
      "dimensions": {
        "data": {"default": "ready", "values": ["missing", "loading", "error", "ready"]},
        "agenda": {"default": "ready", "values": ["empty", "ready", "lookup_loading", "lookup_error"]},
        "failure_source": {"default": "none", "values": ["none", "identity", "saved_events", "club_names"]},
        "accessibility": {"default": "standard", "values": ["standard", "text_scale_2"]},
        "theme": {"default": "standard", "values": ["standard", "light_dark"]}
      },
      "actions": [
        {
          "id": "close_saved_events",
          "owner": "saved_events_screen",
          "codeValue": "back",
          "cardinality": "singleton",
          "scopeKeys": ["routeInstanceId"],
          "outcomes": [{"kind": "side_effect", "id": "navigation.route_popped"}],
          "description": "Closes the standalone saved-events route through its canonical back control."
        },
        {
          "id": "retry_identity",
          "owner": "saved_events_screen",
          "codeValue": "uidProvider",
          "cardinality": "singleton",
          "scopeKeys": ["routeInstanceId", "identityLoadGeneration"],
          "outcomes": [{"kind": "surface_state", "stateIds": ["saved_events_loading", "saved_events_error", "uid_missing"]}],
          "description": "Invalidates the current identity lookup after an authentication-provider failure."
        },
        {
          "id": "retry_saved_events",
          "owner": "saved_events_screen",
          "codeValue": "watchSavedEventDetailsForUserProvider",
          "cardinality": "singleton",
          "scopeKeys": ["viewerUid", "savedEventLoadGeneration"],
          "outcomes": [{"kind": "surface_state", "stateIds": ["saved_events_loading", "saved_events_error", "empty_saved_events", "populated_saved_events"]}],
          "description": "Invalidates the saved-event detail stream for the current viewer."
        },
        {
          "id": "retry_club_names",
          "owner": "saved_events_screen",
          "codeValue": "clubNameLookupProvider",
          "cardinality": "singleton",
          "scopeKeys": ["clubIdSet", "lookupGeneration"],
          "outcomes": [{"kind": "surface_state", "stateIds": ["club_names_loading_error", "populated_saved_events"]}],
          "description": "Retries organizer-name enrichment without discarding loaded saved-event rows."
        },
        {
          "id": "open_planned_event",
          "owner": "saved_events_screen",
          "codeValue": "_openEventDetail",
          "cardinality": "unbounded",
          "scopeKeys": ["routeInstanceId", "eventId"],
          "outcomes": [{"kind": "route", "authority": {"registry": "flutter_screens", "id": "screen.event.detail"}}],
          "description": "Opens Event Detail for one saved-event row."
        }
      ],
      "stateIds": [
        "uid_missing",
        "saved_events_loading",
        "saved_events_error",
        "empty_saved_events",
        "populated_saved_events",
        "club_names_loading_error",
        "detail_navigation",
        "text_scale_2",
        "light_dark"
      ],
      "scenarioDefaults": {"dimensions": {}, "actionCases": [{"id": "default", "enabledActions": ["close_saved_events"]}]},
      "scenarioOverrides": {
        "uid_missing": {"dimensions": {"data": "missing", "agenda": "empty"}},
        "saved_events_loading": {"dimensions": {"data": "loading"}},
        "saved_events_error": {
          "dimensions": {"data": "error"},
          "actionCases": [
            {"id": "identity_error", "dimensions": {"failure_source": "identity"}, "enabledActions": ["close_saved_events", "retry_identity"]},
            {"id": "saved_stream_error", "dimensions": {"failure_source": "saved_events"}, "enabledActions": ["close_saved_events", "retry_saved_events"]}
          ]
        },
        "empty_saved_events": {"dimensions": {"agenda": "empty"}},
        "populated_saved_events": {
          "actionCases": [{"id": "saved_agenda", "enabledActions": ["close_saved_events", "open_planned_event"]}]
        },
        "club_names_loading_error": {
          "actionCases": [
            {"id": "lookup_loading", "dimensions": {"agenda": "lookup_loading"}, "enabledActions": ["close_saved_events"]},
            {"id": "lookup_error", "dimensions": {"agenda": "lookup_error", "failure_source": "club_names"}, "enabledActions": ["close_saved_events", "retry_club_names"]}
          ]
        },
        "detail_navigation": {
          "actionCases": [{"id": "select_row", "enabledActions": ["close_saved_events", "open_planned_event"]}]
        },
        "text_scale_2": {
          "dimensions": {"accessibility": "text_scale_2"},
          "actionCases": [{"id": "scaled_agenda", "enabledActions": ["close_saved_events", "open_planned_event"]}]
        },
        "light_dark": {
          "dimensions": {"theme": "light_dark"},
          "actionCases": [{"id": "paired_theme", "enabledActions": ["close_saved_events", "open_planned_event"]}]
        }
      },
      "requiredEvidence": {"captures": true, "previews": true, "tests": true},
      "evidenceExceptions": [
        {
          "stateIds": ["uid_missing", "saved_events_error", "club_names_loading_error", "text_scale_2", "light_dark"],
          "evidence": ["tests"],
          "debtId": "FEATURE-CONTRACT-MIGRATION-001",
          "reason": "These Saved Events states have deterministic captures and Widgetbook evidence but no focused state-level test recorded by the screen authority."
        },
        {
          "stateIds": ["detail_navigation"],
          "evidence": ["captures"],
          "debtId": "FEATURE-CONTRACT-MIGRATION-001",
          "reason": "Saved-event navigation is focused-test and Widgetbook proven, but the route authority does not register a dedicated post-selection capture."
        }
      ]
    }
  ]
}
