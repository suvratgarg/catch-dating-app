{
  "$schema": "./feature_contract.schema.json",
  "version": 2,
  "updated": "2026-07-23",
  "id": "feature.admin_role_management",
  "name": "Admin Role Management",
  "owner": "admin_console",
  "status": "pilot",
  "description": "Orchestrates exact-uid admin lookup, bounded assignment review, governed role diffs, high-risk confirmation, and audited role persistence.",
  "surfaces": [
    {
      "id": "admin_web",
      "runtime": "react_admin",
      "authority": {"registry": "admin_routes", "id": "route_admin_role_management"},
      "actionScope": {
        "included": "Refreshing or selecting an assignment, loading an exact uid, returning to the register, choosing roles, confirming high-risk changes, saving the governed diff, and freezing the complete Admin workspace while that save is pending.",
        "excluded": [
          "Register search/filter and uid/note text entry remain query or form data.",
          "The route intentionally provides no email, display-name, phone, or unbounded Firebase Auth search."
        ]
      },
      "bindings": {
        "previewSources": ["admin/src/stories/AdminRoutes.stories.tsx"],
        "actionOwners": [
          {"id": "controller", "language": "typescript", "file": "admin/src/features/admin-roles/controllers/useAdminRoleManagementController.ts", "symbol": "useAdminRoleManagementController"},
          {"id": "screen", "language": "typescript", "file": "admin/src/features/admin-roles/ui/AdminRoleManagementScreen.tsx", "symbol": "AdminRoleManagementWorkspace"}
        ],
        "componentContracts": ["route_admin_role_management"],
        "dataContracts": [],
        "runtimeContracts": [
          {"kind": "admin_callable", "registry": "admin/src/generated/validators/adminCallableValidators.ts", "callable": "adminGetAdminUserRoles", "requestValidation": "strict_schema", "responseValidation": "structural_object"},
          {"kind": "admin_callable", "registry": "admin/src/generated/validators/adminCallableValidators.ts", "callable": "adminListAdminRoleAssignments", "requestValidation": "strict_schema", "responseValidation": "structural_object"},
          {"kind": "admin_callable", "registry": "admin/src/generated/validators/adminCallableValidators.ts", "callable": "adminSetAdminUserRoles", "requestValidation": "strict_schema", "responseValidation": "strict_schema"}
        ],
        "testEvidence": {
          "role-assignment-detail": [
            "admin/src/features/admin-roles/controllers/useAdminRoleManagementController.test.tsx",
            "admin/src/shared/pendingOperation.test.tsx"
          ]
        }
      },
      "dimensions": {
        "view": {"default": "register", "values": ["register", "detail", "unavailable"]},
        "risk": {"default": "standard", "values": ["standard", "high_unconfirmed", "high_confirmed"]},
        "mutation": {"default": "idle", "values": ["idle", "pending", "failed", "success"]}
      },
      "actions": [
        {"id": "refresh_role_assignments", "owner": "controller", "codeValue": "refreshAssignments", "cardinality": "singleton", "scopeKeys": ["adminSessionId", "assignmentSnapshotVersion"], "outcomes": [{"kind": "surface_state", "stateIds": ["role-assignment-detail"]}], "description": "Refetches the bounded admin role assignment register."},
        {"id": "select_role_assignment", "owner": "controller", "codeValue": "selectAssignment", "cardinality": "unbounded", "scopeKeys": ["adminSessionId", "targetUid"], "outcomes": [{"kind": "surface_state", "stateIds": ["role-assignment-detail"]}], "description": "Opens one returned assignment by exact uid."},
        {"id": "load_exact_admin_uid", "owner": "controller", "codeValue": "load", "cardinality": "unbounded", "scopeKeys": ["adminSessionId", "targetUid"], "outcomes": [{"kind": "surface_state", "stateIds": ["role-assignment-detail"]}], "description": "Validates and loads one exact Firebase Auth uid."},
        {"id": "back_to_role_register", "owner": "screen", "codeValue": "onBackToRegister", "cardinality": "unbounded", "scopeKeys": ["adminSessionId", "targetUid"], "outcomes": [{"kind": "surface_state", "stateIds": ["role-assignment-detail"]}], "description": "Returns from role detail to the assignment register."},
        {"id": "toggle_admin_role", "owner": "controller", "codeValue": "toggleRole", "cardinality": "domain_bounded", "scopeKeys": ["targetUid", "role", "draftVersion"], "outcomes": [{"kind": "surface_state", "stateIds": ["role-assignment-detail"]}], "description": "Adds or removes one policy-enumerated admin role while protecting self-owner removal."},
        {"id": "confirm_high_risk_role_change", "owner": "controller", "codeValue": "setHighRiskConfirmed", "cardinality": "singleton", "scopeKeys": ["targetUid", "draftVersion"], "outcomes": [{"kind": "surface_state", "stateIds": ["role-assignment-detail"]}], "description": "Confirms the before/after access difference for a high-risk role change."},
        {"id": "save_admin_roles", "owner": "controller", "codeValue": "save", "cardinality": "singleton", "scopeKeys": ["reviewerUid", "targetUid", "draftVersion"], "outcomes": [{"kind": "surface_state", "stateIds": ["role-assignment-detail"]}, {"kind": "side_effect", "id": "admin.role_assignment_saved"}], "description": "Persists the validated role set and exposes a before/after save receipt."}
      ],
      "scenarios": [
        {
          "id": "role_assignment_detail",
          "stateId": "role-assignment-detail",
          "dimensions": {},
          "actionCases": [
            {"id": "register", "enabledActions": ["refresh_role_assignments", "select_role_assignment", "load_exact_admin_uid"]},
            {"id": "detail_standard", "dimensions": {"view": "detail"}, "enabledActions": ["back_to_role_register", "toggle_admin_role", "save_admin_roles"]},
            {"id": "detail_high_risk_unconfirmed", "dimensions": {"view": "detail", "risk": "high_unconfirmed"}, "enabledActions": ["back_to_role_register", "toggle_admin_role", "confirm_high_risk_role_change"], "disabledActions": ["save_admin_roles"]},
            {"id": "detail_high_risk_confirmed", "dimensions": {"view": "detail", "risk": "high_confirmed"}, "enabledActions": ["back_to_role_register", "toggle_admin_role", "confirm_high_risk_role_change", "save_admin_roles"]},
            {"id": "save_pending_frozen_workspace", "dimensions": {"view": "detail", "mutation": "pending"}, "disabledActions": ["back_to_role_register", "toggle_admin_role", "confirm_high_risk_role_change", "save_admin_roles"]},
            {"id": "target_unavailable", "dimensions": {"view": "unavailable"}, "enabledActions": ["back_to_role_register", "load_exact_admin_uid"]}
          ]
        }
      ],
      "requiredEvidence": {"captures": false, "previews": true, "tests": true}
    }
  ]
}
