    {
      "id": "marketing_web",
      "runtime": "react_marketing",
      "authority": {
        "registry": "marketing_routes",
        "id": "organizer_search"
      },
      "actionScope": {
        "included": "URL-owned organizer directory filtering, search submission analytics, and filter reset actions represented by useOrganizerDirectoryController.",
        "excluded": [
          "Organizer detail navigation, organizer saving, claim navigation, and listing-card analytics retain their route, detail-controller, and component owners."
        ]
      },
      "bindings": {
        "previewSources": [
          "website/src/stories/MarketingRoutes.stories.tsx",
          "website/src/stories/OrganizerSearchSections.stories.tsx"
        ],
        "actionOwners": [
          {
            "id": "directory_controller",
            "language": "typescript",
            "file": "website/src/features/organizers/useOrganizerDirectoryController.ts",
            "symbol": "useOrganizerDirectoryController"
          }
        ],
        "componentContracts": [
          "route_organizer_search",
          "organizer_search_hero",
          "organizer_results_section"
        ],
        "dataContracts": [
          "contracts/public/website_host_listing_projection.schema.json"
        ],
        "testEvidence": {
          "default": [
            "website/src/features/organizers/useOrganizerDirectoryController.test.tsx"
          ],
          "filtered": [
            "website/src/features/organizers/useOrganizerDirectoryController.test.tsx"
          ],
          "empty-results": [
            "website/src/features/organizers/useOrganizerDirectoryController.test.tsx"
          ]
        }
      },
      "dimensions": {
        "filters": {
          "default": "default",
          "values": [
            "default",
            "active"
          ]
        },
        "results": {
          "default": "populated",
          "values": [
            "populated",
            "empty"
          ]
        }
      },
      "actions": [
        {
          "id": "update_filters",
          "owner": "directory_controller",
          "codeValue": "updateFilters",
          "cardinality": "unbounded",
          "scopeKeys": [
            "routeInstanceId",
            "searchParamsVersion"
          ],
          "outcomes": [
            {
              "kind": "surface_state",
              "stateIds": [
                "default",
                "filtered",
                "empty-results"
              ]
            }
          ],
          "description": "Projects query and filter updates into canonical URL search parameters and recalculates visible organizer results."
        },
        {
          "id": "submit_search",
          "owner": "directory_controller",
          "codeValue": "handleSearch",
          "cardinality": "unbounded",
          "scopeKeys": [
            "routeInstanceId",
            "appearanceContext"
          ],
          "outcomes": [
            {
              "kind": "side_effect",
              "id": "analytics.organizer_search_submitted"
            }
          ],
          "description": "Records one search submission and bounded organizer appearance events for the current query context."
        },
        {
          "id": "clear_filters",
          "owner": "directory_controller",
          "codeValue": "clearFilters",
          "cardinality": "unbounded",
          "scopeKeys": [
            "routeInstanceId",
            "searchParamsVersion"
          ],
          "outcomes": [
            {
              "kind": "surface_state",
              "stateIds": [
                "default"
              ]
            },
            {
              "kind": "side_effect",
              "id": "analytics.organizer_search_filters_cleared"
            }
          ],
          "description": "Resets the current URL-owned filter tuple once and records the reset."
        }
      ],
      "scenarios": [
        {
          "id": "default",
          "stateId": "default",
          "dimensions": {},
          "actionCases": [
            {
              "id": "default",
              "enabledActions": [
