        "accessibility": {
          "default": "standard",
          "values": [
            "standard",
            "text_scale_2",
            "reduced_motion"
          ]
        }
      },
      "actions": [
        {
          "id": "clear_search",
          "owner": "empty_recovery",
          "codeValue": "clearSearch",
          "cardinality": "singleton",
          "scopeKeys": [
            "routeInstanceId",
            "queryStateVersion"
          ],
          "outcomes": [
            {
              "kind": "surface_state",
              "stateIds": [
                "discovery_feed",
                "no_search_results",
                "empty_city"
              ]
            }
          ],
          "description": "Clears the active search term once for the current Explore query state."
        },
        {
          "id": "clear_filters",
          "owner": "empty_recovery",
          "codeValue": "clearFilters",
          "cardinality": "singleton",
          "scopeKeys": [
            "routeInstanceId",
            "filterStateVersion"
          ],
          "outcomes": [
            {
              "kind": "surface_state",
              "stateIds": [
                "discovery_feed",
                "no_search_results",
                "empty_city"
              ]
            }
          ],
          "description": "Clears active Explore filters once for the current filter state."
        },
        {
          "id": "clear_search_and_filters",
          "owner": "empty_recovery",
          "codeValue": "clearSearchAndFilters",
          "cardinality": "singleton",
          "scopeKeys": [
            "routeInstanceId",
            "queryStateVersion",
            "filterStateVersion"
          ],
          "outcomes": [
            {
              "kind": "surface_state",
              "stateIds": [
                "discovery_feed",
                "empty_city"
              ]
            }
          ],
          "description": "Clears both search and filters as one recovery transition for the current Explore state."
        }
      ],
