{
  "$schema": "./feature_contract.schema.json",
  "version": 2,
  "updated": "2026-07-23",
  "id": "feature.explore",
  "name": "Explore",
  "owner": "explore",
  "status": "pilot",
  "description": "Orchestrates organizer discovery across Flutter and marketing-web projections without duplicating the owning screen, route, component, data, or preview registries.",
  "surfaces": [
    {
      "id": "consumer_flutter",
      "runtime": "flutter",
      "authority": {
        "registry": "flutter_screens",
        "id": "screen.explore.discovery"
      },
      "actionScope": {
        "included": "Empty-result recovery actions represented by ExploreDiscoveryEmptyAction.",
        "excluded": [
          "Search entry, city and filter editing, organizer follow/sign-in, map interaction, event or organizer navigation, and membership mutations retain their existing owners and verification paths."
        ]
      },
      "bindings": {
        "previewSources": [
          "widgetbook/lib/explore/explore_use_cases.dart",
          "widgetbook/lib/primitives/core_catalog_use_cases.dart"
        ],
        "actionOwners": [
