            "id": "empty_recovery",
            "language": "dart",
            "file": "lib/explore/presentation/explore_screen_state.dart",
            "symbol": "ExploreDiscoveryEmptyAction"
          }
        ],
        "componentContracts": [
          "catch.button",
          "catch.chip",
          "catch.count_pill",
          "catch.cover_story",
          "catch.event_card",
          "catch.field",
          "catch.icon_button",
          "catch.surface",
          "catch.top_bar"
