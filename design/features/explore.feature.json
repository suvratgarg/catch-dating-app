      "dimensions": {
        "surface": {
          "default": "discovery",
          "values": [
            "discovery",
            "map"
          ]
        },
        "load": {
          "default": "ready",
          "values": [
            "ready",
            "loading",
            "error",
            "offline"
          ]
        },
        "content": {
          "default": "populated",
          "values": [
            "populated",
            "empty"
          ]
        },
        "viewer": {
          "default": "member",
          "values": [
            "guest",
            "member"
          ]
        },
        "search": {
          "default": "inactive",
          "values": [
            "inactive",
            "active"
          ]
        },
        "filters": {
          "default": "inactive",
          "values": [
            "inactive",
            "active"
          ]
        },
        "selection": {
          "default": "none",
          "values": [
