{
  "$schema": "./feature_contract.schema.json",
  "version": 2,
  "updated": "2026-07-23",
  "id": "feature.admin_data_quality",
  "name": "Admin Data Quality",
  "owner": "admin_console",
  "status": "pilot",
  "description": "Orchestrates multi-source data-quality health, exact signal inspection, per-source recovery, and handoff to the owning administrative workflow.",
  "surfaces": [
    {
      "id": "admin_web",
      "runtime": "react_admin",
      "authority": {"registry": "admin_routes", "id": "route_data_quality"},
      "actionScope": {
        "included": "Selecting a signal, returning to its register, refreshing all sources, retrying one failed source, and opening the owning workflow.",
        "excluded": [
          "Signal query, severity, and owner filters remain local register state.",
          "The route reports partial and failed sources without synthesizing replacement signals.",
          "Only Host Analytics has strict request and response schemas; other source callables retain generated structural-object validation."
        ]
      },
      "bindings": {
        "previewSources": ["admin/src/stories/AdminRoutes.stories.tsx"],
        "actionOwners": [
          {"id": "controller", "language": "typescript", "file": "admin/src/features/data-quality/controllers/useDataQualityController.ts", "symbol": "useDataQualityController"},
          {"id": "screen", "language": "typescript", "file": "admin/src/features/data-quality/ui/DataQualityScreen.tsx", "symbol": "DataQualityWorkspace"}
        ],
        "componentContracts": ["route_data_quality"],
        "dataContracts": [
          "contracts/callables/host_analytics_query_payload.schema.json",
          "contracts/callable_responses/host_analytics_response.schema.json"
        ],
        "runtimeContracts": [
          {"kind": "admin_callable", "registry": "admin/src/generated/validators/adminCallableValidators.ts", "callable": "adminGetOverview", "requestValidation": "strict_schema", "responseValidation": "strict_schema"},
          {"kind": "admin_callable", "registry": "admin/src/generated/validators/adminCallableValidators.ts", "callable": "adminGetHostAnalytics", "requestValidation": "strict_schema", "responseValidation": "strict_schema"},
          {"kind": "admin_callable", "registry": "admin/src/generated/validators/adminCallableValidators.ts", "callable": "adminGetMarketingOpsDashboard", "requestValidation": "strict_schema", "responseValidation": "structural_object"},
          {"kind": "admin_callable", "registry": "admin/src/generated/validators/adminCallableValidators.ts", "callable": "adminGetEventIntakeDashboard", "requestValidation": "strict_schema", "responseValidation": "structural_object"},
          {"kind": "admin_callable", "registry": "admin/src/generated/validators/adminCallableValidators.ts", "callable": "adminGetEventSupplyReadiness", "requestValidation": "strict_schema", "responseValidation": "structural_object"}
        ],
        "testEvidence": {
          "source-register": ["admin/src/features/data-quality/controllers/useDataQualityController.test.tsx"]
        }
      },
      "dimensions": {
        "view": {"default": "register", "values": ["register", "detail", "unavailable"]},
        "source_health": {"default": "complete", "values": ["complete", "loading", "partial", "unavailable"]}
      },
      "actions": [
        {"id": "select_quality_signal", "owner": "controller", "codeValue": "select", "cardinality": "unbounded", "scopeKeys": ["adminSessionId", "signalId"], "outcomes": [{"kind": "surface_state", "stateIds": ["source-register"]}], "description": "Opens one exact quality signal from the available source register."},
        {"id": "back_to_quality_register", "owner": "screen", "codeValue": "onBackToList", "cardinality": "unbounded", "scopeKeys": ["adminSessionId", "signalId"], "outcomes": [{"kind": "surface_state", "stateIds": ["source-register"]}], "description": "Returns from signal detail to the full source register."},
        {"id": "refresh_quality_sources", "owner": "controller", "codeValue": "refresh", "cardinality": "singleton", "scopeKeys": ["adminSessionId", "sourceSnapshotVersion"], "outcomes": [{"kind": "surface_state", "stateIds": ["source-register"]}], "description": "Refetches all five data-quality sources and succeeds if any source returns usable evidence."},
        {"id": "retry_quality_source", "owner": "controller", "codeValue": "retrySource", "cardinality": "domain_bounded", "scopeKeys": ["adminSessionId", "sourceId", "attempt"], "outcomes": [{"kind": "surface_state", "stateIds": ["source-register"]}], "description": "Retries one failed source while retaining explicitly labelled cached evidence from other sources."},
        {"id": "open_quality_owner_workflow", "owner": "screen", "codeValue": "onOpenOwningWorkflow", "cardinality": "unbounded", "scopeKeys": ["adminSessionId", "signalId", "targetPath"], "outcomes": [{"kind": "side_effect", "id": "admin.quality_owner_workflow_opened"}], "description": "Hands the selected signal to its registered owning workflow path."
        }
      ],
      "scenarios": [
        {
          "id": "source_register",
          "stateId": "source-register",
          "dimensions": {},
          "actionCases": [
            {"id": "complete_register", "enabledActions": ["select_quality_signal", "refresh_quality_sources"]},
            {"id": "loading_register", "dimensions": {"source_health": "loading"}, "disabledActions": ["select_quality_signal", "refresh_quality_sources"]},
            {"id": "partial_register", "dimensions": {"source_health": "partial"}, "enabledActions": ["select_quality_signal", "refresh_quality_sources", "retry_quality_source"]},
            {"id": "all_sources_unavailable", "dimensions": {"view": "unavailable", "source_health": "unavailable"}, "enabledActions": ["refresh_quality_sources", "retry_quality_source"]},
            {"id": "signal_detail", "dimensions": {"view": "detail"}, "enabledActions": ["back_to_quality_register", "refresh_quality_sources", "open_quality_owner_workflow"]},
            {"id": "signal_unavailable", "dimensions": {"view": "unavailable"}, "enabledActions": ["back_to_quality_register", "refresh_quality_sources", "retry_quality_source"]}
          ]
        }
      ],
      "requiredEvidence": {"captures": false, "previews": true, "tests": true}
    }
  ]
}
