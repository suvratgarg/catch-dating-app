{
  "$schema": "./feature_contract.schema.json",
  "version": 2,
  "updated": "2026-07-23",
  "id": "feature.admin_marketing_ops",
  "name": "Admin Marketing Operations",
  "owner": "admin_console",
  "status": "pilot",
  "description": "Orchestrates marketing source review, draft creation and composition, rights/compliance confirmation, review receipts, diagnostics, and export-readiness decisions.",
  "surfaces": [
    {
      "id": "admin_web",
      "runtime": "react_admin",
      "authority": {"registry": "admin_routes", "id": "route_marketing_ops"},
      "actionScope": {
        "included": "Refreshing the bridge, switching studio views, opening or creating a draft, navigating composer stages, discarding working-copy edits, confirming media rights, and recording governed review decisions.",
        "excluded": [
          "Type filter, notes, recommendation edits, draft fields, and slide fields remain session-local query or editor data.",
          "Review receipts do not persist later unsaved working-copy edits; refresh or exit can discard them.",
          "Studio navigation and request-defining working copies remain live for independently keyed mutations; ADMIN-MUTATION-SNAPSHOT-001 tracks the shared pending policy."
        ]
      },
      "bindings": {
        "previewSources": ["admin/src/stories/AdminRoutes.stories.tsx"],
        "actionOwners": [
          {"id": "controller", "language": "typescript", "file": "admin/src/features/marketing/controllers/useMarketingOpsController.ts", "symbol": "useMarketingOpsController"}
        ],
        "componentContracts": ["route_marketing_ops"],
        "dataContracts": [],
        "runtimeContracts": [
          {"kind": "admin_callable", "registry": "admin/src/generated/validators/adminCallableValidators.ts", "callable": "adminGetMarketingOpsDashboard", "requestValidation": "structural_object", "responseValidation": "structural_object"},
          {"kind": "admin_callable", "registry": "admin/src/generated/validators/adminCallableValidators.ts", "callable": "adminCreateMarketingContentDraft", "requestValidation": "structural_object", "responseValidation": "structural_object"},
          {"kind": "admin_callable", "registry": "admin/src/generated/validators/adminCallableValidators.ts", "callable": "adminRecordMarketingReviewDecision", "requestValidation": "structural_object", "responseValidation": "structural_object"}
        ],
        "testEvidence": {
          "post-board": ["admin/src/features/marketing/controllers/useMarketingOpsController.test.tsx"]
        }
      },
      "dimensions": {
        "view": {"default": "posts", "values": ["posts", "new", "draft", "events", "media", "activity", "diagnostics", "unavailable"]},
        "composer_step": {"default": "source", "values": ["source", "copy", "compliance", "export"]},
        "working_copy": {"default": "clean", "values": ["clean", "dirty", "too_large"]},
        "mutation": {"default": "idle", "values": ["idle", "pending", "failed", "success"]}
      },
      "actions": [
        {"id": "refresh_marketing_bridge", "owner": "controller", "codeValue": "loadBridge", "cardinality": "singleton", "scopeKeys": ["adminSessionId", "bridgeVersion"], "outcomes": [{"kind": "surface_state", "stateIds": ["post-board"]}], "description": "Refetches the saved marketing operations bridge."},
        {"id": "select_marketing_view", "owner": "controller", "codeValue": "setActiveTab", "cardinality": "unbounded", "scopeKeys": ["adminSessionId", "tabId"], "outcomes": [{"kind": "surface_state", "stateIds": ["post-board"]}], "description": "Switches among Posts, New, Events, Media, Activity, Diagnostics, and Draft views."},
        {"id": "open_marketing_draft", "owner": "controller", "codeValue": "openDraft", "cardinality": "unbounded", "scopeKeys": ["adminSessionId", "draftId"], "outcomes": [{"kind": "surface_state", "stateIds": ["post-board"]}], "description": "Opens one saved content draft at the source stage."},
        {"id": "create_marketing_draft", "owner": "controller", "codeValue": "createDraft", "cardinality": "domain_bounded", "scopeKeys": ["reviewerUid", "draftType", "bridgeVersion"], "outcomes": [{"kind": "surface_state", "stateIds": ["post-board"]}, {"kind": "side_effect", "id": "admin.marketing_draft_created"}], "description": "Creates one event-highlights or feature-explainer draft from the saved bridge."},
        {"id": "select_composer_step", "owner": "controller", "codeValue": "setComposerStep", "cardinality": "unbounded", "scopeKeys": ["adminSessionId", "draftId", "stepId"], "outcomes": [{"kind": "surface_state", "stateIds": ["post-board"]}], "description": "Moves through source, copy, compliance, and export review stages."},
        {"id": "discard_marketing_edits", "owner": "controller", "codeValue": "discardSelectedDraftEdits", "cardinality": "singleton", "scopeKeys": ["adminSessionId", "draftId", "workingCopyVersion"], "outcomes": [{"kind": "surface_state", "stateIds": ["post-board"]}], "description": "Discards the selected draft's session-local working copy."},
        {"id": "confirm_marketing_rights", "owner": "controller", "codeValue": "setRightsConfirmed", "cardinality": "singleton", "scopeKeys": ["reviewerUid", "draftId", "workingCopyVersion"], "outcomes": [{"kind": "surface_state", "stateIds": ["post-board"]}], "description": "Confirms image and media rights before approval or export readiness."},
        {"id": "record_marketing_decision", "owner": "controller", "codeValue": "targetDecision", "cardinality": "singleton", "scopeKeys": ["reviewerUid", "targetType", "targetId", "reviewVersion"], "outcomes": [{"kind": "surface_state", "stateIds": ["post-board"]}, {"kind": "side_effect", "id": "admin.marketing_review_recorded"}], "description": "Records a bounded marketing review receipt with checklist and size validation."
        }
      ],
      "scenarios": [
        {
          "id": "post_board",
          "stateId": "post-board",
          "dimensions": {},
          "actionCases": [
            {"id": "posts", "enabledActions": ["refresh_marketing_bridge", "select_marketing_view", "open_marketing_draft"]},
            {"id": "new_draft", "dimensions": {"view": "new"}, "enabledActions": ["refresh_marketing_bridge", "select_marketing_view", "create_marketing_draft"]},
            {"id": "create_pending", "dimensions": {"view": "new", "mutation": "pending"}, "enabledActions": ["select_marketing_view"], "disabledActions": ["refresh_marketing_bridge", "create_marketing_draft"]},
            {"id": "draft_clean", "dimensions": {"view": "draft"}, "enabledActions": ["refresh_marketing_bridge", "select_marketing_view", "select_composer_step", "confirm_marketing_rights", "record_marketing_decision"]},
            {"id": "draft_dirty", "dimensions": {"view": "draft", "working_copy": "dirty"}, "enabledActions": ["refresh_marketing_bridge", "select_marketing_view", "select_composer_step", "discard_marketing_edits", "confirm_marketing_rights", "record_marketing_decision"]},
            {"id": "draft_too_large", "dimensions": {"view": "draft", "working_copy": "too_large"}, "enabledActions": ["select_marketing_view", "select_composer_step", "discard_marketing_edits"], "disabledActions": ["record_marketing_decision"]},
            {"id": "decision_pending_live_workspace", "dimensions": {"view": "draft", "mutation": "pending"}, "enabledActions": ["select_marketing_view", "select_composer_step", "discard_marketing_edits", "confirm_marketing_rights"], "disabledActions": ["record_marketing_decision"]},
            {"id": "library_or_diagnostics", "dimensions": {"view": "events"}, "enabledActions": ["refresh_marketing_bridge", "select_marketing_view", "record_marketing_decision"]},
            {"id": "bridge_unavailable", "dimensions": {"view": "unavailable"}, "enabledActions": ["refresh_marketing_bridge"]}
          ]
        }
      ],
      "requiredEvidence": {"captures": false, "previews": true, "tests": true}
    }
  ]
}
