{
  "$schema": "./feature_contract.schema.json",
  "version": 2,
  "updated": "2026-07-23",
  "id": "feature.payments",
  "name": "Payments",
  "owner": "payments",
  "status": "pilot",
  "description": "Orchestrates member payment history, payment and identity recovery, receipt inspection, status evidence, and failed-booking support guidance.",
  "surfaces": [
    {
      "id": "history_flutter",
      "runtime": "flutter",
      "authority": {"registry": "flutter_screens", "id": "screen.payments.history"},
      "actionScope": {
        "included": "Closing Payment History, retrying identity, payment, or event-title loads, opening a receipt sheet, and requesting the current failed-booking support guidance.",
        "excluded": [
          "Payment ordering, status presentation, currency/date formatting, and event-title joining are read-model behavior rather than user actions.",
          "Support guidance does not claim to open chat, email, phone, or a support case; those capabilities require a separately configured and implemented channel."
        ]
      },
      "bindings": {
        "previewSources": ["widgetbook/lib/utility/p3_utility_use_cases.dart"],
        "actionOwners": [
          {
            "id": "history_screen",
            "language": "dart",
            "file": "lib/payments/presentation/payment_history_screen.dart",
            "symbol": "PaymentHistoryScreen"
          },
          {
            "id": "receipt_tile",
            "language": "dart",
            "file": "lib/payments/presentation/payment_history_screen.dart",
            "symbol": "PaymentHistoryTile"
          },
          {
            "id": "receipt_sheet",
            "language": "dart",
            "file": "lib/payments/presentation/payment_history_screen.dart",
            "symbol": "PaymentReceiptSheet"
          }
        ],
        "componentContracts": [
          "catch.badge",
          "catch.sheet",
          "catch.button",
          "catch.empty_state",
          "catch.error_state",
          "catch.field",
          "catch.top_bar"
        ],
        "dataContracts": [
          "contracts/firestore/events.schema.json",
          "contracts/firestore/payments.schema.json"
        ]
      },
      "dimensions": {
        "identity": {"default": "ready", "values": ["loading", "error", "signed_out", "ready"]},
        "payments": {"default": "ready", "values": ["loading", "error", "empty", "ready"]},
        "status": {"default": "mixed", "values": ["mixed", "paid", "pending", "failed", "refunded", "refund_attention"]},
        "receipt": {"default": "closed", "values": ["closed", "open", "failed_signup"]},
        "event_title": {"default": "resolved", "values": ["resolved", "loading", "error", "missing"]},
        "connectivity": {"default": "online", "values": ["online", "offline"]},
        "accessibility": {"default": "standard", "values": ["standard", "text_scale_2", "reduced_motion"]},
        "theme": {"default": "standard", "values": ["standard", "light_dark"]}
      },
      "actions": [
        {
          "id": "close_payment_history",
          "owner": "history_screen",
          "codeValue": "back",
          "cardinality": "singleton",
          "scopeKeys": ["routeInstanceId"],
          "outcomes": [{"kind": "side_effect", "id": "navigation.route_popped"}],
          "description": "Closes Payment History through its canonical top-bar back control."
        },
        {
          "id": "retry_identity",
          "owner": "history_screen",
          "codeValue": "uidProvider",
          "cardinality": "singleton",
          "scopeKeys": ["routeInstanceId", "identityLoadGeneration"],
          "outcomes": [{"kind": "surface_state", "stateIds": ["uid_loading", "uid_error", "signed_out", "payment_history_empty", "populated_payments"]}],
          "description": "Invalidates the current identity provider after a Payment History access failure."
        },
        {
          "id": "retry_payments",
          "owner": "history_screen",
          "codeValue": "watchPaymentsForUserProvider",
          "cardinality": "singleton",
          "scopeKeys": ["viewerUid", "paymentLoadGeneration"],
          "outcomes": [{"kind": "surface_state", "stateIds": ["payments_loading", "payments_error", "payment_history_empty", "populated_payments"]}],
          "description": "Invalidates the current member's payment stream after a load failure."
        },
        {
          "id": "retry_event_titles",
          "owner": "history_screen",
          "codeValue": "watchEventsByIdsProvider",
          "cardinality": "singleton",
          "scopeKeys": ["viewerUid", "paymentEventIdSet", "eventTitleLoadGeneration"],
          "outcomes": [
            {"kind": "surface_state", "stateIds": ["event_title_loading", "event_title_error", "event_title_missing", "populated_payments"]}
          ],
          "description": "Retries the batched event-title enrichment without treating a network or backend failure as a missing event."
        },
        {
          "id": "open_receipt",
          "owner": "receipt_tile",
          "codeValue": "_showDetailSheet",
          "cardinality": "unbounded",
          "scopeKeys": ["routeInstanceId", "paymentId"],
          "outcomes": [{"kind": "surface_state", "stateIds": ["detail_sheet", "failed_signup_help"]}],
          "description": "Opens one provider-free receipt sheet for the selected payment row."
        },
        {
          "id": "show_support_guidance",
          "owner": "receipt_sheet",
          "codeValue": "onHelp",
          "cardinality": "unbounded",
          "scopeKeys": ["routeInstanceId", "paymentId"],
          "outcomes": [{"kind": "side_effect", "id": "payments.show_support_guidance"}],
          "description": "The honestly labeled How to get help action closes a failed-signup receipt and shows guidance to include its visible payment and order IDs when contacting Catch support."
        }
      ],
      "stateIds": [
        "uid_loading",
        "uid_error",
        "signed_out",
        "payments_loading",
        "payments_error",
        "payment_history_empty",
        "populated_payments",
        "status_variants",
        "detail_sheet",
        "failed_signup_help",
        "event_title_loading",
        "event_title_error",
        "event_title_missing",
        "offline",
        "text_scale_2",
        "reduced_motion",
        "light_dark"
      ],
      "scenarioDefaults": {
        "dimensions": {},
        "actionCases": [{"id": "history", "enabledActions": ["close_payment_history", "open_receipt"]}]
      },
      "scenarioOverrides": {
        "uid_loading": {
          "dimensions": {"identity": "loading", "payments": "loading"},
          "actionCases": [{"id": "loading", "enabledActions": ["close_payment_history"]}]
        },
        "uid_error": {
          "dimensions": {"identity": "error"},
          "actionCases": [{"id": "retry", "enabledActions": ["close_payment_history", "retry_identity"]}]
        },
        "signed_out": {
          "dimensions": {"identity": "signed_out", "payments": "empty"},
          "actionCases": [{"id": "signed_out", "enabledActions": ["close_payment_history"]}]
        },
        "payments_loading": {
          "dimensions": {"payments": "loading"},
          "actionCases": [{"id": "loading", "enabledActions": ["close_payment_history"]}]
        },
        "payments_error": {
          "dimensions": {"payments": "error"},
          "actionCases": [{"id": "retry", "enabledActions": ["close_payment_history", "retry_payments"]}]
        },
        "payment_history_empty": {
          "dimensions": {"payments": "empty"},
          "actionCases": [{"id": "empty", "enabledActions": ["close_payment_history"]}]
        },
        "status_variants": {
          "actionCases": [
            {"id": "paid", "dimensions": {"status": "paid"}, "enabledActions": ["close_payment_history", "open_receipt"]},
            {"id": "pending", "dimensions": {"status": "pending"}, "enabledActions": ["close_payment_history", "open_receipt"]},
            {"id": "failed", "dimensions": {"status": "failed"}, "enabledActions": ["close_payment_history", "open_receipt"]},
            {"id": "refunded", "dimensions": {"status": "refunded"}, "enabledActions": ["close_payment_history", "open_receipt"]},
            {"id": "refund_attention", "dimensions": {"status": "refund_attention"}, "enabledActions": ["close_payment_history", "open_receipt"]}
          ]
        },
        "detail_sheet": {
          "dimensions": {"receipt": "open"},
          "actionCases": [{"id": "receipt"}]
        },
        "failed_signup_help": {
          "dimensions": {"receipt": "failed_signup"},
          "actionCases": [{"id": "guidance", "enabledActions": ["show_support_guidance"]}]
        },
        "event_title_loading": {
          "dimensions": {"event_title": "loading"},
          "actionCases": [{"id": "loading", "enabledActions": ["close_payment_history"]}]
        },
        "event_title_error": {
          "dimensions": {"event_title": "error"},
          "actionCases": [{"id": "retry", "enabledActions": ["close_payment_history", "retry_event_titles"]}]
        },
        "event_title_missing": {
          "dimensions": {"event_title": "missing"},
          "actionCases": [{"id": "resolved_absence", "enabledActions": ["close_payment_history", "open_receipt"]}]
        },
        "offline": {
          "dimensions": {"connectivity": "offline"},
          "actionCases": [
            {"id": "identity_offline", "dimensions": {"identity": "error"}, "enabledActions": ["close_payment_history", "retry_identity"]},
            {"id": "payments_offline", "dimensions": {"payments": "error"}, "enabledActions": ["close_payment_history", "retry_payments"]},
            {"id": "event_title_offline_error", "dimensions": {"event_title": "error"}, "enabledActions": ["close_payment_history", "retry_event_titles"]}
          ]
        },
        "text_scale_2": {"dimensions": {"accessibility": "text_scale_2"}},
        "reduced_motion": {"dimensions": {"accessibility": "reduced_motion"}},
        "light_dark": {"dimensions": {"theme": "light_dark"}}
      },
      "requiredEvidence": {"captures": true, "previews": true, "tests": true},
      "evidenceExceptions": [
        {
          "stateIds": ["uid_loading", "uid_error", "signed_out", "payments_loading", "payments_error", "payment_history_empty", "offline", "text_scale_2", "reduced_motion", "light_dark"],
          "evidence": ["tests"],
          "debtId": "FEATURE-CONTRACT-MIGRATION-001",
          "reason": "These Payment History states have deterministic capture and Widgetbook evidence but no focused state-level test recorded by the authority."
        },
        {
          "stateIds": ["event_title_loading", "event_title_error"],
          "evidence": ["captures", "previews"],
          "debtId": "FEATURE-CONTRACT-MIGRATION-001",
          "reason": "Event-title loading and error now have focused screen tests; deterministic preview and capture entries are completed in the evidence-closure phase."
        },
        {
          "stateIds": ["status_variants"],
          "evidence": ["captures"],
          "debtId": "FEATURE-CONTRACT-MIGRATION-001",
          "reason": "Payment status variants are focused-test and Widgetbook proven, while their visible subset shares the populated history capture rather than a dedicated authority-state capture."
        }
      ]
    }
  ]
}
