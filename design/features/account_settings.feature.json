{
  "$schema": "./feature_contract.schema.json",
  "version": 2,
  "updated": "2026-07-23",
  "id": "feature.account_settings",
  "name": "Account Settings",
  "owner": "safety",
  "status": "pilot",
  "description": "Orchestrates account identity display, history navigation, notification and visibility preferences, blocked-account recovery and mutation, legal/support links, account deletion, and sign out.",
  "surfaces": [
    {
      "id": "consumer_flutter",
      "runtime": "flutter",
      "authority": {"registry": "flutter_screens", "id": "screen.settings.account"},
      "actionScope": {
        "included": "Profile and blocked-account recovery; review/payment history and host-app navigation; bounded preference changes; unblock, delete-account, and sign-out mutations; and configured privacy, support, and terms links.",
        "excluded": [
          "Phone, email, version, visibility-copy, blocked-count, profile formatting, and blocked-profile enrichment are display projections rather than user actions.",
          "Developer-only policy, Event Success, and manual-QA lab routes are configuration-gated diagnostics rather than Account Settings product actions.",
          "Independent mutation guards allow unrelated navigation, external links, and destructive actions to overlap under DP-SETTINGS-ACCOUNT-004; external link results remain unobserved under DP-SETTINGS-ACCOUNT-005."
        ]
      },
      "bindings": {
        "previewSources": [
          "widgetbook/lib/utility/p3_utility_use_cases.dart",
          "widgetbook/lib/primitives/primitive_contract_use_cases.dart"
        ],
        "actionOwners": [
          {
            "id": "settings_screen",
            "language": "dart",
            "file": "lib/safety/presentation/settings_screen.dart",
            "symbol": "SettingsScreen"
          },
          {
            "id": "settings_controller",
            "language": "dart",
            "file": "lib/safety/presentation/settings_controller.dart",
            "symbol": "SettingsController"
          },
          {
            "id": "auth_session",
            "language": "dart",
            "file": "lib/auth/presentation/auth_session_controller.dart",
            "symbol": "AuthSessionController"
          },
          {
            "id": "external_links",
            "language": "dart",
            "file": "lib/core/external_links.dart",
            "symbol": "ExternalLinkController"
          }
        ],
        "componentContracts": [
          "catch.button",
          "catch.confirm_dialog",
          "catch.empty_state",
          "catch.error_state",
          "catch.field",
          "catch.person_row",
          "catch.surface",
          "catch.toggle",
          "catch.top_bar"
        ],
        "dataContracts": [
          "contracts/firestore/blocks.schema.json",
          "contracts/firestore/deleted_users.schema.json",
          "contracts/firestore/public_profiles.schema.json",
          "contracts/firestore/users.schema.json",
          "contracts/patches/update_user_profile.schema.json"
        ]
      },
      "dimensions": {
        "profile": {"default": "ready", "values": ["loading", "error", "missing", "ready"]},
        "blocked_accounts": {"default": "empty", "values": ["loading", "error", "empty", "content"]},
        "mutation": {
          "default": "idle",
          "values": ["idle", "preference_pending", "preference_error", "unblock_pending", "unblock_error", "delete_confirm", "delete_pending", "delete_error", "sign_out_pending", "sign_out_error"]
        },
        "connectivity": {"default": "online", "values": ["online", "offline"]},
        "accessibility": {"default": "standard", "values": ["standard", "text_scale_2", "reduced_motion"]},
        "theme": {"default": "standard", "values": ["standard", "light_dark"]}
      },
      "actions": [
        {
          "id": "close_settings",
          "owner": "settings_screen",
          "codeValue": "back",
          "cardinality": "singleton",
          "scopeKeys": ["routeInstanceId"],
          "outcomes": [{"kind": "side_effect", "id": "navigation.route_popped"}],
          "description": "Closes Account Settings through its canonical top-bar back control."
        },
        {
          "id": "retry_profile",
          "owner": "settings_screen",
          "codeValue": "watchUserProfileProvider",
          "cardinality": "singleton",
          "scopeKeys": ["viewerUid", "profileLoadGeneration"],
          "outcomes": [{"kind": "surface_state", "stateIds": ["profile_loading", "profile_error", "profile_missing", "profile_backed_account"]}],
          "description": "Invalidates the current profile provider from the inline account-status recovery surface."
        },
        {
          "id": "open_review_history",
          "owner": "settings_screen",
          "codeValue": "reviewsHistoryScreen",
          "cardinality": "unbounded",
          "scopeKeys": ["routeInstanceId"],
          "outcomes": [{"kind": "route", "authority": {"registry": "flutter_screens", "id": "screen.reviews.history"}}],
          "description": "Opens the current member's Review History."
        },
        {
          "id": "open_payment_history",
          "owner": "settings_screen",
          "codeValue": "paymentHistoryScreen",
          "cardinality": "unbounded",
          "scopeKeys": ["routeInstanceId"],
          "outcomes": [{"kind": "route", "authority": {"registry": "flutter_screens", "id": "screen.payments.history"}}],
          "description": "Opens the current member's Payment History."
        },
        {
          "id": "open_host_app",
          "owner": "external_links",
          "codeValue": "openHostApp",
          "cardinality": "unbounded",
          "scopeKeys": ["routeInstanceId"],
          "outcomes": [{"kind": "side_effect", "id": "external_links.open_host_app"}],
          "description": "Requests the configured external Catch Host handoff."
        },
        {
          "id": "set_preference",
          "owner": "settings_controller",
          "codeValue": "savePreference",
          "cardinality": "domain_bounded",
          "scopeKeys": ["viewerUid", "preference", "value", "preferenceVersion"],
          "outcomes": [
            {"kind": "surface_state", "stateIds": ["notification_preferences", "preference_save_error", "privacy_safety_defaults"]},
            {"kind": "side_effect", "id": "user_profile.update_preference"}
          ],
          "description": "Optimistically changes one of the seven supported notification or map-visibility preferences and rolls back on failure."
        },
        {
          "id": "retry_blocked_accounts",
          "owner": "settings_screen",
          "codeValue": "watchBlockedUsersProvider",
          "cardinality": "singleton",
          "scopeKeys": ["viewerUid", "blockedAccountLoadGeneration"],
          "outcomes": [{"kind": "surface_state", "stateIds": ["blocked_accounts_loading_error", "blocked_accounts_empty", "blocked_accounts_list"]}],
          "description": "Invalidates the blocked-account provider after a list or profile-enrichment failure."
        },
        {
          "id": "unblock_account",
          "owner": "settings_controller",
          "codeValue": "unblockUser",
          "cardinality": "unbounded",
          "scopeKeys": ["viewerUid", "targetUserId"],
          "outcomes": [
            {"kind": "surface_state", "stateIds": ["blocked_accounts_list", "blocked_accounts_empty", "unblock_mutation"]},
            {"kind": "side_effect", "id": "safety.unblock_user"}
          ],
          "description": "Removes one selected account from the current member's block list."
        },
        {
          "id": "open_privacy_policy",
          "owner": "external_links",
          "codeValue": "openExternal",
          "cardinality": "unbounded",
          "scopeKeys": ["routeInstanceId", "privacyPolicyUri"],
          "outcomes": [{"kind": "side_effect", "id": "external_links.open_privacy_policy"}],
          "description": "Requests the configured privacy-policy URL when present."
        },
        {
          "id": "request_account_deletion",
          "owner": "settings_controller",
          "codeValue": "requestAccountDeletion",
          "cardinality": "singleton",
          "scopeKeys": ["viewerUid", "accountVersion"],
          "outcomes": [
            {"kind": "surface_state", "stateIds": ["delete_account_flow"]},
            {"kind": "side_effect", "id": "safety.request_account_deletion"}
          ],
          "description": "Opens the destructive confirmation and requests deletion after explicit confirmation."
        },
        {
          "id": "open_help_support",
          "owner": "external_links",
          "codeValue": "openExternal",
          "cardinality": "unbounded",
          "scopeKeys": ["routeInstanceId", "helpUri"],
          "outcomes": [{"kind": "side_effect", "id": "external_links.open_help"}],
          "description": "Requests the configured help and support URL when present."
        },
        {
          "id": "open_terms",
          "owner": "external_links",
          "codeValue": "openExternal",
          "cardinality": "unbounded",
          "scopeKeys": ["routeInstanceId", "termsUri"],
          "outcomes": [{"kind": "side_effect", "id": "external_links.open_terms"}],
          "description": "Requests the configured terms URL when present."
        },
        {
          "id": "sign_out",
          "owner": "auth_session",
          "codeValue": "signOut",
          "cardinality": "singleton",
          "scopeKeys": ["viewerUid", "authSessionVersion"],
          "outcomes": [
            {"kind": "surface_state", "stateIds": ["sign_out_action"]},
            {"kind": "side_effect", "id": "auth.sign_out"}
          ],
          "description": "Signs out the current account through the shared auth-session mutation."
        }
      ],
      "stateIds": [
        "profile_backed_account",
        "profile_loading",
        "profile_error",
        "profile_missing",
        "history_navigation_rows",
        "host_app_handoff",
        "notification_preferences",
        "preference_save_error",
        "privacy_safety_defaults",
        "blocked_accounts_loading_error",
        "blocked_accounts_empty",
        "blocked_accounts_list",
        "unblock_mutation",
        "delete_account_flow",
        "sign_out_action",
        "offline",
        "text_scale_2",
        "reduced_motion",
        "light_dark"
      ],
      "scenarioDefaults": {
        "dimensions": {},
        "actionCases": [
          {
            "id": "configured_account",
            "enabledActions": [
              "close_settings",
              "open_review_history",
              "open_payment_history",
              "open_host_app",
              "set_preference",
              "open_privacy_policy",
              "request_account_deletion",
              "open_help_support",
              "open_terms",
              "sign_out"
            ]
          }
        ]
      },
      "scenarioOverrides": {
        "profile_loading": {"dimensions": {"profile": "loading"}},
        "profile_error": {
          "dimensions": {"profile": "error"},
          "actionCases": [
            {
              "id": "retry_with_other_actions_live",
              "enabledActions": ["close_settings", "retry_profile", "open_review_history", "open_payment_history", "open_host_app", "set_preference", "open_privacy_policy", "request_account_deletion", "open_help_support", "open_terms", "sign_out"]
            }
          ]
        },
        "profile_missing": {"dimensions": {"profile": "missing"}},
        "history_navigation_rows": {
          "actionCases": [{"id": "history_and_host", "enabledActions": ["close_settings", "open_review_history", "open_payment_history", "open_host_app"]}]
        },
        "host_app_handoff": {
          "actionCases": [{"id": "external_handoff", "enabledActions": ["close_settings", "open_host_app"]}]
        },
        "notification_preferences": {
          "dimensions": {"mutation": "preference_pending"},
          "actionCases": [
            {
              "id": "preference_pending_other_actions_live",
              "enabledActions": ["close_settings", "open_review_history", "open_payment_history", "open_host_app", "open_privacy_policy", "request_account_deletion", "open_help_support", "open_terms", "sign_out"],
              "disabledActions": ["set_preference"]
            }
          ]
        },
        "preference_save_error": {"dimensions": {"mutation": "preference_error"}},
        "privacy_safety_defaults": {"dimensions": {"blocked_accounts": "empty"}},
        "blocked_accounts_loading_error": {
          "actionCases": [
            {"id": "loading", "dimensions": {"blocked_accounts": "loading"}, "enabledActions": ["close_settings", "open_review_history", "open_payment_history", "open_host_app", "set_preference", "open_privacy_policy", "request_account_deletion", "open_help_support", "open_terms", "sign_out"]},
            {"id": "error", "dimensions": {"blocked_accounts": "error"}, "enabledActions": ["close_settings", "open_review_history", "open_payment_history", "open_host_app", "set_preference", "retry_blocked_accounts", "open_privacy_policy", "request_account_deletion", "open_help_support", "open_terms", "sign_out"]}
          ]
        },
        "blocked_accounts_empty": {"dimensions": {"blocked_accounts": "empty"}},
        "blocked_accounts_list": {
          "dimensions": {"blocked_accounts": "content"},
          "actionCases": [
            {"id": "content", "enabledActions": ["close_settings", "open_review_history", "open_payment_history", "open_host_app", "set_preference", "unblock_account", "open_privacy_policy", "request_account_deletion", "open_help_support", "open_terms", "sign_out"]}
          ]
        },
        "unblock_mutation": {
          "dimensions": {"blocked_accounts": "content"},
          "actionCases": [
            {
              "id": "pending_other_actions_live",
              "dimensions": {"mutation": "unblock_pending"},
              "enabledActions": ["close_settings", "open_review_history", "open_payment_history", "open_host_app", "set_preference", "open_privacy_policy", "request_account_deletion", "open_help_support", "open_terms", "sign_out"],
              "disabledActions": ["unblock_account"]
            },
            {
              "id": "failed",
              "dimensions": {"mutation": "unblock_error"},
              "enabledActions": ["close_settings", "open_review_history", "open_payment_history", "open_host_app", "set_preference", "unblock_account", "open_privacy_policy", "request_account_deletion", "open_help_support", "open_terms", "sign_out"]
            }
          ]
        },
        "delete_account_flow": {
          "actionCases": [
            {"id": "confirm", "dimensions": {"mutation": "delete_confirm"}, "enabledActions": ["request_account_deletion"]},
            {
              "id": "pending_other_actions_live",
              "dimensions": {"mutation": "delete_pending"},
              "enabledActions": ["close_settings", "open_review_history", "open_payment_history", "open_host_app", "set_preference", "open_privacy_policy", "open_help_support", "open_terms", "sign_out"],
              "disabledActions": ["request_account_deletion"]
            },
            {"id": "failed", "dimensions": {"mutation": "delete_error"}, "enabledActions": ["close_settings", "open_review_history", "open_payment_history", "open_host_app", "set_preference", "open_privacy_policy", "request_account_deletion", "open_help_support", "open_terms", "sign_out"]}
          ]
        },
        "sign_out_action": {
          "actionCases": [
            {
              "id": "pending_other_actions_live",
              "dimensions": {"mutation": "sign_out_pending"},
              "enabledActions": ["close_settings", "open_review_history", "open_payment_history", "open_host_app", "set_preference", "open_privacy_policy", "request_account_deletion", "open_help_support", "open_terms"],
              "disabledActions": ["sign_out"]
            },
            {"id": "failed", "dimensions": {"mutation": "sign_out_error"}, "enabledActions": ["close_settings", "open_review_history", "open_payment_history", "open_host_app", "set_preference", "open_privacy_policy", "request_account_deletion", "open_help_support", "open_terms", "sign_out"]}
          ]
        },
        "offline": {
          "dimensions": {"connectivity": "offline"},
          "actionCases": [
            {"id": "profile_offline", "dimensions": {"profile": "error"}, "enabledActions": ["close_settings", "retry_profile", "open_review_history", "open_payment_history", "open_host_app", "set_preference", "open_privacy_policy", "request_account_deletion", "open_help_support", "open_terms", "sign_out"]},
            {"id": "blocked_accounts_offline", "dimensions": {"blocked_accounts": "error"}, "enabledActions": ["close_settings", "open_review_history", "open_payment_history", "open_host_app", "set_preference", "retry_blocked_accounts", "open_privacy_policy", "request_account_deletion", "open_help_support", "open_terms", "sign_out"]},
            {"id": "preference_offline", "dimensions": {"mutation": "preference_error"}, "enabledActions": ["close_settings", "open_review_history", "open_payment_history", "open_host_app", "set_preference", "open_privacy_policy", "request_account_deletion", "open_help_support", "open_terms", "sign_out"]},
            {"id": "unblock_offline", "dimensions": {"blocked_accounts": "content", "mutation": "unblock_error"}, "enabledActions": ["close_settings", "open_review_history", "open_payment_history", "open_host_app", "set_preference", "unblock_account", "open_privacy_policy", "request_account_deletion", "open_help_support", "open_terms", "sign_out"]},
            {"id": "delete_offline", "dimensions": {"mutation": "delete_error"}, "enabledActions": ["close_settings", "open_review_history", "open_payment_history", "open_host_app", "set_preference", "open_privacy_policy", "request_account_deletion", "open_help_support", "open_terms", "sign_out"]},
            {"id": "sign_out_offline", "dimensions": {"mutation": "sign_out_error"}, "enabledActions": ["close_settings", "open_review_history", "open_payment_history", "open_host_app", "set_preference", "open_privacy_policy", "request_account_deletion", "open_help_support", "open_terms", "sign_out"]}
          ]
        },
        "text_scale_2": {"dimensions": {"accessibility": "text_scale_2"}},
        "reduced_motion": {"dimensions": {"accessibility": "reduced_motion"}},
        "light_dark": {"dimensions": {"theme": "light_dark"}}
      },
      "requiredEvidence": {"captures": true, "previews": true, "tests": true},
      "evidenceExceptions": [
        {
          "stateIds": ["blocked_accounts_loading_error", "offline", "text_scale_2", "reduced_motion", "light_dark"],
          "evidence": ["tests"],
          "debtId": "FEATURE-CONTRACT-MIGRATION-001",
          "reason": "These Account Settings states have deterministic capture and Widgetbook evidence but no focused state-level test recorded by the authority."
        },
        {
          "stateIds": ["history_navigation_rows", "host_app_handoff"],
          "evidence": ["captures"],
          "debtId": "FEATURE-CONTRACT-MIGRATION-001",
          "reason": "History navigation and host handoff are focused-test and Widgetbook proven but do not have dedicated standalone state captures."
        }
      ]
    }
  ]
}
