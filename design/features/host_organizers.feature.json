{
  "$schema": "./feature_contract.schema.json",
  "version": 2,
  "updated": "2026-07-23",
  "id": "feature.host_organizers",
  "name": "Host Organizers",
  "owner": "hosts",
  "status": "pilot",
  "description": "Orchestrates the host organizer workspace across profile and media editing, defaults spokes, insights, public preview, payouts, team membership, host identity, hosted-organizer navigation, and account exit.",
  "surfaces": [
    {
      "id": "host_flutter",
      "runtime": "flutter",
      "authority": {
        "registry": "flutter_screens",
        "id": "screen.host.clubs"
      },
      "actionScope": {
        "included": "Host organizer route recovery, organizer and tab selection, organizer profile/media/default writes, settings-spoke navigation, analytics controls, payout onboarding/status, host-team membership, host identity, hosted-organizer navigation, and sign out.",
        "excluded": [
          "Organizer creation internals, public membership behavior, hosted-event creation and management, Stripe-hosted onboarding UI, analytics computation, and repository authorization retain their owning features, external services, or data-contract layers."
        ]
      },
      "bindings": {
        "previewSources": [
          "widgetbook/lib/hosts/host_operations_use_cases.dart",
          "widgetbook/lib/primitives/primitive_contract_use_cases.dart"
        ],
        "actionOwners": [
          {
            "id": "route_screen",
            "language": "dart",
            "file": "lib/hosts/presentation/host_operations/host_clubs_screen.dart",
            "symbol": "HostClubsScreen"
          },
          {
            "id": "workspace",
            "language": "dart",
            "file": "lib/hosts/presentation/host_operations/host_clubs_scaffold.dart",
            "symbol": "HostClubsScaffold"
          },
          {
            "id": "edit_tab",
            "language": "dart",
            "file": "lib/hosts/presentation/host_operations/host_club_edit_tab.dart",
            "symbol": "HostClubEditTab"
          },
          {
            "id": "edit_controller",
            "language": "dart",
            "file": "lib/hosts/presentation/club_management/host_club_edit_controller.dart",
            "symbol": "HostClubEditController"
          },
          {
            "id": "spoke_resolver",
            "language": "dart",
            "file": "lib/hosts/presentation/host_operations/host_club_spoke_screens.dart",
            "symbol": "HostClubSpokeResolver"
          },
          {
            "id": "defaults_saver",
            "language": "dart",
            "file": "lib/hosts/presentation/club_management/host_club_defaults_saver.dart",
            "symbol": "HostClubDefaultsSaver"
          },
          {
            "id": "insights",
            "language": "dart",
            "file": "lib/hosts/presentation/host_operations/host_analytics.dart",
            "symbol": "HostClubInsightsPane"
          },
          {
            "id": "payout_adapter",
            "language": "dart",
            "file": "lib/hosts/presentation/payments/host_payment_account_controller_card.dart",
            "symbol": "HostPaymentAccountControllerCard"
          },
          {
            "id": "payout_controller",
            "language": "dart",
            "file": "lib/hosts/presentation/payments/host_payment_account_controller.dart",
            "symbol": "HostPaymentAccountController"
          },
          {
            "id": "team_screen",
            "language": "dart",
            "file": "lib/hosts/presentation/host_operations/host_club_team_screen.dart",
            "symbol": "HostClubTeamScreen"
          },
          {
            "id": "team_section",
            "language": "dart",
            "file": "lib/hosts/presentation/widgets/host_team_management_section.dart",
            "symbol": "HostTeamManagementSection"
          },
          {
            "id": "team_controller",
            "language": "dart",
            "file": "lib/hosts/presentation/club_management/host_team_management_controller.dart",
            "symbol": "HostTeamManagementController"
          },
          {
            "id": "profile_controller",
            "language": "dart",
            "file": "lib/hosts/presentation/host_profile_controller.dart",
            "symbol": "HostProfileController"
          },
          {
            "id": "auth_controller",
            "language": "dart",
            "file": "lib/auth/presentation/auth_session_controller.dart",
            "symbol": "AuthSessionController"
          },
          {
            "id": "auth_required",
            "language": "dart",
            "file": "lib/hosts/presentation/host_operations/host_auth_required_screen.dart",
            "symbol": "HostAuthRequiredScreen"
          }
        ],
        "componentContracts": [
          "catch.badge",
          "catch.button",
          "catch.confirm_dialog",
          "catch.empty_state",
          "catch.error_banner",
          "catch.error_state",
          "catch.field",
          "catch.icon_button",
          "catch.menu",
          "catch.option_group",
          "catch.section",
          "catch.sheet",
          "catch.skeleton",
          "catch.surface",
          "catch.tab_rail",
          "catch.tabbed_screen",
          "catch.top_bar"
        ],
        "dataContracts": [
          "contracts/callables/add_organizer_manager_payload.schema.json",
          "contracts/callables/host_analytics_query_payload.schema.json",
          "contracts/callables/refresh_stripe_host_payment_account_payload.schema.json",
          "contracts/callables/remove_organizer_manager_payload.schema.json",
          "contracts/callables/transfer_organizer_ownership_payload.schema.json",
          "contracts/callables/update_organizer_payload.schema.json",
          "contracts/firestore/clubs.schema.json",
          "contracts/firestore/host_analytics_snapshots.schema.json",
          "contracts/firestore/host_payment_accounts.schema.json",
          "contracts/firestore/host_profiles.schema.json",
          "contracts/firestore/organizer_team_memberships.schema.json",
          "contracts/firestore/organizers.schema.json",
          "contracts/storage/organizer_logo_images.schema.json",
          "contracts/storage/organizer_photos.schema.json"
        ]
      },
      "dimensions": {
        "load": {
          "default": "ready",
          "values": ["ready", "loading", "error", "offline"]
        },
        "access": {
          "default": "owner",
          "values": ["owner", "cohost", "signed_out"]
        },
        "organizer_supply": {
          "default": "one",
          "values": ["one", "multiple", "none"]
        },
        "workspace": {
          "default": "edit",
          "values": ["edit", "insights", "preview", "event_defaults", "live_guide", "payments", "team"]
        },
        "mutation": {
          "default": "idle",
          "values": ["idle", "pending", "failed"]
        },
        "profile": {
          "default": "active",
          "values": ["active", "loading", "error", "missing", "fallback"]
        },
        "hosted_organizers": {
          "default": "content",
          "values": ["content", "loading", "error", "empty"]
        },
        "accessibility": {
          "default": "standard",
          "values": ["standard", "text_scale_2", "reduced_motion"]
        },
        "theme": {
          "default": "standard",
          "values": ["standard", "light_dark"]
        }
      },
      "actions": [
        {
          "id": "sign_in",
          "owner": "auth_required",
          "codeValue": "go",
          "cardinality": "singleton",
          "scopeKeys": ["routeInstanceId", "authSessionId"],
          "outcomes": [{"kind": "route", "authority": {"registry": "flutter_screens", "id": "screen.auth.phone_entry"}}],
          "description": "Leaves a signed-out organizer workspace for shared phone authentication."
        },
        {
          "id": "retry_organizer_workspace",
          "owner": "route_screen",
          "codeValue": "invalidate",
          "cardinality": "singleton",
          "scopeKeys": ["routeInstanceId", "retryTarget", "failureStateVersion"],
          "outcomes": [{"kind": "surface_state", "stateIds": ["host_clubs_loading", "organizer_overview", "no_host_clubs"]}],
          "description": "Invalidates only the failed auth or hosted-organizer provider at the main route boundary."
        },
        {
          "id": "create_organizer",
          "owner": "workspace",
          "codeValue": "hostCreateClubScreen",
          "cardinality": "singleton",
          "scopeKeys": ["viewerUid", "routeInstanceId", "emptyStateVersion"],
          "outcomes": [{"kind": "route", "authority": {"registry": "flutter_screens", "id": "screen.host.club.create"}}],
          "description": "Opens Host Create Organizer from the empty workspace."
        },
        {
          "id": "switch_organizer",
          "owner": "workspace",
          "codeValue": "_selectClubIndex",
          "cardinality": "unbounded",
          "scopeKeys": ["viewerUid", "routeInstanceId", "clubId"],
          "outcomes": [{"kind": "surface_state", "stateIds": ["multiple_clubs_switcher", "organizer_overview", "cohost_club_edit_limited"]}],
          "description": "Switches all organizer workspace tabs to another organizer the viewer hosts."
        },
        {
          "id": "select_workspace_tab",
          "owner": "workspace",
          "codeValue": "_handleTabControllerChanged",
          "cardinality": "unbounded",
          "scopeKeys": ["viewerUid", "clubId", "tabSelectionVersion"],
          "outcomes": [{"kind": "surface_state", "stateIds": ["organizer_overview", "insights_report", "preview_tab"]}],
          "description": "Selects Edit, Insights, or Preview while preserving each tab's scroll offset."
        },
        {
          "id": "update_organizer",
          "owner": "edit_controller",
          "codeValue": "updateClub",
          "cardinality": "singleton",
          "scopeKeys": ["viewerUid", "clubId", "fieldId", "organizerVersion"],
          "outcomes": [
            {"kind": "surface_state", "stateIds": ["update_club_pending", "organizer_overview", "update_club_error"]},
            {"kind": "side_effect", "id": "organizer.profile_updated"}
          ],
          "description": "Persists one typed organizer identity or contact patch for the current organizer version."
        },
        {
          "id": "update_organizer_media",
          "owner": "edit_controller",
          "codeValue": "updateClubMedia",
          "cardinality": "singleton",
          "scopeKeys": ["viewerUid", "clubId", "mediaRevision"],
          "outcomes": [
            {"kind": "surface_state", "stateIds": ["club_media_edit", "organizer_overview", "update_club_error"]},
            {"kind": "side_effect", "id": "organizer.media_updated"}
          ],
          "description": "Uploads and commits the current logo/photo order as one guarded organizer-media revision."
        },
        {
          "id": "open_organizer_setting",
          "owner": "edit_tab",
          "codeValue": "_openSpoke",
          "cardinality": "unbounded",
          "scopeKeys": ["viewerUid", "clubId", "settingsRoute"],
          "outcomes": [{"kind": "surface_state", "stateIds": ["club_settings_spokes_loaded", "club_settings_spokes_read_only", "payouts_not_setup", "host_team"]}],
          "description": "Opens Event Defaults, Live Guide, owner-only Payments, or Host Team within the organizer feature authority."
        },
        {
          "id": "retry_organizer_setting",
          "owner": "spoke_resolver",
          "codeValue": "invalidate",
          "cardinality": "singleton",
          "scopeKeys": ["viewerUid", "clubId", "retryTarget", "failureStateVersion"],
          "outcomes": [{"kind": "surface_state", "stateIds": ["club_settings_spokes_loading_error", "club_settings_spokes_loaded", "club_settings_spokes_read_only"]}],
          "description": "Retries the failed auth or hosted-organizer wave for a settings spoke."
        },
        {
          "id": "save_event_defaults",
          "owner": "defaults_saver",
          "codeValue": "apply",
          "cardinality": "singleton",
          "scopeKeys": ["viewerUid", "clubId", "defaultsRevision"],
          "outcomes": [
            {"kind": "surface_state", "stateIds": ["advanced_club_defaults_edit", "update_club_pending", "update_club_error"]},
            {"kind": "side_effect", "id": "organizer.event_defaults_updated"}
          ],
          "description": "Serializes optimistic activity and booking-policy default updates for the current organizer revision."
        },
        {
          "id": "retry_insights",
          "owner": "insights",
          "codeValue": "invalidate",
          "cardinality": "singleton",
          "scopeKeys": ["viewerUid", "clubId", "analyticsQuery", "failureStateVersion"],
          "outcomes": [{"kind": "surface_state", "stateIds": ["insights_loading", "insights_report", "insights_coach"]}],
          "description": "Invalidates the current organizer analytics query after a failed load."
        },
        {
          "id": "refresh_insights",
          "owner": "insights",
          "codeValue": "_refresh",
          "cardinality": "unbounded",
          "scopeKeys": ["viewerUid", "clubId", "analyticsQuery", "refreshAttemptId"],
          "outcomes": [{"kind": "surface_state", "stateIds": ["insights_loading", "insights_report", "insights_coach"]}],
          "description": "Pulls a fresh report for the selected range and resolved device timezone."
        },
        {
          "id": "select_insights_range",
          "owner": "insights",
          "codeValue": "selectRange",
          "cardinality": "unbounded",
          "scopeKeys": ["viewerUid", "clubId", "rangePreset"],
          "outcomes": [{"kind": "surface_state", "stateIds": ["insights_loading", "insights_report", "insights_coach"]}],
          "description": "Selects a supported analytics range and derives the matching query granularity."
        },
        {
          "id": "open_insights_event_report",
          "owner": "insights",
          "codeValue": "_openEventReport",
          "cardinality": "unbounded",
          "scopeKeys": ["viewerUid", "clubId", "eventId"],
          "outcomes": [{"kind": "route", "authority": {"registry": "flutter_screens", "id": "screen.host.event.manage"}}],
          "description": "Opens the selected event's Report section from a recent-event or Coach recommendation."
        },
        {
          "id": "open_all_host_events",
          "owner": "insights",
          "codeValue": "hostEventsScreen",
          "cardinality": "unbounded",
          "scopeKeys": ["viewerUid", "clubId", "tapAttemptId"],
          "outcomes": [{"kind": "route", "authority": {"registry": "flutter_screens", "id": "screen.host.home"}}],
          "description": "Leaves Insights for the host Events workspace."
        },
        {
          "id": "retry_payout_account",
          "owner": "payout_adapter",
          "codeValue": "invalidate",
          "cardinality": "singleton",
          "scopeKeys": ["viewerUid", "failureStateVersion"],
          "outcomes": [{"kind": "surface_state", "stateIds": ["payouts_not_setup", "payouts_ready_or_restricted"]}],
          "description": "Invalidates the current host payment account after a load failure."
        },
        {
          "id": "start_payout_onboarding",
          "owner": "payout_controller",
          "codeValue": "startOnboarding",
          "cardinality": "singleton",
          "scopeKeys": ["viewerUid", "accountVersion", "onboardingAttemptId"],
          "outcomes": [
            {"kind": "surface_state", "stateIds": ["payout_mutation", "payouts_ready_or_restricted"]},
            {"kind": "side_effect", "id": "payments.stripe_onboarding_opened"}
          ],
          "description": "Creates and opens one Stripe onboarding link for the selected country and currency."
        },
        {
          "id": "refresh_payout_status",
          "owner": "payout_controller",
          "codeValue": "refreshStatus",
          "cardinality": "singleton",
          "scopeKeys": ["viewerUid", "accountVersion", "refreshAttemptId"],
          "outcomes": [
            {"kind": "surface_state", "stateIds": ["payout_mutation", "payouts_ready_or_restricted"]},
            {"kind": "side_effect", "id": "payments.host_account_refreshed"}
          ],
          "description": "Refreshes Stripe status once and invalidates the viewer's host payment-account stream."
        },
        {
          "id": "retry_host_profile",
          "owner": "team_screen",
          "codeValue": "invalidate",
          "cardinality": "singleton",
          "scopeKeys": ["viewerUid", "profileVersion", "failureStateVersion"],
          "outcomes": [{"kind": "surface_state", "stateIds": ["profile_loading", "active_profile", "fallback_profile_from_club", "no_profile"]}],
          "description": "Invalidates the viewer's host profile after a team-workspace profile failure."
        },
        {
          "id": "create_host_profile",
          "owner": "profile_controller",
          "codeValue": "ensureProfile",
          "cardinality": "singleton",
          "scopeKeys": ["viewerUid", "profileVersion"],
          "outcomes": [
            {"kind": "surface_state", "stateIds": ["create_profile_mutation", "active_profile"]},
            {"kind": "side_effect", "id": "host.profile_created"}
          ],
          "description": "Creates the signed-in viewer's host identity once when none exists."
        },
        {
          "id": "save_host_profile",
          "owner": "profile_controller",
          "codeValue": "saveProfile",
          "cardinality": "singleton",
          "scopeKeys": ["viewerUid", "profileVersion", "fieldId"],
          "outcomes": [
            {"kind": "surface_state", "stateIds": ["save_profile_mutation", "active_profile"]},
            {"kind": "side_effect", "id": "host.profile_updated"}
          ],
          "description": "Saves validated display-name, role-title, and bio edits for the current host-profile version."
        },
        {
          "id": "add_host",
          "owner": "team_controller",
          "codeValue": "addHostByPhone",
          "cardinality": "singleton",
          "scopeKeys": ["viewerUid", "clubId", "phoneNumber", "teamVersion"],
          "outcomes": [
            {"kind": "surface_state", "stateIds": ["host_team_mutation", "host_team"]},
            {"kind": "side_effect", "id": "organizer.manager_added"}
          ],
          "description": "Adds one organizer manager by normalized phone number for the current team version."
        },
        {
          "id": "remove_host",
          "owner": "team_controller",
          "codeValue": "removeHost",
          "cardinality": "singleton",
          "scopeKeys": ["viewerUid", "clubId", "hostUid", "teamVersion"],
          "outcomes": [
            {"kind": "surface_state", "stateIds": ["host_team_mutation", "host_team"]},
            {"kind": "side_effect", "id": "organizer.manager_removed"}
          ],
          "description": "Removes a confirmed organizer manager once for the current team version."
        },
        {
          "id": "transfer_organizer_ownership",
          "owner": "team_controller",
          "codeValue": "transferOwnership",
          "cardinality": "singleton",
          "scopeKeys": ["viewerUid", "clubId", "hostUid", "teamVersion"],
          "outcomes": [
            {"kind": "surface_state", "stateIds": ["host_team_mutation", "host_team", "cohost_club_edit_limited"]},
            {"kind": "side_effect", "id": "organizer.ownership_transferred"}
          ],
          "description": "Transfers organizer ownership to a confirmed host once for the current team version."
        },
        {
          "id": "retry_hosted_organizers",
          "owner": "team_screen",
          "codeValue": "invalidate",
          "cardinality": "singleton",
          "scopeKeys": ["viewerUid", "failureStateVersion"],
          "outcomes": [{"kind": "surface_state", "stateIds": ["clubs_loading", "clubs_section"]}],
          "description": "Invalidates the hosted-organizer list after a team-workspace failure."
        },
        {
          "id": "open_hosted_organizer",
          "owner": "team_screen",
          "codeValue": "_openHostedClub",
          "cardinality": "unbounded",
          "scopeKeys": ["viewerUid", "clubId", "role"],
          "outcomes": [
            {"kind": "surface_state", "stateIds": ["organizer_overview", "cohost_club_edit_limited"]},
            {"kind": "route", "authority": {"registry": "flutter_screens", "id": "screen.host.club.detail"}}
          ],
          "description": "Opens an owned organizer in Edit or a co-hosted organizer in the host public preview according to typed role policy."
        },
        {
          "id": "select_team_tab",
          "owner": "team_screen",
          "codeValue": "HostTeamMode",
          "cardinality": "unbounded",
          "scopeKeys": ["viewerUid", "clubId", "tabSelectionVersion"],
          "outcomes": [{"kind": "surface_state", "stateIds": ["edit_preview_tabs", "active_profile"]}],
          "description": "Selects the host-identity Edit or Preview projection and gates mutations accordingly."
        },
        {
          "id": "leave_team_workspace",
          "owner": "team_screen",
          "codeValue": "_leaveTeam",
          "cardinality": "unbounded",
          "scopeKeys": ["viewerUid", "clubId", "navigationStackVersion"],
          "outcomes": [{"kind": "surface_state", "stateIds": ["organizer_overview"]}],
          "description": "Pops the team spoke when possible or returns to the organizer Edit workspace."
        },
        {
          "id": "sign_out",
          "owner": "auth_controller",
          "codeValue": "signOut",
          "cardinality": "singleton",
          "scopeKeys": ["viewerUid", "authSessionId"],
          "outcomes": [
            {"kind": "route", "authority": {"registry": "flutter_screens", "id": "screen.start.welcome"}},
            {"kind": "side_effect", "id": "auth.session_signed_out"}
          ],
          "description": "Signs out once from the Edit-only account action and returns to Start."
        }
      ],
      "stateIds": [
        "uid_missing", "host_clubs_loading", "host_clubs_error", "no_host_clubs", "organizer_overview", "club_media_edit", "advanced_club_defaults_edit", "cohost_club_edit_limited", "multiple_clubs_switcher", "inline_text_edit", "inline_choice_edit", "age_range_edit", "club_settings_spokes_loaded", "club_settings_spokes_loading_error", "club_settings_spokes_read_only", "update_club_pending", "update_club_error", "payouts_not_setup", "payouts_ready_or_restricted", "payout_mutation", "host_team", "host_team_mutation", "insights_loading", "insights_report", "insights_coach", "insights_error", "preview_tab", "offline", "text_scale_2", "reduced_motion", "light_dark", "host_team_uid_missing", "profile_loading", "profile_error", "no_profile", "fallback_profile_from_club", "active_profile", "edit_preview_tabs", "inline_profile_editor", "create_profile_mutation", "save_profile_mutation", "clubs_loading", "clubs_error", "clubs_section", "sign_out_action", "host_team_offline", "host_team_text_scale_2", "host_team_reduced_motion", "host_team_light_dark"
      ],
      "scenarioDefaults": {
        "dimensions": {},
        "actionCases": [{"id": "default"}]
      },
      "scenarioOverrides": {
        "uid_missing": {"dimensions": {"access": "signed_out"}, "actionCases": [{"id": "authentication", "enabledActions": ["sign_in"]}]},
        "host_clubs_loading": {"dimensions": {"load": "loading"}},
        "host_clubs_error": {"dimensions": {"load": "error"}, "actionCases": [{"id": "recovery", "enabledActions": ["retry_organizer_workspace"]}]},
        "no_host_clubs": {"dimensions": {"organizer_supply": "none"}, "actionCases": [{"id": "create", "enabledActions": ["create_organizer"]}]},
        "organizer_overview": {"actionCases": [{"id": "workspace", "enabledActions": ["select_workspace_tab", "update_organizer", "update_organizer_media", "open_organizer_setting"]}]},
        "club_media_edit": {"dimensions": {"mutation": "pending"}, "actionCases": [{"id": "media", "disabledActions": ["update_organizer_media"]}]},
        "advanced_club_defaults_edit": {"dimensions": {"workspace": "event_defaults"}, "actionCases": [{"id": "defaults", "enabledActions": ["save_event_defaults"]}]},
        "cohost_club_edit_limited": {"dimensions": {"access": "cohost"}, "actionCases": [{"id": "readonly", "enabledActions": ["switch_organizer", "open_organizer_setting"]}]},
        "multiple_clubs_switcher": {"dimensions": {"organizer_supply": "multiple"}, "actionCases": [{"id": "switch", "enabledActions": ["switch_organizer"]}]},
        "inline_text_edit": {"actionCases": [{"id": "save", "enabledActions": ["update_organizer"]}]},
        "inline_choice_edit": {"actionCases": [{"id": "save", "enabledActions": ["update_organizer"]}]},
        "age_range_edit": {"dimensions": {"workspace": "event_defaults"}, "actionCases": [{"id": "save", "enabledActions": ["save_event_defaults"]}]},
        "club_settings_spokes_loaded": {"actionCases": [{"id": "settings", "enabledActions": ["open_organizer_setting", "save_event_defaults"]}]},
        "club_settings_spokes_loading_error": {"dimensions": {"load": "error"}, "actionCases": [{"id": "recovery", "enabledActions": ["retry_organizer_setting"]}]},
        "club_settings_spokes_read_only": {"dimensions": {"access": "cohost"}, "actionCases": [{"id": "readonly"}]},
        "update_club_pending": {"dimensions": {"mutation": "pending"}, "actionCases": [{"id": "pending", "disabledActions": ["update_organizer", "save_event_defaults"]}]},
        "update_club_error": {"dimensions": {"mutation": "failed"}, "actionCases": [{"id": "retry", "enabledActions": ["update_organizer", "save_event_defaults"]}]},
