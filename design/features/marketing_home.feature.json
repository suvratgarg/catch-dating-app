{
  "$schema": "./feature_contract.schema.json",
  "version": 2,
  "updated": "2026-07-23",
  "id": "feature.marketing_home",
  "name": "Marketing Home",
  "owner": "marketing_website",
  "status": "pilot",
  "description": "Orchestrates the public product entry, organizer and event discovery handoff, store availability, host acquisition handoff, and member waitlist conversion surface.",
  "surfaces": [
    {
      "id": "marketing_web",
      "runtime": "react_marketing",
      "authority": {"registry": "marketing_routes", "id": "home"},
      "actionScope": {
        "included": "Organizer and public-event discovery handoffs, Host acquisition routing, configured or unavailable store CTAs, and member waitlist submission.",
        "excluded": [
          "In-page section anchors, consent choices, and footer legal links retain shared site-shell ownership.",
          "Waitlist field edits and first-focus analytics are form data and telemetry rather than separately cardinalized product actions.",
          "The /api/join-waitlist payload and response are duplicated TypeScript shapes without a shared schema; WEB-LEAD-API-CONTRACT-001 tracks that data-contract boundary.",
          "Member waitlist inputs remain live after the controller captures the submission payload; WEB-FORM-SUBMISSION-SNAPSHOT-001 tracks the shared pending-snapshot policy."
        ]
      },
      "bindings": {
        "previewSources": [
          "website/src/stories/HomeSections.stories.tsx",
          "website/src/stories/MarketingPrimitives.stories.tsx",
          "website/src/stories/MarketingRoutes.stories.tsx",
          "website/src/stories/WaitlistForm.stories.tsx"
        ],
        "actionOwners": [
          {
            "id": "home_sections",
            "language": "typescript",
            "file": "website/src/features/home/sections/HomePageSections.tsx",
            "symbol": "HomeDiscoverySection"
          },
          {
            "id": "app_download_controller",
            "language": "typescript",
            "file": "website/src/features/marketing/useAppDownloadCtas.ts",
            "symbol": "useAppDownloadCtas"
          },
          {
            "id": "waitlist_controller",
            "language": "typescript",
            "file": "website/src/features/waitlist/useWaitlistFormController.ts",
            "symbol": "useWaitlistFormController"
          }
        ],
        "componentContracts": [
          "route_home",
          "home_discovery_section",
          "home_waitlist_section",
          "shared_app_download_shell",
          "waitlist_form_adapter"
        ],
        "dataContracts": [
          "contracts/public/website_host_listing_projection.schema.json"
        ],
        "testEvidence": {
          "default": [
            "website/src/features/marketing/tracking.test.ts",
            "website/src/features/organizers/publicDiscovery.test.ts"
          ],
          "app-download-pending": [
            "website/src/features/marketing/useAppDownloadCtas.test.tsx"
          ],
          "waitlist-form": [
            "website/src/features/waitlist/useWaitlistFormController.test.tsx"
          ]
        }
      },
      "dimensions": {
        "presentation": {"default": "default", "values": ["default", "app_download", "waitlist"]},
        "store": {"default": "mixed", "values": ["mixed", "configured", "unavailable"]},
        "waitlist": {"default": "idle", "values": ["idle", "pending", "validation_error", "failed", "success"]}
      },
      "actions": [
        {
          "id": "browse_organizers",
          "owner": "home_sections",
          "codeValue": "trackCtaClick",
          "cardinality": "unbounded",
          "scopeKeys": ["routeInstanceId", "placement"],
          "outcomes": [{"kind": "route", "authority": {"registry": "marketing_routes", "id": "organizer_search"}}],
          "description": "Opens the public organizer directory from Home hero, discovery, empty, or featured-organizer affordances."
        },
        {
          "id": "open_host_acquisition",
          "owner": "home_sections",
          "codeValue": "trackCtaClick",
          "cardinality": "unbounded",
          "scopeKeys": ["routeInstanceId", "placement"],
          "outcomes": [{"kind": "route", "authority": {"registry": "marketing_routes", "id": "host"}}],
          "description": "Opens the canonical Host acquisition page and records the CTA placement."
        },
        {
          "id": "submit_public_search",
          "owner": "home_sections",
          "codeValue": "trackPublicSearchSubmit",
          "cardinality": "unbounded",
          "scopeKeys": ["routeInstanceId", "queryVersion"],
          "outcomes": [
            {"kind": "route", "authority": {"registry": "marketing_routes", "id": "organizer_search"}},
            {"kind": "side_effect", "id": "analytics.public_search_submitted"}
          ],
          "description": "Projects the Home search query into the canonical Organizer Search URL and records the handoff."
        },
        {
          "id": "select_public_search_suggestion",
          "owner": "home_sections",
          "codeValue": "trackPublicSearchSuggestionClick",
          "cardinality": "unbounded",
          "scopeKeys": ["routeInstanceId", "suggestionId"],
          "outcomes": [
            {"kind": "route", "authority": {"registry": "marketing_routes", "id": "organizer_search"}},
            {"kind": "route", "authority": {"registry": "marketing_routes", "id": "organizer_listing_canonical"}}
          ],
          "description": "Opens a format search or a source-backed organizer/event destination from the public search suggestions."
        },
        {
          "id": "open_public_event",
          "owner": "home_sections",
          "codeValue": "trackPublicEventCardClick",
          "cardinality": "unbounded",
          "scopeKeys": ["routeInstanceId", "eventId"],
          "outcomes": [{"kind": "route", "authority": {"registry": "marketing_routes", "id": "organizer_listing_canonical"}}],
          "description": "Opens the source-backed organizer listing event deep link from a Home event card."
        },
        {
          "id": "open_featured_organizer",
          "owner": "home_sections",
          "codeValue": "featuredOrganizerCardItemForListing",
          "cardinality": "unbounded",
          "scopeKeys": ["routeInstanceId", "organizerId"],
          "outcomes": [{"kind": "route", "authority": {"registry": "marketing_routes", "id": "organizer_listing_canonical"}}],
          "description": "Opens a canonical listing from the ranked public featured-organizer cards."
        },
        {
          "id": "open_store_listing",
          "owner": "app_download_controller",
          "codeValue": "handleStoreLinkClick",
          "cardinality": "unbounded",
          "scopeKeys": ["routeInstanceId", "placement", "platform"],
          "outcomes": [{"kind": "side_effect", "id": "external.store_listing_opened"}],
          "description": "Opens a configured app-store destination and records platform and placement analytics."
        },
        {
          "id": "acknowledge_store_unavailable",
          "owner": "app_download_controller",
          "codeValue": "handlePendingClick",
          "cardinality": "unbounded",
          "scopeKeys": ["routeInstanceId", "placement", "platform"],
          "outcomes": [{"kind": "side_effect", "id": "analytics.store_cta_pending"}],
          "description": "Records that a platform CTA has no configured store destination without pretending navigation occurred."
        },
        {
          "id": "submit_member_waitlist",
          "owner": "waitlist_controller",
          "codeValue": "handleSubmit",
          "cardinality": "singleton",
          "scopeKeys": ["formInstanceId", "submissionVersion"],
          "outcomes": [
            {"kind": "surface_state", "stateIds": ["waitlist-form"]},
            {"kind": "side_effect", "id": "marketing.member_waitlist_submitted"}
          ],
          "description": "Validates and submits one normalized member waitlist payload, then renders success or actionable failure status."
        }
      ],
      "scenarios": [
        {
          "id": "default",
          "stateId": "default",
          "dimensions": {},
          "actionCases": [
            {
              "id": "configured_store",
              "dimensions": {"store": "configured"},
              "enabledActions": ["browse_organizers", "open_host_acquisition", "submit_public_search", "select_public_search_suggestion", "open_public_event", "open_featured_organizer", "open_store_listing", "submit_member_waitlist"]
            },
            {
              "id": "unavailable_store",
              "dimensions": {"store": "unavailable"},
              "enabledActions": ["browse_organizers", "open_host_acquisition", "submit_public_search", "select_public_search_suggestion", "open_public_event", "open_featured_organizer", "acknowledge_store_unavailable", "submit_member_waitlist"]
            }
          ]
        },
        {
          "id": "app_download_pending",
          "stateId": "app-download-pending",
          "dimensions": {"presentation": "app_download", "store": "unavailable"},
          "actionCases": [
            {
              "id": "store_destination_missing",
              "enabledActions": ["browse_organizers", "open_host_acquisition", "submit_public_search", "select_public_search_suggestion", "open_public_event", "open_featured_organizer", "acknowledge_store_unavailable", "submit_member_waitlist"]
            }
          ]
        },
        {
          "id": "waitlist_form",
          "stateId": "waitlist-form",
          "dimensions": {"presentation": "waitlist"},
          "actionCases": [
            {
              "id": "idle",
              "enabledActions": ["browse_organizers", "open_host_acquisition", "submit_public_search", "select_public_search_suggestion", "open_public_event", "open_featured_organizer", "submit_member_waitlist"]
            },
            {
              "id": "pending_live_fields",
              "dimensions": {"waitlist": "pending"},
              "enabledActions": ["browse_organizers", "open_host_acquisition", "submit_public_search", "select_public_search_suggestion", "open_public_event", "open_featured_organizer"],
              "disabledActions": ["submit_member_waitlist"]
            },
            {
              "id": "validation_or_failure",
              "dimensions": {"waitlist": "failed"},
              "enabledActions": ["browse_organizers", "open_host_acquisition", "submit_public_search", "select_public_search_suggestion", "open_public_event", "open_featured_organizer", "submit_member_waitlist"]
            },
            {
              "id": "submitted",
              "dimensions": {"waitlist": "success"},
              "enabledActions": ["browse_organizers", "open_host_acquisition", "submit_member_waitlist"]
            }
          ]
        }
      ],
      "requiredEvidence": {"captures": false, "previews": true, "tests": true}
    }
  ]
}
