{
  "$schema": "./feature_contract.schema.json",
  "version": 2,
  "updated": "2026-07-23",
  "id": "feature.matching_preferences",
  "name": "Matching Preferences",
  "owner": "swipes",
  "status": "pilot",
  "description": "Orchestrates profile-backed age and interested-gender preference editing, reset/apply lifecycle, route dismissal, error recovery, and accessibility states.",
  "surfaces": [
    {
      "id": "consumer_flutter",
      "runtime": "flutter",
      "authority": {"registry": "flutter_screens", "id": "screen.filters.preferences"},
      "actionScope": {
        "included": "Closing the route, retrying profile load, adjusting the preferred age range, toggling interested genders, resetting the local draft, and applying the persisted preference patch.",
        "excluded": [
          "Slider drag events within one age-range decision and chip rendering are UI mechanics rather than additional actions.",
          "Profile stream hydration, preference normalization, mutation-listener error display, and success-triggered pop are lifecycle effects.",
          "Match generation and swipe decisions consume these preferences but retain their own feature ownership."
        ]
      },
      "bindings": {
        "previewSources": ["widgetbook/lib/consumer/p2_consumer_use_cases.dart"],
        "actionOwners": [
          {
            "id": "filters_screen",
            "language": "dart",
            "file": "lib/swipes/presentation/filters_screen.dart",
            "symbol": "FiltersScreen"
          },
          {
            "id": "filters_content",
            "language": "dart",
            "file": "lib/swipes/presentation/filters_screen.dart",
            "symbol": "FiltersContent"
          },
          {
            "id": "filters_controller",
            "language": "dart",
            "file": "lib/swipes/presentation/filters_controller.dart",
            "symbol": "FiltersController"
          }
        ],
        "componentContracts": ["catch.button", "catch.chip", "catch.error_state", "catch.range_slider", "catch.surface", "catch.top_bar"],
        "dataContracts": [
          "contracts/firestore/users.schema.json",
          "contracts/patches/update_user_profile.schema.json"
        ]
      },
      "dimensions": {
        "data": {"default": "ready", "values": ["loading", "error", "missing", "ready"]},
        "draft": {"default": "saved", "values": ["saved", "edited", "reset"]},
        "mutation": {"default": "idle", "values": ["idle", "pending", "error", "success"]},
        "accessibility": {"default": "standard", "values": ["standard", "text_scale_2", "reduced_motion"]}
      },
      "actions": [
        {
          "id": "close_preferences",
          "owner": "filters_screen",
          "codeValue": "pop",
          "cardinality": "singleton",
          "scopeKeys": ["routeInstanceId"],
          "outcomes": [{"kind": "side_effect", "id": "navigation.route_popped"}],
          "description": "Closes Matching Preferences without starting another save."
        },
        {
          "id": "retry_profile",
          "owner": "filters_screen",
          "codeValue": "watchUserProfileProvider",
          "cardinality": "singleton",
          "scopeKeys": ["viewerUid", "profileLoadGeneration"],
          "outcomes": [{"kind": "surface_state", "stateIds": ["profile_loading", "profile_error", "profile_missing", "default_preferences"]}],
          "description": "Invalidates the profile stream after a load failure."
        },
        {
          "id": "adjust_age_range",
          "owner": "filters_content",
          "codeValue": "onAgeRangeChanged",
          "cardinality": "unbounded",
          "scopeKeys": ["viewerUid", "minAge", "maxAge"],
          "outcomes": [{"kind": "surface_state", "stateIds": ["edited_preferences", "reset_preferences", "save_pending"]}],
          "description": "Changes the bounded preferred match-age range in the local draft."
        },
        {
          "id": "toggle_interested_gender",
          "owner": "filters_content",
          "codeValue": "onGenderToggled",
          "cardinality": "domain_bounded",
          "scopeKeys": ["viewerUid", "gender", "interestSet"],
          "outcomes": [{"kind": "surface_state", "stateIds": ["edited_preferences", "reset_preferences", "save_pending"]}],
          "description": "Adds or removes one value from the finite interested-gender domain."
        },
        {
          "id": "reset_preferences",
          "owner": "filters_screen",
          "codeValue": "_reset",
          "cardinality": "unbounded",
          "scopeKeys": ["routeInstanceId", "savedPreferenceVersion"],
          "outcomes": [{"kind": "surface_state", "stateIds": ["reset_preferences", "default_preferences"]}],
          "description": "Restores the local age and gender draft from the latest loaded profile without persisting."
        },
        {
          "id": "apply_preferences",
          "owner": "filters_controller",
          "codeValue": "saveFilters",
          "cardinality": "singleton",
          "scopeKeys": ["viewerUid", "preferenceRequestSignature"],
          "outcomes": [
            {"kind": "surface_state", "stateIds": ["save_pending", "save_error", "save_success_exit"]},
            {"kind": "side_effect", "id": "matching_preferences.saved_and_route_closed"}
          ],
          "description": "Persists the captured preference request and closes the route after mutation success."
        }
      ],
      "stateIds": [
        "profile_loading",
        "profile_error",
        "profile_missing",
        "default_preferences",
        "edited_preferences",
        "reset_preferences",
        "save_pending",
        "save_error",
        "save_success_exit",
        "text_scale_2",
        "reduced_motion"
      ],
      "scenarioDefaults": {"dimensions": {}, "actionCases": [{"id": "default"}]},
      "scenarioOverrides": {
        "profile_loading": {
          "dimensions": {"data": "loading"},
          "actionCases": [{"id": "loading", "enabledActions": ["close_preferences"]}]
        },
        "profile_error": {
          "dimensions": {"data": "error"},
          "actionCases": [{"id": "retry", "enabledActions": ["close_preferences", "retry_profile"]}]
        },
        "profile_missing": {
          "dimensions": {"data": "missing"},
          "actionCases": [{"id": "blank_body", "enabledActions": ["close_preferences"]}]
        },
        "default_preferences": {
          "actionCases": [{"id": "saved_values", "enabledActions": ["close_preferences", "adjust_age_range", "toggle_interested_gender", "reset_preferences", "apply_preferences"]}]
        },
        "edited_preferences": {
          "dimensions": {"draft": "edited"},
          "actionCases": [{"id": "dirty_values", "enabledActions": ["close_preferences", "adjust_age_range", "toggle_interested_gender", "reset_preferences", "apply_preferences"]}]
        },
        "reset_preferences": {
          "dimensions": {"draft": "reset"},
          "actionCases": [{"id": "restored_values", "enabledActions": ["close_preferences", "adjust_age_range", "toggle_interested_gender", "reset_preferences", "apply_preferences"]}]
        },
        "save_pending": {
          "dimensions": {"mutation": "pending"},
          "actionCases": [
            {
              "id": "frozen_request_snapshot",
              "disabledActions": ["close_preferences", "adjust_age_range", "toggle_interested_gender", "reset_preferences", "apply_preferences"]
            }
          ]
        },
        "save_error": {
          "dimensions": {"mutation": "error"},
          "actionCases": [{"id": "retryable_values", "enabledActions": ["close_preferences", "adjust_age_range", "toggle_interested_gender", "reset_preferences", "apply_preferences"]}]
        },
        "save_success_exit": {
          "dimensions": {"mutation": "success"},
          "actionCases": [{"id": "route_exit"}]
        },
        "text_scale_2": {
          "dimensions": {"accessibility": "text_scale_2"},
          "actionCases": [{"id": "scaled_values", "enabledActions": ["close_preferences", "adjust_age_range", "toggle_interested_gender", "reset_preferences", "apply_preferences"]}]
        },
        "reduced_motion": {
          "dimensions": {"accessibility": "reduced_motion"},
          "actionCases": [{"id": "motion_reduced", "enabledActions": ["close_preferences", "adjust_age_range", "toggle_interested_gender", "reset_preferences", "apply_preferences"]}]
        }
      },
      "requiredEvidence": {"captures": true, "previews": true, "tests": true},
      "evidenceExceptions": [
        {
          "stateIds": ["profile_error", "profile_missing", "reset_preferences", "save_error", "text_scale_2", "reduced_motion"],
          "evidence": ["tests"],
          "debtId": "FEATURE-CONTRACT-MIGRATION-001",
          "reason": "These Matching Preferences states have deterministic capture and Widgetbook evidence but no focused state-level test recorded by the screen authority."
        },
        {
          "stateIds": ["save_success_exit"],
          "evidence": ["captures", "previews"],
          "debtId": "FEATURE-CONTRACT-MIGRATION-001",
          "reason": "Successful apply is a tested immediate route exit, so there is no stable post-success screen to capture or preview."
        }
      ]
    }
  ]
}
