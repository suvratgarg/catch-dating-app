{
  "$schema": "./feature_contract.schema.json",
  "version": 2,
  "updated": "2026-07-23",
  "id": "feature.event_recap",
  "name": "Event Recap",
  "owner": "swipes",
  "status": "pilot",
  "description": "Orchestrates post-event attendee recall, local vibe selection, recap recovery, and the handoff into the event-scoped Catches deck.",
  "surfaces": [
    {
      "id": "consumer_flutter",
      "runtime": "flutter",
      "authority": {
        "registry": "flutter_screens",
        "id": "screen.event.recap"
      },
      "actionScope": {
        "included": "Closing or retrying Event Recap, retrying attendee-profile enrichment, toggling remembered attendees, and opening the event-scoped Catches deck with the current selection.",
        "excluded": [
          "Event, attendance-roster, catch-window, and public-profile derivation are read-model behavior rather than user actions.",
          "Pass and reaction mutations after the handoff retain Catches Event Deck ownership."
        ]
      },
      "bindings": {
        "previewSources": [
          "widgetbook/lib/catches/catches_use_cases.dart"
        ],
        "actionOwners": [
          {
            "id": "recap_screen",
            "language": "dart",
            "file": "lib/swipes/presentation/event_recap_screen.dart",
            "symbol": "EventRecapScreen"
          }
        ],
        "componentContracts": [
          "catch.button",
          "catch.empty_state",
          "catch.error_state",
          "catch.surface",
          "catch.top_bar"
        ],
        "dataContracts": [
          "contracts/firestore/event_participations.schema.json",
          "contracts/firestore/events.schema.json",
          "contracts/firestore/public_profiles.schema.json"
        ]
      },
      "dimensions": {
        "load": {
          "default": "ready",
          "values": ["ready", "loading", "error", "not_found"]
        },
        "roster": {
          "default": "populated",
          "values": ["populated", "empty", "loading", "error", "partial"]
        },
        "selection": {
          "default": "none",
          "values": ["none", "selected"]
        },
        "catch_window": {
          "default": "closed",
          "values": ["closed", "open"]
        },
        "handoff": {
          "default": "idle",
          "values": ["idle", "opened"]
        },
        "accessibility": {
          "default": "standard",
          "values": ["standard", "text_scale_2", "reduced_motion"]
        }
      },
      "actions": [
        {
          "id": "close_recap",
          "owner": "recap_screen",
          "codeValue": "pop",
          "cardinality": "singleton",
          "scopeKeys": ["routeInstanceId"],
          "outcomes": [
            {"kind": "side_effect", "id": "navigation.route_popped"}
          ],
          "description": "Closes Event Recap through the compact top-bar control or equivalent back action."
        },
        {
          "id": "retry_recap",
          "owner": "recap_screen",
          "codeValue": "_retry",
          "cardinality": "singleton",
          "scopeKeys": ["eventId", "recapLoadGeneration"],
          "outcomes": [
            {"kind": "surface_state", "stateIds": ["recap_loading", "recap_error", "event_not_found", "populated_attendees", "empty_roster"]}
          ],
          "description": "Invalidates the event, participation, identity, and composed recap providers as one recovery decision."
        },
        {
          "id": "retry_roster_profiles",
          "owner": "recap_screen",
          "codeValue": "_retryRosterProfiles",
          "cardinality": "singleton",
          "scopeKeys": ["eventId", "attendeeIdSet", "profileLoadGeneration"],
          "outcomes": [
            {"kind": "surface_state", "stateIds": ["profile_lookup_loading", "profile_lookup_error", "populated_attendees", "profile_lookup_fallback"]}
          ],
          "description": "Invalidates the batched public-profile lookup while preserving the resolved recap and its event-scoped deck handoff."
        },
        {
          "id": "toggle_vibe_selection",
          "owner": "recap_screen",
          "codeValue": "_toggleVibe",
          "cardinality": "domain_bounded",
          "scopeKeys": ["routeInstanceId", "eventId", "attendeeId", "selected"],
          "outcomes": [
            {"kind": "surface_state", "stateIds": ["populated_attendees", "profile_lookup_fallback", "vibe_selection"]}
          ],
          "description": "Adds or removes one eligible checked-in attendee from the route-local remembered-attendee set."
        },
        {
          "id": "open_catches_deck",
          "owner": "recap_screen",
          "codeValue": "_openCatchesDeck",
          "cardinality": "singleton",
          "scopeKeys": ["routeInstanceId", "eventId", "selectedVibeSignature"],
          "outcomes": [
            {
              "kind": "route",
              "authority": {
                "registry": "flutter_screens",
                "id": "screen.catches.event"
              }
            }
          ],
          "description": "Replaces Event Recap with the event-scoped Catches deck and passes the current remembered-attendee ids as route extra."
        }
      ],
      "stateIds": [
        "recap_loading",
        "recap_error",
        "event_not_found",
        "populated_attendees",
        "empty_roster",
        "profile_lookup_loading",
        "profile_lookup_error",
        "profile_lookup_fallback",
        "vibe_selection",
        "open_catches_deck",
        "text_scale_2",
        "reduced_motion"
      ],
      "scenarioDefaults": {
        "dimensions": {},
        "actionCases": [
          {
            "id": "ready",
            "enabledActions": ["close_recap", "toggle_vibe_selection", "open_catches_deck"]
          }
        ]
      },
      "scenarioOverrides": {
        "recap_loading": {
          "dimensions": {"load": "loading"},
          "actionCases": [{"id": "loading", "enabledActions": ["close_recap"]}]
        },
        "recap_error": {
          "dimensions": {"load": "error"},
          "actionCases": [{"id": "retry", "enabledActions": ["close_recap", "retry_recap"]}]
        },
        "event_not_found": {
          "dimensions": {"load": "not_found"},
          "actionCases": [{"id": "missing", "enabledActions": ["close_recap"]}]
        },
        "populated_attendees": {
          "actionCases": [
            {"id": "window_closed", "enabledActions": ["close_recap", "toggle_vibe_selection", "open_catches_deck"]},
            {
              "id": "window_open",
              "dimensions": {"catch_window": "open"},
              "enabledActions": ["close_recap", "toggle_vibe_selection", "open_catches_deck"]
            }
          ]
        },
        "empty_roster": {
          "dimensions": {"roster": "empty"},
          "actionCases": [{"id": "no_other_attendees", "enabledActions": ["close_recap", "open_catches_deck"]}]
        },
        "profile_lookup_fallback": {
          "dimensions": {"roster": "partial"},
          "actionCases": [{"id": "genuinely_missing_profiles", "enabledActions": ["close_recap", "toggle_vibe_selection", "open_catches_deck"]}]
        },
        "profile_lookup_loading": {
          "dimensions": {"roster": "loading"},
          "actionCases": [{"id": "batched_lookup_loading", "enabledActions": ["close_recap", "open_catches_deck"]}]
        },
        "profile_lookup_error": {
          "dimensions": {"roster": "error"},
          "actionCases": [{"id": "retry_profiles", "enabledActions": ["close_recap", "retry_roster_profiles", "open_catches_deck"]}]
        },
        "vibe_selection": {
          "dimensions": {"selection": "selected"}
        },
        "open_catches_deck": {
          "dimensions": {"handoff": "opened"},
          "actionCases": [{"id": "route_handoff"}]
        },
        "text_scale_2": {
          "dimensions": {"accessibility": "text_scale_2"}
        },
        "reduced_motion": {
          "dimensions": {"accessibility": "reduced_motion"}
        }
      },
      "requiredEvidence": {
        "captures": true,
        "previews": true,
        "tests": true
      },
      "evidenceExceptions": [
        {
          "stateIds": ["text_scale_2", "reduced_motion"],
          "evidence": ["tests"],
          "debtId": "FEATURE-CONTRACT-MIGRATION-001",
          "reason": "These Event Recap accessibility states have deterministic capture and Widgetbook evidence but no focused state-level test recorded by the screen authority."
        },
        {
          "stateIds": ["open_catches_deck"],
          "evidence": ["captures", "previews"],
          "debtId": "FEATURE-CONTRACT-MIGRATION-001",
          "reason": "The selected-id handoff is a focused-tested immediate route replacement, so Event Recap has no stable post-action state to capture or preview."
        }
      ]
    }
  ]
}
