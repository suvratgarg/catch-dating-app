{
  "$schema": "./feature_contract.schema.json",
  "version": 2,
  "updated": "2026-07-23",
  "id": "feature.profile_self",
  "name": "Self Profile",
  "owner": "user_profile",
  "status": "pilot",
  "description": "Orchestrates the signed-in member's editable profile, photo operations, inline field mutations, preview projection, and account-settings entry.",
  "surfaces": [
    {
      "id": "consumer_flutter",
      "runtime": "flutter",
      "authority": {
        "registry": "flutter_screens",
        "id": "screen.profile.self"
      },
      "actionScope": {
        "included": "Profile field saves, bounded photo operations, and account-settings navigation.",
        "excluded": [
          "Tab selection, editor disclosure, validation descriptors, and public-profile projection remain presentation/domain concerns rather than persisted actions."
        ]
      },
      "bindings": {
        "previewSources": [
          "widgetbook/lib/profiles/profile_use_cases.dart"
        ],
        "actionOwners": [
          {
            "id": "profile_edits",
            "language": "dart",
            "file": "lib/user_profile/presentation/profile_edit_controller.dart",
            "symbol": "ProfileEditController"
          },
          {
            "id": "photos",
            "language": "dart",
            "file": "lib/image_uploads/shared/photo_upload_controller.dart",
            "symbol": "PhotoUploadController"
          },
          {
            "id": "profile_route",
            "language": "dart",
            "file": "lib/user_profile/presentation/widgets/profile_sliver_header.dart",
            "symbol": "ProfileSettingsButton"
          }
        ],
        "componentContracts": [
          "catch.field",
          "catch.icon_button",
          "catch.option_group",
          "catch.range_slider",
          "catch.section",
          "catch.surface",
          "catch.top_bar"
        ],
        "dataContracts": [
          "contracts/embedded/profile_photo.schema.json",
          "contracts/embedded/profile_prompt_answer.schema.json",
          "contracts/firestore/public_profiles.schema.json",
          "contracts/firestore/users.schema.json",
          "contracts/patches/update_user_profile.schema.json",
          "contracts/storage/profile_photo_thumbnails.schema.json",
          "contracts/storage/profile_photos.schema.json"
        ]
      },
      "dimensions": {
        "load": {
          "default": "ready",
          "values": [
            "ready",
            "loading",
            "error",
            "offline",
            "unavailable"
          ]
        },
        "tab": {
          "default": "edit",
          "values": [
            "edit",
            "preview"
          ]
        },
        "editor": {
          "default": "closed",
          "values": [
            "closed",
            "text",
            "prompt",
            "choice"
          ]
        },
        "mutation": {
          "default": "idle",
          "values": [
            "idle",
            "photo_pending",
            "save_pending",
            "failed"
          ]
        },
        "accessibility": {
          "default": "standard",
          "values": [
            "standard",
            "text_scale_2",
            "reduced_motion"
          ]
        },
        "theme": {
          "default": "standard",
          "values": [
            "standard",
            "light_dark"
          ]
        }
      },
      "actions": [
        {
          "id": "save_profile_fields",
          "owner": "profile_edits",
          "codeValue": "saveFields",
          "cardinality": "unbounded",
          "scopeKeys": [
            "viewerUid",
            "profileVersion",
            "patchFingerprint"
          ],
          "outcomes": [
            {
              "kind": "surface_state",
              "stateIds": [
                "edit_tab_default",
                "inline_text_edit",
                "inline_prompt_edit",
                "inline_choice_edit",
                "inline_save_pending",
                "inline_save_error",
                "preview_tab_default"
              ]
            },
            {
              "kind": "side_effect",
              "id": "profile.update_fields"
            }
          ],
          "description": "Serializes and persists one typed profile patch against the latest signed-in profile version."
        },
        {
          "id": "pick_and_upload_photo",
          "owner": "photos",
          "codeValue": "pickAndUpload",
          "cardinality": "domain_bounded",
          "scopeKeys": [
            "viewerUid",
            "photoSlotIndex",
            "profileVersion"
          ],
          "outcomes": [
            {
              "kind": "surface_state",
              "stateIds": [
                "photo_grid",
                "photo_upload_mutation"
              ]
            },
            {
              "kind": "side_effect",
              "id": "profile.upload_photo"
            }
          ],
          "description": "Selects, uploads, and persists a photo into one bounded profile slot."
        },
        {
          "id": "delete_photo",
          "owner": "photos",
          "codeValue": "deletePhoto",
          "cardinality": "domain_bounded",
          "scopeKeys": [
            "viewerUid",
            "photoSlotIndex",
            "photoStoragePath",
            "profileVersion"
          ],
          "outcomes": [
            {
              "kind": "surface_state",
              "stateIds": [
                "photo_grid",
                "photo_upload_mutation"
              ]
            },
            {
              "kind": "side_effect",
              "id": "profile.delete_photo"
            }
          ],
          "description": "Deletes one occupied photo slot and synchronizes storage plus profile projections."
        },
        {
          "id": "reorder_photo",
          "owner": "photos",
          "codeValue": "reorderPhoto",
          "cardinality": "domain_bounded",
          "scopeKeys": [
            "viewerUid",
            "fromIndex",
            "toIndex",
            "profileVersion"
          ],
          "outcomes": [
            {
              "kind": "surface_state",
              "stateIds": [
                "photo_grid",
                "photo_upload_mutation",
                "preview_tab_default"
              ]
            },
            {
              "kind": "side_effect",
              "id": "profile.reorder_photos"
            }
          ],
          "description": "Moves one existing profile photo between bounded slots and persists the new order."
        },
        {
          "id": "open_account_settings",
          "owner": "profile_route",
          "codeValue": "settingsScreen",
          "cardinality": "unbounded",
          "scopeKeys": [
            "viewerUid",
            "routeInstanceId"
          ],
          "outcomes": [
            {
              "kind": "route",
              "authority": {
                "registry": "flutter_screens",
                "id": "screen.settings.account"
              }
            }
          ],
          "description": "Opens account settings from the self-profile top bar."
        }
      ],
      "stateIds": [
        "profile_loading",
        "profile_error",
        "profile_unavailable",
        "edit_tab_default",
        "photo_grid",
        "photo_upload_mutation",
        "inline_text_edit",
        "inline_prompt_edit",
        "inline_choice_edit",
        "inline_save_pending",
        "inline_save_error",
        "preview_tab_default",
        "settings_action",
        "offline",
        "text_scale_2",
        "reduced_motion",
        "light_dark"
      ],
      "scenarioDefaults": {
        "dimensions": {},
        "actionCases": [
          {
            "id": "default"
          }
        ]
      },
      "scenarioOverrides": {
        "profile_loading": {
          "dimensions": {
            "load": "loading"
          }
        },
        "profile_error": {
          "dimensions": {
            "load": "error"
          }
        },
        "profile_unavailable": {
          "dimensions": {
            "load": "unavailable"
          }
        },
        "edit_tab_default": {
          "actionCases": [
            {
              "id": "editable",
              "enabledActions": [
                "save_profile_fields",
                "pick_and_upload_photo",
                "delete_photo",
                "reorder_photo",
                "open_account_settings"
              ]
            }
          ]
        },
        "photo_grid": {
          "actionCases": [
            {
              "id": "photo_slots",
              "enabledActions": [
                "pick_and_upload_photo",
                "delete_photo",
                "reorder_photo",
                "open_account_settings"
              ]
            }
          ]
        },
        "photo_upload_mutation": {
          "dimensions": {
            "mutation": "photo_pending"
          },
          "actionCases": [
            {
              "id": "photo_pending",
              "enabledActions": [
                "open_account_settings"
              ],
              "disabledActions": [
                "pick_and_upload_photo",
                "delete_photo",
                "reorder_photo"
              ]
            }
          ]
        },
        "inline_text_edit": {
          "dimensions": {
            "editor": "text"
          },
          "actionCases": [
            {
              "id": "editable",
              "enabledActions": [
                "save_profile_fields"
              ]
            }
          ]
        },
        "inline_prompt_edit": {
          "dimensions": {
            "editor": "prompt"
          },
          "actionCases": [
            {
              "id": "editable",
              "enabledActions": [
                "save_profile_fields"
              ]
            }
          ]
        },
        "inline_choice_edit": {
          "dimensions": {
            "editor": "choice"
          },
          "actionCases": [
            {
              "id": "editable",
              "enabledActions": [
                "save_profile_fields"
              ]
            }
          ]
        },
        "inline_save_pending": {
          "dimensions": {
            "mutation": "save_pending"
          },
          "actionCases": [
            {
              "id": "save_pending",
              "disabledActions": [
                "save_profile_fields"
              ]
            }
          ]
        },
        "inline_save_error": {
          "dimensions": {
            "mutation": "failed"
          },
          "actionCases": [
            {
              "id": "retryable",
              "enabledActions": [
                "save_profile_fields"
              ]
            }
          ]
        },
        "preview_tab_default": {
          "dimensions": {
            "tab": "preview"
          },
          "actionCases": [
            {
              "id": "preview",
              "enabledActions": [
                "open_account_settings"
              ]
            }
          ]
        },
        "settings_action": {
          "actionCases": [
            {
              "id": "available",
              "enabledActions": [
                "open_account_settings"
              ]
            }
          ]
        },
        "offline": {
          "dimensions": {
            "load": "offline"
          }
        },
        "text_scale_2": {
          "dimensions": {
            "accessibility": "text_scale_2"
          },
          "actionCases": [
            {
              "id": "available",
              "enabledActions": [
                "open_account_settings"
              ]
            }
          ]
        },
        "reduced_motion": {
          "dimensions": {
            "accessibility": "reduced_motion"
          },
          "actionCases": [
            {
              "id": "available",
              "enabledActions": [
                "open_account_settings"
              ]
            }
          ]
        },
        "light_dark": {
          "dimensions": {
            "theme": "light_dark"
          },
          "actionCases": [
            {
              "id": "available",
              "enabledActions": [
                "open_account_settings"
              ]
            }
          ]
        }
      },
      "requiredEvidence": {
        "captures": true,
        "previews": true,
        "tests": true
      },
      "evidenceExceptions": [
        {
          "stateIds": [
            "photo_grid",
            "inline_text_edit",
            "inline_prompt_edit",
            "inline_choice_edit"
          ],
          "evidence": [
            "captures"
          ],
          "debtId": "FEATURE-CONTRACT-MIGRATION-001",
          "reason": "These editor states have focused widget tests and Widgetbook evidence but no registered deterministic capture."
        },
        {
          "stateIds": [
            "profile_loading",
            "profile_error",
            "profile_unavailable",
            "offline",
            "text_scale_2",
            "reduced_motion"
          ],
          "evidence": [
            "tests"
          ],
          "debtId": "FEATURE-CONTRACT-MIGRATION-001",
          "reason": "These route variants are captured and previewed but do not yet have focused state-level tests registered by the screen authority."
        }
      ]
    }
  ]
}
