{
  "$schema": "./feature_contract.schema.json",
  "version": 2,
  "updated": "2026-07-23",
  "id": "feature.phone_auth",
  "name": "Phone Authentication",
  "owner": "auth",
  "status": "pilot",
  "description": "Orchestrates shared consumer/host phone-number entry, Firebase verification-code delivery, OTP verification and resend, and returning to phone entry.",
  "surfaces": [
    {
      "id": "shared_flutter",
      "runtime": "flutter",
      "authority": {"registry": "flutter_screens", "id": "screen.auth.phone_entry"},
      "actionScope": {
        "included": "Country-code selection, verification-code request, OTP verification, resend after cooldown, and changing the phone number.",
        "excluded": [
          "Raw phone and OTP character entry remains form data governed by AuthInput, field formatters, and Firebase Auth rather than separately cardinalized keystrokes.",
          "Firebase automatic credential verification is an external lifecycle callback, not a user action.",
          "Post-auth consumer onboarding and host-shell redirection retain router and destination-feature ownership."
        ]
      },
      "bindings": {
        "previewSources": ["widgetbook/lib/utility/p3_utility_use_cases.dart"],
        "actionOwners": [
          {
            "id": "country_selector",
            "language": "dart",
            "file": "lib/auth/presentation/phone_page.dart",
            "symbol": "CountryCodeSelector"
          },
          {
            "id": "auth_controller",
            "language": "dart",
            "file": "lib/auth/presentation/auth_controller.dart",
            "symbol": "AuthController"
          }
        ],
        "componentContracts": ["catch.button", "catch.error_banner", "catch.field"],
        "dataContracts": []
      },
      "dimensions": {
        "step": {"default": "phone", "values": ["phone", "otp"]},
        "mutation": {"default": "idle", "values": ["idle", "validation", "pending", "error"]},
        "resend": {"default": "cooldown", "values": ["cooldown", "ready", "pending", "error"]},
        "accessibility": {"default": "standard", "values": ["standard", "text_scale_2", "reduced_motion"]}
      },
      "actions": [
        {
          "id": "open_country_selector",
          "owner": "country_selector",
          "codeValue": "CountryCodePicker",
          "cardinality": "unbounded",
          "scopeKeys": ["routeInstanceId"],
          "outcomes": [
            {"kind": "surface_state", "stateIds": ["country_selector"]}
          ],
          "description": "Opens the country-code picker and its searchable supported-market list."
        },
        {
          "id": "select_country_code",
          "owner": "auth_controller",
          "codeValue": "setCountryCode",
          "cardinality": "domain_bounded",
          "scopeKeys": ["routeInstanceId", "dialCode"],
          "outcomes": [
            {"kind": "surface_state", "stateIds": ["phone_entry", "country_selector", "validation_error", "send_code_mutation"]}
          ],
          "description": "Selects one supported market dial code and clears prior send-code feedback."
        },
        {
          "id": "send_code",
          "owner": "auth_controller",
          "codeValue": "sendOtp",
          "cardinality": "singleton",
          "scopeKeys": ["routeInstanceId", "phoneRequestSignature"],
          "outcomes": [
            {"kind": "surface_state", "stateIds": ["validation_error", "send_code_mutation", "otp_entry"]}
          ],
          "description": "Validates and normalizes the phone request, asks Firebase to send a verification code, and advances after codeSent."
        },
        {
          "id": "verify_code",
          "owner": "auth_controller",
          "codeValue": "verifyOtp",
          "cardinality": "singleton",
          "scopeKeys": ["verificationId", "otpSignature"],
          "outcomes": [
            {"kind": "surface_state", "stateIds": ["verify_otp_mutation"]},
            {"kind": "side_effect", "id": "phone_auth.signed_in"}
          ],
          "description": "Verifies a complete OTP against the current Firebase verification session."
        },
        {
          "id": "resend_code",
          "owner": "auth_controller",
          "codeValue": "sendOtp",
          "cardinality": "singleton",
          "scopeKeys": ["verificationId", "resendAttempt"],
          "outcomes": [
            {"kind": "surface_state", "stateIds": ["verify_otp_mutation", "otp_entry"]}
          ],
          "description": "Requests another code with the Firebase resend token after the local cooldown reaches zero."
        },
        {
          "id": "change_number",
          "owner": "auth_controller",
          "codeValue": "goToStep",
          "cardinality": "singleton",
          "scopeKeys": ["routeInstanceId", "verificationId"],
          "outcomes": [
            {"kind": "surface_state", "stateIds": ["phone_entry"]}
          ],
          "description": "Returns from OTP verification to phone entry when no auth mutation is pending."
        }
      ],
      "stateIds": [
        "phone_entry",
        "country_selector",
        "validation_error",
        "send_code_mutation",
        "otp_entry",
        "verify_otp_mutation",
        "text_scale_2",
        "reduced_motion"
      ],
      "scenarioDefaults": {"dimensions": {}, "actionCases": [{"id": "default"}]},
      "scenarioOverrides": {
        "phone_entry": {
          "actionCases": [{"id": "entry", "enabledActions": ["open_country_selector", "send_code"]}]
        },
        "country_selector": {
          "actionCases": [{"id": "selection", "enabledActions": ["select_country_code"]}]
        },
        "validation_error": {
          "dimensions": {"mutation": "validation"},
          "actionCases": [{"id": "correct", "enabledActions": ["open_country_selector", "send_code"]}]
        },
        "send_code_mutation": {
          "actionCases": [
            {
              "id": "frozen_request_snapshot",
              "dimensions": {"mutation": "pending"},
              "disabledActions": ["open_country_selector", "send_code"]
            },
            {
              "id": "error",
              "dimensions": {"mutation": "error"},
              "enabledActions": ["open_country_selector", "send_code"]
            }
          ]
        },
        "otp_entry": {
          "dimensions": {"step": "otp"},
          "actionCases": [
            {
              "id": "cooldown_incomplete",
              "dimensions": {"resend": "cooldown"},
              "enabledActions": ["change_number"],
              "disabledActions": ["verify_code", "resend_code"]
            },
            {
              "id": "code_complete",
              "dimensions": {"resend": "cooldown"},
              "enabledActions": ["verify_code", "change_number"],
              "disabledActions": ["resend_code"]
            },
            {
              "id": "resend_ready",
              "dimensions": {"resend": "ready"},
              "enabledActions": ["resend_code", "change_number"]
            }
          ]
        },
        "verify_otp_mutation": {
          "dimensions": {"step": "otp"},
          "actionCases": [
            {
              "id": "verify_pending",
              "dimensions": {"mutation": "pending"},
              "disabledActions": ["verify_code", "resend_code", "change_number"]
            },
            {
              "id": "verify_error",
              "dimensions": {"mutation": "error"},
              "enabledActions": ["verify_code", "change_number"]
            },
            {
              "id": "resend_pending",
              "dimensions": {"mutation": "pending", "resend": "pending"},
              "disabledActions": ["verify_code", "resend_code", "change_number"]
            },
            {
              "id": "resend_error",
              "dimensions": {"mutation": "error", "resend": "error"},
              "enabledActions": ["change_number"],
              "disabledActions": ["verify_code", "resend_code"]
            }
          ]
        },
        "text_scale_2": {"dimensions": {"accessibility": "text_scale_2"}},
        "reduced_motion": {"dimensions": {"accessibility": "reduced_motion"}}
      },
      "requiredEvidence": {"captures": true, "previews": true, "tests": true},
      "evidenceExceptions": [
        {
          "stateIds": ["text_scale_2", "reduced_motion"],
          "evidence": ["tests"],
          "debtId": "FEATURE-CONTRACT-MIGRATION-001",
          "reason": "The accessibility variants have deterministic Auth captures and Widgetbook proof but no focused state-level test registered by the screen authority."
        }
      ]
    }
  ]
}
