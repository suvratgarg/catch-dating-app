{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://catch.app/design/features/feature_contract.schema.json",
  "title": "Catch feature orchestration contract",
  "type": "object",
  "required": [
    "$schema",
    "version",
    "updated",
    "id",
    "name",
    "owner",
    "status",
    "description",
    "actionScope",
    "screenContract",
    "bindings",
    "dimensions",
    "actions",
    "scenarios",
    "requiredEvidence"
  ],
  "additionalProperties": false,
  "properties": {
    "$schema": {"const": "./feature_contract.schema.json"},
    "version": {"const": 1},
    "updated": {"type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$"},
    "id": {"type": "string", "pattern": "^feature\\.[a-z0-9_.-]+$"},
    "name": {"type": "string", "minLength": 1},
    "owner": {"type": "string", "minLength": 1},
    "status": {"enum": ["pilot", "active", "retired"]},
    "description": {"type": "string", "minLength": 1},
    "actionScope": {"$ref": "#/$defs/actionScope"},
    "screenContract": {"type": "string", "pattern": "^screen\\.[a-z0-9_.-]+$"},
    "bindings": {"$ref": "#/$defs/bindings"},
    "dimensions": {
      "type": "object",
      "minProperties": 1,
      "propertyNames": {"pattern": "^[a-z][a-z0-9_]*$"},
      "additionalProperties": {"$ref": "#/$defs/dimension"}
    },
    "actions": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/action"}
    },
    "scenarios": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/scenario"}
    },
    "requiredEvidence": {
      "type": "object",
      "required": ["captures", "previews", "tests"],
      "additionalProperties": false,
      "properties": {
        "captures": {"const": true},
        "previews": {"const": true},
        "tests": {"const": true}
      }
    },
    "evidenceExceptions": {
      "type": "array",
      "items": {"$ref": "#/$defs/evidenceException"}
    }
  },
  "$defs": {
    "actionScope": {
      "type": "object",
      "required": ["included", "excluded"],
      "additionalProperties": false,
      "properties": {
        "included": {"type": "string", "minLength": 1},
        "excluded": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"type": "string", "minLength": 1}
        }
      }
    },
    "dartBinding": {
      "type": "object",
      "required": ["file", "symbol"],
      "additionalProperties": false,
      "properties": {
        "file": {"type": "string", "pattern": "^lib/.+\\.dart$"},
        "symbol": {"type": "string", "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"}
      }
    },
    "bindings": {
      "type": "object",
      "required": [
        "widgetbookSources",
        "actionOwner",
        "componentContracts",
        "dataContracts"
      ],
      "additionalProperties": false,
      "properties": {
        "widgetbookSources": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^widgetbook/lib/.+\\.dart$"
          }
        },
        "actionOwner": {"$ref": "#/$defs/dartBinding"},
        "componentContracts": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"type": "string", "pattern": "^catch\\.[a-z0-9_.-]+$"}
        },
        "dataContracts": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"type": "string", "pattern": "^contracts/.+\\.json$"}
        }
      }
    },
    "dimension": {
      "type": "object",
      "required": ["default", "values"],
      "additionalProperties": false,
      "properties": {
        "default": {"type": "string", "minLength": 1},
        "values": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"type": "string", "pattern": "^[a-z][a-z0-9_]*$"}
        }
      }
    },
    "action": {
      "type": "object",
      "required": [
        "id",
        "codeValue",
        "cardinality",
        "scopeKeys",
        "outcomes",
        "description"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {"type": "string", "pattern": "^[a-z][a-z0-9_]*$"},
        "codeValue": {"type": "string", "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"},
        "cardinality": {"enum": ["singleton", "unbounded", "domain_bounded"]},
        "scopeKeys": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"type": "string", "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"}
        },
        "outcomes": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/actionOutcome"}
        },
        "description": {"type": "string", "minLength": 1}
      }
    },
    "actionOutcome": {
      "oneOf": [
        {
          "type": "object",
          "required": ["kind", "stateIds"],
          "additionalProperties": false,
          "properties": {
            "kind": {"const": "screen_state"},
            "stateIds": {
              "type": "array",
              "minItems": 1,
              "uniqueItems": true,
              "items": {"type": "string", "pattern": "^[a-z0-9_.-]+$"}
            }
          }
        },
        {
          "type": "object",
          "required": ["kind", "screenContract"],
          "additionalProperties": false,
          "properties": {
            "kind": {"const": "route"},
            "screenContract": {"type": "string", "pattern": "^screen\\.[a-z0-9_.-]+$"}
          }
        },
        {
          "type": "object",
          "required": ["kind", "id"],
          "additionalProperties": false,
          "properties": {
            "kind": {"const": "side_effect"},
            "id": {"type": "string", "pattern": "^[a-z][a-z0-9_.-]+$"}
          }
        }
      ]
    },
    "evidenceException": {
      "type": "object",
      "required": ["screenStateIds", "evidence", "debtId", "reason"],
      "additionalProperties": false,
      "properties": {
        "screenStateIds": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"type": "string", "pattern": "^[a-z0-9_.-]+$"}
        },
        "evidence": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"enum": ["captures", "previews", "tests"]}
        },
        "debtId": {"type": "string", "pattern": "^[A-Z][A-Z0-9_.-]+$"},
        "reason": {"type": "string", "minLength": 1}
      }
    },
    "scenario": {
      "type": "object",
      "required": ["id", "screenStateId", "dimensions", "actionCases"],
      "additionalProperties": false,
      "properties": {
        "id": {"type": "string", "pattern": "^[a-z][a-z0-9_]*$"},
        "screenStateId": {"type": "string", "pattern": "^[a-z0-9_.-]+$"},
        "dimensions": {"$ref": "#/$defs/dimensionSelection"},
        "actionCases": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/actionCase"}
        }
      }
    },
    "dimensionSelection": {
      "type": "object",
      "propertyNames": {"pattern": "^[a-z][a-z0-9_]*$"},
      "additionalProperties": {"type": "string", "pattern": "^[a-z][a-z0-9_]*$"}
    },
    "actionCase": {
      "type": "object",
      "required": ["id"],
      "additionalProperties": false,
      "properties": {
        "id": {"type": "string", "pattern": "^[a-z][a-z0-9_]*$"},
        "dimensions": {"$ref": "#/$defs/dimensionSelection"},
        "enabledActions": {
          "type": "array",
          "uniqueItems": true,
          "items": {"type": "string", "pattern": "^[a-z][a-z0-9_]*$"}
        },
        "disabledActions": {
          "type": "array",
          "uniqueItems": true,
          "items": {"type": "string", "pattern": "^[a-z][a-z0-9_]*$"}
        }
      }
    }
  }
}
