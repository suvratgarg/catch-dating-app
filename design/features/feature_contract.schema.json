{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://catch.app/design/features/feature_contract.schema.json",
  "title": "Catch multi-surface feature orchestration contract",
  "type": "object",
  "required": [
    "$schema",
    "version",
    "updated",
    "id",
    "name",
    "owner",
    "status",
    "description",
    "surfaces"
  ],
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "const": "./feature_contract.schema.json"
    },
    "version": {
      "const": 2
    },
    "updated": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "id": {
      "type": "string",
      "pattern": "^feature\\.[a-z0-9_.-]+$"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "owner": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "enum": [
        "pilot",
        "active",
        "retired"
      ]
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "surfaces": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/surface"
      }
    }
  },
  "$defs": {
    "surface": {
      "type": "object",
      "required": [
        "id",
        "runtime",
        "authority",
        "actionScope",
        "bindings",
        "dimensions",
        "actions",
        "requiredEvidence"
      ],
      "additionalProperties": false,
      "oneOf": [
        {
          "required": [
            "scenarios"
          ],
          "not": {
            "anyOf": [
              {
                "required": [
                  "stateIds"
                ]
              },
              {
                "required": [
                  "scenarioDefaults"
                ]
              },
              {
                "required": [
                  "scenarioOverrides"
                ]
              }
            ]
          }
        },
        {
          "required": [
            "stateIds",
            "scenarioDefaults",
            "scenarioOverrides"
          ],
          "not": {
            "required": [
              "scenarios"
            ]
          }
        }
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$"
        },
        "runtime": {
          "enum": [
            "flutter",
            "react_marketing",
            "react_admin"
          ]
        },
        "authority": {
          "$ref": "#/$defs/authority"
        },
        "actionScope": {
          "$ref": "#/$defs/actionScope"
        },
        "bindings": {
          "$ref": "#/$defs/bindings"
        },
        "dimensions": {
          "type": "object",
          "propertyNames": {
            "pattern": "^[a-z][a-z0-9_]*$"
          },
          "additionalProperties": {
            "$ref": "#/$defs/dimension"
          }
        },
        "actions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/action"
          }
        },
        "scenarios": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/scenario"
          }
        },
        "stateIds": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9_.-]+$"
          }
        },
        "scenarioDefaults": {
          "$ref": "#/$defs/scenarioDefaults"
        },
        "scenarioOverrides": {
          "type": "object",
          "propertyNames": {
            "pattern": "^[a-z0-9_.-]+$"
          },
          "additionalProperties": {
            "$ref": "#/$defs/scenarioOverride"
          }
        },
        "requiredEvidence": {
          "$ref": "#/$defs/requiredEvidence"
        },
        "evidenceExceptions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/evidenceException"
          }
        }
      }
    },
    "authority": {
      "type": "object",
      "required": [
        "registry",
        "id"
      ],
      "additionalProperties": false,
      "properties": {
        "registry": {
          "enum": [
            "flutter_screens",
            "marketing_routes",
            "admin_routes"
          ]
        },
        "id": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "actionScope": {
      "type": "object",
      "required": [
        "included",
        "excluded"
      ],
      "additionalProperties": false,
      "properties": {
        "included": {
          "type": "string",
          "minLength": 1
        },
        "excluded": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "bindings": {
      "type": "object",
      "required": [
        "previewSources",
        "actionOwners",
        "componentContracts",
        "dataContracts"
      ],
      "additionalProperties": false,
      "properties": {
        "previewSources": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^(widgetbook/lib/.+\\.dart|website/src/.+\\.tsx|admin/src/.+\\.tsx)$"
          }
        },
        "actionOwners": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/actionOwner"
          }
        },
        "componentContracts": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_.-]+$"
          }
        },
        "dataContracts": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^contracts/.+\\.json$"
          }
        },
        "runtimeContracts": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/runtimeContract"
          }
        },
        "testEvidence": {
          "type": "object",
          "propertyNames": {
            "pattern": "^[a-z0-9_.-]+$"
          },
          "additionalProperties": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
              "type": "string",
              "pattern": "^(test/.+\\.dart|website/(src/.+\\.test\\.tsx?|scripts/.+\\.test\\.mjs)|admin/src/.+\\.test\\.tsx?)$"
            }
          }
        },
        "previewEvidence": {
          "type": "object",
          "propertyNames": {
            "pattern": "^[a-z0-9_.-]+$"
          },
          "additionalProperties": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
              "type": "string",
              "pattern": "^[a-z][a-z0-9_.-]+/[A-Za-z][A-Za-z0-9_]*$"
            }
          }
        }
      }
    },
    "runtimeContract": {
      "type": "object",
      "required": [
        "kind",
        "registry",
        "callable",
        "requestValidation",
        "responseValidation"
      ],
      "additionalProperties": false,
      "properties": {
        "kind": {
          "const": "admin_callable"
        },
        "registry": {
          "const": "admin/src/generated/validators/adminCallableValidators.ts"
        },
        "callable": {
          "type": "string",
          "pattern": "^admin[A-Z][A-Za-z0-9]+$"
        },
        "requestValidation": {
          "enum": [
            "strict_schema",
            "structural_object"
          ]
        },
        "responseValidation": {
          "enum": [
            "strict_schema",
            "structural_object"
          ]
        }
      }
    },
    "actionOwner": {
      "type": "object",
      "required": [
        "id",
        "language",
        "file",
        "symbol"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$"
        },
        "language": {
          "enum": [
            "dart",
            "typescript"
          ]
        },
        "file": {
          "type": "string",
          "pattern": "^(lib/.+\\.dart|website/src/.+\\.tsx?|admin/src/.+\\.tsx?)$"
        },
        "symbol": {
          "type": "string",
          "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"
        }
      }
    },
    "dimension": {
      "type": "object",
      "required": [
        "default",
        "values"
      ],
      "additionalProperties": false,
      "properties": {
        "default": {
          "type": "string",
          "minLength": 1
        },
        "values": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_]*$"
          }
        }
      }
    },
    "action": {
      "type": "object",
      "required": [
        "id",
        "owner",
        "codeValue",
        "cardinality",
        "scopeKeys",
        "outcomes",
        "description"
      ],
      "additionalProperties": false,
      "allOf": [
        {
          "if": {
            "properties": {
              "implementationStatus": {
                "const": "known_gap"
              }
            },
            "required": [
              "implementationStatus"
            ]
          },
          "then": {
            "required": [
              "debtId",
              "implementationNotes"
            ]
          },
          "else": {
            "not": {
              "anyOf": [
                {
                  "required": [
                    "debtId"
                  ]
                },
                {
                  "required": [
                    "implementationNotes"
                  ]
                }
              ]
            }
          }
        }
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$"
        },
        "owner": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$"
        },
        "codeValue": {
          "type": "string",
          "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"
        },
        "cardinality": {
          "enum": [
            "singleton",
            "unbounded",
            "domain_bounded"
          ]
        },
        "scopeKeys": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"
          }
        },
        "outcomes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/actionOutcome"
          }
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "implementationStatus": {
          "enum": [
            "implemented",
            "known_gap"
          ]
        },
        "debtId": {
          "type": "string",
          "pattern": "^[A-Z][A-Z0-9_.-]+$"
        },
        "implementationNotes": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "actionOutcome": {
      "oneOf": [
        {
          "type": "object",
          "required": [
            "kind",
            "stateIds"
          ],
          "additionalProperties": false,
          "properties": {
            "kind": {
              "const": "surface_state"
            },
            "stateIds": {
              "type": "array",
              "minItems": 1,
              "uniqueItems": true,
              "items": {
                "type": "string",
                "pattern": "^[a-z0-9_.-]+$"
              }
            }
          }
        },
        {
          "type": "object",
          "required": [
            "kind",
            "authority"
          ],
          "additionalProperties": false,
          "properties": {
            "kind": {
              "const": "route"
            },
            "authority": {
              "$ref": "#/$defs/authority"
            }
          }
        },
        {
          "type": "object",
          "required": [
            "kind",
            "id"
          ],
          "additionalProperties": false,
          "properties": {
            "kind": {
              "const": "side_effect"
            },
            "id": {
              "type": "string",
              "pattern": "^[a-z][a-z0-9_.-]+$"
            }
          }
        }
      ]
    },
    "scenario": {
      "type": "object",
      "required": [
        "id",
        "stateId",
        "dimensions",
        "actionCases"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$"
        },
        "stateId": {
          "type": "string",
          "pattern": "^[a-z0-9_.-]+$"
        },
        "dimensions": {
          "$ref": "#/$defs/dimensionSelection"
        },
        "actionCases": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/actionCase"
          }
        }
      }
    },
    "scenarioDefaults": {
      "type": "object",
      "required": [
        "dimensions",
        "actionCases"
      ],
      "additionalProperties": false,
      "properties": {
        "dimensions": {
          "$ref": "#/$defs/dimensionSelection"
        },
        "actionCases": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/actionCase"
          }
        }
      }
    },
    "scenarioOverride": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": false,
      "properties": {
        "dimensions": {
          "$ref": "#/$defs/dimensionSelection"
        },
        "actionCases": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/actionCase"
          }
        }
      }
    },
    "dimensionSelection": {
      "type": "object",
      "propertyNames": {
        "pattern": "^[a-z][a-z0-9_]*$"
      },
      "additionalProperties": {
        "type": "string",
        "pattern": "^[a-z][a-z0-9_]*$"
      }
    },
    "actionCase": {
      "type": "object",
      "required": [
        "id"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$"
        },
        "dimensions": {
          "$ref": "#/$defs/dimensionSelection"
        },
        "enabledActions": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_]*$"
          }
        },
        "disabledActions": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_]*$"
          }
        }
      }
    },
    "requiredEvidence": {
      "type": "object",
      "required": [
        "captures",
        "previews",
        "tests"
      ],
      "additionalProperties": false,
      "properties": {
        "captures": {
          "type": "boolean"
        },
        "previews": {
          "type": "boolean"
        },
        "tests": {
          "type": "boolean"
        }
      }
    },
    "evidenceException": {
      "type": "object",
      "required": [
        "stateIds",
        "evidence",
        "debtId",
        "reason"
      ],
      "additionalProperties": false,
      "properties": {
        "stateIds": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9_.-]+$"
          }
        },
        "evidence": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "enum": [
              "captures",
              "previews",
              "tests"
            ]
          }
        },
        "debtId": {
          "type": "string",
          "pattern": "^[A-Z][A-Z0-9_.-]+$"
        },
        "reason": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
