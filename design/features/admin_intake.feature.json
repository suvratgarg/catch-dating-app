{
  "$schema": "./feature_contract.schema.json",
  "version": 2,
  "updated": "2026-07-23",
  "id": "feature.admin_intake",
  "name": "Admin Supply Intake",
  "owner": "admin_console",
  "status": "pilot",
  "description": "Orchestrates Event, Organizer, and Automation intake projections as one supply-ingestion workspace while preserving their distinct decisions, evidence boundaries, and route states.",
  "surfaces": [
    {
      "id": "admin_intake_workspace",
      "runtime": "react_admin",
      "authority": {"registry": "admin_routes", "id": "route_intake_workspace"},
      "actionScope": {
        "included": "Switching intake workspaces, expanding publication boundaries, navigating Event Intake, refreshing or deciding event evidence, refreshing or paging read-only Automation operations, and freezing the complete Admin workspace while an Event Intake decision is pending.",
        "excluded": [
          "Event source/result/candidate edits and decision notes remain session form data.",
          "Automation is read-only; exceptions are resolved in the owning Event or Organizer surface and a later run observes the receipt.",
          "Organizer-specific decision actions are owned by the second projection below rather than duplicated on this shell."
        ]
      },
      "bindings": {
        "previewSources": ["admin/src/stories/AdminRoutes.stories.tsx"],
        "actionOwners": [
          {"id": "workspace", "language": "typescript", "file": "admin/src/features/intake/ui/IntakeWorkspaceScreen.tsx", "symbol": "IntakeWorkspace"},
          {"id": "event_controller", "language": "typescript", "file": "admin/src/features/intake/events/controllers/useEventIntakeController.ts", "symbol": "useEventIntakeController"},
          {"id": "operations_controller", "language": "typescript", "file": "admin/src/features/intake/operations/controllers/useIntakeOperationsController.ts", "symbol": "useIntakeOperationsController"}
        ],
        "componentContracts": ["route_intake_workspace"],
        "dataContracts": [
          "contracts/callables/admin_record_event_intake_review_decision_payload.schema.json",
          "contracts/callables/admin_list_intake_operations_payload.schema.json",
          "contracts/callable_responses/admin_list_intake_operations_response.schema.json",
          "contracts/firestore/event_intake_review_decisions.schema.json"
        ],
        "runtimeContracts": [
          {"kind": "admin_callable", "registry": "admin/src/generated/validators/adminCallableValidators.ts", "callable": "adminGetEventIntakeDashboard", "requestValidation": "strict_schema", "responseValidation": "structural_object"},
          {"kind": "admin_callable", "registry": "admin/src/generated/validators/adminCallableValidators.ts", "callable": "adminRecordEventIntakeReviewDecision", "requestValidation": "strict_schema", "responseValidation": "structural_object"},
          {"kind": "admin_callable", "registry": "admin/src/generated/validators/adminCallableValidators.ts", "callable": "adminListIntakeOperations", "requestValidation": "strict_schema", "responseValidation": "strict_schema"}
        ],
        "testEvidence": {
          "event-review": [
            "admin/src/features/intake/events/controllers/useEventIntakeController.test.tsx",
            "admin/src/features/intake/events/controllers/eventIntakeReviewDecisionHelpers.test.ts",
            "admin/src/features/intake/operations/controllers/useIntakeOperationsController.test.tsx",
            "admin/src/features/intake/operations/ui/IntakeOperationsWorkspace.test.tsx",
            "admin/src/features/intake/ui/intakeWorkbenchDefaults.test.tsx",
            "admin/src/shared/pendingOperation.test.tsx"
          ]
        }
      },
      "dimensions": {
        "workspace": {"default": "events", "values": ["events", "organizers", "operations"]},
        "event_tab": {"default": "candidates", "values": ["setup", "inbox", "candidates"]},
        "source": {"default": "ready", "values": ["ready", "loading", "failed"]},
        "mutation": {"default": "idle", "values": ["idle", "pending", "failed", "success"]}
      },
      "actions": [
        {"id": "select_intake_workspace", "owner": "workspace", "codeValue": "onWorkspaceChange", "cardinality": "unbounded", "scopeKeys": ["adminSessionId", "workspaceId"], "outcomes": [{"kind": "surface_state", "stateIds": ["event-review"]}], "description": "Routes among Event leads, Organizers, and Automation while retaining one intake feature identity."},
        {"id": "toggle_intake_publication_boundary", "owner": "workspace", "codeValue": "setShowBoundaryDetails", "cardinality": "unbounded", "scopeKeys": ["adminSessionId", "workspaceId"], "outcomes": [{"kind": "surface_state", "stateIds": ["event-review"]}], "description": "Shows or hides the explicit approval-versus-publication boundary for Event or Organizer intake."},
        {"id": "select_event_intake_tab", "owner": "event_controller", "codeValue": "setActiveTab", "cardinality": "unbounded", "scopeKeys": ["adminSessionId", "eventIntakeTab"], "outcomes": [{"kind": "surface_state", "stateIds": ["event-review"]}], "description": "Switches among Event Intake setup, inbox, and candidate review."},
        {"id": "refresh_event_intake", "owner": "event_controller", "codeValue": "loadBridge", "cardinality": "singleton", "scopeKeys": ["adminSessionId", "eventBridgeVersion"], "outcomes": [{"kind": "surface_state", "stateIds": ["event-review"]}], "description": "Refetches the saved Event Intake bridge."},
        {"id": "record_event_intake_decision", "owner": "event_controller", "codeValue": "targetDecision", "cardinality": "singleton", "scopeKeys": ["reviewerUid", "targetType", "targetId", "decisionVersion"], "outcomes": [{"kind": "surface_state", "stateIds": ["event-review"]}, {"kind": "side_effect", "id": "admin.event_intake_decision_recorded"}], "description": "Records one validated Event Intake approve, hold, reject, or needs-changes receipt."},
        {"id": "refresh_intake_operations", "owner": "operations_controller", "codeValue": "refresh", "cardinality": "singleton", "scopeKeys": ["adminSessionId", "runSnapshotVersion"], "outcomes": [{"kind": "surface_state", "stateIds": ["event-review"]}], "description": "Reloads the bounded active Supply Intake run and exception inventory."},
        {"id": "load_more_intake_operations", "owner": "operations_controller", "codeValue": "loadMore", "cardinality": "singleton", "scopeKeys": ["adminSessionId", "runId", "workItemCursor"], "outcomes": [{"kind": "surface_state", "stateIds": ["event-review"]}], "description": "Loads the next ordinary work-item page without overwriting a newer refresh."
        }
      ],
      "scenarios": [
        {
          "id": "event_review",
          "stateId": "event-review",
          "dimensions": {},
          "actionCases": [
            {"id": "event_candidates", "enabledActions": ["select_intake_workspace", "toggle_intake_publication_boundary", "select_event_intake_tab", "refresh_event_intake", "record_event_intake_decision"]},
            {"id": "event_decision_pending_frozen_workspace", "dimensions": {"mutation": "pending"}, "disabledActions": ["select_intake_workspace", "toggle_intake_publication_boundary", "select_event_intake_tab", "refresh_event_intake", "record_event_intake_decision"]},
            {"id": "event_source_failed", "dimensions": {"source": "failed"}, "enabledActions": ["select_intake_workspace", "toggle_intake_publication_boundary", "refresh_event_intake"]},
            {"id": "organizer_projection", "dimensions": {"workspace": "organizers"}, "enabledActions": ["select_intake_workspace", "toggle_intake_publication_boundary"]},
            {"id": "operations_ready", "dimensions": {"workspace": "operations"}, "enabledActions": ["select_intake_workspace", "refresh_intake_operations", "load_more_intake_operations"]},
            {"id": "operations_loading", "dimensions": {"workspace": "operations", "source": "loading"}, "enabledActions": ["select_intake_workspace"], "disabledActions": ["refresh_intake_operations", "load_more_intake_operations"]}
          ]
        }
      ],
      "requiredEvidence": {"captures": false, "previews": true, "tests": true}
    },
    {
      "id": "admin_organizer_intake",
      "runtime": "react_admin",
      "authority": {"registry": "admin_routes", "id": "route_organizer_intake"},
      "actionScope": {
        "included": "Switching review and diagnostics, deciding organizer intake, attaching or curating candidates, deciding event candidates and policy gaps, classifying pending inputs, resolving event locations, and freezing the complete Admin workspace during any organizer-intake write.",
        "excluded": [
          "Decision notes, curation fields, manual-report acknowledgement, and location fields remain form data.",
          "Approval creates a publishing handoff; ownership, app visibility, claims, crawling, and canonical publication remain separately gated."
        ]
      },
      "bindings": {
        "previewSources": ["admin/src/stories/AdminRoutes.stories.tsx"],
        "actionOwners": [
          {"id": "controller", "language": "typescript", "file": "admin/src/features/intake/organizer/controllers/useOrganizerIntakeController.ts", "symbol": "useOrganizerIntakeController"},
          {"id": "screen", "language": "typescript", "file": "admin/src/features/intake/organizer/ui/OrganizerIntakeScreen.tsx", "symbol": "OrganizerIntakeWorkspace"}
        ],
        "componentContracts": ["route_organizer_intake"],
        "dataContracts": [
          "contracts/callables/admin_decide_organizer_intake_payload.schema.json",
          "contracts/callables/admin_decide_organizer_event_candidate_payload.schema.json",
          "contracts/callables/admin_decide_organizer_policy_gap_payload.schema.json",
          "contracts/callables/admin_record_organizer_curation_payload.schema.json",
          "contracts/callables/admin_resolve_organizer_event_location_payload.schema.json",
          "contracts/firestore/organizer_intake_review_decisions.schema.json",
          "contracts/firestore/organizer_event_candidate_review_decisions.schema.json",
          "contracts/firestore/organizer_policy_gap_review_decisions.schema.json",
          "contracts/firestore/organizer_intake_curation_decisions.schema.json",
          "contracts/firestore/organizer_event_location_resolution_decisions.schema.json"
        ],
        "runtimeContracts": [
          {"kind": "admin_callable", "registry": "admin/src/generated/validators/adminCallableValidators.ts", "callable": "adminDecideOrganizerIntake", "requestValidation": "strict_schema", "responseValidation": "structural_object"},
          {"kind": "admin_callable", "registry": "admin/src/generated/validators/adminCallableValidators.ts", "callable": "adminDecideOrganizerEventCandidate", "requestValidation": "strict_schema", "responseValidation": "structural_object"},
          {"kind": "admin_callable", "registry": "admin/src/generated/validators/adminCallableValidators.ts", "callable": "adminDecideOrganizerPolicyGap", "requestValidation": "strict_schema", "responseValidation": "structural_object"},
          {"kind": "admin_callable", "registry": "admin/src/generated/validators/adminCallableValidators.ts", "callable": "adminRecordOrganizerCuration", "requestValidation": "strict_schema", "responseValidation": "structural_object"},
          {"kind": "admin_callable", "registry": "admin/src/generated/validators/adminCallableValidators.ts", "callable": "adminResolveOrganizerEventLocation", "requestValidation": "strict_schema", "responseValidation": "structural_object"}
        ],
        "testEvidence": {
          "default": [
            "admin/src/features/intake/organizer/controllers/useOrganizerIntakeController.test.tsx",
            "admin/src/features/intake/organizer/controllers/organizerIntakeHelpers.test.ts",
            "admin/src/shared/pendingOperation.test.tsx"
          ],
          "workflow-readiness": [
            "admin/src/features/intake/organizer/controllers/useOrganizerIntakeController.test.tsx",
            "admin/src/features/intake/organizer/controllers/organizerIntakeHelpers.test.ts",
            "admin/src/shared/pendingOperation.test.tsx"
          ],
          "publication-packets": [
            "admin/src/features/intake/organizer/controllers/useOrganizerIntakeController.test.tsx",
            "admin/src/features/intake/organizer/controllers/organizerIntakeHelpers.test.ts",
            "admin/src/shared/pendingOperation.test.tsx"
          ]
        }
      },
      "dimensions": {
        "view": {"default": "review", "values": ["review", "diagnostics"]},
        "mutation": {"default": "idle", "values": ["idle", "pending", "failed", "success"]}
      },
      "actions": [
        {"id": "toggle_organizer_intake_diagnostics", "owner": "screen", "codeValue": "setShowDiagnostics", "cardinality": "unbounded", "scopeKeys": ["adminSessionId", "viewVersion"], "outcomes": [{"kind": "surface_state", "stateIds": ["default", "workflow-readiness", "publication-packets"]}], "description": "Switches between daily review work and generated diagnostics without losing controller evidence."},
        {"id": "decide_organizer_intake", "owner": "controller", "codeValue": "handleDecision", "cardinality": "singleton", "scopeKeys": ["reviewerUid", "entityId", "decisionVersion"], "outcomes": [{"kind": "surface_state", "stateIds": ["default", "publication-packets"]}, {"kind": "side_effect", "id": "admin.organizer_intake_decided"}], "description": "Records approve-public, hold, or suppress with a publication handoff rather than direct visibility."},
        {"id": "attach_organizer_candidate", "owner": "controller", "codeValue": "handleAttachCandidate", "cardinality": "singleton", "scopeKeys": ["reviewerUid", "candidateId", "targetOrganizerId"], "outcomes": [{"kind": "surface_state", "stateIds": ["default"]}, {"kind": "side_effect", "id": "admin.organizer_candidate_attached"}], "description": "Records a candidate-to-organizer attachment curation decision."},
        {"id": "record_organizer_curation", "owner": "controller", "codeValue": "handleItemCuration", "cardinality": "singleton", "scopeKeys": ["reviewerUid", "operationId", "curationVersion"], "outcomes": [{"kind": "surface_state", "stateIds": ["default", "publication-packets"]}, {"kind": "side_effect", "id": "admin.organizer_curation_recorded"}], "description": "Persists one explicit merge, create, hide, or projection curation operation."},
        {"id": "decide_organizer_event_candidate", "owner": "controller", "codeValue": "handleEventDecision", "cardinality": "singleton", "scopeKeys": ["reviewerUid", "candidateId", "decisionVersion"], "outcomes": [{"kind": "surface_state", "stateIds": ["workflow-readiness"]}, {"kind": "side_effect", "id": "admin.organizer_event_candidate_decided"}], "description": "Records import readiness for one organizer event candidate without publishing it."},
        {"id": "decide_organizer_policy_gap", "owner": "controller", "codeValue": "handlePolicyGapDecision", "cardinality": "singleton", "scopeKeys": ["reviewerUid", "gapId", "decisionVersion"], "outcomes": [{"kind": "surface_state", "stateIds": ["workflow-readiness"]}, {"kind": "side_effect", "id": "admin.organizer_policy_gap_decided"}], "description": "Records accept, hold, or reject for one unencoded policy gap."},
        {"id": "decide_pending_intake_input", "owner": "controller", "codeValue": "handlePendingInputDecision", "cardinality": "singleton", "scopeKeys": ["reviewerUid", "inputId", "decisionVersion"], "outcomes": [{"kind": "surface_state", "stateIds": ["workflow-readiness"]}, {"kind": "side_effect", "id": "admin.pending_intake_input_classified"}], "description": "Classifies one pending pipeline input with an explicit submitted/in-flight decision."},
        {"id": "resolve_organizer_event_location", "owner": "controller", "codeValue": "handleLocationResolution", "cardinality": "singleton", "scopeKeys": ["reviewerUid", "candidateId", "locationVersion"], "outcomes": [{"kind": "surface_state", "stateIds": ["workflow-readiness"]}, {"kind": "side_effect", "id": "admin.organizer_event_location_resolved"}], "description": "Records reviewed place identity and coordinates for one organizer event candidate."
        }
      ],
      "scenarios": [
        {
          "id": "default",
          "stateId": "default",
          "dimensions": {},
          "actionCases": [
            {"id": "review_queue", "enabledActions": ["toggle_organizer_intake_diagnostics", "decide_organizer_intake", "attach_organizer_candidate", "record_organizer_curation"]},
            {"id": "decision_pending_frozen_workspace", "dimensions": {"mutation": "pending"}, "disabledActions": ["toggle_organizer_intake_diagnostics", "decide_organizer_intake", "attach_organizer_candidate", "record_organizer_curation"]},
            {"id": "diagnostics", "dimensions": {"view": "diagnostics"}, "enabledActions": ["toggle_organizer_intake_diagnostics"]}
          ]
        },
        {
          "id": "workflow_readiness",
          "stateId": "workflow-readiness",
          "dimensions": {},
          "actionCases": [
            {"id": "readiness_tasks", "enabledActions": ["toggle_organizer_intake_diagnostics", "decide_organizer_event_candidate", "decide_organizer_policy_gap", "decide_pending_intake_input", "resolve_organizer_event_location"]},
            {"id": "readiness_mutation_pending_frozen_workspace", "dimensions": {"mutation": "pending"}, "disabledActions": ["toggle_organizer_intake_diagnostics", "decide_organizer_event_candidate", "decide_organizer_policy_gap", "decide_pending_intake_input", "resolve_organizer_event_location"]}
          ]
        },
        {
          "id": "publication_packets",
          "stateId": "publication-packets",
          "dimensions": {},
          "actionCases": [
            {"id": "handoff_packets", "enabledActions": ["toggle_organizer_intake_diagnostics", "decide_organizer_intake", "record_organizer_curation"]}
          ]
        }
      ],
      "requiredEvidence": {"captures": false, "previews": true, "tests": true}
    }
  ]
}
