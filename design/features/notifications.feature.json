{
  "$schema": "./feature_contract.schema.json",
  "version": 2,
  "updated": "2026-07-23",
  "id": "feature.notifications",
  "name": "Notifications",
  "owner": "dashboard",
  "status": "pilot",
  "description": "Orchestrates the member Activity feed, read-state mutation, recovery, grouping evidence, and dynamic notification-route handoff.",
  "surfaces": [
    {
      "id": "consumer_flutter",
      "runtime": "flutter",
      "authority": {"registry": "flutter_screens", "id": "screen.notifications.list"},
      "actionScope": {
        "included": "Retrying identity or activity loads, marking visible unread notifications as read, and opening a notification's derived chat, Event Detail, or Organizer Detail target.",
        "excluded": [
          "Time labels, visibility filtering, day grouping, and dynamic route derivation are read-model behavior rather than user actions.",
          "Shell navigation and non-navigable notification rows do not create synthetic feature actions."
        ]
      },
      "bindings": {
        "previewSources": [
          "widgetbook/lib/dashboard/dashboard_use_cases.dart",
          "widgetbook/lib/utility/p3_utility_use_cases.dart"
        ],
        "actionOwners": [
          {
            "id": "activity_screen",
            "language": "dart",
            "file": "lib/dashboard/presentation/activity_screen.dart",
            "symbol": "ActivityScreen"
          },
          {
            "id": "activity_controller",
            "language": "dart",
            "file": "lib/dashboard/presentation/activity_controller.dart",
            "symbol": "ActivityController"
          },
          {
            "id": "notification_router",
            "language": "dart",
            "file": "lib/dashboard/presentation/notification_route_util.dart",
            "symbol": "openNotificationRoute"
          }
        ],
        "componentContracts": [
          "catch.empty_state",
          "catch.error_state",
          "catch.surface",
          "catch.button",
          "catch.top_bar"
        ],
        "dataContracts": ["contracts/firestore/activity_notifications.schema.json"]
      },
      "dimensions": {
        "access": {"default": "signed_in", "values": ["loading", "error", "signed_out", "signed_in"]},
        "data": {"default": "ready", "values": ["loading", "error", "empty", "ready"]},
        "rows": {"default": "mixed", "values": ["mixed", "read", "unread", "navigable", "non_navigable"]},
        "mutation": {"default": "idle", "values": ["idle", "mark_all_pending", "mark_all_error"]},
        "navigation": {"default": "idle", "values": ["idle", "target_opened", "failed"]},
        "accessibility": {"default": "standard", "values": ["standard", "text_scale_2", "reduced_motion"]},
        "theme": {"default": "standard", "values": ["standard", "light_dark"]}
      },
      "actions": [
        {
          "id": "retry_identity",
          "owner": "activity_screen",
          "codeValue": "uidProvider",
          "cardinality": "singleton",
          "scopeKeys": ["routeInstanceId", "identityLoadGeneration"],
          "outcomes": [
            {"kind": "surface_state", "stateIds": ["uid_loading", "uid_error", "signed_out", "activity_loading", "activity_error", "empty_activity", "notifications_activity"]}
          ],
          "description": "Invalidates the viewer identity provider after Activity access fails without presenting the failure as a signed-out empty state."
        },
        {
          "id": "retry_activity",
          "owner": "activity_screen",
          "codeValue": "invalidate",
          "cardinality": "singleton",
          "scopeKeys": ["viewerUid", "activityLoadGeneration"],
          "outcomes": [
            {"kind": "surface_state", "stateIds": ["activity_loading", "activity_error", "empty_activity", "notifications_activity"]}
          ],
          "description": "Invalidates the current member's activity-notification stream after a load failure."
        },
        {
          "id": "mark_all_read",
          "owner": "activity_controller",
          "codeValue": "markAllRead",
          "cardinality": "singleton",
          "scopeKeys": ["viewerUid", "unreadNotificationSet", "activityVersion"],
          "outcomes": [
            {"kind": "surface_state", "stateIds": ["read_unread_rows", "mark_all_read"]},
            {"kind": "side_effect", "id": "activity_notifications.mark_all_read"}
          ],
          "description": "Marks the currently visible unread notification set as read in one guarded mutation."
        },
        {
          "id": "open_notification_target",
          "owner": "notification_router",
          "codeValue": "openNotificationRoute",
          "cardinality": "unbounded",
          "scopeKeys": ["routeInstanceId", "notificationId", "derivedRoute"],
          "outcomes": [
            {"kind": "route", "authority": {"registry": "flutter_screens", "id": "screen.matches.chat"}},
            {"kind": "route", "authority": {"registry": "flutter_screens", "id": "screen.event.detail"}},
            {"kind": "route", "authority": {"registry": "flutter_screens", "id": "screen.club.detail"}}
          ],
          "description": "Opens the row's derived chat, Event Detail, or Organizer Detail route and surfaces navigation failure feedback."
        }
      ],
      "stateIds": [
        "uid_loading",
        "uid_error",
        "signed_out",
        "activity_loading",
        "activity_error",
        "empty_activity",
        "notifications_activity",
        "read_unread_rows",
        "mark_all_read",
        "row_navigation_targets",
        "deep_link_failures",
        "text_scale_2",
        "reduced_motion",
        "light_dark"
      ],
      "scenarioDefaults": {
        "dimensions": {},
        "actionCases": [{"id": "mixed_activity", "enabledActions": ["mark_all_read", "open_notification_target"]}]
      },
      "scenarioOverrides": {
        "uid_loading": {
          "dimensions": {"access": "loading", "data": "loading"},
          "actionCases": [{"id": "loading"}]
        },
        "uid_error": {
          "dimensions": {"access": "error", "data": "error"},
          "actionCases": [{"id": "retry", "enabledActions": ["retry_identity"]}]
        },
        "signed_out": {
          "dimensions": {"access": "signed_out", "data": "empty"},
          "actionCases": [{"id": "null_uid"}]
        },
        "activity_loading": {
          "dimensions": {"data": "loading"},
          "actionCases": [{"id": "loading"}]
        },
        "activity_error": {
          "dimensions": {"data": "error"},
          "actionCases": [{"id": "retry", "enabledActions": ["retry_activity"]}]
        },
        "empty_activity": {
          "dimensions": {"data": "empty"},
          "actionCases": [{"id": "empty"}]
        },
        "read_unread_rows": {
          "actionCases": [
            {"id": "unread_navigable", "dimensions": {"rows": "unread"}, "enabledActions": ["mark_all_read", "open_notification_target"]},
            {"id": "read_navigable", "dimensions": {"rows": "read"}, "enabledActions": ["open_notification_target"]},
            {"id": "non_navigable", "dimensions": {"rows": "non_navigable"}}
          ]
        },
        "mark_all_read": {
          "actionCases": [
            {
              "id": "pending",
              "dimensions": {"mutation": "mark_all_pending"},
              "enabledActions": ["open_notification_target"],
              "disabledActions": ["mark_all_read"]
            },
            {
              "id": "failed",
              "dimensions": {"mutation": "mark_all_error"},
              "enabledActions": ["mark_all_read", "open_notification_target"]
            }
          ]
        },
        "row_navigation_targets": {
          "dimensions": {"rows": "navigable", "navigation": "target_opened"},
          "actionCases": [{"id": "derived_route", "enabledActions": ["open_notification_target"]}]
        },
        "deep_link_failures": {
          "dimensions": {"navigation": "failed"},
          "actionCases": [{"id": "retry_by_row", "enabledActions": ["open_notification_target"]}]
        },
        "text_scale_2": {"dimensions": {"accessibility": "text_scale_2"}},
        "reduced_motion": {"dimensions": {"accessibility": "reduced_motion"}},
        "light_dark": {"dimensions": {"theme": "light_dark"}}
      },
      "requiredEvidence": {"captures": true, "previews": true, "tests": true},
      "evidenceExceptions": [
        {
          "stateIds": ["uid_loading", "signed_out", "activity_loading", "activity_error", "empty_activity", "text_scale_2", "reduced_motion", "light_dark"],
          "evidence": ["tests"],
          "debtId": "FEATURE-CONTRACT-MIGRATION-001",
          "reason": "These Notifications states have deterministic capture and Widgetbook evidence but no focused state-level test recorded by the screen authority."
        },
        {
          "stateIds": ["read_unread_rows", "row_navigation_targets"],
          "evidence": ["captures"],
          "debtId": "FEATURE-CONTRACT-MIGRATION-001",
          "reason": "Read/unread rendering and derived-route actions are focused-test and Widgetbook proven, but the authority does not register dedicated standalone captures for those semantic states."
        }
      ]
    }
  ]
}
