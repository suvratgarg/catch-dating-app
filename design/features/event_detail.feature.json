{
  "$schema": "./feature_contract.schema.json",
  "version": 2,
  "updated": "2026-07-24",
  "id": "feature.event_detail",
  "name": "Event Detail",
  "owner": "events",
  "status": "pilot",
  "description": "Orchestrates Event Detail across the consumer app, public marketing projection, and exact-location route with explicit state, booking, registration handoff, navigation, directions, and evidence contracts.",
  "surfaces": [
    {
      "id": "consumer_flutter",
      "runtime": "flutter",
      "authority": {
        "registry": "flutter_screens",
        "id": "screen.event.detail"
      },
      "actionScope": {
        "included": "Booking-dock actions represented by EventDetailBookingDockAction plus opening the exact-location child projection.",
        "excluded": [
          "Navigation chrome, sharing, saving, calendar, companion, organizer, messaging, authentication, and profile-completion actions remain owned and verified by their existing route and widget contracts.",
          "Directions and exact-location child-route recovery belong to the Event Location Map projection below."
        ]
      },
      "bindings": {
        "previewSources": [
          "widgetbook/lib/events/event_detail_use_cases.dart",
          "widgetbook/lib/primitives/core_catalog_use_cases.dart"
        ],
        "actionOwners": [
          {
            "id": "booking_dock",
            "language": "dart",
            "file": "lib/events/presentation/event_detail_screen_state.dart",
            "symbol": "EventDetailBookingDockAction"
          },
          {
            "id": "event_detail_route",
            "language": "dart",
            "file": "lib/events/presentation/event_detail_screen.dart",
            "symbol": "EventDetailScreen"
          }
        ],
        "componentContracts": [
          "catch.async_value",
          "catch.error_state",
          "catch.event_detail_sections"
        ],
        "dataContracts": [
          "contracts/callables/event_booking_payload.schema.json",
          "contracts/client_writes/create_saved_event.schema.json",
          "contracts/client_writes/delete_saved_event.schema.json",
          "contracts/firestore/event_participations.schema.json",
          "contracts/firestore/event_waitlist_offers.schema.json",
          "contracts/firestore/events.schema.json",
          "contracts/firestore/saved_events.schema.json"
        ]
      },
      "dimensions": {
        "load": {
          "default": "ready",
          "values": [
            "ready",
            "loading",
            "not_found",
            "error",
            "offline"
          ]
        },
        "viewer": {
          "default": "member",
          "values": [
            "guest",
            "member",
            "host"
          ]
        },
        "presentation": {
          "default": "standard",
          "values": [
            "standard",
            "ticket",
            "spotlight_dark"
          ]
        },
        "participation": {
          "default": "eligible",
          "values": [
            "eligible",
            "signed_up",
            "waitlisted",
            "waitlist_offer",
            "full",
            "attended",
            "past",
            "cancelled"
          ]
        },
        "mutation": {
          "default": "idle",
          "values": [
            "idle",
            "book_pending",
            "cancel_pending",
            "book_failed",
            "cancel_failed",
            "book_succeeded",
            "cancel_succeeded"
          ]
        },
        "accessibility": {
          "default": "standard",
          "values": [
            "standard",
            "text_scale_2",
            "reduced_motion"
          ]
        }
      },
      "actions": [
        {
          "id": "book",
          "owner": "booking_dock",
          "codeValue": "book",
          "cardinality": "singleton",
          "scopeKeys": [
            "viewerUid",
            "eventId"
          ],
          "outcomes": [
            {
              "kind": "surface_state",
              "stateIds": [
                "booking_signed_up"
              ]
            }
          ],
          "description": "Creates at most one active booking relationship for the viewer and event."
        },
        {
          "id": "cancel_booking",
          "owner": "booking_dock",
          "codeValue": "cancelBooking",
          "cardinality": "singleton",
          "scopeKeys": [
            "viewerUid",
            "eventId"
          ],
          "outcomes": [
            {
              "kind": "surface_state",
              "stateIds": [
                "member_default"
              ]
            }
          ],
          "description": "Cancels the viewer's single active booking for the event."
        },
        {
          "id": "join_waitlist",
          "owner": "booking_dock",
          "codeValue": "joinWaitlist",
          "cardinality": "singleton",
          "scopeKeys": [
            "viewerUid",
            "eventId"
          ],
          "outcomes": [
            {
              "kind": "surface_state",
              "stateIds": [
                "waitlist_sold_out_cancelled_past"
              ]
            }
          ],
          "description": "Creates at most one active waitlist relationship for the viewer and event."
        },
        {
          "id": "leave_waitlist",
          "owner": "booking_dock",
          "codeValue": "leaveWaitlist",
          "cardinality": "singleton",
          "scopeKeys": [
            "viewerUid",
            "eventId"
          ],
          "outcomes": [
            {
              "kind": "surface_state",
              "stateIds": [
                "member_default"
              ]
            }
          ],
          "description": "Removes the viewer's single active waitlist relationship for the event."
        },
        {
          "id": "accept_waitlist_offer",
          "owner": "booking_dock",
          "codeValue": "acceptWaitlistOffer",
          "cardinality": "singleton",
          "scopeKeys": [
            "viewerUid",
            "eventId",
            "waitlistOfferId"
          ],
          "outcomes": [
            {
              "kind": "surface_state",
              "stateIds": [
                "booking_signed_up"
              ]
            }
          ],
          "description": "Accepts one active waitlist offer and transitions it to a booking."
        },
        {
          "id": "decline_waitlist_offer",
          "owner": "booking_dock",
          "codeValue": "declineWaitlistOffer",
          "cardinality": "singleton",
          "scopeKeys": [
            "viewerUid",
            "eventId",
            "waitlistOfferId"
          ],
          "outcomes": [
            {
              "kind": "surface_state",
              "stateIds": [
                "waitlist_sold_out_cancelled_past"
              ]
            }
          ],
          "description": "Declines one active waitlist offer without creating another offer action."
        },
        {
          "id": "open_location_map",
          "owner": "event_detail_route",
          "codeValue": "eventLocationMapScreen",
          "cardinality": "unbounded",
          "scopeKeys": [
            "routeInstanceId",
            "eventId"
          ],
          "outcomes": [
            {
              "kind": "route",
              "authority": {
                "registry": "flutter_screens",
                "id": "screen.event.location_map"
              }
            }
          ],
          "description": "Opens the same event's exact-location map from the always-rendered Where section."
        }
      ],
      "stateIds": [
        "loading",
        "not_found",
        "fatal_error",
        "member_default",
        "member_ticket",
        "member_spotlight_dark",
        "guest",
        "host_app",
        "booking_signed_up",
        "booking_pending",
        "booking_failed",
        "waitlist_sold_out_cancelled_past",
        "offline",
        "text_scale_2",
        "reduced_motion"
      ],
      "scenarioDefaults": {
        "dimensions": {},
        "actionCases": [
          {
            "id": "location_available",
            "enabledActions": [
              "open_location_map"
            ]
          }
        ]
      },
      "scenarioOverrides": {
        "loading": {
          "dimensions": {"load": "loading"},
          "actionCases": [{"id": "default"}]
        },
        "not_found": {
          "dimensions": {"load": "not_found"},
          "actionCases": [{"id": "default"}]
        },
        "fatal_error": {
          "dimensions": {"load": "error"},
          "actionCases": [{"id": "default"}]
        },
        "member_default": {
          "actionCases": [
            {"id": "eligible", "enabledActions": ["book", "open_location_map"]}
          ]
        },
        "member_ticket": {
          "dimensions": {"presentation": "ticket"},
          "actionCases": [
            {"id": "eligible", "enabledActions": ["book", "open_location_map"]}
          ]
        },
        "member_spotlight_dark": {
          "dimensions": {"presentation": "spotlight_dark"},
          "actionCases": [
            {"id": "eligible", "enabledActions": ["book", "open_location_map"]}
          ]
        },
        "guest": {"dimensions": {"viewer": "guest"}},
        "host_app": {"dimensions": {"viewer": "host"}},
        "booking_signed_up": {
          "dimensions": {"participation": "signed_up"},
          "actionCases": [
            {"id": "signed_up", "enabledActions": ["cancel_booking", "open_location_map"]}
          ]
        },
        "booking_pending": {
          "actionCases": [
            {
              "id": "book_pending",
              "dimensions": {"mutation": "book_pending"},
              "enabledActions": ["open_location_map"],
              "disabledActions": ["book"]
            },
            {
              "id": "cancel_pending",
              "dimensions": {"participation": "signed_up", "mutation": "cancel_pending"},
              "enabledActions": ["open_location_map"],
              "disabledActions": ["cancel_booking"]
            }
          ]
        },
        "booking_failed": {
          "actionCases": [
            {
              "id": "book_failed",
              "dimensions": {"mutation": "book_failed"},
              "enabledActions": ["book", "open_location_map"]
            },
            {
              "id": "cancel_failed",
              "dimensions": {"participation": "signed_up", "mutation": "cancel_failed"},
              "enabledActions": ["cancel_booking", "open_location_map"]
            },
            {
              "id": "book_succeeded",
              "dimensions": {"participation": "signed_up", "mutation": "book_succeeded"},
              "enabledActions": ["cancel_booking", "open_location_map"]
            },
            {
              "id": "cancel_succeeded",
              "dimensions": {"mutation": "cancel_succeeded"},
              "enabledActions": ["book", "open_location_map"]
            }
          ]
        },
        "waitlist_sold_out_cancelled_past": {
          "actionCases": [
            {
              "id": "waitlisted",
              "dimensions": {"participation": "waitlisted"},
              "enabledActions": ["leave_waitlist", "open_location_map"]
            },
            {
              "id": "waitlist_offer",
              "dimensions": {"participation": "waitlist_offer"},
              "enabledActions": ["accept_waitlist_offer", "decline_waitlist_offer", "open_location_map"]
            },
            {
              "id": "full",
              "dimensions": {"participation": "full"},
              "enabledActions": ["join_waitlist", "open_location_map"]
            },
            {
              "id": "attended",
              "dimensions": {"participation": "attended"},
              "enabledActions": ["open_location_map"]
            },
            {
              "id": "past",
              "dimensions": {"participation": "past"},
              "enabledActions": ["open_location_map"]
            },
            {
              "id": "cancelled",
              "dimensions": {"participation": "cancelled"},
              "enabledActions": ["open_location_map"]
            }
          ]
        },
        "offline": {
          "dimensions": {"load": "offline"},
          "actionCases": [{"id": "default"}]
        },
        "text_scale_2": {
          "dimensions": {"accessibility": "text_scale_2"},
          "actionCases": [
            {"id": "eligible", "enabledActions": ["book", "open_location_map"]}
          ]
        },
        "reduced_motion": {
          "dimensions": {"accessibility": "reduced_motion"},
          "actionCases": [
            {"id": "eligible", "enabledActions": ["book", "open_location_map"]}
          ]
        }
      },
      "requiredEvidence": {
        "captures": true,
        "previews": true,
        "tests": true
      }
    },
    {
      "id": "marketing_web",
      "runtime": "react_marketing",
      "authority": {
        "registry": "marketing_routes",
        "id": "event_detail_canonical"
      },
      "actionScope": {
        "included": "Read-only public Event Detail handoffs to the Catch app, an official external registration source, the canonical organizer page, or the organizer claim flow.",
        "excluded": [
          "The marketing projection never books, joins a waitlist, checks out, authenticates, or writes an event review.",
          "Static path generation, canonical metadata, Event JSON-LD, sitemap inclusion, and missing-event fallback remain owned by the route and postbuild contracts."
        ]
      },
      "bindings": {
        "previewSources": [
          "website/src/stories/MarketingRoutes.stories.tsx",
          "website/src/stories/EventDetailSections.stories.tsx"
        ],
        "actionOwners": [
          {
            "id": "event_detail_hero",
            "language": "typescript",
            "file": "website/src/features/events/sections/EventDetailSections.tsx",
            "symbol": "EventDetailHeroSection"
          }
        ],
        "componentContracts": [
          "route_event_detail",
          "shared_event_detail_shells",
          "event_detail_hero_section",
          "event_detail_facts_section",
          "event_detail_reviews_section",
          "event_detail_provenance_section"
        ],
        "dataContracts": [
          "contracts/public/website_host_listing_projection.schema.json"
        ],
        "previewEvidence": {
          "catch-native": [
            "route_event_detail/EventDetailCatch",
            "event_detail_hero_section/EventDetailHero"
          ],
          "external-source": [
            "route_event_detail/EventDetailCatch",
            "event_detail_hero_section/EventDetailHero"
          ],
          "event-reviews": [
            "route_event_detail/EventDetailCatch",
            "event_detail_reviews_section/EventDetailReviews"
          ]
        },
        "testEvidence": {
          "catch-native": [
            "website/src/features/events/eventDetailModel.test.ts",
            "website/src/features/events/sections/EventDetailSections.test.tsx",
            "website/scripts/postbuild.test.mjs"
          ],
          "external-source": [
            "website/src/features/events/eventDetailModel.test.ts",
            "website/src/features/events/sections/EventDetailSections.test.tsx",
            "website/scripts/postbuild.test.mjs"
          ],
          "event-reviews": [
            "website/src/features/events/eventDetailModel.test.ts",
            "website/src/features/events/sections/EventDetailSections.test.tsx"
          ],
          "missing-event": [
            "website/src/features/events/eventDetailModel.test.ts",
            "website/scripts/postbuild.test.mjs"
          ]
        }
      },
      "dimensions": {
        "availability": {
          "default": "ready",
          "values": ["ready", "missing"]
        },
        "supply": {
          "default": "catch_native",
          "values": ["catch_native", "external"]
        },
        "registration": {
          "default": "open",
          "values": ["open", "full", "closed"]
        },
        "reviews": {
          "default": "empty",
          "values": ["empty", "present"]
        },
        "claim": {
          "default": "hidden",
          "values": ["hidden", "available"]
        }
      },
      "actions": [
        {
          "id": "open_catch_registration_handoff",
          "owner": "event_detail_hero",
          "codeValue": "appDownloadCtas",
          "cardinality": "unbounded",
          "scopeKeys": ["routeInstanceId", "eventId", "storeTarget"],
          "outcomes": [
            {"kind": "side_effect", "id": "event.web_catch_registration_handoff"}
          ],
          "description": "Hands an eligible Catch-native event to the configured app-store destination without claiming the website performed a booking."
        },
        {
          "id": "open_official_registration_source",
          "owner": "event_detail_hero",
          "codeValue": "sourceHref",
          "cardinality": "unbounded",
          "scopeKeys": ["routeInstanceId", "eventId", "sourceHref"],
          "outcomes": [
            {"kind": "side_effect", "id": "event.web_official_source_opened"}
          ],
          "description": "Opens the supplied official source for an external event in a separate browser context."
        },
        {
          "id": "open_event_organizer",
          "owner": "event_detail_hero",
          "codeValue": "listingPath",
          "cardinality": "unbounded",
          "scopeKeys": ["routeInstanceId", "eventId", "listingId"],
          "outcomes": [
            {
              "kind": "route",
              "authority": {
                "registry": "marketing_routes",
                "id": "organizer_listing_canonical"
              }
            }
          ],
          "description": "Navigates to the canonical public organizer projection that supplied the event."
        },
        {
          "id": "open_event_organizer_claim",
          "owner": "event_detail_hero",
          "codeValue": "claimHrefForListing",
          "cardinality": "singleton",
          "scopeKeys": ["routeInstanceId", "listingId", "claimCapabilityVersion"],
          "outcomes": [
            {
              "kind": "route",
              "authority": {
                "registry": "marketing_routes",
                "id": "claim"
              }
            }
          ],
          "description": "Exposes the organizer claim flow only when the canonical listing policy declares an enabled claim capability."
        }
      ],
      "stateIds": [
        "catch-native",
        "external-source",
        "event-reviews",
        "missing-event"
      ],
      "scenarioDefaults": {
        "dimensions": {},
        "actionCases": [
          {
            "id": "catch_registration_open",
            "enabledActions": [
              "open_catch_registration_handoff",
              "open_event_organizer"
            ]
          }
        ]
      },
      "scenarioOverrides": {
        "catch-native": {
          "actionCases": [
            {
              "id": "registration_open",
              "enabledActions": [
                "open_catch_registration_handoff",
                "open_event_organizer"
              ]
            },
            {
              "id": "claim_available",
              "dimensions": {"claim": "available"},
              "enabledActions": [
                "open_catch_registration_handoff",
                "open_event_organizer",
                "open_event_organizer_claim"
              ]
            },
            {
              "id": "registration_closed",
              "dimensions": {"registration": "closed"},
              "enabledActions": ["open_event_organizer"]
            }
          ]
        },
        "external-source": {
          "dimensions": {"supply": "external"},
          "actionCases": [
            {
              "id": "registration_open",
              "enabledActions": [
                "open_official_registration_source",
                "open_event_organizer"
              ]
            },
            {
              "id": "claim_available",
              "dimensions": {"claim": "available"},
              "enabledActions": [
                "open_official_registration_source",
                "open_event_organizer",
                "open_event_organizer_claim"
              ]
            },
            {
              "id": "registration_closed",
              "dimensions": {"registration": "closed"},
              "enabledActions": ["open_event_organizer"]
            }
          ]
        },
        "event-reviews": {
          "dimensions": {"reviews": "present"}
        },
        "missing-event": {
          "dimensions": {"availability": "missing"},
          "actionCases": [{"id": "missing"}]
        }
      },
      "requiredEvidence": {
        "captures": false,
        "previews": true,
        "tests": true
      },
      "evidenceExceptions": [
        {
          "stateIds": ["missing-event"],
          "evidence": ["previews"],
          "debtId": "FEATURE-CONTRACT-MIGRATION-001",
          "reason": "Missing Event Detail paths fall through to the canonical not-found route and are proved by route-model and postbuild tests rather than a duplicate Event Detail story."
        }
      ]
    },
    {
      "id": "location_map_flutter",
      "runtime": "flutter",
      "authority": {
        "registry": "flutter_screens",
        "id": "screen.event.location_map"
      },
      "actionScope": {
        "included": "Closing the exact-location projection, retrying its Event Detail read model, and launching walking directions for the event's canonical starting point.",
        "excluded": [
          "Map camera movement, network-tile loading, and marker rendering are presentation behavior rather than user decisions.",
          "This read-only route does not search for, move, or persist event locations; LocationPickerScreen remains owned by host create/edit workflows."
        ]
      },
      "bindings": {
        "previewSources": [
          "widgetbook/lib/utility/p3_utility_use_cases.dart"
        ],
        "actionOwners": [
          {
            "id": "location_map_route",
            "language": "dart",
            "file": "lib/events/presentation/event_location_map_screen.dart",
            "symbol": "EventLocationMapRouteScreen"
          },
          {
            "id": "map_overlay",
            "language": "dart",
            "file": "lib/events/presentation/widgets/map_overlay_controls.dart",
            "symbol": "MapOverlayControls"
          },
          {
            "id": "external_links",
            "language": "dart",
            "file": "lib/core/external_links.dart",
            "symbol": "ExternalLinkController"
          }
        ],
        "componentContracts": [
          "catch.button",
          "catch.error_state",
          "catch.map_preview",
          "catch.surface"
        ],
        "dataContracts": [
          "contracts/firestore/events.schema.json"
        ]
      },
      "dimensions": {
        "load": {
          "default": "ready",
          "values": ["ready", "loading", "error", "not_found"]
        },
        "location": {
          "default": "exact",
          "values": ["exact", "unavailable"]
        },
        "map_mode": {
          "default": "network",
          "values": ["network", "deterministic", "masking_unresolved"]
        },
        "directions": {
          "default": "idle",
          "values": ["idle", "pending", "failure"]
        },
        "accessibility": {
          "default": "standard",
          "values": ["standard", "text_scale_2", "reduced_motion"]
        },
        "theme": {
          "default": "standard",
          "values": ["standard", "light_dark"]
        }
      },
      "actions": [
        {
          "id": "close_location_map",
          "owner": "map_overlay",
          "codeValue": "maybePop",
          "cardinality": "singleton",
          "scopeKeys": ["routeInstanceId"],
          "outcomes": [
            {"kind": "side_effect", "id": "navigation.route_popped"}
          ],
          "description": "Closes the exact-location projection through its floating back control."
        },
        {
          "id": "retry_event_location",
          "owner": "location_map_route",
          "codeValue": "invalidate",
          "cardinality": "singleton",
          "scopeKeys": ["eventId", "eventLoadGeneration"],
          "outcomes": [
            {"kind": "surface_state", "stateIds": ["route_loading", "route_error", "event_not_found", "pinned_location"]}
          ],
          "description": "Invalidates the shared Event Detail read model after an event-location load failure."
        },
        {
          "id": "get_directions",
          "owner": "external_links",
          "codeValue": "openExternal",
          "cardinality": "singleton",
          "scopeKeys": ["routeInstanceId", "eventId", "directionsUri"],
          "outcomes": [
            {"kind": "surface_state", "stateIds": ["directions_action"]},
            {"kind": "side_effect", "id": "external_links.open_walking_directions"}
          ],
          "description": "Requests the platform's external maps application with walking directions to the exact starting coordinate, disables duplicate launches while pending, and restores the action with visible feedback after false or thrown failures."
        }
      ],
      "stateIds": [
        "route_loading",
        "route_error",
        "event_not_found",
        "no_exact_coordinate",
        "pinned_location",
        "directions_action",
        "network_tiles_disabled_capture",
        "map_masking",
        "text_scale_2",
        "reduced_motion",
        "light_dark"
      ],
      "scenarioDefaults": {
        "dimensions": {},
        "actionCases": [
          {"id": "exact_location", "enabledActions": ["close_location_map", "get_directions"]}
        ]
      },
      "scenarioOverrides": {
        "route_loading": {
          "dimensions": {"load": "loading"},
          "actionCases": [{"id": "loading", "enabledActions": ["close_location_map"]}]
        },
        "route_error": {
          "dimensions": {"load": "error"},
          "actionCases": [{"id": "retry", "enabledActions": ["close_location_map", "retry_event_location"]}]
        },
        "event_not_found": {
          "dimensions": {"load": "not_found"},
          "actionCases": [{"id": "missing", "enabledActions": ["close_location_map"]}]
        },
        "no_exact_coordinate": {
          "dimensions": {"location": "unavailable"},
          "actionCases": [{"id": "unavailable", "enabledActions": ["close_location_map"]}]
        },
        "directions_action": {
          "actionCases": [
            {
              "id": "idle",
              "dimensions": {"directions": "idle"},
              "enabledActions": ["close_location_map", "get_directions"]
            },
