          }
        }
      },
      "requiredEvidence": {
        "captures": true,
        "previews": true,
        "tests": true
      },
      "evidenceExceptions": [
        {
          "stateIds": [
            "event_not_found",
            "sign_in_required",
            "no_booking",
            "data_load_error",
            "self_check_in",
            "offline",
            "text_scale_2",
            "reduced_motion",
            "light_dark"
          ],
          "evidence": [
            "tests"
          ],
          "debtId": "FEATURE-CONTRACT-MIGRATION-001",
          "reason": "These registered companion states have deterministic captures and Widgetbook evidence but no focused state-level automated test recorded by the screen authority yet."
        },
        {
          "stateIds": [
            "auto_launch"
          ],
          "evidence": [
            "captures",
            "previews"
          ],
          "debtId": "FEATURE-CONTRACT-MIGRATION-001",
          "reason": "Auto-launch is transition policy verified by the companion-launcher test rather than a stable standalone render state, so no deterministic capture or Widgetbook preview is registered."
        }
      ]
    }
  ]
}
