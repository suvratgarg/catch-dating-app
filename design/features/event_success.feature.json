{
  "$schema": "./feature_contract.schema.json",
  "version": 2,
  "updated": "2026-07-23",
  "id": "feature.event_success",
  "name": "Event Success",
  "owner": "event_success",
  "status": "pilot",
  "description": "Orchestrates the attendee Event Success Companion from route gating and arrival through live guidance, assignments, reveal, host-help requests, private feedback, opt-outs, and transition-triggered auto-launch.",
  "surfaces": [
    {
      "id": "consumer_flutter",
      "runtime": "flutter",
      "authority": {
        "registry": "flutter_screens",
        "id": "screen.event_success.companion"
      },
      "actionScope": {
        "included": "Companion data recovery, self-check-in and First Hello arrival actions, compatibility answers, assignment preferences, cue copy, host-help requests, and private event feedback.",
        "excluded": [
          "Host setup, live-step control, assignment generation and overrides, reveal control, effect scheduling, and route auto-launch policy retain their host or launcher owners; the registered auto-launch state is evidence-only rather than a user action."
        ]
      },
      "bindings": {
        "previewSources": [
          "widgetbook/lib/event_success/event_success_companion_use_cases.dart"
        ],
        "actionOwners": [
          {
            "id": "companion_route",
            "language": "dart",
            "file": "lib/event_success/presentation/event_success_companion_screen.dart",
            "symbol": "EventSuccessCompanionRouteScreen"
          },
          {
            "id": "event_success_controller",
            "language": "dart",
            "file": "lib/event_success/presentation/event_success_controller.dart",
            "symbol": "EventSuccessController"
          },
          {
            "id": "booking_controller",
            "language": "dart",
            "file": "lib/events/presentation/event_booking_controller.dart",
            "symbol": "EventBookingController"
          },
          {
            "id": "conversation_cue",
            "language": "dart",
            "file": "lib/event_success/presentation/companion_parts/event_success_companion_live_cards.dart",
            "symbol": "StageCueLine"
          }
        ],
        "componentContracts": [
          "catch.button",
          "catch.error_state",
          "catch.field",
          "catch.icon_button",
          "catch.privacy_badge",
          "catch.skeleton",
          "catch.surface",
          "catch.toggle",
          "catch.top_bar"
        ],
        "dataContracts": [
          "contracts/callables/complete_event_success_first_hello_mission_payload.schema.json",
          "contracts/callables/self_check_in_attendance_payload.schema.json",
          "contracts/callables/start_event_success_first_hello_mission_payload.schema.json",
          "contracts/callables/submit_event_success_wingman_request_payload.schema.json",
          "contracts/firestore/event_participations.schema.json",
          "contracts/firestore/event_success_arrival_missions.schema.json",
          "contracts/firestore/event_success_assignments.schema.json",
          "contracts/firestore/event_success_compatibility_responses.schema.json",
          "contracts/firestore/event_success_feedback.schema.json",
          "contracts/firestore/event_success_plans.schema.json",
          "contracts/firestore/event_success_preferences.schema.json",
          "contracts/firestore/event_success_wingman_requests.schema.json",
          "contracts/firestore/events.schema.json",
          "contracts/firestore/public_profiles.schema.json",
          "contracts/firestore/users.schema.json"
        ]
      },
      "dimensions": {
        "load": {
          "default": "ready",
          "values": [
            "ready",
            "loading",
            "message",
            "error",
            "offline"
          ]
        },
        "moment": {
          "default": "live",
          "values": [
            "live",
            "pre_arrival",
            "arrival",
            "first_hello",
            "questionnaire",
            "assignment",
            "reveal",
            "wingman",
            "post_event"
          ]
        },
        "mutation": {
          "default": "idle",
          "values": [
            "idle",
            "pending",
            "known_gap"
          ]
        },
        "launch": {
          "default": "route",
          "values": [
            "route",
            "transition_auto_launch"
          ]
        },
        "accessibility": {
          "default": "standard",
          "values": [
            "standard",
            "text_scale_2",
            "reduced_motion"
          ]
        },
        "theme": {
          "default": "standard",
          "values": [
            "standard",
            "light_dark"
          ]
        }
      },
      "actions": [
        {
          "id": "retry_companion_data",
          "owner": "companion_route",
          "codeValue": "companionRouteRetryCallback",
          "cardinality": "singleton",
          "scopeKeys": [
            "viewerUid",
            "eventId",
            "retryIntent",
            "failureStateVersion"
          ],
          "outcomes": [
            {
              "kind": "surface_state",
              "stateIds": [
                "route_loading",
                "default_live_guide"
              ]
            }
          ],
          "description": "Invalidates only the provider selected by the companion route's typed retry intent."
        },
        {
          "id": "self_check_in",
          "owner": "booking_controller",
          "codeValue": "selfCheckIn",
          "cardinality": "singleton",
          "scopeKeys": [
            "viewerUid",
            "eventId",
            "participationVersion"
          ],
          "outcomes": [
            {
              "kind": "surface_state",
              "stateIds": [
                "self_check_in",
                "default_live_guide"
              ]
            },
            {
              "kind": "side_effect",
              "id": "event.participation_self_checked_in"
            }
          ],
          "description": "Confirms attendance once through location verification, after either direct check-in or a matching host QR scan."
        },
        {
          "id": "start_first_hello",
          "owner": "event_success_controller",
          "codeValue": "startFirstHelloMission",
          "cardinality": "singleton",
          "scopeKeys": [
            "viewerUid",
            "eventId",
            "missionVersion"
          ],
          "outcomes": [
            {
              "kind": "surface_state",
              "stateIds": [
                "first_hello_assigned"
              ]
            },
            {
              "kind": "side_effect",
              "id": "event_success.first_hello_started"
            }
          ],
          "description": "Creates the viewer's location-verified First Hello mission once for the current event."
        },
        {
          "id": "complete_first_hello",
          "owner": "event_success_controller",
          "codeValue": "completeFirstHelloMission",
          "cardinality": "singleton",
          "scopeKeys": [
            "viewerUid",
            "eventId",
            "missionId",
            "answerId"
          ],
          "outcomes": [
            {
              "kind": "surface_state",
              "stateIds": [
                "default_live_guide"
              ]
            },
            {
              "kind": "side_effect",
              "id": "event_success.first_hello_completed"
            }
          ],
          "description": "Completes the assigned First Hello mission once with the selected answer and verified location."
        },
        {
          "id": "skip_first_hello",
          "owner": "booking_controller",
          "codeValue": "selfCheckIn",
          "cardinality": "singleton",
          "scopeKeys": [
            "viewerUid",
            "eventId",
            "missionVersion"
          ],
          "outcomes": [
            {
              "kind": "surface_state",
              "stateIds": [
                "default_live_guide"
              ]
            },
            {
              "kind": "side_effect",
              "id": "event.participation_self_checked_in"
            }
          ],
          "description": "Skips First Hello by completing the shared self-check-in path for the current event."
        },
        {
          "id": "save_compatibility_answers",
          "owner": "event_success_controller",
          "codeValue": "saveCompatibilityResponse",
          "cardinality": "singleton",
          "scopeKeys": [
            "viewerUid",
            "eventId",
            "questionnaireVersion"
          ],
          "outcomes": [
            {
              "kind": "surface_state",
              "stateIds": [
                "compatibility_questionnaire",
                "default_live_guide"
              ]
            },
            {
              "kind": "side_effect",
              "id": "event_success.compatibility_response_saved"
            }
          ],
          "description": "Normalizes and persists one compatibility-questionnaire response for the current event and viewer.",
          "implementationStatus": "known_gap",
          "debtId": "FEATURE-ACTION-WIRING-001",
          "implementationNotes": "EventSuccessController.saveCompatibilityResponse and the provider-free callback exist, but EventSuccessCompanionRouteScreen does not pass onSaveCompatibilityAnswers into EventSuccessCompanionScreen; production taps currently fall through to the no-op default."
        },
        {
          "id": "set_micro_pods_included",
          "owner": "event_success_controller",
          "codeValue": "setMicroPodsOptOut",
          "cardinality": "singleton",
          "scopeKeys": [
            "viewerUid",
            "eventId",
            "preferenceVersion"
          ],
          "outcomes": [
            {
              "kind": "surface_state",
              "stateIds": [
                "micro_pod_assignment",
                "opt_out_assignments"
              ]
            },
            {
              "kind": "side_effect",
              "id": "event_success.micro_pod_preference_updated"
            }
          ],
          "description": "Persists whether the viewer is included in micro-pod assignments for this event."
        },
        {
          "id": "set_guided_rotations_included",
          "owner": "event_success_controller",
          "codeValue": "setGuidedRotationsOptOut",
          "cardinality": "singleton",
          "scopeKeys": [
            "viewerUid",
            "eventId",
            "preferenceVersion"
          ],
          "outcomes": [
            {
              "kind": "surface_state",
              "stateIds": [
                "rotation_schedule",
                "live_reveal_countdown",
                "live_reveal_unlocked",
                "opt_out_assignments"
              ]
            },
            {
              "kind": "side_effect",
              "id": "event_success.guided_rotation_preference_updated"
            }
          ],
          "description": "Persists whether the viewer is included in guided rotations for this event."
        },
        {
          "id": "save_wingman_request",
          "owner": "event_success_controller",
          "codeValue": "saveWingmanRequest",
          "cardinality": "singleton",
          "scopeKeys": [
            "viewerUid",
            "eventId",
            "targetUid",
            "requestVersion"
          ],
          "outcomes": [
            {
              "kind": "surface_state",
              "stateIds": [
                "wingman_request"
              ]
            },
            {
              "kind": "side_effect",
              "id": "event_success.wingman_request_saved"
            }
          ],
          "description": "Creates or replaces the viewer's private host-help request for one checked-in attendee."
        },
        {
          "id": "withdraw_wingman_request",
          "owner": "event_success_controller",
          "codeValue": "withdrawWingmanRequest",
          "cardinality": "singleton",
          "scopeKeys": [
            "viewerUid",
            "eventId",
            "requestVersion"
          ],
          "outcomes": [
            {
              "kind": "surface_state",
              "stateIds": [
                "wingman_request"
              ]
            },
            {
              "kind": "side_effect",
              "id": "event_success.wingman_request_withdrawn"
            }
          ],
          "description": "Withdraws the viewer's active private host-help request for the event."
        },
        {
          "id": "submit_feedback",
          "owner": "event_success_controller",
          "codeValue": "submitFeedback",
          "cardinality": "singleton",
          "scopeKeys": [
            "viewerUid",
            "eventId",
            "feedbackVersion"
          ],
          "outcomes": [
            {
              "kind": "surface_state",
              "stateIds": [
                "post_event_afterglow_feedback"
              ]
            },
            {
              "kind": "side_effect",
              "id": "event_success.private_feedback_saved"
            }
          ],
          "description": "Creates or updates the viewer's private post-event feedback once for the current feedback version."
        },
        {
          "id": "copy_conversation_cue",
          "owner": "conversation_cue",
          "codeValue": "_copyCue",
          "cardinality": "unbounded",
          "scopeKeys": [
            "viewerUid",
            "eventId",
            "cueId",
            "copyAttemptId"
          ],
          "outcomes": [
            {
              "kind": "side_effect",
              "id": "event_success.conversation_cue_copied"
            }
          ],
          "description": "Copies one live or post-event conversation cue to the clipboard and confirms the copy in branded feedback."
        }
      ],
      "stateIds": [
        "route_loading",
        "event_not_found",
        "sign_in_required",
        "no_booking",
        "plan_missing",
        "data_load_error",
        "default_live_guide",
        "pre_arrival_planning",
        "self_check_in",
        "first_hello_start",
        "first_hello_assigned",
        "compatibility_questionnaire",
        "live_step_context",
        "conversation_cues",
        "micro_pod_assignment",
        "rotation_schedule",
        "live_reveal_countdown",
        "live_reveal_unlocked",
        "wingman_request",
        "post_event_afterglow_feedback",
        "opt_out_assignments",
        "auto_launch",
        "offline",
        "text_scale_2",
        "reduced_motion",
        "light_dark"
      ],
      "scenarioDefaults": {
        "dimensions": {},
        "actionCases": [
          {
            "id": "default"
          }
        ]
      },
      "scenarioOverrides": {
        "route_loading": {
          "dimensions": {
            "load": "loading"
          }
        },
        "event_not_found": {
          "dimensions": {
            "load": "message"
          }
        },
        "sign_in_required": {
          "dimensions": {
            "load": "message"
          }
        },
        "no_booking": {
          "dimensions": {
            "load": "message"
          }
        },
        "plan_missing": {
          "dimensions": {
            "load": "message"
          }
        },
        "data_load_error": {
          "dimensions": {
            "load": "error"
          },
          "actionCases": [
            {
              "id": "recovery",
              "enabledActions": [
                "retry_companion_data"
              ]
            }
          ]
        },
        "pre_arrival_planning": {
          "dimensions": {
            "moment": "pre_arrival"
          }
