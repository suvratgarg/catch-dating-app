              ]
            }
          ]
        },
        "first_hello_start": {
          "dimensions": {
            "moment": "first_hello"
          },
          "actionCases": [
            {
              "id": "idle",
              "enabledActions": [
                "start_first_hello",
                "skip_first_hello"
              ]
            },
            {
              "id": "pending",
              "dimensions": {
                "mutation": "pending"
              },
              "disabledActions": [
                "start_first_hello",
                "skip_first_hello"
              ]
            }
          ]
        },
        "first_hello_assigned": {
          "dimensions": {
            "moment": "first_hello"
          },
          "actionCases": [
            {
              "id": "idle",
              "enabledActions": [
                "complete_first_hello",
                "skip_first_hello"
              ]
            },
            {
              "id": "pending",
              "dimensions": {
                "mutation": "pending"
              },
              "disabledActions": [
                "complete_first_hello",
                "skip_first_hello"
              ]
            }
          ]
        },
        "compatibility_questionnaire": {
          "dimensions": {
            "moment": "questionnaire",
            "mutation": "known_gap"
          },
          "actionCases": [
