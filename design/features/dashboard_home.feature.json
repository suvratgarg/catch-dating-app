{
  "$schema": "./feature_contract.schema.json",
  "version": 2,
  "updated": "2026-07-23",
  "id": "feature.dashboard_home",
  "name": "Dashboard Home",
  "owner": "dashboard",
  "status": "pilot",
  "description": "Orchestrates the signed-in consumer home across initial loading and recovery, empty discovery, event focus, check-in, Catch-window and review entry, notification routing, and registered enrichment variants.",
  "surfaces": [
    {
      "id": "consumer_flutter",
      "runtime": "flutter",
      "authority": {
        "registry": "flutter_screens",
        "id": "screen.dashboard.home"
      },
      "actionScope": {
        "included": "Dashboard route recovery, header navigation, empty-state discovery, event-focus actions, club-post routing, and self-check-in recovery.",
        "excluded": [
          "Notification-list mutations, Event Detail booking, Catch deck decisions, review submission, calendar persistence, companion internals, and recommendation ranking retain their owning feature contracts or controllers."
        ]
      },
      "bindings": {
        "previewSources": [
          "widgetbook/lib/dashboard/dashboard_use_cases.dart"
        ],
        "actionOwners": [
          {
            "id": "route_screen",
            "language": "dart",
            "file": "lib/dashboard/presentation/dashboard_screen.dart",
            "symbol": "DashboardScreen"
          },
          {
            "id": "full_body",
            "language": "dart",
            "file": "lib/dashboard/presentation/widgets/dashboard_full.dart",
            "symbol": "DashboardFullSliverBody"
          },
          {
            "id": "event_focus_controller",
            "language": "dart",
            "file": "lib/dashboard/presentation/dashboard_event_focus_controller.dart",
            "symbol": "DashboardEventFocusController"
          }
        ],
        "componentContracts": [
          "catch.button",
          "catch.error_banner",
          "catch.error_state",
          "catch.event_card",
          "catch.icon_button",
          "catch.skeleton",
          "catch.surface",
          "catch.top_bar"
        ],
        "dataContracts": [
          "contracts/client_writes/mark_notification_read.schema.json",
          "contracts/firestore/activity_notifications.schema.json",
          "contracts/firestore/club_memberships.schema.json",
          "contracts/firestore/club_posts.schema.json",
          "contracts/firestore/event_participations.schema.json",
          "contracts/firestore/events.schema.json",
          "contracts/firestore/reviews.schema.json",
          "contracts/firestore/users.schema.json"
        ]
      },
      "dimensions": {
        "load": {
          "default": "ready",
          "values": [
            "ready",
            "loading",
            "error",
            "offline"
          ]
        },
        "content": {
          "default": "full",
          "values": [
            "full",
            "empty"
          ]
        },
        "focus": {
          "default": "none",
          "values": [
            "none",
            "upcoming",
            "check_in",
            "after_event"
          ]
        },
        "enrichment": {
          "default": "ready",
          "values": [
            "ready",
            "loading",
            "error",
            "permission_required"
          ]
        },
        "accessibility": {
          "default": "standard",
          "values": [
            "standard",
            "text_scale_2",
            "reduced_motion"
          ]
        },
        "theme": {
          "default": "standard",
          "values": [
            "standard",
            "light_dark"
          ]
        }
      },
      "actions": [
        {
          "id": "retry_dashboard",
          "owner": "route_screen",
          "codeValue": "invalidate",
          "cardinality": "singleton",
          "scopeKeys": [
            "routeInstanceId",
            "retryTarget",
            "failureStateVersion"
          ],
          "outcomes": [
            {
              "kind": "surface_state",
              "stateIds": [
                "loading",
                "empty_start",
                "full_dashboard"
              ]
            }
          ],
          "description": "Invalidates only the failed dashboard provider selected by the typed retry target."
        },
        {
          "id": "open_calendar",
          "owner": "route_screen",
          "codeValue": "calendarScreen",
          "cardinality": "unbounded",
          "scopeKeys": [
            "viewerUid",
            "routeInstanceId",
            "tapAttemptId"
          ],
          "outcomes": [
            {
              "kind": "route",
              "authority": {
                "registry": "flutter_screens",
                "id": "screen.calendar.home"
              }
            }
          ],
          "description": "Opens the consumer calendar from full-dashboard header chrome."
        },
        {
          "id": "open_notifications",
          "owner": "route_screen",
          "codeValue": "notificationsScreen",
          "cardinality": "unbounded",
          "scopeKeys": [
            "viewerUid",
            "routeInstanceId",
            "tapAttemptId"
          ],
          "outcomes": [
            {
              "kind": "route",
              "authority": {
                "registry": "flutter_screens",
                "id": "screen.notifications.list"
              }
            }
          ],
          "description": "Opens the notification list while preserving unread-count presentation in the dashboard header."
        },
        {
          "id": "find_event",
          "owner": "full_body",
          "codeValue": "_openExplore",
          "cardinality": "singleton",
          "scopeKeys": [
            "viewerUid",
            "routeInstanceId",
            "emptyStateVersion"
          ],
          "outcomes": [
            {
              "kind": "route",
              "authority": {
                "registry": "flutter_screens",
                "id": "screen.explore.discovery"
              }
            }
          ],
          "description": "Leaves the empty dashboard for Explore once for the current empty-state presentation."
        },
        {
          "id": "open_club_post",
          "owner": "full_body",
          "codeValue": "_openClubPost",
          "cardinality": "domain_bounded",
          "scopeKeys": [
            "viewerUid",
            "notificationId",
            "notificationVersion"
          ],
          "outcomes": [
            {
              "kind": "side_effect",
              "id": "dashboard.club_post_opened_and_marked_read"
            }
          ],
          "description": "Marks the selected club-post notification read and follows its typed destination when one exists."
        },
        {
          "id": "open_event",
          "owner": "full_body",
          "codeValue": "_openEvent",
          "cardinality": "unbounded",
          "scopeKeys": [
            "viewerUid",
            "eventId",
            "tapAttemptId"
          ],
          "outcomes": [
            {
              "kind": "route",
              "authority": {
                "registry": "flutter_screens",
                "id": "screen.event.detail"
              }
            }
          ],
          "description": "Opens Event Detail for the selected upcoming focus event."
        },
        {
          "id": "open_directions",
          "owner": "full_body",
          "codeValue": "_openDirections",
          "cardinality": "unbounded",
          "scopeKeys": [
            "viewerUid",
            "eventId",
            "launchAttemptId"
          ],
          "outcomes": [
            {
              "kind": "side_effect",
              "id": "dashboard.event_directions_opened"
            }
          ],
          "description": "Opens the event location through the shared external-link controller."
        },
        {
          "id": "add_to_calendar",
          "owner": "full_body",
          "codeValue": "_addToCalendar",
          "cardinality": "unbounded",
          "scopeKeys": [
            "viewerUid",
            "eventId",
            "calendarAttemptId"
          ],
          "outcomes": [
            {
              "kind": "side_effect",
              "id": "dashboard.event_calendar_add_requested"
            }
          ],
          "description": "Hands the selected event to the native calendar controller."
        },
        {
          "id": "open_catch_window",
          "owner": "full_body",
          "codeValue": "_openSwipe",
          "cardinality": "domain_bounded",
          "scopeKeys": [
            "viewerUid",
            "eventId",
            "windowClosesAt"
          ],
          "outcomes": [
            {
              "kind": "route",
              "authority": {
                "registry": "flutter_screens",
                "id": "screen.catches.event"
              }
            }
          ],
          "description": "Opens the active event-scoped Catch deck while its window is available."
        },
        {
          "id": "write_review",
          "owner": "full_body",
          "codeValue": "_writeReview",
          "cardinality": "domain_bounded",
          "scopeKeys": [
            "viewerUid",
            "eventId",
            "reviewVersion"
          ],
          "outcomes": [
            {
              "kind": "side_effect",
              "id": "dashboard.event_review_sheet_opened"
            }
          ],
          "description": "Opens the shared event-review sheet for the current pending-review event."
        },
        {
          "id": "self_check_in",
          "owner": "full_body",
          "codeValue": "_checkIn",
          "cardinality": "singleton",
          "scopeKeys": [
            "viewerUid",
            "eventId",
            "participationVersion"
          ],
          "outcomes": [
            {
              "kind": "surface_state",
              "stateIds": [
                "self_check_in_mutation",
                "full_dashboard"
              ]
            },
            {
              "kind": "side_effect",
              "id": "event.participation_self_checked_in"
            }
          ],
          "description": "Runs the location-verified self-check-in mutation once, then launches the companion or fallback celebration."
        },
        {
          "id": "retry_check_in",
          "owner": "event_focus_controller",
          "codeValue": "resetSelfCheckInError",
          "cardinality": "singleton",
          "scopeKeys": [
            "viewerUid",
            "eventId",
            "failureStateVersion"
          ],
          "outcomes": [
            {
              "kind": "surface_state",
              "stateIds": [
                "self_check_in_mutation"
              ]
            }
          ],
          "description": "Clears the inline self-check-in mutation error so the current event action can be attempted again."
        }
      ],
      "stateIds": [
        "loading",
        "profile_error",
        "memberships_error",
        "booked_events_error",
        "empty_start",
        "full_dashboard",
        "event_focus_upcoming",
        "self_check_in_mutation",
        "after_event_swipe_review",
        "notifications_unread",
        "joined_clubs_rail",
        "weekly_activity_permission",
        "recommendations_ready",
        "recommendations_loading",
        "recommendations_error",
        "offline",
        "text_scale_2",
        "reduced_motion",
        "light_dark"
      ],
      "scenarioDefaults": {
        "dimensions": {},
        "actionCases": [
          {
            "id": "default"
          }
        ]
      },
      "scenarioOverrides": {
        "loading": {
          "dimensions": {
            "load": "loading"
          }
        },
        "profile_error": {
          "dimensions": {
            "load": "error"
          },
          "actionCases": [
            {
              "id": "recovery",
              "enabledActions": [
                "retry_dashboard"
              ]
            }
          ]
        },
        "memberships_error": {
          "dimensions": {
            "load": "error"
          },
          "actionCases": [
            {
              "id": "recovery",
              "enabledActions": [
                "retry_dashboard"
              ]
            }
          ]
        },
        "booked_events_error": {
          "dimensions": {
            "load": "error"
          },
          "actionCases": [
            {
              "id": "recovery",
              "enabledActions": [
                "retry_dashboard"
              ]
            }
          ]
        },
        "empty_start": {
          "dimensions": {
            "content": "empty"
          },
          "actionCases": [
            {
              "id": "discovery",
              "enabledActions": [
                "find_event"
              ]
            }
          ]
        },
        "full_dashboard": {
          "actionCases": [
            {
              "id": "header_and_content",
              "enabledActions": [
                "open_calendar",
                "open_notifications",
                "open_event",
                "open_directions",
                "add_to_calendar",
                "open_club_post"
              ]
            }
          ]
        },
        "event_focus_upcoming": {
          "dimensions": {
            "focus": "upcoming"
          },
          "actionCases": [
            {
              "id": "event_focus",
              "enabledActions": [
                "open_event",
                "open_directions",
                "add_to_calendar"
              ]
            }
          ]
        },
        "self_check_in_mutation": {
          "dimensions": {
            "focus": "check_in"
          },
          "actionCases": [
            {
              "id": "idle",
              "enabledActions": [
                "self_check_in",
                "open_directions"
              ]
            },
            {
              "id": "pending",
              "enabledActions": [
                "open_directions"
              ],
              "disabledActions": [
                "self_check_in"
              ]
            },
            {
              "id": "failed",
              "enabledActions": [
                "retry_check_in",
                "open_directions"
              ]
            }
          ]
        },
        "after_event_swipe_review": {
          "dimensions": {
            "focus": "after_event"
          },
          "actionCases": [
            {
              "id": "catch_and_review",
              "enabledActions": [
                "open_catch_window",
                "write_review"
              ]
            }
          ]
        },
        "notifications_unread": {
          "actionCases": [
            {
              "id": "unread",
              "enabledActions": [
                "open_notifications"
              ]
            }
          ]
        },
        "weekly_activity_permission": {
          "dimensions": {
            "enrichment": "permission_required"
          }
        },
        "recommendations_loading": {
          "dimensions": {
            "enrichment": "loading"
          }
        },
        "recommendations_error": {
          "dimensions": {
            "enrichment": "error"
          }
        },
        "offline": {
          "dimensions": {
            "load": "offline"
          },
          "actionCases": [
            {
              "id": "recovery",
              "enabledActions": [
                "retry_dashboard"
              ]
            }
          ]
        },
        "text_scale_2": {
          "dimensions": {
            "accessibility": "text_scale_2"
          },
          "actionCases": [
            {
              "id": "full",
              "enabledActions": [
                "open_calendar",
                "open_notifications",
                "open_event",
                "open_directions",
                "add_to_calendar"
              ]
            }
          ]
        },
        "reduced_motion": {
          "dimensions": {
            "accessibility": "reduced_motion"
          },
          "actionCases": [
            {
              "id": "full",
              "enabledActions": [
                "open_calendar",
                "open_notifications",
                "open_event",
                "open_directions",
                "add_to_calendar"
              ]
            }
          ]
        },
        "light_dark": {
          "dimensions": {
            "theme": "light_dark"
          },
          "actionCases": [
            {
              "id": "full",
              "enabledActions": [
                "open_calendar",
                "open_notifications",
                "open_event",
                "open_directions",
                "add_to_calendar"
              ]
            }
          ]
        }
      },
      "requiredEvidence": {
        "captures": true,
        "previews": true,
        "tests": true
      },
      "evidenceExceptions": [
        {
          "stateIds": [
            "profile_error",
            "memberships_error",
            "offline",
            "text_scale_2",
            "reduced_motion",
            "light_dark"
          ],
          "evidence": [
            "tests"
          ],
          "debtId": "FEATURE-CONTRACT-MIGRATION-001",
          "reason": "These registered Dashboard states have deterministic captures and Widgetbook evidence but no focused state-level automated test recorded by the screen authority yet."
        }
      ]
    }
  ]
}
