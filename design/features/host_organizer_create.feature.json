{
  "$schema": "./feature_contract.schema.json",
  "version": 2,
  "updated": "2026-07-23",
  "id": "feature.host_organizer_create",
  "name": "Host Organizer Create",
  "owner": "hosts",
  "status": "pilot",
  "description": "Orchestrates the host organizer-creation wizard, local draft recovery, media and organizer-default choices, submission, and route dismissal.",
  "surfaces": [
    {
      "id": "host_flutter",
      "runtime": "flutter",
      "authority": {
        "registry": "flutter_screens",
        "id": "screen.host.club.create"
      },
      "actionScope": {
        "included": "Wizard navigation; organizer type, city, cover/profile media, Host defaults, and Event Success defaults; local draft save and recovery; organizer submission; and route dismissal.",
        "excluded": [
          "Raw text-field edits are form data governed by CatchField, form validators, and organizer data contracts rather than separately cardinalized actions.",
          "Automatic initial draft loading, submit-success draft deletion, and submit-success route closure are lifecycle effects rather than user actions.",
          "Launching organizer creation from Host Home or Host Organizers retains the source feature's navigation ownership; post-create organizer administration retains Host Organizer Detail ownership."
        ]
      },
      "bindings": {
        "previewSources": [
          "widgetbook/lib/hosts/host_operations_use_cases.dart"
        ],
        "actionOwners": [
          {
            "id": "route_intent",
            "language": "dart",
            "file": "lib/hosts/presentation/club_management/create/create_club_screen.dart",
            "symbol": "HostClubCreateRouteIntent"
          },
          {
            "id": "primary_intent",
            "language": "dart",
            "file": "lib/hosts/presentation/club_management/create/create_club_screen_state.dart",
            "symbol": "HostClubCreatePrimaryIntent"
          },
          {
            "id": "submit_controller",
            "language": "dart",
            "file": "lib/hosts/presentation/club_management/create/create_club_controller.dart",
            "symbol": "CreateClubController"
          },
          {
            "id": "draft_controller",
            "language": "dart",
            "file": "lib/hosts/presentation/club_management/create/create_club_draft_controller.dart",
            "symbol": "CreateClubDraftController"
          }
        ],
        "componentContracts": [
          "catch.button",
          "catch.error_banner",
          "catch.field",
          "catch.option_card",
          "catch.option_group",
          "catch.surface",
          "catch.top_bar"
        ],
        "dataContracts": [
          "contracts/firestore/clubs.schema.json",
          "contracts/storage/club_logo_images.schema.json",
          "contracts/storage/club_logo_thumbnails.schema.json",
          "contracts/storage/club_photos.schema.json"
        ]
      },
      "dimensions": {
        "step": {
          "default": "basics",
          "values": [
            "basics",
            "details",
            "host_defaults",
            "event_success"
          ]
        },
        "draft": {
          "default": "none",
          "values": [
            "none",
            "restored",
            "saving",
            "error"
          ]
        },
        "media": {
          "default": "empty",
          "values": [
            "empty",
            "selected"
          ]
        },
        "authentication": {
          "default": "signed_in",
          "values": [
            "signed_in",
            "missing"
          ]
        },
        "mutation": {
          "default": "idle",
          "values": [
            "idle",
            "validation",
            "pending",
            "error",
            "settled"
          ]
        },
        "connectivity": {
          "default": "online",
          "values": [
            "online",
            "offline"
          ]
        },
        "accessibility": {
          "default": "standard",
          "values": [
            "standard",
            "text_scale_2",
            "reduced_motion"
          ]
        },
        "theme": {
          "default": "standard",
          "values": [
            "standard",
            "light_dark"
          ]
        }
      },
      "actions": [
        {
          "id": "navigate_back",
          "owner": "route_intent",
          "codeValue": "HostClubCreateBackIntent",
          "cardinality": "unbounded",
          "scopeKeys": [
            "routeInstanceId",
            "currentStep"
          ],
          "outcomes": [
            {
              "kind": "surface_state",
              "stateIds": [
                "basics_default",
                "details_step",
                "host_defaults_step"
              ]
            },
            {
              "kind": "side_effect",
              "id": "host_organizer_create.dismissed"
            }
          ],
          "description": "Moves to the preceding wizard step, or dismisses the route from the first step."
        },
        {
          "id": "next_step",
          "owner": "primary_intent",
          "codeValue": "nextStep",
          "cardinality": "unbounded",
          "scopeKeys": [
            "routeInstanceId",
            "currentStep",
            "draftSignature"
          ],
          "outcomes": [
            {
              "kind": "surface_state",
              "stateIds": [
                "basics_validation",
                "details_step",
                "host_defaults_step",
                "event_success_defaults_step"
              ]
            }
          ],
          "description": "Validates the current wizard step and advances only when its form rules pass."
        },
        {
          "id": "select_club_photos",
          "owner": "route_intent",
          "codeValue": "HostClubCreatePickClubPhotosIntent",
          "cardinality": "unbounded",
          "scopeKeys": [
            "routeInstanceId",
            "remainingPhotoSlots"
          ],
          "outcomes": [
            {
              "kind": "surface_state",
              "stateIds": [
                "club_photos",
                "offline"
              ]
            }
          ],
          "description": "Selects ordered organizer cover photos up to the remaining media limit."
        },
        {
          "id": "select_profile_image",
          "owner": "route_intent",
          "codeValue": "HostClubCreatePickProfileImageIntent",
          "cardinality": "unbounded",
          "scopeKeys": [
            "routeInstanceId",
            "profileImageVersion"
          ],
          "outcomes": [
            {
              "kind": "surface_state",
              "stateIds": [
                "club_photos",
                "offline"
              ]
            }
          ],
          "description": "Selects or replaces the organizer profile image."
        },
        {
          "id": "remove_club_photo",
          "owner": "route_intent",
          "codeValue": "HostClubCreateRemoveClubPhotoIntent",
          "cardinality": "unbounded",
          "scopeKeys": [
            "routeInstanceId",
            "photoDraftId"
          ],
          "outcomes": [
            {
              "kind": "surface_state",
              "stateIds": [
                "club_photos",
                "basics_default"
              ]
            }
          ],
          "description": "Removes one locally selected organizer cover photo."
        },
        {
          "id": "reorder_club_photo",
          "owner": "route_intent",
          "codeValue": "HostClubCreateReorderClubPhotoIntent",
          "cardinality": "unbounded",
          "scopeKeys": [
            "routeInstanceId",
            "photoDraftId",
            "targetIndex"
          ],
          "outcomes": [
            {
              "kind": "surface_state",
              "stateIds": [
                "club_photos"
              ]
            }
          ],
          "description": "Reorders selected cover photos and therefore changes the primary cover."
        },
        {
          "id": "select_city",
          "owner": "route_intent",
          "codeValue": "HostClubCreateCityChangedIntent",
          "cardinality": "unbounded",
          "scopeKeys": [
            "routeInstanceId",
            "marketId"
          ],
          "outcomes": [
            {
              "kind": "surface_state",
              "stateIds": [
                "basics_default",
                "basics_validation"
              ]
            }
          ],
          "description": "Selects the organizer market used for location and currency defaults."
        },
        {
          "id": "select_organizer_type",
          "owner": "route_intent",
          "codeValue": "HostClubCreateOrganizerTypeChangedIntent",
          "cardinality": "domain_bounded",
          "scopeKeys": [
            "routeInstanceId",
            "organizerType"
          ],
          "outcomes": [
            {
              "kind": "surface_state",
              "stateIds": [
                "basics_default"
              ]
            }
          ],
          "description": "Selects one organizer type from the finite OrganizerType domain."
        },
        {
          "id": "update_defaults",
          "owner": "route_intent",
          "codeValue": "HostClubCreateDefaultsChangedIntent",
          "cardinality": "unbounded",
          "scopeKeys": [
            "routeInstanceId",
            "defaultsSignature"
          ],
          "outcomes": [
            {
              "kind": "surface_state",
              "stateIds": [
                "host_defaults_step",
                "event_success_defaults_step"
              ]
            }
          ],
          "description": "Updates the organizer's reusable host and Event Success defaults as one compound configuration."
        },
        {
          "id": "save_draft",
          "owner": "draft_controller",
          "codeValue": "saveDraft",
          "cardinality": "singleton",
          "scopeKeys": [
            "viewerUid",
            "draftSignature"
          ],
          "outcomes": [
            {
              "kind": "surface_state",
              "stateIds": [
                "save_draft_pending_error",
                "draft_restore"
              ]
            }
          ],
          "description": "Persists the non-empty organizer draft for the signed-in host."
        },
        {
          "id": "retry_draft_restore",
          "owner": "draft_controller",
          "codeValue": "loadDraft",
          "cardinality": "singleton",
          "scopeKeys": [
            "viewerUid",
            "failureStateVersion"
          ],
          "outcomes": [
            {
              "kind": "surface_state",
              "stateIds": [
                "draft_restore",
                "save_draft_pending_error"
              ]
            }
          ],
          "description": "Retries loading the signed-in host's local organizer draft after a load failure."
        },
        {
          "id": "submit_organizer",
          "owner": "submit_controller",
          "codeValue": "submit",
          "cardinality": "singleton",
          "scopeKeys": [
            "viewerUid",
            "draftSignature"
          ],
          "outcomes": [
            {
              "kind": "surface_state",
              "stateIds": [
                "submit_pending",
                "submit_error",
                "uid_missing_submit",
                "offline",
                "success_pop"
              ]
            }
          ],
          "description": "Creates the organizer, uploads selected media, clears the saved draft, and lets the success transition close the caller route."
        }
      ],
      "stateIds": [
        "route_entry",
        "draft_restore",
        "basics_default",
        "basics_validation",
        "club_photos",
        "details_step",
        "host_defaults_step",
        "event_success_defaults_step",
        "save_draft_pending_error",
        "submit_pending",
        "submit_error",
        "success_pop",
        "uid_missing_submit",
        "offline",
        "text_scale_2",
        "reduced_motion",
        "light_dark"
      ],
      "scenarioDefaults": {
        "dimensions": {},
        "actionCases": [
          {
            "id": "default"
          }
        ]
      },
      "scenarioOverrides": {
        "route_entry": {
          "actionCases": [
            {
              "id": "start",
              "enabledActions": [
                "navigate_back",
                "next_step",
                "select_club_photos",
                "select_profile_image",
                "select_city",
                "select_organizer_type",
                "save_draft"
              ]
            }
          ]
        },
        "draft_restore": {
          "dimensions": {
            "draft": "restored"
          },
          "actionCases": [
            {
              "id": "restored",
              "enabledActions": [
                "navigate_back",
                "next_step",
                "select_club_photos",
                "select_profile_image",
                "select_city",
                "select_organizer_type",
                "save_draft"
              ]
            },
            {
              "id": "load_error",
              "dimensions": {
                "draft": "error"
              },
              "enabledActions": [
                "retry_draft_restore"
              ]
            }
          ]
        },
        "basics_default": {
          "actionCases": [
            {
              "id": "basics",
              "enabledActions": [
                "navigate_back",
                "next_step",
                "select_club_photos",
                "select_profile_image",
                "select_city",
                "select_organizer_type",
                "save_draft"
              ]
            }
          ]
        },
        "basics_validation": {
          "dimensions": {
            "mutation": "validation"
          },
          "actionCases": [
            {
              "id": "correct",
              "enabledActions": [
                "navigate_back",
                "next_step",
                "select_club_photos",
                "select_profile_image",
                "select_city",
                "select_organizer_type",
                "save_draft"
              ]
            }
          ]
        },
        "club_photos": {
          "dimensions": {
            "media": "selected"
          },
          "actionCases": [
            {
              "id": "media",
              "enabledActions": [
                "navigate_back",
                "next_step",
                "select_club_photos",
                "select_profile_image",
                "remove_club_photo",
                "reorder_club_photo",
                "select_city",
                "select_organizer_type",
                "save_draft"
              ]
            }
          ]
        },
        "details_step": {
          "dimensions": {
            "step": "details"
          },
          "actionCases": [
            {
              "id": "details",
              "enabledActions": [
                "navigate_back",
                "next_step",
                "save_draft"
              ]
            }
          ]
        },
        "host_defaults_step": {
          "dimensions": {
            "step": "host_defaults"
          },
          "actionCases": [
            {
              "id": "defaults",
              "enabledActions": [
                "navigate_back",
                "next_step",
                "update_defaults",
                "save_draft"
              ]
            }
          ]
        },
        "event_success_defaults_step": {
          "dimensions": {
            "step": "event_success"
          },
          "actionCases": [
            {
              "id": "defaults",
              "enabledActions": [
                "navigate_back",
                "update_defaults",
                "submit_organizer",
                "save_draft"
              ]
            }
          ]
        },
        "save_draft_pending_error": {
          "actionCases": [
            {
              "id": "pending",
              "dimensions": {
                "draft": "saving",
                "mutation": "pending"
              },
              "enabledActions": [
                "navigate_back",
                "select_club_photos",
                "select_profile_image",
                "select_city",
                "select_organizer_type"
              ],
              "disabledActions": [
                "next_step",
                "save_draft"
              ]
            },
            {
              "id": "error",
              "dimensions": {
                "draft": "error",
                "mutation": "error"
              },
              "enabledActions": [
                "navigate_back",
                "next_step",
                "select_club_photos",
                "select_profile_image",
                "select_city",
                "select_organizer_type",
                "save_draft"
              ]
            }
          ]
        },
        "submit_pending": {
          "dimensions": {
            "step": "event_success",
            "mutation": "pending"
          },
          "actionCases": [
            {
              "id": "pending",
              "enabledActions": [
                "navigate_back",
                "update_defaults"
              ],
              "disabledActions": [
                "submit_organizer",
                "save_draft"
              ]
            }
          ]
        },
        "submit_error": {
          "dimensions": {
            "step": "event_success",
            "mutation": "error"
          },
          "actionCases": [
            {
              "id": "retry",
              "enabledActions": [
                "navigate_back",
                "update_defaults",
                "submit_organizer",
                "save_draft"
              ]
            }
          ]
        },
        "success_pop": {
          "dimensions": {
            "step": "event_success",
            "mutation": "settled"
          }
        },
        "uid_missing_submit": {
          "dimensions": {
            "step": "event_success",
            "authentication": "missing",
            "mutation": "error"
          },
          "actionCases": [
            {
              "id": "retry_after_auth",
              "enabledActions": [
                "navigate_back",
                "update_defaults",
                "submit_organizer",
                "save_draft"
              ]
            }
          ]
        },
        "offline": {
          "dimensions": {
            "step": "event_success",
            "connectivity": "offline",
            "mutation": "error"
          },
          "actionCases": [
            {
              "id": "submit_retry",
              "enabledActions": [
                "navigate_back",
                "update_defaults",
                "submit_organizer",
                "save_draft"
              ]
            }
          ]
        },
        "text_scale_2": {
          "dimensions": {
            "accessibility": "text_scale_2"
          }
        },
        "reduced_motion": {
          "dimensions": {
            "accessibility": "reduced_motion"
          }
        },
        "light_dark": {
          "dimensions": {
            "theme": "light_dark"
          }
        }
      },
      "requiredEvidence": {
        "captures": true,
        "previews": true,
        "tests": true
      },
      "evidenceExceptions": [
        {
          "stateIds": [
            "route_entry",
            "success_pop",
            "uid_missing_submit"
          ],
          "evidence": [
            "captures"
          ],
          "debtId": "FEATURE-CONTRACT-MIGRATION-001",
          "reason": "These lifecycle or permission transitions are implemented but do not yet have deterministic image-capture evidence registered by the screen authority."
        },
        {
          "stateIds": [
            "route_entry",
            "draft_restore",
            "basics_default",
            "details_step",
            "host_defaults_step",
            "event_success_defaults_step",
            "save_draft_pending_error",
            "submit_pending",
            "uid_missing_submit",
            "offline",
            "text_scale_2",
            "reduced_motion",
            "light_dark"
          ],
          "evidence": [
            "tests"
          ],
          "debtId": "FEATURE-CONTRACT-MIGRATION-001",
          "reason": "These deterministic organizer-create states have Widgetbook/capture evidence where visual and no focused state-level automated test recorded by the screen authority yet."
        }
      ]
    }
  ]
}
