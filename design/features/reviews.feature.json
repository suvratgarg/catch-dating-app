{
  "$schema": "./feature_contract.schema.json",
  "version": 2,
  "updated": "2026-07-23",
  "id": "feature.reviews",
  "name": "Reviews",
  "owner": "reviews",
  "status": "pilot",
  "description": "Orchestrates member review history, profile and review recovery, event-context enrichment, and the shared edit/delete sheet workflow.",
  "surfaces": [
    {
      "id": "history_flutter",
      "runtime": "flutter",
      "authority": {"registry": "flutter_screens", "id": "screen.reviews.history"},
      "actionScope": {
        "included": "Closing Review History; retrying profile or review loads; opening an editable event review; selecting a rating; and submitting or deleting the existing review.",
        "excluded": [
          "Review/event joining, row ordering, context labels, and edit eligibility are read-model behavior rather than user actions.",
          "Raw review-comment entry remains form data governed by CatchField and the review schema rather than a cardinalized action.",
          "Event-context loading, failure, and genuine absence currently share the same fallback label under DP-REVIEWS-HISTORY-005; submit/delete pending leaves the rating and comment draft live under DP-REVIEWS-HISTORY-006."
        ]
      },
      "bindings": {
        "previewSources": ["widgetbook/lib/utility/p3_utility_use_cases.dart"],
        "actionOwners": [
          {
            "id": "history_screen",
            "language": "dart",
            "file": "lib/reviews/presentation/reviews_history_screen.dart",
            "symbol": "ReviewsHistoryScreen"
          },
          {
            "id": "review_sheet",
            "language": "dart",
            "file": "lib/reviews/shared/write_review_sheet.dart",
            "symbol": "WriteReviewSheet"
          },
          {
            "id": "review_controller",
            "language": "dart",
            "file": "lib/reviews/shared/write_review_controller.dart",
            "symbol": "WriteReviewController"
          }
        ],
        "componentContracts": [
          "catch.sheet",
          "catch.button",
          "catch.empty_state",
          "catch.error_state",
          "catch.field",
          "catch.surface",
          "catch.top_bar"
        ],
        "dataContracts": [
          "contracts/firestore/events.schema.json",
          "contracts/firestore/reviews.schema.json",
          "contracts/firestore/users.schema.json"
        ]
      },
      "dimensions": {
        "access": {"default": "signed_in", "values": ["signed_out", "signed_in"]},
        "profile": {"default": "ready", "values": ["loading", "error", "ready"]},
        "reviews": {"default": "ready", "values": ["loading", "error", "empty", "ready"]},
        "event_context": {"default": "resolved", "values": ["resolved", "missing_or_unresolved"]},
        "sheet": {"default": "closed", "values": ["closed", "edit"]},
        "mutation": {"default": "idle", "values": ["idle", "submit_pending", "delete_pending", "failed"]},
        "accessibility": {"default": "standard", "values": ["standard", "text_scale_2", "reduced_motion"]},
        "theme": {"default": "standard", "values": ["standard", "light_dark"]}
      },
      "actions": [
        {
          "id": "close_review_history",
          "owner": "history_screen",
          "codeValue": "back",
          "cardinality": "singleton",
          "scopeKeys": ["routeInstanceId"],
          "outcomes": [{"kind": "side_effect", "id": "navigation.route_popped"}],
          "description": "Closes Review History through its canonical top-bar back control."
        },
        {
          "id": "retry_profile",
          "owner": "history_screen",
          "codeValue": "onRetryProfile",
          "cardinality": "singleton",
          "scopeKeys": ["viewerUid", "profileLoadGeneration"],
          "outcomes": [{"kind": "surface_state", "stateIds": ["profile_loading", "profile_error", "empty_reviews", "reviews_history_list"]}],
          "description": "Invalidates the member profile provider after a profile-load failure."
        },
        {
          "id": "retry_reviews",
          "owner": "history_screen",
          "codeValue": "onRetryReviews",
          "cardinality": "singleton",
          "scopeKeys": ["viewerUid", "reviewLoadGeneration"],
          "outcomes": [{"kind": "surface_state", "stateIds": ["reviews_loading", "reviews_error", "empty_reviews", "reviews_history_list"]}],
          "description": "Invalidates the member's review stream after a review-load failure."
        },
        {
          "id": "open_edit_review",
          "owner": "history_screen",
          "codeValue": "_showEditReviewSheet",
          "cardinality": "unbounded",
          "scopeKeys": ["routeInstanceId", "reviewId", "eventId"],
          "outcomes": [{"kind": "surface_state", "stateIds": ["edit_review_sheet"]}],
          "description": "Opens the shared review sheet for an event-backed review owned by the current member."
        },
        {
          "id": "select_review_rating",
          "owner": "review_sheet",
          "codeValue": "onChanged",
          "cardinality": "domain_bounded",
          "scopeKeys": ["reviewId", "rating"],
          "outcomes": [{"kind": "surface_state", "stateIds": ["edit_review_sheet"]}],
          "description": "Selects one rating from the review sheet's finite star domain."
        },
        {
          "id": "save_review",
          "owner": "review_controller",
          "codeValue": "submit",
          "cardinality": "singleton",
          "scopeKeys": ["reviewId", "reviewDraftSignature"],
          "outcomes": [
            {"kind": "surface_state", "stateIds": ["edit_review_sheet", "reviews_history_list"]},
            {"kind": "side_effect", "id": "reviews.update"}
          ],
          "description": "Submits one rating/comment snapshot for the existing review and dismisses the sheet after success."
        },
        {
          "id": "delete_review",
          "owner": "review_controller",
          "codeValue": "delete",
          "cardinality": "singleton",
          "scopeKeys": ["reviewId"],
          "outcomes": [
            {"kind": "surface_state", "stateIds": ["edit_review_sheet", "reviews_history_list", "empty_reviews"]},
            {"kind": "side_effect", "id": "reviews.delete"}
          ],
          "description": "Confirms and deletes the existing review, then dismisses the sheet after success."
        }
      ],
      "stateIds": [
        "uid_missing",
        "profile_loading",
        "profile_error",
        "reviews_loading",
        "reviews_error",
        "empty_reviews",
        "reviews_history_list",
        "event_context_missing",
        "edit_review_sheet",
        "text_scale_2",
        "reduced_motion",
        "light_dark"
      ],
      "scenarioDefaults": {
        "dimensions": {},
        "actionCases": [{"id": "history", "enabledActions": ["close_review_history", "open_edit_review"]}]
      },
      "scenarioOverrides": {
        "uid_missing": {
          "dimensions": {"access": "signed_out", "reviews": "empty"},
          "actionCases": [{"id": "signed_out", "enabledActions": ["close_review_history"]}]
        },
        "profile_loading": {
          "dimensions": {"profile": "loading", "reviews": "loading"},
          "actionCases": [{"id": "loading", "enabledActions": ["close_review_history"]}]
        },
        "profile_error": {
          "dimensions": {"profile": "error"},
          "actionCases": [{"id": "retry", "enabledActions": ["close_review_history", "retry_profile"]}]
        },
        "reviews_loading": {
          "dimensions": {"reviews": "loading"},
          "actionCases": [{"id": "loading", "enabledActions": ["close_review_history"]}]
        },
        "reviews_error": {
          "dimensions": {"reviews": "error"},
          "actionCases": [{"id": "retry", "enabledActions": ["close_review_history", "retry_reviews"]}]
        },
        "empty_reviews": {
          "dimensions": {"reviews": "empty"},
          "actionCases": [{"id": "empty", "enabledActions": ["close_review_history"]}]
        },
        "event_context_missing": {
          "dimensions": {"event_context": "missing_or_unresolved"}
        },
        "edit_review_sheet": {
          "dimensions": {"sheet": "edit"},
          "actionCases": [
            {"id": "editable", "enabledActions": ["select_review_rating", "save_review", "delete_review"]},
            {
              "id": "submit_pending_with_live_draft",
              "dimensions": {"mutation": "submit_pending"},
              "enabledActions": ["select_review_rating"],
              "disabledActions": ["save_review", "delete_review"]
            },
            {
              "id": "delete_pending_with_live_draft",
              "dimensions": {"mutation": "delete_pending"},
              "enabledActions": ["select_review_rating"],
              "disabledActions": ["save_review", "delete_review"]
            },
            {
              "id": "failed",
              "dimensions": {"mutation": "failed"},
              "enabledActions": ["select_review_rating", "save_review", "delete_review"]
            }
          ]
        },
        "text_scale_2": {"dimensions": {"accessibility": "text_scale_2"}},
        "reduced_motion": {"dimensions": {"accessibility": "reduced_motion"}},
        "light_dark": {"dimensions": {"theme": "light_dark"}}
      },
      "requiredEvidence": {"captures": true, "previews": true, "tests": true},
      "evidenceExceptions": [
        {
          "stateIds": ["profile_loading", "text_scale_2", "reduced_motion", "light_dark"],
          "evidence": ["tests"],
          "debtId": "FEATURE-CONTRACT-MIGRATION-001",
          "reason": "These Reviews History states have deterministic capture and Widgetbook evidence but no focused state-level test recorded by the authority."
        },
        {
          "stateIds": ["edit_review_sheet"],
          "evidence": ["captures"],
          "debtId": "FEATURE-CONTRACT-MIGRATION-001",
          "reason": "The edit sheet and its mutation behavior have focused tests plus Widgetbook evidence, but the Reviews History authority does not register a dedicated sheet capture."
        }
      ]
    }
  ]
}
