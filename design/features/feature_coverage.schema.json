{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://catch.app/design/features/feature_coverage.schema.json",
  "title": "Catch cross-surface feature contract coverage",
  "type": "object",
  "required": [
    "$schema",
    "version",
    "updated",
    "owner",
    "sourceOfTruth",
    "authorities",
    "decisions"
  ],
  "additionalProperties": false,
  "properties": {
    "$schema": {"const": "./feature_coverage.schema.json"},
    "version": {"const": 1},
    "updated": {"type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$"},
    "owner": {"type": "string", "minLength": 1},
    "sourceOfTruth": {"type": "string", "minLength": 1},
    "authorities": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/authority"}
    },
    "decisions": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/decision"}
    }
  },
  "$defs": {
    "authority": {
      "type": "object",
      "required": ["id", "runtime", "registry", "collection", "idField"],
      "additionalProperties": false,
      "properties": {
        "id": {"type": "string", "pattern": "^[a-z][a-z0-9_]*$"},
        "runtime": {
          "enum": ["flutter", "react_marketing", "react_admin"]
        },
        "registry": {"type": "string", "pattern": "^design/.+\\.json$"},
        "collection": {"type": "string", "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"},
        "idField": {"type": "string", "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"},
        "filter": {
          "type": "object",
          "required": ["field", "value"],
          "additionalProperties": false,
          "properties": {
            "field": {"type": "string", "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"},
            "value": {"type": ["string", "number", "boolean"]}
          }
        }
      }
    },
    "decisionBase": {
      "type": "object",
      "required": ["authority", "authorityId", "status", "priority", "reason"],
      "properties": {
        "authority": {"type": "string", "pattern": "^[a-z][a-z0-9_]*$"},
        "authorityId": {"type": "string", "minLength": 1},
        "status": {
          "enum": ["contracted", "grouped", "planned", "excluded"]
        },
        "priority": {"enum": ["P1", "P2", "P3", "P4"]},
        "reason": {"type": "string", "minLength": 1}
      }
    },
    "decision": {
      "oneOf": [
        {
          "allOf": [
            {"$ref": "#/$defs/decisionBase"},
            {
              "type": "object",
              "required": ["featureContract"],
              "additionalProperties": false,
              "properties": {
                "authority": {},
                "authorityId": {},
                "status": {"const": "contracted"},
                "priority": {},
                "reason": {},
                "featureContract": {
                  "type": "string",
                  "pattern": "^feature\\.[a-z0-9_.-]+$"
                }
              }
            }
          ]
        },
        {
          "allOf": [
            {"$ref": "#/$defs/decisionBase"},
            {
              "type": "object",
              "required": ["primaryAuthorityId"],
              "additionalProperties": false,
              "properties": {
                "authority": {},
                "authorityId": {},
                "status": {"const": "grouped"},
                "priority": {},
                "reason": {},
                "primaryAuthorityId": {"type": "string", "minLength": 1}
              }
            }
          ]
        },
        {
          "allOf": [
            {"$ref": "#/$defs/decisionBase"},
            {
              "type": "object",
              "required": ["targetFeature", "debtId"],
              "additionalProperties": false,
              "properties": {
                "authority": {},
                "authorityId": {},
                "status": {"const": "planned"},
                "priority": {},
                "reason": {},
                "targetFeature": {
                  "type": "string",
                  "pattern": "^feature\\.[a-z0-9_.-]+$"
                },
                "debtId": {
                  "type": "string",
                  "pattern": "^[A-Z][A-Z0-9_.-]+$"
                }
              }
            }
          ]
        },
        {
          "allOf": [
            {"$ref": "#/$defs/decisionBase"},
            {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "authority": {},
                "authorityId": {},
                "status": {"const": "excluded"},
                "priority": {},
                "reason": {}
              }
            }
          ]
        }
      ]
    }
  }
}
