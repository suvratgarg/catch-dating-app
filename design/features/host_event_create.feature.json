{
  "$schema": "./feature_contract.schema.json",
  "version": 2,
  "updated": "2026-07-23",
  "id": "feature.host_event_create",
  "name": "Host Event Create",
  "owner": "hosts",
  "status": "pilot",
  "description": "Orchestrates Host Event Create route resolution, the five-step event wizard, local drafts, media and location selection, event submission, and post-create navigation.",
  "surfaces": [
    {
      "id": "host_flutter",
      "runtime": "flutter",
      "authority": {"registry": "flutter_screens", "id": "screen.host.event.create"},
      "actionScope": {
        "included": "Host Event Create route recovery; wizard navigation; activity, schedule, policy, and guide choices; event-photo and meeting-location selection; local draft restore, save, delete, and exit handling; event submission; and success navigation.",
        "excluded": [
          "Raw text-field edits are form data governed by CatchField, form validators, and the event data contracts rather than separately cardinalized actions.",
          "Host Home launch and repeat-template selection retain Host Home ownership; post-create event administration retains Host Event Manage ownership."
        ]
      },
      "bindings": {
        "previewSources": ["widgetbook/lib/hosts/host_operations_use_cases.dart"],
        "actionOwners": [
          {"id": "route_screen", "language": "dart", "file": "lib/hosts/presentation/event_management/host_create_event_screen.dart", "symbol": "HostCreateEventRouteStateView"},
          {"id": "wizard_state", "language": "dart", "file": "lib/hosts/presentation/event_management/create/create_event_wizard_state.dart", "symbol": "CreateEventWizardState"},
          {"id": "create_screen", "language": "dart", "file": "lib/hosts/presentation/event_management/create/create_event_screen.dart", "symbol": "CreateEventScreen"},
          {"id": "location_picker", "language": "dart", "file": "lib/events/presentation/location_picker_screen.dart", "symbol": "LocationPickerScreen"},
          {"id": "draft_picker", "language": "dart", "file": "lib/hosts/presentation/event_management/widgets/draft_picker_sheet.dart", "symbol": "DraftPickerSheet"},
          {"id": "submit_controller", "language": "dart", "file": "lib/hosts/presentation/event_management/create/create_event_controller.dart", "symbol": "CreateEventController"},
          {"id": "draft_controller", "language": "dart", "file": "lib/hosts/presentation/event_management/create/create_event_draft_controller.dart", "symbol": "CreateEventDraftController"}
        ],
        "componentContracts": [
          "catch.button",
          "catch.error_banner",
          "catch.error_state",
          "catch.field",
          "catch.form_dialog",
          "catch.map_preview",
          "catch.option_card",
          "catch.option_group",
          "catch.surface",
          "catch.top_bar"
        ],
        "dataContracts": [
          "contracts/callables/place_details_payload.schema.json",
          "contracts/callables/places_autocomplete_payload.schema.json",
          "contracts/firestore/clubs.schema.json",
          "contracts/firestore/event_success_preferences.schema.json",
          "contracts/firestore/events.schema.json",
          "contracts/storage/event_photos.schema.json"
        ]
      },
      "dimensions": {
        "route": {"default": "ready", "values": ["ready", "loading", "error", "not_found", "forbidden"]},
        "step": {"default": "basics", "values": ["basics", "location", "schedule", "policy", "guide", "success"]},
        "mutation": {"default": "idle", "values": ["idle", "validation", "pending", "error", "settled"]},
        "draft": {"default": "none", "values": ["none", "picker", "restored", "saved", "deleted", "dirty"]},
        "media": {"default": "empty", "values": ["empty", "selected"]},
        "location": {"default": "empty", "values": ["empty", "selected", "search"]},
        "policy": {"default": "standard", "values": ["standard", "invite_only", "cohort_caps", "dynamic_pricing"]},
        "connectivity": {"default": "online", "values": ["online", "offline"]},
        "accessibility": {"default": "standard", "values": ["standard", "text_scale_2", "reduced_motion"]},
        "theme": {"default": "standard", "values": ["standard", "light_dark"]}
      },
      "actions": [
        {
          "id": "retry_route",
          "owner": "route_screen",
          "codeValue": "reloadClub",
          "cardinality": "singleton",
          "scopeKeys": ["routeInstanceId", "clubId", "failureStateVersion"],
          "outcomes": [{"kind": "surface_state", "stateIds": ["club_fetch_loading", "initial_club_extra", "club_fetch_error", "club_not_found", "unauthorized_host"]}],
          "description": "Reloads the organizer needed to authorize and start the create route."
        },
        {
          "id": "close_flow",
          "owner": "wizard_state",
          "codeValue": "close",
          "cardinality": "singleton",
          "scopeKeys": ["routeInstanceId", "draftSignature"],
          "outcomes": [{"kind": "side_effect", "id": "host_event_create.dismissed"}],
          "description": "Closes a clean create flow from the first step."
        },
        {
          "id": "previous_step",
          "owner": "wizard_state",
          "codeValue": "previousStep",
          "cardinality": "unbounded",
          "scopeKeys": ["routeInstanceId", "currentStep"],
          "outcomes": [{"kind": "surface_state", "stateIds": ["basics_default", "where_step_default", "when_step_default", "policy_default", "event_success_step"]}],
          "description": "Moves to the preceding wizard step without discarding the current draft state."
        },
        {
          "id": "next_step",
          "owner": "wizard_state",
          "codeValue": "nextStep",
          "cardinality": "unbounded",
          "scopeKeys": ["routeInstanceId", "currentStep", "draftSignature"],
          "outcomes": [{"kind": "surface_state", "stateIds": ["basics_validation", "where_step_default", "when_step_default", "same_day_time_error", "policy_default", "policy_age_validation", "event_success_step"]}],
          "description": "Validates the current step and advances only when its form and schedule rules pass."
        },
        {
          "id": "select_event_photos",
          "owner": "create_screen",
          "codeValue": "_pickEventPhotos",
          "cardinality": "unbounded",
          "scopeKeys": ["routeInstanceId", "clubId", "remainingPhotoSlots"],
          "outcomes": [{"kind": "surface_state", "stateIds": ["event_photos", "offline"]}],
          "description": "Selects up to the remaining event-photo limit for ordered upload on submission."
        },
        {
          "id": "remove_event_photo",
          "owner": "create_screen",
          "codeValue": "_removeEventPhoto",
          "cardinality": "unbounded",
          "scopeKeys": ["routeInstanceId", "photoDraftId"],
          "outcomes": [{"kind": "surface_state", "stateIds": ["event_photos", "basics_default"]}],
          "description": "Removes one locally selected event photo."
        },
        {
          "id": "reorder_event_photo",
          "owner": "create_screen",
          "codeValue": "_reorderEventPhoto",
          "cardinality": "unbounded",
          "scopeKeys": ["routeInstanceId", "photoDraftId", "targetIndex"],
          "outcomes": [{"kind": "surface_state", "stateIds": ["event_photos"]}],
          "description": "Changes the deterministic upload and display order of selected photos."
        },
        {
          "id": "select_activity",
          "owner": "create_screen",
          "codeValue": "onActivityKindChanged",
          "cardinality": "unbounded",
          "scopeKeys": ["routeInstanceId", "activityKind"],
          "outcomes": [{"kind": "surface_state", "stateIds": ["basics_default", "custom_activity"]}],
          "description": "Selects a standard or custom event activity and refreshes format-dependent defaults."
        },
        {
          "id": "select_interaction_model",
          "owner": "create_screen",
          "codeValue": "onInteractionModelChanged",
          "cardinality": "unbounded",
          "scopeKeys": ["routeInstanceId", "interactionModel"],
          "outcomes": [{"kind": "surface_state", "stateIds": ["custom_activity"]}],
          "description": "Selects the interaction model for a custom activity."
        },
        {
          "id": "select_pace",
          "owner": "create_screen",
          "codeValue": "onPaceChanged",
          "cardinality": "unbounded",
          "scopeKeys": ["routeInstanceId", "pace"],
          "outcomes": [{"kind": "surface_state", "stateIds": ["basics_default"]}],
          "description": "Selects pace for a distance-based event format."
        },
        {
          "id": "open_location_picker",
          "owner": "create_screen",
          "codeValue": "_pickLocation",
          "cardinality": "unbounded",
          "scopeKeys": ["routeInstanceId", "clubId", "locationSelectionVersion"],
          "outcomes": [{"kind": "surface_state", "stateIds": ["location_picker_selected", "location_picker_offline_search"]}],
          "description": "Opens the meeting-location picker with the current pin or city/device hint."
        },
        {
          "id": "search_location",
          "owner": "location_picker",
          "codeValue": "_onSearchChanged",
          "cardinality": "unbounded",
          "scopeKeys": ["routeInstanceId", "placesSessionToken", "query"],
          "outcomes": [{"kind": "surface_state", "stateIds": ["location_picker_selected", "location_picker_offline_search"]}],
          "description": "Debounces a scoped Places query and exposes deterministic search or offline failure state."
        },
        {
          "id": "select_location_suggestion",
          "owner": "location_picker",
          "codeValue": "_selectSuggestion",
          "cardinality": "unbounded",
          "scopeKeys": ["routeInstanceId", "placesSessionToken", "placeId"],
          "outcomes": [{"kind": "surface_state", "stateIds": ["location_picker_selected", "location_picker_offline_search"]}],
          "description": "Resolves one Places suggestion into the selected pin and attendee-facing label."
        },
        {
          "id": "set_location_pin",
          "owner": "location_picker",
          "codeValue": "_setSelectedPoint",
          "cardinality": "unbounded",
          "scopeKeys": ["routeInstanceId", "latitude", "longitude"],
          "outcomes": [{"kind": "surface_state", "stateIds": ["location_picker_selected"]}],
          "description": "Selects a meeting point directly from the map."
        },
        {
          "id": "confirm_location",
          "owner": "location_picker",
          "codeValue": "LocationPickerResult",
          "cardinality": "singleton",
          "scopeKeys": ["routeInstanceId", "locationSelectionVersion"],
          "outcomes": [{"kind": "surface_state", "stateIds": ["where_step_default"]}],
          "description": "Returns the selected coordinate and place metadata to the create wizard."
        },
        {
          "id": "select_date",
          "owner": "create_screen",
          "codeValue": "_pickDate",
          "cardinality": "unbounded",
          "scopeKeys": ["routeInstanceId", "selectedDate"],
          "outcomes": [{"kind": "surface_state", "stateIds": ["when_step_default", "same_day_time_error"]}],
          "description": "Selects an event date inside the permitted one-year window."
        },
        {
          "id": "select_start_time",
          "owner": "create_screen",
          "codeValue": "_pickStartTime",
          "cardinality": "unbounded",
          "scopeKeys": ["routeInstanceId", "selectedDate", "selectedStartTime"],
          "outcomes": [{"kind": "surface_state", "stateIds": ["when_step_default", "same_day_time_error"]}],
          "description": "Selects a start time and immediately recomputes same-day schedule validity."
        },
        {
          "id": "adjust_duration",
          "owner": "create_screen",
          "codeValue": "increaseDuration",
          "cardinality": "unbounded",
          "scopeKeys": ["routeInstanceId", "durationMinutes"],
          "outcomes": [{"kind": "surface_state", "stateIds": ["when_step_default"]}],
          "description": "Increases or decreases duration within the schedule state's bounded increments."
        },
        {
          "id": "select_admission_policy",
          "owner": "create_screen",
          "codeValue": "selectAdmissionPreset",
          "cardinality": "unbounded",
          "scopeKeys": ["routeInstanceId", "admissionPreset"],
          "outcomes": [{"kind": "surface_state", "stateIds": ["policy_default", "invite_only_policy"]}],
          "description": "Selects the event admission preset, including invite-only policy."
        },
        {
          "id": "toggle_cohort_caps",
          "owner": "create_screen",
          "codeValue": "setCohortCapsEnabled",
          "cardinality": "unbounded",
          "scopeKeys": ["routeInstanceId", "cohortCapsEnabled"],
          "outcomes": [{"kind": "surface_state", "stateIds": ["policy_default", "cohort_caps_policy"]}],
          "description": "Enables or disables cohort-specific capacity limits."
        },
        {
          "id": "toggle_dynamic_pricing",
          "owner": "create_screen",
          "codeValue": "setDynamicPricingEnabled",
          "cardinality": "unbounded",
          "scopeKeys": ["routeInstanceId", "dynamicPricingEnabled"],
          "outcomes": [{"kind": "surface_state", "stateIds": ["policy_default", "dynamic_pricing_policy"]}],
          "description": "Enables or disables bounded dynamic pricing fields."
        },
        {
          "id": "select_cancellation_policy",
          "owner": "create_screen",
          "codeValue": "setCancellationPolicy",
          "cardinality": "unbounded",
          "scopeKeys": ["routeInstanceId", "cancellationPolicyId"],
          "outcomes": [{"kind": "surface_state", "stateIds": ["policy_default"]}],
          "description": "Selects the event cancellation policy."
        },
        {
          "id": "configure_event_success",
          "owner": "create_screen",
          "codeValue": "onEventSuccessDefaultsChanged",
          "cardinality": "unbounded",
          "scopeKeys": ["routeInstanceId", "eventSuccessDefaultsVersion"],
          "outcomes": [{"kind": "surface_state", "stateIds": ["event_success_step"]}],
          "description": "Updates the live event guide defaults for the selected event format."
        },
        {
          "id": "save_draft",
          "owner": "draft_controller",
          "codeValue": "saveDraft",
          "cardinality": "singleton",
          "scopeKeys": ["viewerUid", "clubId", "draftId", "draftSignature"],
          "outcomes": [{"kind": "surface_state", "stateIds": ["draft_save_update", "offline"]}],
          "description": "Creates or updates the viewer's device-local draft for this organizer."
        },
        {
          "id": "restore_draft",
          "owner": "create_screen",
          "codeValue": "_restoreFromDraft",
          "cardinality": "unbounded",
          "scopeKeys": ["viewerUid", "clubId", "draftId"],
          "outcomes": [{"kind": "surface_state", "stateIds": ["draft_picker_restore"]}],
          "description": "Restores a selected local draft into all compatible wizard fields."
        },
        {
          "id": "start_fresh",
          "owner": "draft_picker",
          "codeValue": "_onStartFresh",
          "cardinality": "singleton",
          "scopeKeys": ["viewerUid", "clubId", "pickerInstanceId"],
          "outcomes": [{"kind": "surface_state", "stateIds": ["basics_default"]}],
          "description": "Dismisses the saved-draft picker without restoring a draft."
        },
        {
          "id": "delete_draft",
          "owner": "draft_controller",
          "codeValue": "deleteDraft",
          "cardinality": "singleton",
          "scopeKeys": ["viewerUid", "clubId", "draftId"],
          "outcomes": [{"kind": "surface_state", "stateIds": ["draft_delete"]}],
          "description": "Deletes one confirmed device-local draft."
        },
        {
          "id": "request_exit",
          "owner": "wizard_state",
          "codeValue": "confirmUnsavedChanges",
          "cardinality": "singleton",
          "scopeKeys": ["routeInstanceId", "draftSignature"],
          "outcomes": [{"kind": "surface_state", "stateIds": ["unsaved_changes"]}],
          "description": "Prompts before leaving the first step when the current values differ from the last saved baseline."
        },
        {
          "id": "save_and_exit",
          "owner": "create_screen",
          "codeValue": "showCreateEventUnsavedChangesDialog",
          "cardinality": "singleton",
          "scopeKeys": ["viewerUid", "clubId", "routeInstanceId", "draftSignature"],
          "outcomes": [{"kind": "side_effect", "id": "host_event_create.draft_saved_and_dismissed"}],
          "description": "Saves the current draft and closes the flow from the unsaved-changes dialog."
        },
        {
          "id": "discard_and_exit",
          "owner": "create_screen",
          "codeValue": "_showUnsavedChangesDialog",
          "cardinality": "singleton",
          "scopeKeys": ["routeInstanceId", "draftSignature"],
          "outcomes": [{"kind": "side_effect", "id": "host_event_create.discarded_and_dismissed"}],
          "description": "Closes the flow without saving from the unsaved-changes dialog."
        },
        {
          "id": "submit_event",
          "owner": "submit_controller",
          "codeValue": "submit",
          "cardinality": "singleton",
          "scopeKeys": ["viewerUid", "clubId", "draftSignature"],
          "outcomes": [{"kind": "surface_state", "stateIds": ["submit_pending", "submit_error", "success_manage", "offline"]}],
          "description": "Validates, creates the event, uploads ordered photos, and removes a restored draft only after successful submission."
        },
        {
          "id": "manage_created_event",
          "owner": "wizard_state",
          "codeValue": "manageEvent",
          "cardinality": "singleton",
          "scopeKeys": ["viewerUid", "clubId", "eventId"],
          "outcomes": [{"kind": "route", "authority": {"registry": "flutter_screens", "id": "screen.host.event.manage"}}],
          "description": "Replaces the success surface with Host Event Manage for the newly created event."
        },
        {
          "id": "dismiss_success",
          "owner": "wizard_state",
          "codeValue": "backToClub",
          "cardinality": "singleton",
          "scopeKeys": ["routeInstanceId", "clubId", "eventId"],
          "outcomes": [{"kind": "side_effect", "id": "host_event_create.success_dismissed_to_caller"}],
          "description": "Pops the successful create flow back to whichever host surface launched it."
        }
      ],
      "stateIds": [
        "initial_club_extra",
        "club_fetch_loading",
        "club_fetch_error",
        "club_not_found",
        "basics_default",
        "basics_validation",
        "event_photos",
        "custom_activity",
        "where_step_default",
        "location_picker_selected",
        "location_picker_offline_search",
        "when_step_default",
        "same_day_time_error",
        "policy_default",
        "policy_age_validation",
        "invite_only_policy",
        "cohort_caps_policy",
        "dynamic_pricing_policy",
        "event_success_step",
        "submit_pending",
        "submit_error",
        "success_manage",
        "draft_picker_restore",
        "draft_save_update",
        "draft_delete",
        "unsaved_changes",
        "unauthorized_host",
        "offline",
        "text_scale_2",
        "reduced_motion",
        "light_dark"
      ],
      "scenarioDefaults": {"dimensions": {}, "actionCases": [{"id": "default"}]},
      "scenarioOverrides": {
        "initial_club_extra": {"actionCases": [
          {"id": "clean", "enabledActions": ["close_flow", "next_step", "select_activity", "select_pace", "select_event_photos", "save_draft"]},
          {"id": "dirty", "enabledActions": ["request_exit", "next_step", "select_activity", "select_pace", "select_event_photos", "save_draft"]}
        ]},
        "club_fetch_loading": {"dimensions": {"route": "loading"}},
        "club_fetch_error": {"dimensions": {"route": "error"}, "actionCases": [{"id": "recovery", "enabledActions": ["retry_route"]}]},
        "club_not_found": {"dimensions": {"route": "not_found"}},
        "basics_default": {"actionCases": [
          {"id": "clean", "enabledActions": ["close_flow", "next_step", "select_activity", "select_pace", "select_event_photos", "save_draft"]},
          {"id": "dirty", "enabledActions": ["request_exit", "next_step", "select_activity", "select_pace", "select_event_photos", "save_draft"]}
        ]},
        "basics_validation": {"dimensions": {"mutation": "validation"}, "actionCases": [{"id": "correct", "enabledActions": ["next_step", "select_activity", "select_pace", "select_event_photos", "save_draft"]}]},
        "event_photos": {"dimensions": {"media": "selected"}, "actionCases": [{"id": "media", "enabledActions": ["select_event_photos", "remove_event_photo", "reorder_event_photo", "next_step", "save_draft"]}]},
        "custom_activity": {"actionCases": [{"id": "custom", "enabledActions": ["select_activity", "select_interaction_model", "select_event_photos", "next_step", "save_draft"]}]},
        "where_step_default": {"dimensions": {"step": "location"}, "actionCases": [{"id": "location", "enabledActions": ["previous_step", "open_location_picker", "next_step", "save_draft"]}]},
        "location_picker_selected": {"dimensions": {"step": "location", "location": "selected"}, "actionCases": [{"id": "picker", "enabledActions": ["search_location", "select_location_suggestion", "set_location_pin", "confirm_location"]}]},
        "location_picker_offline_search": {"dimensions": {"step": "location", "location": "search", "connectivity": "offline"}, "actionCases": [{"id": "retry_search", "enabledActions": ["search_location", "select_location_suggestion", "set_location_pin"]}]},
        "when_step_default": {"dimensions": {"step": "schedule"}, "actionCases": [{"id": "schedule", "enabledActions": ["previous_step", "select_date", "select_start_time", "adjust_duration", "next_step", "save_draft"]}]},
        "same_day_time_error": {"dimensions": {"step": "schedule", "mutation": "validation"}, "actionCases": [{"id": "correct", "enabledActions": ["previous_step", "select_date", "select_start_time", "adjust_duration", "next_step", "save_draft"]}]},
        "policy_default": {"dimensions": {"step": "policy"}, "actionCases": [{"id": "policy", "enabledActions": ["previous_step", "select_admission_policy", "toggle_cohort_caps", "toggle_dynamic_pricing", "select_cancellation_policy", "next_step", "save_draft"]}]},
        "policy_age_validation": {"dimensions": {"step": "policy", "mutation": "validation"}, "actionCases": [{"id": "correct", "enabledActions": ["previous_step", "select_admission_policy", "toggle_cohort_caps", "toggle_dynamic_pricing", "select_cancellation_policy", "next_step", "save_draft"]}]},
        "invite_only_policy": {"dimensions": {"step": "policy", "policy": "invite_only"}, "actionCases": [{"id": "invite", "enabledActions": ["previous_step", "select_admission_policy", "next_step", "save_draft"]}]},
        "cohort_caps_policy": {"dimensions": {"step": "policy", "policy": "cohort_caps"}, "actionCases": [{"id": "caps", "enabledActions": ["previous_step", "toggle_cohort_caps", "next_step", "save_draft"]}]},
        "dynamic_pricing_policy": {"dimensions": {"step": "policy", "policy": "dynamic_pricing"}, "actionCases": [{"id": "pricing", "enabledActions": ["previous_step", "toggle_dynamic_pricing", "next_step", "save_draft"]}]},
        "event_success_step": {"dimensions": {"step": "guide"}, "actionCases": [{"id": "guide", "enabledActions": ["previous_step", "configure_event_success", "submit_event", "save_draft"]}]},
        "submit_pending": {"dimensions": {"step": "guide", "mutation": "pending"}},
        "submit_error": {"dimensions": {"step": "guide", "mutation": "error"}, "actionCases": [{"id": "retry", "enabledActions": ["previous_step", "configure_event_success", "submit_event", "save_draft"]}]},
        "success_manage": {"dimensions": {"step": "success", "mutation": "settled"}, "actionCases": [{"id": "success", "enabledActions": ["manage_created_event", "dismiss_success"]}]},
        "draft_picker_restore": {"dimensions": {"draft": "picker"}, "actionCases": [{"id": "picker", "enabledActions": ["restore_draft", "start_fresh", "delete_draft"]}]},
        "draft_save_update": {"dimensions": {"draft": "saved", "mutation": "settled"}, "actionCases": [{"id": "save", "enabledActions": ["save_draft"]}]},
        "draft_delete": {"dimensions": {"draft": "deleted", "mutation": "settled"}, "actionCases": [{"id": "delete", "enabledActions": ["delete_draft"]}]},
        "unsaved_changes": {"dimensions": {"draft": "dirty"}, "actionCases": [{"id": "exit", "enabledActions": ["save_and_exit", "discard_and_exit"]}]},
        "unauthorized_host": {"dimensions": {"route": "forbidden"}},
        "offline": {"dimensions": {"connectivity": "offline"}, "actionCases": [
          {"id": "route_recovery", "enabledActions": ["retry_route"]},
          {"id": "photo_retry", "enabledActions": ["select_event_photos"]},
          {"id": "draft_retry", "enabledActions": ["save_draft"]},
          {"id": "submit_retry", "enabledActions": ["submit_event"]}
        ]},
        "text_scale_2": {"dimensions": {"accessibility": "text_scale_2"}},
        "reduced_motion": {"dimensions": {"accessibility": "reduced_motion"}},
        "light_dark": {"dimensions": {"theme": "light_dark"}}
      },
      "requiredEvidence": {"captures": true, "previews": true, "tests": true},
      "evidenceExceptions": [
        {
          "stateIds": ["club_fetch_loading", "club_fetch_error", "club_not_found", "event_photos", "submit_pending", "offline", "text_scale_2", "reduced_motion", "light_dark"],
          "evidence": ["tests"],
          "debtId": "FEATURE-CONTRACT-MIGRATION-001",
          "reason": "These deterministic Host Event Create states have registered captures and the shared route-and-wizard preview but no focused state-level automated test recorded by the screen authority yet."
        },
        {
          "stateIds": ["location_picker_offline_search"],
          "evidence": ["previews"],
          "debtId": "FEATURE-CONTRACT-MIGRATION-001",
          "reason": "The offline Places-search state has focused test and capture evidence but no dedicated Widgetbook scenario registered yet."
        }
      ]
    }
  ]
}
