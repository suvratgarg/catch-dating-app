{
  "$schema": "./feature_contract.schema.json",
  "version": 2,
  "updated": "2026-07-23",
  "id": "feature.admin_growth_kpi",
  "name": "Admin Growth KPI",
  "owner": "admin_console",
  "status": "pilot",
  "description": "Orchestrates acquisition, supply, and conversion signal inspection across current Overview metrics and ranged Host Analytics evidence.",
  "surfaces": [
    {
      "id": "admin_web",
      "runtime": "react_admin",
      "authority": {"registry": "admin_routes", "id": "route_growth_kpi"},
      "actionScope": {
        "included": "Selecting a signal, returning to the directory, refreshing both sources, and independently retrying Overview or Host Analytics.",
        "excluded": [
          "Signal search, lifecycle-stage filter, and range choice remain local query inputs.",
          "The route is analytical and read-only; it does not alter growth targets, cohorts, or campaign state.",
          "Overview retains structural-object validation while Host Analytics has strict request and response schemas."
        ]
      },
      "bindings": {
        "previewSources": ["admin/src/stories/AdminRoutes.stories.tsx"],
        "actionOwners": [
          {"id": "controller", "language": "typescript", "file": "admin/src/features/growth/controllers/useGrowthKpiController.ts", "symbol": "useGrowthKpiController"},
          {"id": "screen", "language": "typescript", "file": "admin/src/features/growth/ui/GrowthKpiScreen.tsx", "symbol": "GrowthKpiWorkspace"}
        ],
        "componentContracts": ["route_growth_kpi"],
        "dataContracts": [
          "contracts/callables/host_analytics_query_payload.schema.json",
          "contracts/callable_responses/host_analytics_response.schema.json"
        ],
        "runtimeContracts": [
          {"kind": "admin_callable", "registry": "admin/src/generated/validators/adminCallableValidators.ts", "callable": "adminGetOverview", "requestValidation": "strict_schema", "responseValidation": "strict_schema"},
          {"kind": "admin_callable", "registry": "admin/src/generated/validators/adminCallableValidators.ts", "callable": "adminGetHostAnalytics", "requestValidation": "strict_schema", "responseValidation": "strict_schema"}
        ],
        "testEvidence": {
          "signal-directory": ["admin/src/features/growth/controllers/useGrowthKpiController.test.tsx"]
        }
      },
      "dimensions": {
        "view": {"default": "directory", "values": ["directory", "detail"]},
        "source_health": {"default": "complete", "values": ["complete", "loading", "overview_failed", "analytics_failed", "failed"]}
      },
      "actions": [
        {"id": "select_growth_signal", "owner": "controller", "codeValue": "select", "cardinality": "unbounded", "scopeKeys": ["adminSessionId", "signalId"], "outcomes": [{"kind": "surface_state", "stateIds": ["signal-directory"]}], "description": "Opens one source-labelled growth signal."},
        {"id": "back_to_growth_directory", "owner": "screen", "codeValue": "onBackToList", "cardinality": "unbounded", "scopeKeys": ["adminSessionId", "signalId"], "outcomes": [{"kind": "surface_state", "stateIds": ["signal-directory"]}], "description": "Returns from signal detail to the KPI directory."},
        {"id": "refresh_growth_sources", "owner": "controller", "codeValue": "refresh", "cardinality": "singleton", "scopeKeys": ["adminSessionId", "rangePreset", "sourceSnapshotVersion"], "outcomes": [{"kind": "surface_state", "stateIds": ["signal-directory"]}], "description": "Refetches both current Overview and ranged Host Analytics evidence."},
        {"id": "refresh_growth_overview", "owner": "controller", "codeValue": "refreshOverview", "cardinality": "singleton", "scopeKeys": ["adminSessionId", "overviewSnapshotVersion"], "outcomes": [{"kind": "surface_state", "stateIds": ["signal-directory"]}], "description": "Retries only the current Overview source."},
        {"id": "refresh_growth_analytics", "owner": "controller", "codeValue": "refreshHostAnalytics", "cardinality": "singleton", "scopeKeys": ["adminSessionId", "rangePreset", "analyticsSnapshotVersion"], "outcomes": [{"kind": "surface_state", "stateIds": ["signal-directory"]}], "description": "Retries only the selected Host Analytics range."
        }
      ],
      "scenarios": [
        {
          "id": "signal_directory",
          "stateId": "signal-directory",
          "dimensions": {},
          "actionCases": [
            {"id": "complete_directory", "enabledActions": ["select_growth_signal", "refresh_growth_sources", "refresh_growth_overview", "refresh_growth_analytics"]},
            {"id": "loading", "dimensions": {"source_health": "loading"}, "disabledActions": ["select_growth_signal", "refresh_growth_sources", "refresh_growth_overview", "refresh_growth_analytics"]},
            {"id": "overview_failed", "dimensions": {"source_health": "overview_failed"}, "enabledActions": ["select_growth_signal", "refresh_growth_sources", "refresh_growth_overview", "refresh_growth_analytics"]},
            {"id": "analytics_failed", "dimensions": {"source_health": "analytics_failed"}, "enabledActions": ["select_growth_signal", "refresh_growth_sources", "refresh_growth_overview", "refresh_growth_analytics"]},
            {"id": "signal_detail", "dimensions": {"view": "detail"}, "enabledActions": ["back_to_growth_directory"]}
          ]
        }
      ],
      "requiredEvidence": {"captures": false, "previews": true, "tests": true}
    }
  ]
}
