        {
          "id": "delete_event",
          "owner": "event_lifecycle",
          "codeValue": "deleteEvent",
          "cardinality": "singleton",
          "scopeKeys": [
            "hostUid",
            "eventId"
          ],
          "outcomes": [
            {
              "kind": "side_effect",
              "id": "event.deleted"
            }
          ],
          "description": "Deletes an unused managed event once after host confirmation."
        }
