            {"kind": "surface_state", "stateIds": ["schedule_editable", "validation_error"]}
          ],
          "description": "Selects an editable start time and recomputes schedule validation."
        },
        {
          "id": "adjust_edit_duration",
          "owner": "edit_intent",
