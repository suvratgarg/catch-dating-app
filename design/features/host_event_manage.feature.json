        },
        {
          "id": "select_edit_pace",
          "owner": "edit_intent",
          "codeValue": "HostEventEditPaceChangedIntent",
          "cardinality": "domain_bounded",
          "scopeKeys": ["routeInstanceId", "pace"],
          "outcomes": [
            {"kind": "surface_state", "stateIds": ["prefilled_event"]}
          ],
          "description": "Selects one pace from the event format's finite pace domain."
        },
        {
          "id": "select_edit_admission_policy",
          "owner": "edit_intent",
          "codeValue": "HostEventEditAdmissionPresetChangedIntent",
          "cardinality": "domain_bounded",
          "scopeKeys": ["routeInstanceId", "admissionPreset"],
          "outcomes": [
            {"kind": "surface_state", "stateIds": ["policy_editable", "private_access_loading"]}
          ],
          "description": "Selects one admission preset and resets incompatible cohort or pricing choices."
        },
        {
          "id": "toggle_edit_cohort_caps",
          "owner": "edit_intent",
          "codeValue": "HostEventEditCohortCapsChangedIntent",
          "cardinality": "unbounded",
          "scopeKeys": ["routeInstanceId", "cohortCapsEnabled"],
          "outcomes": [
            {"kind": "surface_state", "stateIds": ["policy_editable"]}
          ],
          "description": "Enables or disables fixed cohort caps while the event policy is editable."
        },
        {
          "id": "toggle_edit_dynamic_pricing",
          "owner": "edit_intent",
          "codeValue": "HostEventEditDynamicPricingChangedIntent",
          "cardinality": "unbounded",
          "scopeKeys": ["routeInstanceId", "dynamicPricingEnabled"],
          "outcomes": [
            {"kind": "surface_state", "stateIds": ["policy_editable"]}
          ],
          "description": "Enables or disables dynamic pricing and seeds its default amounts when first enabled."
        },
        {
          "id": "select_edit_cancellation_policy",
          "owner": "edit_intent",
          "codeValue": "HostEventEditCancellationPolicyChangedIntent",
          "cardinality": "domain_bounded",
          "scopeKeys": ["routeInstanceId", "cancellationPolicyId"],
          "outcomes": [
            {"kind": "surface_state", "stateIds": ["policy_editable"]}
          ],
          "description": "Selects one cancellation policy from the finite supported policy domain."
        },
        {
          "id": "save_event_edits",
