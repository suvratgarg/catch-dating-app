              "kind": "surface_state",
              "stateIds": ["validation_error", "submit_pending", "submit_error", "success_pop"]
            }
          ],
          "description": "Validates the editable form, updates the event and optional private-access policy, invalidates event readers, and returns to the caller after success."
        }
