{
  "$schema": "./feature_contract.schema.json",
  "version": 2,
  "updated": "2026-07-23",
  "id": "feature.host_event_manage",
  "name": "Host Event Manage",
  "owner": "hosts",
  "status": "pilot",
  "description": "Orchestrates the Host Event Manage workspace and its owner-edit projection without duplicating the owning screen, component, data, or Widgetbook registries.",
