{
  "$schema": "./feature_contract.schema.json",
  "version": 1,
  "updated": "2026-07-23",
  "id": "feature.host_event_manage",
  "name": "Host Event Manage",
  "owner": "hosts",
  "status": "pilot",
  "description": "Orchestrates Host Event Manage route, workspace, lifecycle-action, and evidence contracts without duplicating the owning screen, component, data, or Widgetbook registries.",
  "actionScope": {
    "included": "Primary event lifecycle action rows represented by HostEventManageActionIntent.",
    "excluded": [
      "Section selection, private and named invite-link actions, participant lifecycle mutations, report exports, and Event Success actions retain their existing owners and verification paths."
    ]
  },
  "screenContract": "screen.host.event.manage",
  "bindings": {
    "widgetbookSources": [
      "widgetbook/lib/hosts/host_operations_use_cases.dart"
    ],
    "actionOwner": {
      "file": "lib/hosts/presentation/host_event_manage_screen_state.dart",
      "symbol": "HostEventManageActionIntent"
    },
    "componentContracts": [
      "catch.badge",
      "catch.button",
      "catch.field",
      "catch.icon_button",
      "catch.option_card",
      "catch.option_group",
      "catch.surface",
      "catch.top_bar"
    ],
    "dataContracts": [
      "contracts/callables/create_event_invite_link_payload.schema.json",
      "contracts/callables/disable_event_invite_link_payload.schema.json",
      "contracts/callables/mark_event_attendance_payload.schema.json",
      "contracts/firestore/clubs.schema.json",
      "contracts/firestore/event_invite_links.schema.json",
      "contracts/firestore/event_participations.schema.json",
      "contracts/firestore/event_success_assignments.schema.json",
      "contracts/firestore/event_success_plans.schema.json",
      "contracts/firestore/event_success_preferences.schema.json",
      "contracts/firestore/event_success_scorecards.schema.json",
      "contracts/firestore/event_success_wingman_requests.schema.json",
      "contracts/firestore/events.schema.json",
      "contracts/firestore/public_profiles.schema.json"
    ]
  },
  "dimensions": {
    "route": {
      "default": "ready",
      "values": [
        "ready",
        "loading",
        "error",
        "not_found",
        "unauthorized",
        "offline"
      ]
    },
    "section": {
      "default": "setup",
      "values": ["setup", "guests", "live", "report"]
    },
    "content": {
      "default": "ready",
      "values": ["ready", "loading", "error", "empty", "offline"]
    },
    "mutation": {
      "default": "idle",
      "values": ["idle", "pending", "error", "mixed", "settled"]
    },
    "activity": {
      "default": "known",
      "values": ["known", "unused"]
    },
    "lifecycle": {
      "default": "active",
      "values": ["active", "cancelled"]
    },
    "accessibility": {
      "default": "standard",
      "values": ["standard", "text_scale_2", "reduced_motion"]
    },
    "theme": {
      "default": "light",
      "values": ["light", "light_dark"]
    }
  },
  "actions": [
    {
      "id": "edit_event",
      "codeValue": "editEvent",
      "cardinality": "singleton",
      "scopeKeys": ["hostUid", "eventId"],
      "outcomes": [
        {"kind": "route", "screenContract": "screen.host.event.edit"}
      ],
      "description": "Navigates the host to the single edit route for the managed event."
    },
    {
      "id": "cancel_event",
      "codeValue": "cancelEvent",
      "cardinality": "singleton",
      "scopeKeys": ["hostUid", "eventId"],
      "outcomes": [
        {"kind": "screen_state", "stateIds": ["cancelled_event"]}
      ],
      "description": "Cancels the managed event once after host confirmation."
    },
    {
      "id": "delete_event",
      "codeValue": "deleteEvent",
      "cardinality": "singleton",
      "scopeKeys": ["hostUid", "eventId"],
      "outcomes": [
        {"kind": "side_effect", "id": "event.deleted"}
      ],
      "description": "Deletes an unused managed event once after host confirmation."
    }
  ],
  "scenarios": [
