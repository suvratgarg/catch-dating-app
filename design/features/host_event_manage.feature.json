    {
      "id": "host_flutter",
      "runtime": "flutter",
      "authority": {
        "registry": "flutter_screens",
        "id": "screen.host.event.manage"
      },
      "actionScope": {
        "included": "Primary event lifecycle action rows represented by HostEventManageActionIntent.",
        "excluded": [
          "Section selection, private and named invite-link actions, participant lifecycle mutations, report exports, and Event Success actions retain their existing owners and verification paths."
        ]
      },
      "bindings": {
        "previewSources": [
          "widgetbook/lib/hosts/host_operations_use_cases.dart"
        ],
        "actionOwners": [
          {
            "id": "event_lifecycle",
            "language": "dart",
            "file": "lib/hosts/presentation/host_event_manage_screen_state.dart",
            "symbol": "HostEventManageActionIntent"
          }
        ],
        "componentContracts": [
          "catch.badge",
          "catch.button",
