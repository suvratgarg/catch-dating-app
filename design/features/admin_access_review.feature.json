{
  "$schema": "./feature_contract.schema.json",
  "version": 2,
  "updated": "2026-07-23",
  "id": "feature.admin_access_review",
  "name": "Admin Access Review",
  "owner": "admin_console",
  "status": "pilot",
  "description": "Orchestrates bounded launch-access queue review, direct applicant evidence reads, audited approval or denial, and recovery from unavailable detail.",
  "surfaces": [
    {
      "id": "admin_web",
      "runtime": "react_admin",
      "authority": {"registry": "admin_routes", "id": "route_access_review"},
      "actionScope": {
        "included": "Selecting an application, returning to the queue, refreshing list or detail evidence, recording the audited access decision, and freezing the complete Admin workspace while that decision is pending.",
        "excluded": [
          "Queue search and note/cohort field edits remain local query or form data.",
          "Approval records eligibility for profile creation; it does not invite or notify the applicant."
        ]
      },
      "bindings": {
        "previewSources": ["admin/src/stories/AdminRoutes.stories.tsx"],
        "actionOwners": [
          {
            "id": "controller",
            "language": "typescript",
            "file": "admin/src/features/access/controllers/useAccessReviewController.ts",
            "symbol": "useAccessReviewController"
          },
          {
            "id": "screen",
            "language": "typescript",
            "file": "admin/src/features/access/ui/AccessReviewScreen.tsx",
            "symbol": "AccessReviewWorkspace"
          }
        ],
        "componentContracts": ["route_access_review"],
        "dataContracts": [],
        "runtimeContracts": [
          {"kind": "admin_callable", "registry": "admin/src/generated/validators/adminCallableValidators.ts", "callable": "adminGetOverview", "requestValidation": "structural_object", "responseValidation": "structural_object"},
          {"kind": "admin_callable", "registry": "admin/src/generated/validators/adminCallableValidators.ts", "callable": "adminGetAccessApplicationDetails", "requestValidation": "structural_object", "responseValidation": "structural_object"},
          {"kind": "admin_callable", "registry": "admin/src/generated/validators/adminCallableValidators.ts", "callable": "adminDecideAccessApplication", "requestValidation": "structural_object", "responseValidation": "structural_object"}
        ],
        "testEvidence": {
          "capped-directory": [
            "admin/src/features/access/controllers/useAccessReviewController.test.tsx",
            "admin/src/shared/pendingOperation.test.tsx"
          ]
        }
      },
      "dimensions": {
        "view": {"default": "directory", "values": ["directory", "detail", "unavailable"]},
        "source": {"default": "ready", "values": ["ready", "loading", "failed"]},
        "mutation": {"default": "idle", "values": ["idle", "pending", "failed", "success"]}
      },
      "actions": [
        {
          "id": "select_access_application",
          "owner": "controller",
          "codeValue": "select",
          "cardinality": "unbounded",
          "scopeKeys": ["adminSessionId", "applicationUid"],
          "outcomes": [{"kind": "surface_state", "stateIds": ["capped-directory"]}],
          "description": "Opens one returned queue item using its validated application uid."
        },
        {
          "id": "back_to_access_queue",
          "owner": "screen",
          "codeValue": "onBackToList",
          "cardinality": "unbounded",
          "scopeKeys": ["adminSessionId", "applicationUid"],
          "outcomes": [{"kind": "surface_state", "stateIds": ["capped-directory"]}],
          "description": "Returns from applicant detail to the bounded access queue."
        },
        {
          "id": "refresh_access_queue",
          "owner": "controller",
          "codeValue": "refresh",
          "cardinality": "singleton",
          "scopeKeys": ["adminSessionId", "queueSnapshotVersion"],
          "outcomes": [{"kind": "surface_state", "stateIds": ["capped-directory"]}],
          "description": "Refetches the access queue and its independently reported pending total."
        },
        {
          "id": "refresh_access_detail",
          "owner": "controller",
          "codeValue": "refreshDetail",
          "cardinality": "singleton",
          "scopeKeys": ["adminSessionId", "applicationUid"],
          "outcomes": [{"kind": "surface_state", "stateIds": ["capped-directory"]}],
          "description": "Retries the direct applicant evidence read without substituting another application."
        },
        {
          "id": "decide_access_application",
          "owner": "controller",
          "codeValue": "decide",
          "cardinality": "singleton",
          "scopeKeys": ["reviewerUid", "applicationUid", "decisionVersion"],
          "outcomes": [
            {"kind": "surface_state", "stateIds": ["capped-directory"]},
            {"kind": "side_effect", "id": "admin.access_decision_recorded"}
          ],
          "description": "Records one approve-for-profile or not-selected-yet decision with review evidence."
        }
      ],
      "scenarios": [
        {
          "id": "capped_directory",
          "stateId": "capped-directory",
          "dimensions": {},
          "actionCases": [
            {"id": "directory_ready", "enabledActions": ["select_access_application", "refresh_access_queue"]},
            {"id": "directory_loading", "dimensions": {"source": "loading"}, "disabledActions": ["select_access_application", "refresh_access_queue"]},
            {"id": "detail_ready", "dimensions": {"view": "detail"}, "enabledActions": ["back_to_access_queue", "refresh_access_detail", "decide_access_application"]},
            {"id": "detail_unavailable", "dimensions": {"view": "unavailable", "source": "failed"}, "enabledActions": ["back_to_access_queue", "refresh_access_detail"]},
            {"id": "decision_pending_frozen_workspace", "dimensions": {"view": "detail", "mutation": "pending"}, "disabledActions": ["back_to_access_queue", "refresh_access_detail", "decide_access_application"]},
            {"id": "decision_failed", "dimensions": {"view": "detail", "mutation": "failed"}, "enabledActions": ["back_to_access_queue", "refresh_access_detail", "decide_access_application"]}
          ]
        }
      ],
      "requiredEvidence": {"captures": false, "previews": true, "tests": true}
    }
  ]
}
