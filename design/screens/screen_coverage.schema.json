{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://catch.app/design/screens/screen_coverage.schema.json",
  "title": "Catch screen coverage registry",
  "type": "object",
  "required": [
    "$schema",
    "version",
    "updated",
    "generatedAgainst",
    "description",
    "routes"
  ],
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string"
    },
    "version": {
      "const": 1
    },
    "updated": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "generatedAgainst": {
      "const": "tool/ui_capture/route_inventory.json"
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "routes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/routeCoverage"
      }
    }
  },
  "$defs": {
    "routeCoverage": {
      "type": "object",
      "required": ["routeId", "status", "priority", "reason"],
      "additionalProperties": false,
      "properties": {
        "routeId": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "enum": ["contracted", "alias", "planned", "excluded"]
        },
        "priority": {
          "enum": ["P1", "P2", "P3", "P4"]
        },
        "screenId": {
          "type": "string",
          "pattern": "^screen\\.[a-z0-9_.-]+$"
        },
        "canonicalRouteId": {
          "type": "string",
          "minLength": 1
        },
        "reason": {
          "type": "string",
          "minLength": 1
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "status": {
                "const": "contracted"
              }
            }
          },
          "then": {
            "required": ["screenId"],
            "not": {
              "required": ["canonicalRouteId"]
            }
          }
        },
        {
          "if": {
            "properties": {
              "status": {
                "const": "alias"
              }
            }
          },
          "then": {
            "required": ["canonicalRouteId"]
          }
        },
        {
          "if": {
            "properties": {
              "status": {
                "enum": ["planned", "excluded"]
              }
            }
          },
          "then": {
            "not": {
              "anyOf": [
                {
                  "required": ["screenId"]
                },
                {
                  "required": ["canonicalRouteId"]
                }
              ]
            }
          }
        }
      ]
    }
  }
}
