{
  "$description": "Canonical Catch design tokens. DTCG-shaped source for website CSS and Flutter primitive generators.",
  "$extensions": {
    "org.catch": {
      "version": 1,
      "dtcg": "Design Tokens Format Module 2025.10",
      "sources": [
        "docs/design_language.md",
        "lib/core/theme/catch_tokens.dart",
        "lib/core/theme/activity_palette.dart",
        "lib/core/theme/catch_fonts.dart",
        "lib/core/theme/catch_text_styles.dart"
      ],
      "dart": {
        "output": "lib/core/theme/generated/catch_design_tokens.g.dart"
      },
      "website": {
        "output": "packages/web-config/generated/catch-tokens.css",
        "fontFaces": [
          {
            "family": "Archivo",
            "style": "normal",
            "weight": "100 900",
            "source": "assets/fonts/Archivo-Roman-VF.woff2",
            "target": "packages/web-config/generated/assets/fonts/Archivo-Roman-VF.woff2",
            "url": "./assets/fonts/Archivo-Roman-VF.woff2",
            "format": "woff2"
          },
          {
            "family": "IBM Plex Mono",
            "style": "normal",
            "weight": "400",
            "source": "assets/fonts/IBMPlexMono-Regular.ttf",
            "target": "packages/web-config/generated/assets/fonts/IBMPlexMono-Regular.ttf",
            "url": "./assets/fonts/IBMPlexMono-Regular.ttf",
            "format": "truetype"
          },
          {
            "family": "IBM Plex Mono",
            "style": "normal",
            "weight": "500",
            "source": "assets/fonts/IBMPlexMono-Medium.ttf",
            "target": "packages/web-config/generated/assets/fonts/IBMPlexMono-Medium.ttf",
            "url": "./assets/fonts/IBMPlexMono-Medium.ttf",
            "format": "truetype"
          },
          {
            "family": "IBM Plex Mono",
            "style": "normal",
            "weight": "600",
            "source": "assets/fonts/IBMPlexMono-SemiBold.ttf",
            "target": "packages/web-config/generated/assets/fonts/IBMPlexMono-SemiBold.ttf",
            "url": "./assets/fonts/IBMPlexMono-SemiBold.ttf",
            "format": "truetype"
          },
          {
            "family": "IBM Plex Mono",
            "style": "normal",
            "weight": "700",
            "source": "assets/fonts/IBMPlexMono-Bold.ttf",
            "target": "packages/web-config/generated/assets/fonts/IBMPlexMono-Bold.ttf",
            "url": "./assets/fonts/IBMPlexMono-Bold.ttf",
            "format": "truetype"
          }
        ],
        "legacyAliases": {
          "ink": "{theme.dark.color.bg}",
          "ink-2": "{theme.dark.color.surface}",
          "bone": "{theme.dark.color.ink}",
          "bone-2": "{theme.light.color.raised}",
          "mist": "{theme.dark.color.line2}",
          "muted": "{theme.dark.color.ink2}",
          "line": "{theme.dark.color.line}",
          "line-dark": "{theme.light.color.line2}",
          "lime": "{theme.dark.color.primary}",
          "lime-2": "{theme.dark.color.ink2}",
          "plum": "{theme.dark.color.surface}",
          "oxblood": "{activity.dinner.accent}",
          "teal": "{activity.padel.accent}",
          "cobalt": "{activity.pubQuiz.accent}",
          "shadow": "0 28px 80px rgba(0, 0, 0, 0.28)",
          "shadow-soft": "0 18px 44px rgba(0, 0, 0, 0.16)",
          "content": "{website.content.max}",
          "gutter": "{space.s5}",
          "radius": "{radius.sm}",
          "header-height": "{website.header.height}"
        }
      }
    }
  },
