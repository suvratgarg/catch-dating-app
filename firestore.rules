rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthed() {
      return request.auth != null;
    }

    function hasField(data, field) {
      return data.keys().hasAny([field]);
    }

    function optionalString(data, field) {
      return !hasField(data, field)
        || data[field] == null
        || data[field] is string;
    }

    function optionalNumber(data, field) {
      return !hasField(data, field)
        || data[field] == null
        || data[field] is number;
    }

    function optionalHeightCm(data, field) {
      return !hasField(data, field)
        || data[field] == null
        || (
          data[field] is number
          && data[field] >= 120
          && data[field] <= 220
        );
    }

    function optionalBool(data, field) {
      return !hasField(data, field)
        || data[field] == null
        || data[field] is bool;
    }

    function optionalTimestamp(data, field) {
      return !hasField(data, field)
        || data[field] == null
        || data[field] is timestamp;
    }

    function optionalIn(data, field, values) {
      return !hasField(data, field)
        || data[field] == null
        || data[field] in values;
    }

    function optionalList(data, field) {
      return !hasField(data, field)
        || data[field] == null
        || data[field] is list;
    }

    function optionalListMax(data, field, maxSize) {
      return !hasField(data, field)
        || data[field] == null
        || (data[field] is list && data[field].size() <= maxSize);
    }

    function isDefaultCity(city) {
      return city in [
        'mumbai',
        'delhi',
        'bangalore',
        'hyderabad',
        'chennai',
	        'kolkata',
	        'pune',
	        'ahmedabad',
	        'indore',
	        'kathmandu',
	        'pokhara',
	        'sydney',
	        'melbourne',
	        'brisbane',
	        'new-york',
	        'san-francisco',
	        'los-angeles'
	      ];
	    }

    function isConfiguredCity(city) {
      return exists(/databases/$(database)/documents/config/cities)
        && get(/databases/$(database)/documents/config/cities)
            .data.keys().hasAny(['cityNames'])
        && get(/databases/$(database)/documents/config/cities)
            .data.cityNames is list
        && city in get(/databases/$(database)/documents/config/cities)
            .data.cityNames;
    }

    function isValidCity(city) {
      return city is string
        && (isDefaultCity(city) || isConfiguredCity(city));
    }

    function blockDocId(blockerUid, blockedUid) {
      return blockerUid + '__' + blockedUid;
    }

    function eventParticipationDocId(eventId, uid) {
      return eventId + '_' + uid;
    }

    function savedEventDocId(uid, eventId) {
      return uid + '_' + eventId;
    }

    function eventSuccessFeedbackDocId(eventId, uid) {
      return eventId + '_' + uid;
    }

    function eventSuccessPreferenceDocId(eventId, uid) {
      return eventId + '_' + uid;
    }

    function eventSuccessWingmanRequestDocId(eventId, uid) {
      return eventId + '_' + uid;
    }

    function eventSuccessCompatibilityResponseDocId(eventId, uid) {
      return eventId + '_' + uid;
    }

    function eventSuccessAssignmentDocId(eventId, moduleId, uid) {
      return eventId + '_' + moduleId + '_' + uid;
    }

    function hasBlockBetween(uidA, uidB) {
      return exists(/databases/$(database)/documents/blocks/$(blockDocId(uidA, uidB)))
        || exists(/databases/$(database)/documents/blocks/$(blockDocId(uidB, uidA)));
    }

    function hasParticipantId(matchData, uid) {
      return matchData.participantIds is list
        && uid in matchData.participantIds;
    }

    function isMatchParticipant(matchData, uid) {
      return hasParticipantId(matchData, uid)
        || matchData.user1Id == uid
        || matchData.user2Id == uid;
    }

    function isDeletedUser(uid) {
      return exists(/databases/$(database)/documents/deletedUsers/$(uid));
    }

    function isClubHostData(clubData) {
      return clubData.hostUserId == request.auth.uid
        || (
          clubData.keys().hasAny(['ownerUserId'])
          && clubData.ownerUserId == request.auth.uid
        )
        || (
          clubData.keys().hasAny(['hostUserIds'])
          && request.auth.uid in clubData.hostUserIds
        );
    }

    function isClubHostForEvent(eventId) {
      return exists(/databases/$(database)/documents/events/$(eventId))
        && exists(/databases/$(database)/documents/clubs/$(
          get(/databases/$(database)/documents/events/$(eventId)).data.clubId
        ))
        && isClubHostData(get(/databases/$(database)/documents/clubs/$(
          get(/databases/$(database)/documents/events/$(eventId)).data.clubId
        )).data);
    }

    function hasEventParticipationStatus(eventId, uid, statuses) {
      return exists(/databases/$(database)/documents/eventParticipations/$(eventParticipationDocId(eventId, uid)))
        && get(/databases/$(database)/documents/eventParticipations/$(eventParticipationDocId(eventId, uid)))
        .data.status in statuses;
    }

    function hasAttendedEvent(eventId, uid) {
      return exists(/databases/$(database)/documents/eventParticipations/$(eventParticipationDocId(eventId, uid)))
        && get(/databases/$(database)/documents/eventParticipations/$(eventParticipationDocId(eventId, uid)))
        .data.status == 'attended';
    }

    function canReadEventSuccess(eventId) {
      return isAuthed()
        && (
          isClubHostForEvent(eventId)
          || hasEventParticipationStatus(eventId, request.auth.uid, [
            'signedUp', 'waitlisted', 'attended'
          ])
        );
    }

    // ── Users ─────────────────────────────────────────────────────────────────
    function hasValidUserShape(data) {
      return data.keys().hasOnly([
          // Core
          'name', 'firstName', 'lastName', 'displayName', 'email',
          'profilePrompts',
	          'instagramHandle', 'phoneNumber', 'countryCode', 'dateOfBirth',
          'gender', 'profileComplete',
          // Photos
          'photoUrls', 'photoThumbnailUrls', 'photoPrompts', 'profilePhotos',
          // Location
          'city',
          'latitude',
          'longitude',
          // Matching
          'interestedInGenders',
          'minAgePreference', 'maxAgePreference',
          // Background
          'height', 'occupation', 'company', 'education', 'religion',
          'languages',
          // Intentions
          'relationshipGoal',
          // Lifestyle
          'drinking', 'smoking', 'workout', 'diet', 'children',
          // Running
          'paceMinSecsPerKm', 'paceMaxSecsPerKm',
          'preferredDistances', 'runningReasons', 'preferredRunTimes',
          'runPreferencesVersion',
          // Notification / discovery preferences
          'prefsNewCatches', 'prefsMessages', 'prefsEventReminders',
          'prefsRunStatusUpdates', 'prefsClubUpdates',
          'prefsWeeklyDigest', 'prefsShowOnMap',
          // Runtime fields
          'fcmToken',
          // Server-owned lifecycle fields. These must be tolerated on existing
          // retained docs, but clients cannot create or change them.
          'deleted',
          'deletedAt'
        ])
        && data.keys().hasAll([
          'name', 'displayName', 'email', 'phoneNumber', 'dateOfBirth',
          'gender', 'profileComplete', 'profilePrompts',
          'firstName', 'lastName',
          'photoUrls', 'photoThumbnailUrls', 'photoPrompts',
          'interestedInGenders', 'minAgePreference', 'maxAgePreference',
          'languages', 'paceMinSecsPerKm', 'paceMaxSecsPerKm',
          'preferredDistances', 'runningReasons', 'preferredRunTimes',
          'runPreferencesVersion',
          'prefsNewCatches', 'prefsMessages', 'prefsEventReminders',
          'prefsRunStatusUpdates', 'prefsClubUpdates',
          'prefsWeeklyDigest', 'prefsShowOnMap'
        ])
        // Core
        && data.name is string
        && data.firstName is string
        && data.firstName.size() <= 80
        && data.lastName is string
        && data.lastName.size() <= 80
        && data.displayName is string
        && data.displayName.size() <= 80
        && data.displayName.matches('.*\\S.*')
        && data.email is string
        && data.profilePrompts is list
        && data.profilePrompts.size() <= 3
	        && optionalString(data, 'instagramHandle')
	        && data.phoneNumber is string
	        && optionalString(data, 'countryCode')
	        && data.dateOfBirth is timestamp
        && data.gender in ['man', 'woman', 'nonBinary', 'other']
        && data.profileComplete is bool
        // Photos
        && data.photoUrls is list
        && data.photoUrls.size() <= 6
        && data.photoThumbnailUrls is list
        && data.photoThumbnailUrls.size() <= 6
        && data.photoPrompts is list
        && data.photoPrompts.size() <= 6
        && optionalListMax(data, 'profilePhotos', 6)
        // Location
        && (!hasField(data, 'city') || data.city == null || isValidCity(data.city))
        && optionalNumber(data, 'latitude')
        && optionalNumber(data, 'longitude')
        // Matching
        && data.interestedInGenders is list
        && data.interestedInGenders.size() > 0
        && data.interestedInGenders.size() <= 8
        && data.minAgePreference is number
        && data.minAgePreference >= 18
        && data.minAgePreference <= 99
        && data.maxAgePreference is number
        && data.maxAgePreference >= 18
        && data.maxAgePreference <= 99
        // Background
        && optionalHeightCm(data, 'height')
        && optionalString(data, 'occupation')
        && optionalString(data, 'company')
        && optionalIn(data, 'education', [
          'highSchool', 'someCollege', 'bachelors', 'masters', 'phd',
          'tradeSchool', 'other'
        ])
        && optionalIn(data, 'religion', [
          'hindu', 'muslim', 'christian', 'sikh', 'jain', 'buddhist',
          'other', 'nonReligious'
        ])
        && data.languages is list
        && data.languages.size() <= 20
        // Intentions
        && optionalIn(data, 'relationshipGoal', [
          'relationship', 'casual', 'marriage', 'friendship', 'unsure'
        ])
        // Lifestyle
        && optionalIn(data, 'drinking', [
          'never', 'socially', 'often'
        ])
        && optionalIn(data, 'smoking', [
          'never', 'occasionally', 'often'
        ])
        && optionalIn(data, 'workout', [
          'never', 'sometimes', 'often', 'everyday'
        ])
        && optionalIn(data, 'diet', [
          'omnivore', 'vegetarian', 'vegan', 'jain', 'other'
        ])
        && optionalIn(data, 'children', [
          'dontHave', 'haveWantMore', 'haveNoMore', 'wantSomeday', 'dontWant'
        ])
        // Running
        && data.paceMinSecsPerKm is number
        && data.paceMinSecsPerKm > 0
        && data.paceMaxSecsPerKm is number
        && data.paceMaxSecsPerKm > 0
        && data.preferredDistances is list
        && data.preferredDistances.size() <= 12
        && data.runningReasons is list
        && data.runningReasons.size() <= 12
        && data.preferredRunTimes is list
        && data.preferredRunTimes.size() <= 8
        && data.runPreferencesVersion is number
        && data.runPreferencesVersion >= 0
        // Notification / discovery preferences
        && data.prefsNewCatches is bool
        && data.prefsMessages is bool
        && data.prefsEventReminders is bool
        && data.prefsRunStatusUpdates is bool
        && data.prefsClubUpdates is bool
        && data.prefsWeeklyDigest is bool
        && data.prefsShowOnMap is bool
        // Runtime fields (optional)
        && optionalString(data, 'fcmToken')
        && optionalBool(data, 'deleted')
        && optionalTimestamp(data, 'deletedAt');
    }

    function isValidUserCreate(uid) {
      return isAuthed()
        && request.auth.uid == uid
        && !isDeletedUser(uid)
        && hasValidUserShape(request.resource.data)
        && !hasField(request.resource.data, 'deleted')
        && !hasField(request.resource.data, 'deletedAt');
    }

    function userChangedKeys() {
      return request.resource.data.diff(resource.data).affectedKeys();
    }

    function isValidFcmTokenUpdate() {
      return userChangedKeys().hasOnly(['fcmToken'])
        && optionalString(request.resource.data, 'fcmToken');
    }

    function isValidUserUpdate(uid) {
      return isAuthed()
        && request.auth.uid == uid
        && !isDeletedUser(uid)
        && isValidFcmTokenUpdate();
    }

    function hasValidOnboardingDraftShape(data) {
      // Private owner-only draft state changes faster than shared production
      // documents. Keep this intentionally forward-compatible and validate
      // only the routing-critical invariant.
      return data.keys().hasAll(['step'])
        && data.step is int
        && data.step >= 0;
    }

    function isValidNotificationReadUpdate(uid) {
      return isAuthed()
        && request.auth.uid == uid
        && resource.data.uid == uid
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['readAt'])
        && request.resource.data.uid == uid
        && request.resource.data.readAt is timestamp;
    }

    // ── Public config ──────────────────────────────────────────────────────────
    match /config/cities {
      allow read: if true;
      allow write: if false;
    }

    match /config/{docId} {
      allow read, write: if false;
    }

    // Private profile/account documents are owner-only. User discovery,
    // matches, chats, reviews, and notifications must read publicProfiles.
    match /users/{uid} {
      allow read: if isAuthed()
        && request.auth.uid == uid
        && !isDeletedUser(uid)
        && !hasBlockBetween(request.auth.uid, uid);

      // Owners create their initial profile directly with full shape validation.
      // Profile edits go through updateUserProfile so complex field validation
      // stays in Zod instead of Firestore rules. Direct updates here are limited
      // to narrow runtime fields that rules can validate cheaply.
      allow create: if isValidUserCreate(uid);
      allow update: if isValidUserUpdate(uid);

      // Client-side deletes are blocked — account deletion is handled
      // exclusively by the requestAccountDeletion Cloud Function, which
      // uses the admin SDK to anonymize the document in place.
      allow delete: if false;
    }

    // ── Onboarding drafts ─────────────────────────────────────────────────────
    // Drafts contain pre-profile onboarding state. Only the signed-in owner can
    // read/write/delete their draft.
    match /onboarding_drafts/{uid} {
      allow read: if isAuthed() && request.auth.uid == uid;
      allow create, update: if isAuthed()
        && request.auth.uid == uid
        && hasValidOnboardingDraftShape(request.resource.data);
      allow delete: if isAuthed() && request.auth.uid == uid;
    }

    // ── Blocks ───────────────────────────────────────────────────────────────
    // Clients can read only block edges involving themselves. Mutations go
    // through Cloud Functions so existing matches can be closed atomically.
    match /blocks/{blockId} {
      allow read: if isAuthed() && (
        resource.data.blockerUserId == request.auth.uid
        || resource.data.blockedUserId == request.auth.uid
      );
      allow write: if false;
    }

    // Written exclusively by the reportUser Cloud Function.
    match /reports/{reportId} {
      allow read, write: if false;
    }

    // Written exclusively by the rate-limit middleware in Cloud Functions.
    match /rateLimits/{docId} {
      allow read, write: if false;
    }

    // Written exclusively by idempotent Cloud Function trigger handlers.
    match /functionEventReceipts/{receiptId} {
      allow read, write: if false;
    }

    // Written exclusively by demo-data tooling to track synthetic-data cleanup.
    match /seedEvents/{manifestId} {
      allow read, write: if false;
    }

    // Backend-owned allowlist for seeded beta users who can ask Suvbot for
    // self-scoped demo refreshes.
    match /demoSelfServiceAccess/{uid} {
      allow read: if isAuthed() && request.auth.uid == uid;
      allow write: if false;
    }

    // Backend-owned request audit trail for Suvbot demo operations.
    match /demoOpsRequests/{requestId} {
      allow read, write: if false;
    }

    // Backend-owned temporary confirmation tokens for destructive Suvbot
    // operations.
    match /demoOpsConfirmations/{confirmationId} {
      allow read, write: if false;
    }

    // Written exclusively by event scheduling Cloud Functions to prevent
    // overlapping events and bookings.
    match /clubScheduleLocks/{lockId} {
      allow read, write: if false;
    }

    match /userEventScheduleLocks/{lockId} {
      allow read, write: if false;
    }

    // Server-owned durable activity timeline. Users can read their own timeline
    // and mark items as read, but cannot create, delete, or edit notification
    // content.
    match /notifications/{uid}/items/{notificationId} {
      allow read: if isAuthed() && request.auth.uid == uid;
      allow update: if isValidNotificationReadUpdate(uid);
      allow create, delete: if false;
    }

    // Written exclusively by the moderation Cloud Functions.
    match /moderationFlags/{flagId} {
      allow read, write: if false;
    }

    // Written exclusively by the account-deletion Cloud Function.
    match /deletedUsers/{uid} {
      allow read, write: if false;
    }

    // ── Public profiles ───────────────────────────────────────────────────────
    // Synced by the syncPublicProfile Cloud Function trigger. No client writes.
    match /publicProfiles/{uid} {
      allow read: if isAuthed()
        && !isDeletedUser(uid)
        && !hasBlockBetween(request.auth.uid, uid);
      allow write: if false;
    }

    // ── Clubs ─────────────────────────────────────────────────────────────
    match /clubMemberships/{membershipId} {
      allow read: if isAuthed()
        && (
          resource.data.status == 'active'
          || resource.data.uid == request.auth.uid
        );
      allow write: if false;
    }

    match /clubHostClaims/{uid} {
      allow read, write: if false;
    }

    match /clubs/{clubId} {
      allow read: if true;

      // Club creation is handled by the createClub Cloud Function so the
      // initial club doc and user membership projection stay atomic.
      allow create: if false;

      // Club profile edits go through updateClub. Keeping direct updates
      // closed lets rules avoid duplicating Zod validation and prevents
      // clients from touching aggregate/projection fields.
      allow update: if false;

      // Club deletion needs backend cleanup of events, memberships, reviews, and
      // images before it can be safely exposed.
      allow delete: if false;
    }

    // ── Swipes helper ─────────────────────────────────────────────────────────
    function optionalSwipeText(data, field, maxSize) {
      return !hasField(data, field)
        || (data[field] is string && data[field].size() <= maxSize);
    }

    function hasValidSwipeCreate(userId, targetId) {
      return isAuthed()
        && request.auth.uid == userId
        && userId != targetId
        && request.resource.data.keys().hasOnly([
          'swiperId',
          'targetId',
          'eventId',
          'direction',
          'reactionTargetId',
          'reactionTargetType',
          'reactionTargetLabel',
          'reactionTargetPreview',
          'comment',
          'createdAt'
        ])
        && request.resource.data.keys().hasAll([
          'swiperId',
          'targetId',
          'eventId',
          'direction',
          'createdAt'
        ])
        && request.resource.data.swiperId == userId
        && request.resource.data.targetId == targetId
        && request.resource.data.eventId is string
        && request.resource.data.direction in ['like', 'pass']
        && optionalSwipeText(request.resource.data, 'reactionTargetId', 80)
        && optionalSwipeText(request.resource.data, 'reactionTargetLabel', 80)
        && optionalSwipeText(
          request.resource.data,
          'reactionTargetPreview',
          240
        )
        && optionalSwipeText(request.resource.data, 'comment', 240)
        && (
          !hasField(request.resource.data, 'reactionTargetType')
          || request.resource.data.reactionTargetType in [
            'heroPhoto',
            'photo',
            'profilePrompt',
            'compatibility',
            'running',
            'details',
            'lifestyle'
          ]
        )
        && (
          request.resource.data.direction == 'like'
          || (
            !hasField(request.resource.data, 'reactionTargetId')
            && !hasField(request.resource.data, 'reactionTargetType')
            && !hasField(request.resource.data, 'reactionTargetLabel')
            && !hasField(request.resource.data, 'reactionTargetPreview')
            && !hasField(request.resource.data, 'comment')
          )
        )
        && request.resource.data.createdAt is timestamp
        && !isDeletedUser(userId)
        && !isDeletedUser(targetId)
        && exists(/databases/$(database)/documents/publicProfiles/$(targetId))
        && exists(/databases/$(database)/documents/events/$(request.resource.data.eventId))
        && hasAttendedEvent(request.resource.data.eventId, userId)
        && hasAttendedEvent(request.resource.data.eventId, targetId)
        && !hasBlockBetween(userId, targetId);
    }

    // ── Events ──────────────────────────────────────────────────────────────────
    match /eventParticipations/{participationId} {
      allow read: if isAuthed()
        && (
          resource.data.uid == request.auth.uid
          || resource.data.status in ['signedUp', 'waitlisted', 'attended']
          || isClubHostForEvent(resource.data.eventId)
        );
      allow write: if false;
    }

    match /savedEvents/{savedEventId} {
      allow read: if isAuthed() && resource.data.uid == request.auth.uid;
      allow create: if isAuthed()
        && request.resource.data.keys().hasOnly(['uid', 'eventId', 'savedAt'])
        && request.resource.data.keys().hasAll(['uid', 'eventId', 'savedAt'])
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.eventId is string
        && request.resource.data.savedAt is timestamp
        && exists(/databases/$(database)/documents/events/$(request.resource.data.eventId))
        && savedEventId == savedEventDocId(request.auth.uid, request.resource.data.eventId);
      allow delete: if isAuthed() && resource.data.uid == request.auth.uid;
      allow update: if false;
    }

    match /events/{eventId} {
      allow read: if true;

      // Event creation is callable-owned so host authority and server-owned
      // booking fields stay in one backend contract.
      allow create: if false;

      // Booking, waitlist, attendance, cancellation, and host edits are all
      // callable-owned so canonical event projections cannot be mutated directly.
      allow update: if false;

      // Event deletion needs backend cleanup/refunds before it can be safely
      // exposed.
      allow delete: if false;
    }

    match /eventPrivateAccess/{eventId} {
      allow read: if isAuthed()
        && resource.data.eventId == eventId
        && isClubHostForEvent(eventId);
      allow write: if false;
    }

    function isValidEventSuccessPlan(eventId, data) {
      return data.keys().hasOnly([
          'eventId', 'clubId', 'playbookId', 'selectedModuleIds',
          'targetAttendeeCount', 'structureConfig', 'hostGoal', 'wingmanRequestsEnabled',
          'contextualOpenersEnabled', 'compatibilityAffectsRanking',
          'questionnaireConfig',
          'activeStepIndex', 'status',
          'revealStatus', 'activeRevealRoundIndex', 'revealStartedAt',
          'attendeePrompt', 'createdAt', 'updatedAt', 'frozenAt',
          'completedAt'
        ])
        && data.keys().hasAll([
          'eventId', 'clubId', 'playbookId', 'selectedModuleIds',
          'targetAttendeeCount', 'hostGoal', 'wingmanRequestsEnabled',
          'contextualOpenersEnabled', 'activeStepIndex', 'status',
          'createdAt', 'updatedAt'
        ])
        && exists(/databases/$(database)/documents/events/$(eventId))
        && data.eventId == eventId
        && data.clubId == get(/databases/$(database)/documents/events/$(eventId)).data.clubId
        && data.playbookId is string
        && data.playbookId.size() > 0
        && data.playbookId.size() <= 120
        && data.selectedModuleIds is list
        && data.selectedModuleIds.size() <= 24
        && data.targetAttendeeCount is number
        && data.targetAttendeeCount >= 1
        && data.targetAttendeeCount <= 1000
        && (
          !hasField(data, 'structureConfig')
          || isValidEventSuccessStructureConfig(data.structureConfig)
        )
        && data.hostGoal is string
        && data.hostGoal.size() <= 300
        && data.wingmanRequestsEnabled is bool
        && data.contextualOpenersEnabled is bool
        && optionalBool(data, 'compatibilityAffectsRanking')
        && (
          !hasField(data, 'questionnaireConfig')
          || isValidEventSuccessQuestionnaireConfig(data.questionnaireConfig)
        )
        && data.activeStepIndex is number
        && data.activeStepIndex >= 0
        && data.activeStepIndex <= 100
        && data.status in ['setup', 'live', 'complete']
        && (
          !hasField(data, 'revealStatus')
          || data.revealStatus in ['idle', 'countingDown', 'revealed']
        )
        && optionalNumber(data, 'activeRevealRoundIndex')
        && (
          !hasField(data, 'activeRevealRoundIndex')
          || (
            data.activeRevealRoundIndex >= 0
            && data.activeRevealRoundIndex <= 100
          )
        )
        && optionalTimestamp(data, 'revealStartedAt')
        && optionalString(data, 'attendeePrompt')
        && (!hasField(data, 'attendeePrompt') || data.attendeePrompt == null || data.attendeePrompt.size() <= 300)
        && data.createdAt is timestamp
        && data.updatedAt is timestamp
        && optionalTimestamp(data, 'frozenAt')
        && optionalTimestamp(data, 'completedAt');
    }

    function isValidEventSuccessStructureConfig(data) {
      return data is map
        && data.keys().hasOnly([
          'unitKind',
          'unitSize',
          'unitCount',
          'rotationIntervalMinutes',
          'revealCountdownSeconds'
        ])
        && data.keys().hasAll(['unitKind', 'unitSize', 'revealCountdownSeconds'])
        && data.unitKind in ['wholeGroup', 'pods', 'pairs', 'teams', 'tables']
        && data.unitSize is number
        && data.unitSize >= 1
        && data.unitSize <= 1000
        && optionalNumber(data, 'unitCount')
        && (
          !hasField(data, 'unitCount')
          || data.unitCount == null
          || (data.unitCount >= 1 && data.unitCount <= 200)
        )
        && optionalNumber(data, 'rotationIntervalMinutes')
        && (
          !hasField(data, 'rotationIntervalMinutes')
          || data.rotationIntervalMinutes == null
          || (
            data.rotationIntervalMinutes >= 5
            && data.rotationIntervalMinutes <= 180
          )
        )
        && data.revealCountdownSeconds is number
        && data.revealCountdownSeconds >= 0
        && data.revealCountdownSeconds <= 60;
    }

    function isValidEventSuccessQuestionnaireConfig(data) {
      return data is map
        && data.keys().hasOnly([
          'templateId',
          'customTitle',
          'customQuestions'
        ])
        && data.keys().hasAll(['templateId'])
        && data.templateId is string
        && data.templateId.size() > 0
        && data.templateId.size() <= 120
        && optionalString(data, 'customTitle')
        && (
          !hasField(data, 'customTitle')
          || data.customTitle == null
          || data.customTitle.size() <= 80
        )
        && (
          !hasField(data, 'customQuestions')
          || (
            data.customQuestions is list
            && data.customQuestions.size() <= 8
          )
        );
    }

    function eventCountPositive(data, field) {
      return data.keys().hasAny([field])
        && data[field] is number
        && data[field] > 0;
    }

    function eventSuccessSetupBlockedByEvent(eventId) {
      let eventData = get(/databases/$(database)/documents/events/$(eventId)).data;
      return eventData.startTime <= request.time
        || eventCountPositive(eventData, 'bookedCount')
        || eventCountPositive(eventData, 'waitlistedCount')
        || eventCountPositive(eventData, 'checkedInCount');
    }

    function eventSuccessPlanSetupFrozen() {
      return resource.data.status != 'setup'
        || (
          resource.data.keys().hasAny(['frozenAt'])
          && resource.data.frozenAt != null
        );
    }

    function eventSuccessPlanChangedKeys() {
      return request.resource.data.diff(resource.data).affectedKeys();
    }

    function eventSuccessPlanImmutableFieldsUnchanged() {
      return request.resource.data.eventId == resource.data.eventId
        && request.resource.data.clubId == resource.data.clubId
        && request.resource.data.createdAt == resource.data.createdAt;
    }

    function isEventSuccessPlanCreateAllowed(eventId) {
      return isValidEventSuccessPlan(eventId, request.resource.data)
        && !eventSuccessSetupBlockedByEvent(eventId)
        && request.resource.data.status == 'setup'
        && request.resource.data.activeStepIndex == 0
        && (
          !request.resource.data.keys().hasAny(['revealStatus'])
          || request.resource.data.revealStatus == 'idle'
        )
        && (
          !request.resource.data.keys().hasAny(['activeRevealRoundIndex'])
          || request.resource.data.activeRevealRoundIndex == 0
        )
        && (
          !request.resource.data.keys().hasAny(['revealStartedAt'])
          || request.resource.data.revealStartedAt == null
        )
        && (
          !request.resource.data.keys().hasAny(['frozenAt'])
          || request.resource.data.frozenAt == null
        )
        && (
          !request.resource.data.keys().hasAny(['completedAt'])
          || request.resource.data.completedAt == null
        );
    }

    function isEventSuccessLiveOnlyUpdate() {
      return eventSuccessPlanChangedKeys().hasOnly([
        'activeStepIndex', 'status', 'revealStatus',
        'activeRevealRoundIndex', 'revealStartedAt',
        'updatedAt', 'frozenAt', 'completedAt'
      ]);
    }

    function isEventSuccessSetupOrLiveUpdate() {
      return eventSuccessPlanChangedKeys().hasOnly([
        'playbookId', 'selectedModuleIds', 'targetAttendeeCount',
        'structureConfig', 'hostGoal', 'wingmanRequestsEnabled',
        'contextualOpenersEnabled', 'compatibilityAffectsRanking',
        'questionnaireConfig', 'attendeePrompt',
        'activeStepIndex', 'status', 'revealStatus',
        'activeRevealRoundIndex', 'revealStartedAt',
        'updatedAt', 'frozenAt', 'completedAt'
      ]);
    }

    function isEventSuccessPlanUpdateAllowed(eventId) {
      return isValidEventSuccessPlan(eventId, request.resource.data)
        && eventSuccessPlanImmutableFieldsUnchanged()
        && (
          eventSuccessSetupBlockedByEvent(eventId)
            || eventSuccessPlanSetupFrozen()
            ? isEventSuccessLiveOnlyUpdate()
            : isEventSuccessSetupOrLiveUpdate()
        );
    }

    function isValidEventSuccessFeedback(feedbackId, data) {
      return data.keys().hasOnly([
          'eventId', 'clubId', 'uid', 'welcomeRating', 'structureRating',
          'metNewPeopleCount', 'safetyConcern',
          'privateNote', 'createdAt', 'updatedAt'
        ])
        && data.keys().hasAll([
          'eventId', 'clubId', 'uid', 'welcomeRating', 'structureRating',
          'metNewPeopleCount', 'safetyConcern',
          'createdAt', 'updatedAt'
        ])
        && exists(/databases/$(database)/documents/events/$(data.eventId))
        && feedbackId == eventSuccessFeedbackDocId(data.eventId, data.uid)
        && data.uid == request.auth.uid
        && data.clubId == get(/databases/$(database)/documents/events/$(data.eventId)).data.clubId
        && get(/databases/$(database)/documents/events/$(data.eventId)).data.endTime <= request.time
        && hasAttendedEvent(data.eventId, data.uid)
        && data.welcomeRating is number
        && data.welcomeRating >= 1
        && data.welcomeRating <= 5
        && data.structureRating is number
        && data.structureRating >= 1
        && data.structureRating <= 5
        && data.metNewPeopleCount is number
        && data.metNewPeopleCount >= 0
        && data.metNewPeopleCount <= 100
        && data.safetyConcern is bool
        && optionalString(data, 'privateNote')
        && (!hasField(data, 'privateNote') || data.privateNote == null || data.privateNote.size() <= 500)
        && data.createdAt is timestamp
        && data.updatedAt is timestamp;
    }

    function isValidEventSuccessPreference(preferenceId, data) {
      return data.keys().hasOnly([
          'eventId', 'clubId', 'uid', 'microPodsOptedOut',
          'guidedRotationsOptedOut',
          'createdAt', 'updatedAt'
        ])
        && data.keys().hasAll([
          'eventId', 'clubId', 'uid', 'microPodsOptedOut',
          'guidedRotationsOptedOut',
          'createdAt', 'updatedAt'
        ])
        && exists(/databases/$(database)/documents/events/$(data.eventId))
        && preferenceId == eventSuccessPreferenceDocId(data.eventId, data.uid)
        && data.uid == request.auth.uid
        && data.clubId == get(/databases/$(database)/documents/events/$(data.eventId)).data.clubId
        && hasEventParticipationStatus(data.eventId, data.uid, [
          'signedUp', 'attended'
        ])
        && data.microPodsOptedOut is bool
        && data.guidedRotationsOptedOut is bool
        && data.createdAt is timestamp
        && data.updatedAt is timestamp;
    }

    function isValidEventSuccessCompatibilityResponse(responseId, data) {
      return data.keys().hasOnly([
          'eventId', 'clubId', 'uid', 'answerIds', 'createdAt', 'updatedAt'
        ])
        && data.keys().hasAll([
          'eventId', 'clubId', 'uid', 'answerIds', 'createdAt', 'updatedAt'
        ])
        && exists(/databases/$(database)/documents/events/$(data.eventId))
        && responseId == eventSuccessCompatibilityResponseDocId(
          data.eventId,
          data.uid
        )
        && data.uid == request.auth.uid
        && data.clubId == get(/databases/$(database)/documents/events/$(data.eventId)).data.clubId
        && hasEventParticipationStatus(data.eventId, data.uid, [
          'signedUp', 'attended'
        ])
        && data.answerIds is list
        && data.answerIds.size() >= 1
        && data.answerIds.size() <= 8
        && data.createdAt is timestamp
        && data.updatedAt is timestamp;
    }

    function isValidEventSuccessWingmanRequest(requestId, data) {
      return data.keys().hasOnly([
          'eventId', 'clubId', 'requesterUid', 'targetUid', 'status',
          'hostVisibleConsent', 'note', 'createdAt', 'updatedAt'
        ])
        && data.keys().hasAll([
          'eventId', 'clubId', 'requesterUid', 'targetUid', 'status',
          'hostVisibleConsent', 'createdAt', 'updatedAt'
        ])
        && exists(/databases/$(database)/documents/events/$(data.eventId))
        && requestId == eventSuccessWingmanRequestDocId(
          data.eventId,
          data.requesterUid
        )
        && data.requesterUid == request.auth.uid
        && data.targetUid is string
        && data.targetUid != data.requesterUid
        && data.clubId == get(/databases/$(database)/documents/events/$(data.eventId)).data.clubId
        && hasAttendedEvent(data.eventId, data.requesterUid)
        && hasAttendedEvent(data.eventId, data.targetUid)
        && !hasBlockBetween(data.requesterUid, data.targetUid)
        && data.status in ['active', 'withdrawn']
        && data.hostVisibleConsent == true
        && optionalString(data, 'note')
        && (!hasField(data, 'note') || data.note == null || data.note.size() <= 240)
        && data.createdAt is timestamp
        && data.updatedAt is timestamp;
    }

    match /eventSuccessPlans/{eventId} {
      allow read: if canReadEventSuccess(eventId);
      allow create: if isAuthed()
        && isClubHostForEvent(eventId)
        && isEventSuccessPlanCreateAllowed(eventId);
      allow update: if isAuthed()
        && isClubHostForEvent(eventId)
        && isEventSuccessPlanUpdateAllowed(eventId);
      allow delete: if false;
    }

    match /eventSuccessFeedback/{feedbackId} {
      allow read: if isAuthed()
        && resource.data.uid == request.auth.uid;
      allow create, update: if isAuthed()
        && isValidEventSuccessFeedback(feedbackId, request.resource.data);
      allow delete: if false;
    }

    match /eventSafetyReports/{reportId} {
      allow read, write: if false;
    }

    match /eventSuccessPreferences/{preferenceId} {
      allow read: if isAuthed()
        && (
          resource.data.uid == request.auth.uid
          || isClubHostForEvent(resource.data.eventId)
        );
      allow create, update: if isAuthed()
        && isValidEventSuccessPreference(preferenceId, request.resource.data);
      allow delete: if false;
    }

    match /eventSuccessCompatibilityResponses/{responseId} {
      allow get: if isAuthed()
        && resource.data.keys().hasAll(['eventId', 'uid'])
        && resource.data.eventId is string
        && resource.data.uid == request.auth.uid
        && responseId == eventSuccessCompatibilityResponseDocId(
          resource.data.eventId,
          request.auth.uid
        )
        && hasEventParticipationStatus(resource.data.eventId, request.auth.uid, [
          'signedUp', 'attended'
        ]);
      allow list: if false;
      allow create, update: if isAuthed()
        && isValidEventSuccessCompatibilityResponse(
          responseId,
          request.resource.data
        );
      allow delete: if false;
    }

    match /eventSuccessWingmanRequests/{requestId} {
      allow get: if isAuthed()
        && resource.data.keys().hasAll([
          'eventId', 'requesterUid', 'status', 'hostVisibleConsent'
        ])
        && resource.data.eventId is string
        && resource.data.requesterUid is string
        && resource.data.status is string
        && resource.data.hostVisibleConsent is bool
        && (
          resource.data.requesterUid == request.auth.uid
          || (
            resource.data.status == 'active'
            && resource.data.hostVisibleConsent == true
            && isClubHostForEvent(resource.data.eventId)
          )
        );
      allow list: if isAuthed()
        && resource.data.eventId is string
        && resource.data.status == 'active'
        && resource.data.hostVisibleConsent == true
        && isClubHostForEvent(resource.data.eventId);
      allow create, update: if false;
      allow delete: if false;
    }

    match /eventSuccessAssignments/{assignmentId} {
      allow read: if isAuthed()
        && resource.data.eventId is string
        && resource.data.moduleId is string
        && resource.data.uid is string
        && assignmentId == eventSuccessAssignmentDocId(
          resource.data.eventId,
          resource.data.moduleId,
          resource.data.uid
        )
        && (
          isClubHostForEvent(resource.data.eventId)
          || (
            resource.data.uid == request.auth.uid
            && hasEventParticipationStatus(resource.data.eventId, request.auth.uid, [
              'signedUp', 'attended'
            ])
          )
        );
      allow write: if false;
    }

    match /eventSuccessScorecards/{eventId} {
      allow read: if isAuthed() && isClubHostForEvent(eventId);
      allow write: if false;
    }

    // ── Participant success / marketplace metrics ───────────────────────────
    // Raw signals and absolute marketplace metrics are server-owned. User-facing
    // participant momentum should be materialized separately and read only by
    // the subject user.
    match /participantSignalFacts/{factId} {
      allow read, write: if false;
    }

    match /participantMetricCounters/{uid} {
      allow read, write: if false;
    }

    match /participantMarketplaceMetrics/{uid} {
      allow read, write: if false;
    }

    match /participantMomentum/{uid} {
      allow read: if isAuthed() && request.auth.uid == uid;
      allow write: if false;
    }

    // ── Payments ──────────────────────────────────────────────────────────────
    // Written exclusively by Cloud Functions (verifyRazorpayPayment).
    // Users can only read their own payment records.
    match /payments/{paymentId} {
      allow read: if isAuthed() && resource.data.userId == request.auth.uid;
      allow write: if false;
    }

    // ── Reviews ───────────────────────────────────────────────────────────────
    match /reviews/{reviewId} {
      allow read: if isAuthed();
      // Review create/update/delete is callable-owned so attendance checks,
      // public reviewer naming, and aggregate recomputation stay server-side.
      allow write: if false;
    }

    // ── Profile decisions / legacy swipes ───────────────────────────────────
    // Each user owns their outgoing decisions subcollection. `swipes` remains
    // the primary trigger path while `profileDecisions` mirrors new writes.
    match /swipes/{userId}/outgoing/{targetId} {
      allow read: if request.auth.uid == userId;
      allow create: if hasValidSwipeCreate(userId, targetId);
    }

    match /profileDecisions/{userId}/outgoing/{targetId} {
      allow read: if request.auth.uid == userId;
      allow create: if hasValidSwipeCreate(userId, targetId);
    }

    // ── Matches ───────────────────────────────────────────────────────────────
    // Created by the onSwipeCreated Cloud Function. Participants can read.
    function isValidMatchUnreadReset() {
      return isAuthed()
        && isMatchParticipant(resource.data, request.auth.uid)
        && resource.data.status == 'active'
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['unreadCounts'])
        && resource.data.unreadCounts is map
        && request.resource.data.unreadCounts is map
        && request.resource.data.unreadCounts.diff(resource.data.unreadCounts)
            .affectedKeys().hasOnly([request.auth.uid])
        && request.resource.data.unreadCounts[request.auth.uid] == 0;
    }

    match /matches/{matchId} {
      allow get: if isAuthed()
        && isMatchParticipant(resource.data, request.auth.uid)
        && resource.data.status != 'blocked'
        && !hasBlockBetween(resource.data.user1Id, resource.data.user2Id);
      allow list: if isAuthed()
        && resource.data.user1Id == request.auth.uid
        && resource.data.status == 'active';
      allow list: if isAuthed()
        && resource.data.user2Id == request.auth.uid
        && resource.data.status == 'active';
      allow update: if isValidMatchUnreadReset();
      allow create, delete: if false;
    }

    // ── Chat messages ─────────────────────────────────────────────────────────
    function hasValidChatMessageCreate(matchId) {
      return request.resource.data.keys().hasOnly([
          'senderId',
          'text',
          'imageUrl',
          'sentAt'
        ])
        && request.resource.data.keys().hasAll(['senderId', 'text', 'sentAt'])
        && request.resource.data.senderId == request.auth.uid
        && request.resource.data.text is string
        && request.resource.data.text.size() <= 2000
        && optionalString(request.resource.data, 'imageUrl')
        && (
          request.resource.data.text.size() > 0
          || (
            hasField(request.resource.data, 'imageUrl')
            && request.resource.data.imageUrl is string
            && request.resource.data.imageUrl.size() > 0
            && request.resource.data.imageUrl.size() <= 2048
          )
        )
        && request.resource.data.sentAt is timestamp
        && isMatchParticipant(
          get(/databases/$(database)/documents/matches/$(matchId)).data,
          request.auth.uid
        )
        && get(/databases/$(database)/documents/matches/$(matchId))
            .data.status == 'active';
    }

    match /matches/{matchId}/messages/{messageId} {
      allow read: if isAuthed()
        && isMatchParticipant(
          get(/databases/$(database)/documents/matches/$(matchId)).data,
          request.auth.uid
        )
        && get(/databases/$(database)/documents/matches/$(matchId))
            .data.status != 'blocked';
      allow create: if isAuthed()
        && hasValidChatMessageCreate(matchId);
      allow update, delete: if false;
    }

  }
}
