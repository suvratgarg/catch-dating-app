rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthed() {
      return request.auth != null;
    }

    function hasField(data, field) {
      return data.keys().hasAny([field]);
    }

    function optionalString(data, field) {
      return !hasField(data, field)
        || data[field] == null
        || data[field] is string;
    }

    function optionalNumber(data, field) {
      return !hasField(data, field)
        || data[field] == null
        || data[field] is number;
    }

    function optionalBool(data, field) {
      return !hasField(data, field)
        || data[field] == null
        || data[field] is bool;
    }

    function optionalTimestamp(data, field) {
      return !hasField(data, field)
        || data[field] == null
        || data[field] is timestamp;
    }

    function optionalIn(data, field, values) {
      return !hasField(data, field)
        || data[field] == null
        || data[field] in values;
    }

    function optionalList(data, field) {
      return !hasField(data, field)
        || data[field] == null
        || data[field] is list;
    }

    function isDefaultCity(city) {
      return city in [
        'mumbai',
        'delhi',
        'bangalore',
        'hyderabad',
        'chennai',
        'kolkata',
        'pune',
        'ahmedabad',
        'indore'
      ];
    }

    function isConfiguredCity(city) {
      return exists(/databases/$(database)/documents/config/cities)
        && get(/databases/$(database)/documents/config/cities)
            .data.keys().hasAny(['cityNames'])
        && get(/databases/$(database)/documents/config/cities)
            .data.cityNames is list
        && city in get(/databases/$(database)/documents/config/cities)
            .data.cityNames;
    }

    function isValidCity(city) {
      return city is string
        && (isDefaultCity(city) || isConfiguredCity(city));
    }

    function blockDocId(blockerUid, blockedUid) {
      return blockerUid + '__' + blockedUid;
    }

    function runParticipationDocId(runId, uid) {
      return runId + '_' + uid;
    }

    function savedRunDocId(uid, runId) {
      return uid + '_' + runId;
    }

    function hasBlockBetween(uidA, uidB) {
      return exists(/databases/$(database)/documents/blocks/$(blockDocId(uidA, uidB)))
        || exists(/databases/$(database)/documents/blocks/$(blockDocId(uidB, uidA)));
    }

    function hasParticipantId(matchData, uid) {
      return matchData.participantIds is list
        && uid in matchData.participantIds;
    }

    function isMatchParticipant(matchData, uid) {
      return hasParticipantId(matchData, uid)
        || matchData.user1Id == uid
        || matchData.user2Id == uid;
    }

    function isDeletedUser(uid) {
      return exists(/databases/$(database)/documents/deletedUsers/$(uid));
    }

    function isRunHostForRun(runId) {
      return exists(/databases/$(database)/documents/runs/$(runId))
        && exists(/databases/$(database)/documents/runClubs/$(
          get(/databases/$(database)/documents/runs/$(runId)).data.runClubId
        ))
        && get(/databases/$(database)/documents/runClubs/$(
          get(/databases/$(database)/documents/runs/$(runId)).data.runClubId
        )).data.hostUserId == request.auth.uid;
    }

    function hasAttendedRun(runId, uid) {
      return exists(/databases/$(database)/documents/runParticipations/$(runParticipationDocId(runId, uid)))
        && get(/databases/$(database)/documents/runParticipations/$(runParticipationDocId(runId, uid)))
        .data.status == 'attended';
    }

    // ── Users ─────────────────────────────────────────────────────────────────
    function hasValidUserShape(data) {
      return data.keys().hasOnly([
          // Core
          'name', 'firstName', 'lastName', 'displayName', 'email', 'bio',
          'instagramHandle', 'phoneNumber', 'dateOfBirth',
          'gender', 'sexualOrientation', 'profileComplete',
          // Photos
          'photoUrls', 'photoThumbnailUrls',
          // Location
          'city',
          'latitude',
          'longitude',
          // Matching
          'interestedInGenders',
          'minAgePreference', 'maxAgePreference',
          // Background
          'height', 'occupation', 'company', 'education', 'religion',
          'languages',
          // Intentions
          'relationshipGoal',
          // Lifestyle
          'drinking', 'smoking', 'workout', 'diet', 'children',
          // Running
          'paceMinSecsPerKm', 'paceMaxSecsPerKm',
          'preferredDistances', 'runningReasons',
          // Notification / discovery preferences
          'prefsNewCatches', 'prefsMessages', 'prefsRunReminders',
          'prefsRunStatusUpdates', 'prefsClubUpdates',
          'prefsWeeklyDigest', 'prefsShowOnMap',
          // Runtime fields
          'fcmToken',
          // Server-owned lifecycle fields. These must be tolerated on existing
          // retained docs, but clients cannot create or change them.
          'deleted',
          'deletedAt'
        ])
        && data.keys().hasAll([
          'name', 'displayName', 'email', 'bio', 'phoneNumber', 'dateOfBirth',
          'gender', 'profileComplete',
          'photoUrls',
          'interestedInGenders', 'minAgePreference', 'maxAgePreference',
          'languages', 'paceMinSecsPerKm', 'paceMaxSecsPerKm',
          'preferredDistances', 'runningReasons',
          'prefsNewCatches', 'prefsMessages', 'prefsRunReminders',
          'prefsRunStatusUpdates', 'prefsClubUpdates',
          'prefsWeeklyDigest', 'prefsShowOnMap'
        ])
        // Core
        && data.name is string
        && optionalString(data, 'firstName')
        && optionalString(data, 'lastName')
        && data.displayName is string
        && data.displayName.size() <= 80
        && data.displayName.matches('.*\\S.*')
        && data.email is string
        && data.bio is string
        && optionalString(data, 'instagramHandle')
        && data.phoneNumber is string
        && data.dateOfBirth is timestamp
        && data.gender in ['man', 'woman', 'nonBinary', 'other']
        // Legacy tolerance: older clients may still have written this field.
        // New Dart/TypeScript contracts do not include it.
        && optionalIn(data, 'sexualOrientation', [
          'straight', 'gay', 'bisexual', 'pansexual', 'asexual', 'other'
        ])
        && data.profileComplete is bool
        // Photos
        && data.photoUrls is list
        && optionalList(data, 'photoThumbnailUrls')
        // Location
        && (!hasField(data, 'city') || data.city == null || isValidCity(data.city))
        && optionalNumber(data, 'latitude')
        && optionalNumber(data, 'longitude')
        // Matching
        && data.interestedInGenders is list
        && data.interestedInGenders.size() > 0
        && data.minAgePreference is number
        && data.maxAgePreference is number
        // Background
        && optionalNumber(data, 'height')
        && optionalString(data, 'occupation')
        && optionalString(data, 'company')
        && optionalIn(data, 'education', [
          'highSchool', 'someCollege', 'bachelors', 'masters', 'phd',
          'tradeSchool', 'other'
        ])
        && optionalIn(data, 'religion', [
          'hindu', 'muslim', 'christian', 'sikh', 'jain', 'buddhist',
          'other', 'nonReligious'
        ])
        && data.languages is list
        // Intentions
        && optionalIn(data, 'relationshipGoal', [
          'relationship', 'casual', 'marriage', 'friendship', 'unsure'
        ])
        // Lifestyle
        && optionalIn(data, 'drinking', [
          'never', 'socially', 'often'
        ])
        && optionalIn(data, 'smoking', [
          'never', 'occasionally', 'often'
        ])
        && optionalIn(data, 'workout', [
          'never', 'sometimes', 'often', 'everyday'
        ])
        && optionalIn(data, 'diet', [
          'omnivore', 'vegetarian', 'vegan', 'jain', 'other'
        ])
        && optionalIn(data, 'children', [
          'dontHave', 'haveWantMore', 'haveNoMore', 'wantSomeday', 'dontWant'
        ])
        // Running
        && data.paceMinSecsPerKm is number
        && data.paceMinSecsPerKm > 0
        && data.paceMaxSecsPerKm is number
        && data.paceMaxSecsPerKm > 0
        && data.preferredDistances is list
        && data.runningReasons is list
        // Notification / discovery preferences
        && data.prefsNewCatches is bool
        && data.prefsMessages is bool
        && data.prefsRunReminders is bool
        && data.prefsRunStatusUpdates is bool
        && data.prefsClubUpdates is bool
        && data.prefsWeeklyDigest is bool
        && data.prefsShowOnMap is bool
        // Runtime fields (optional)
        && optionalString(data, 'fcmToken')
        && optionalBool(data, 'deleted')
        && optionalTimestamp(data, 'deletedAt');
    }

    function isValidUserCreate(uid) {
      return isAuthed()
        && request.auth.uid == uid
        && !isDeletedUser(uid)
        && hasValidUserShape(request.resource.data)
        && !hasField(request.resource.data, 'deleted')
        && !hasField(request.resource.data, 'deletedAt');
    }

    function userChangedKeys() {
      return request.resource.data.diff(resource.data).affectedKeys();
    }

    function isValidFcmTokenUpdate() {
      return userChangedKeys().hasOnly(['fcmToken'])
        && optionalString(request.resource.data, 'fcmToken');
    }

    function isValidUserUpdate(uid) {
      return isAuthed()
        && request.auth.uid == uid
        && !isDeletedUser(uid)
        && isValidFcmTokenUpdate();
    }

    function hasValidOnboardingDraftShape(data) {
      // Private owner-only draft state changes faster than shared production
      // documents. Keep this intentionally forward-compatible and validate
      // only the routing-critical invariant.
      return data.keys().hasAll(['step'])
        && data.step is int
        && data.step >= 0;
    }

    function isValidNotificationReadUpdate(uid) {
      return isAuthed()
        && request.auth.uid == uid
        && resource.data.uid == uid
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['readAt'])
        && request.resource.data.uid == uid
        && request.resource.data.readAt is timestamp;
    }

    // ── Public config ──────────────────────────────────────────────────────────
    match /config/cities {
      allow read: if true;
      allow write: if false;
    }

    match /config/{docId} {
      allow read, write: if false;
    }

    // Private profile/account documents are owner-only. User discovery,
    // matches, chats, reviews, and notifications must read publicProfiles.
    match /users/{uid} {
      allow read: if isAuthed()
        && request.auth.uid == uid
        && !isDeletedUser(uid)
        && !hasBlockBetween(request.auth.uid, uid);

      // Owners create their initial profile directly with full shape validation.
      // Profile edits go through updateUserProfile so complex field validation
      // stays in Zod instead of Firestore rules. Direct updates here are limited
      // to narrow runtime fields that rules can validate cheaply.
      allow create: if isValidUserCreate(uid);
      allow update: if isValidUserUpdate(uid);

      // Client-side deletes are blocked — account deletion is handled
      // exclusively by the requestAccountDeletion Cloud Function, which
      // uses the admin SDK to anonymize the document in place.
      allow delete: if false;
    }

    // ── Onboarding drafts ─────────────────────────────────────────────────────
    // Drafts contain pre-profile onboarding state. Only the signed-in owner can
    // read/write/delete their draft.
    match /onboarding_drafts/{uid} {
      allow read: if isAuthed() && request.auth.uid == uid;
      allow create, update: if isAuthed()
        && request.auth.uid == uid
        && hasValidOnboardingDraftShape(request.resource.data);
      allow delete: if isAuthed() && request.auth.uid == uid;
    }

    // ── Blocks ───────────────────────────────────────────────────────────────
    // Clients can read only block edges involving themselves. Mutations go
    // through Cloud Functions so existing matches can be closed atomically.
    match /blocks/{blockId} {
      allow read: if isAuthed() && (
        resource.data.blockerUserId == request.auth.uid
        || resource.data.blockedUserId == request.auth.uid
      );
      allow write: if false;
    }

    // Written exclusively by the reportUser Cloud Function.
    match /reports/{reportId} {
      allow read, write: if false;
    }

    // Written exclusively by the rate-limit middleware in Cloud Functions.
    match /rateLimits/{docId} {
      allow read, write: if false;
    }

    // Written exclusively by idempotent Cloud Function trigger handlers.
    match /functionEventReceipts/{receiptId} {
      allow read, write: if false;
    }

    // Server-owned durable activity timeline. Users can read their own timeline
    // and mark items as read, but cannot create, delete, or edit notification
    // content.
    match /notifications/{uid}/items/{notificationId} {
      allow read: if isAuthed() && request.auth.uid == uid;
      allow update: if isValidNotificationReadUpdate(uid);
      allow create, delete: if false;
    }

    // Written exclusively by the moderation Cloud Functions.
    match /moderationFlags/{flagId} {
      allow read, write: if false;
    }

    // Written exclusively by the account-deletion Cloud Function.
    match /deletedUsers/{uid} {
      allow read, write: if false;
    }

    // ── Public profiles ───────────────────────────────────────────────────────
    // Synced by the syncPublicProfile Cloud Function trigger. No client writes.
    match /publicProfiles/{uid} {
      allow read: if isAuthed()
        && !isDeletedUser(uid)
        && !hasBlockBetween(request.auth.uid, uid);
      allow write: if false;
    }

    // ── Run clubs ─────────────────────────────────────────────────────────────
    match /runClubMemberships/{membershipId} {
      allow read: if isAuthed()
        && (
          resource.data.status == 'active'
          || resource.data.uid == request.auth.uid
        );
      allow write: if false;
    }

    match /runClubHostClaims/{uid} {
      allow read, write: if false;
    }

    match /runClubs/{clubId} {
      allow read: if true;

      // Club creation is handled by the createRunClub Cloud Function so the
      // initial club doc and user membership projection stay atomic.
      allow create: if false;

      // Club profile edits go through updateRunClub. Keeping direct updates
      // closed lets rules avoid duplicating Zod validation and prevents
      // clients from touching aggregate/projection fields.
      allow update: if false;

      // Club deletion needs backend cleanup of runs, memberships, reviews, and
      // images before it can be safely exposed.
      allow delete: if false;
    }

    // ── Swipes helper ─────────────────────────────────────────────────────────
    function hasValidSwipeCreate(userId, targetId) {
      return isAuthed()
        && request.auth.uid == userId
        && userId != targetId
        && request.resource.data.keys().hasOnly([
          'swiperId',
          'targetId',
          'runId',
          'direction',
          'createdAt'
        ])
        && request.resource.data.keys().hasAll([
          'swiperId',
          'targetId',
          'runId',
          'direction',
          'createdAt'
        ])
        && request.resource.data.swiperId == userId
        && request.resource.data.targetId == targetId
        && request.resource.data.runId is string
        && request.resource.data.direction in ['like', 'pass']
        && request.resource.data.createdAt is timestamp
        && !isDeletedUser(userId)
        && !isDeletedUser(targetId)
        && exists(/databases/$(database)/documents/publicProfiles/$(targetId))
        && exists(/databases/$(database)/documents/runs/$(request.resource.data.runId))
        && hasAttendedRun(request.resource.data.runId, userId)
        && hasAttendedRun(request.resource.data.runId, targetId)
        && !hasBlockBetween(userId, targetId);
    }

    // ── Runs ──────────────────────────────────────────────────────────────────
    match /runParticipations/{participationId} {
      allow read: if isAuthed()
        && (
          resource.data.uid == request.auth.uid
          || resource.data.status == 'attended'
          || isRunHostForRun(resource.data.runId)
        );
      allow write: if false;
    }

    match /savedRuns/{savedRunId} {
      allow read: if isAuthed() && resource.data.uid == request.auth.uid;
      allow create: if isAuthed()
        && request.resource.data.keys().hasOnly(['uid', 'runId', 'savedAt'])
        && request.resource.data.keys().hasAll(['uid', 'runId', 'savedAt'])
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.runId is string
        && request.resource.data.savedAt is timestamp
        && exists(/databases/$(database)/documents/runs/$(request.resource.data.runId))
        && savedRunId == savedRunDocId(request.auth.uid, request.resource.data.runId);
      allow delete: if isAuthed() && resource.data.uid == request.auth.uid;
      allow update: if false;
    }

    match /runs/{runId} {
      allow read: if true;

      // Run creation is callable-owned so host authority and server-owned
      // booking fields stay in one backend contract.
      allow create: if false;

      // Booking, waitlist, attendance, cancellation, and host edits are all
      // callable-owned so canonical run projections cannot be mutated directly.
      allow update: if false;

      // Run deletion needs backend cleanup/refunds before it can be safely
      // exposed.
      allow delete: if false;
    }

    // ── Payments ──────────────────────────────────────────────────────────────
    // Written exclusively by Cloud Functions (verifyRazorpayPayment).
    // Users can only read their own payment records.
    match /payments/{paymentId} {
      allow read: if isAuthed() && resource.data.userId == request.auth.uid;
      allow write: if false;
    }

    // ── Reviews ───────────────────────────────────────────────────────────────
    match /reviews/{reviewId} {
      allow read: if isAuthed();
      // Review create/update/delete is callable-owned so attendance checks,
      // public reviewer naming, and aggregate recomputation stay server-side.
      allow write: if false;
    }

    // ── Swipes ────────────────────────────────────────────────────────────────
    // Each user owns their outgoing swipes subcollection.
    match /swipes/{userId}/outgoing/{targetId} {
      allow read: if request.auth.uid == userId;
      allow create: if hasValidSwipeCreate(userId, targetId);
    }

    // ── Matches ───────────────────────────────────────────────────────────────
    // Created by the onSwipeCreated Cloud Function. Participants can read.
    function isValidMatchUnreadReset() {
      return isAuthed()
        && isMatchParticipant(resource.data, request.auth.uid)
        && resource.data.status == 'active'
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['unreadCounts'])
        && resource.data.unreadCounts is map
        && request.resource.data.unreadCounts is map
        && request.resource.data.unreadCounts.diff(resource.data.unreadCounts)
            .affectedKeys().hasOnly([request.auth.uid])
        && request.resource.data.unreadCounts[request.auth.uid] == 0;
    }

    match /matches/{matchId} {
      allow get: if isAuthed()
        && isMatchParticipant(resource.data, request.auth.uid)
        && resource.data.status != 'blocked'
        && !hasBlockBetween(resource.data.user1Id, resource.data.user2Id);
      allow list: if isAuthed()
        && resource.data.user1Id == request.auth.uid
        && resource.data.status == 'active';
      allow list: if isAuthed()
        && resource.data.user2Id == request.auth.uid
        && resource.data.status == 'active';
      allow update: if isValidMatchUnreadReset();
      allow create, delete: if false;
    }

    // ── Chat messages ─────────────────────────────────────────────────────────
    function hasValidChatMessageCreate(matchId) {
      return request.resource.data.keys().hasOnly([
          'senderId',
          'text',
          'imageUrl',
          'sentAt'
        ])
        && request.resource.data.keys().hasAll(['senderId', 'text', 'sentAt'])
        && request.resource.data.senderId == request.auth.uid
        && request.resource.data.text is string
        && optionalString(request.resource.data, 'imageUrl')
        && request.resource.data.sentAt is timestamp
        && isMatchParticipant(
          get(/databases/$(database)/documents/matches/$(matchId)).data,
          request.auth.uid
        )
        && get(/databases/$(database)/documents/matches/$(matchId))
            .data.status == 'active';
    }

    match /matches/{matchId}/messages/{messageId} {
      allow read: if isAuthed()
        && isMatchParticipant(
          get(/databases/$(database)/documents/matches/$(matchId)).data,
          request.auth.uid
        )
        && get(/databases/$(database)/documents/matches/$(matchId))
            .data.status != 'blocked';
      allow create: if isAuthed()
        && hasValidChatMessageCreate(matchId);
      allow update, delete: if false;
    }

  }
}
