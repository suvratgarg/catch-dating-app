rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthed() {
      return request.auth != null;
    }

    function blockDocId(blockerUid, blockedUid) {
      return blockerUid + '__' + blockedUid;
    }

    function hasBlockBetween(uidA, uidB) {
      return exists(/databases/$(database)/documents/blocks/$(blockDocId(uidA, uidB)))
        || exists(/databases/$(database)/documents/blocks/$(blockDocId(uidB, uidA)));
    }

    function hasParticipantId(matchData, uid) {
      return matchData.participantIds is list
        && uid in matchData.participantIds;
    }

    function isMatchParticipant(matchData, uid) {
      return hasParticipantId(matchData, uid)
        || matchData.user1Id == uid
        || matchData.user2Id == uid;
    }

    function isDeletedUser(uid) {
      return exists(/databases/$(database)/documents/deletedUsers/$(uid));
    }

    function hasValidRunClubShape(data) {
      return data.keys().hasOnly([
          'name',
          'description',
          'location',
          'area',
          'hostUserId',
          'hostName',
          'hostAvatarUrl',
          'createdAt',
          'imageUrl',
          'tags',
          'memberUserIds',
          'memberCount',
          'rating',
          'reviewCount',
          'nextRunAt',
          'nextRunLabel',
          'instagramHandle',
          'phoneNumber',
          'email'
        ])
        && data.keys().hasAll([
          'name',
          'description',
          'location',
          'area',
          'hostUserId',
          'hostName',
          'createdAt',
          'tags',
          'memberUserIds',
          'memberCount',
          'rating',
          'reviewCount'
        ])
        && data.name is string
        && data.description is string
        && data.location in [
          'mumbai',
          'delhi',
          'bangalore',
          'hyderabad',
          'chennai',
          'kolkata',
          'pune',
          'ahmedabad',
          'indore'
        ]
        && data.area is string
        && data.hostUserId is string
        && data.hostName is string
        && (data.hostAvatarUrl == null || data.hostAvatarUrl is string)
        && data.createdAt is timestamp
        && (data.imageUrl == null || data.imageUrl is string)
        && data.tags is list
        && data.memberUserIds is list
        && data.memberCount is int
        && data.memberCount == data.memberUserIds.size()
        && data.rating is number
        && data.rating >= 0
        && data.rating <= 5
        && data.reviewCount is int
        && data.reviewCount >= 0
        && (data.nextRunAt == null || data.nextRunAt is timestamp)
        && (data.nextRunLabel == null || data.nextRunLabel is string)
        && (data.instagramHandle == null || data.instagramHandle is string)
        && (data.phoneNumber == null || data.phoneNumber is string)
        && (data.email == null || data.email is string);
    }

    function isValidRunClubCreate() {
      return hasValidRunClubShape(request.resource.data)
        && request.resource.data.hostUserId == request.auth.uid
        && request.resource.data.memberUserIds.size() == 1
        && request.resource.data.memberUserIds.hasAll([request.auth.uid])
        && request.resource.data.memberCount == 1
        && request.resource.data.rating == 0
        && request.resource.data.reviewCount == 0
        && request.resource.data.nextRunAt == null
        && request.resource.data.nextRunLabel == null;
    }

    function isValidRunClubHostUpdate() {
      return resource.data.hostUserId == request.auth.uid
        && hasValidRunClubShape(request.resource.data)
        && request.resource.data.hostUserId == resource.data.hostUserId
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.memberUserIds == resource.data.memberUserIds
        && request.resource.data.memberCount == resource.data.memberCount
        && request.resource.data.rating == resource.data.rating
        && request.resource.data.reviewCount == resource.data.reviewCount
        && request.resource.data.nextRunAt == resource.data.nextRunAt
        && request.resource.data.nextRunLabel == resource.data.nextRunLabel
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'name',
          'description',
          'location',
          'area',
          'hostName',
          'hostAvatarUrl',
          'imageUrl',
          'tags',
          'instagramHandle',
          'phoneNumber',
          'email'
        ]);
    }

    function isValidRunClubMembershipUpdate() {
      return hasValidRunClubShape(request.resource.data)
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['memberUserIds', 'memberCount',
                    'instagramHandle', 'phoneNumber', 'email'])
        && request.resource.data.hostUserId == resource.data.hostUserId
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.memberCount
          == request.resource.data.memberUserIds.size()
        && (
          // Adding only self.
          (
            request.resource.data.memberUserIds.size()
              == resource.data.memberUserIds.size() + 1
            && request.resource.data.memberUserIds
                .hasAll(resource.data.memberUserIds)
            && request.resource.data.memberUserIds
                .hasAll([request.auth.uid])
          )
          ||
          // Removing only self.
          (
            request.resource.data.memberUserIds.size()
              == resource.data.memberUserIds.size() - 1
            && resource.data.memberUserIds
                .hasAll(request.resource.data.memberUserIds)
            && resource.data.memberUserIds.hasAll([request.auth.uid])
            && !request.resource.data.memberUserIds.hasAll([request.auth.uid])
          )
        );
    }

    function expectedReviewId() {
      return 'club_' + request.resource.data.runClubId + '_user_' + request.auth.uid;
    }

    function hasValidReviewReference(data) {
      return exists(/databases/$(database)/documents/runClubs/$(data.runClubId))
        && (
          data.runId == null
          || (
            exists(/databases/$(database)/documents/runs/$(data.runId))
            && get(/databases/$(database)/documents/runs/$(data.runId))
                .data.runClubId == data.runClubId
          )
        );
    }

    function isValidReviewPayload(data) {
      return data.keys().hasAll([
          'runClubId',
          'reviewerUserId',
          'reviewerName',
          'rating',
          'comment',
          'createdAt'
        ])
        && data.keys().hasOnly([
          'runClubId',
          'runId',
          'reviewerUserId',
          'reviewerName',
          'rating',
          'comment',
          'createdAt',
          'updatedAt'
        ])
        && data.runClubId is string
        && (data.runId == null || data.runId is string)
        && data.reviewerUserId == request.auth.uid
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && data.reviewerName is string
        && data.reviewerName == get(/databases/$(database)/documents/users/$(request.auth.uid))
            .data.name
        && data.rating is int
        && data.rating >= 1
        && data.rating <= 5
        && data.comment is string
        && data.createdAt is timestamp
        && (data.updatedAt == null || data.updatedAt is timestamp)
        && hasValidReviewReference(data);
    }

    // ── Users ─────────────────────────────────────────────────────────────────
    function hasValidUserShape(data) {
      return data.keys().hasOnly([
          // Core
          'name', 'email', 'bio', 'phoneNumber', 'dateOfBirth',
          'gender', 'sexualOrientation', 'profileComplete',
          // Photos
          'photoUrls',
          // Location
          'city',
          // Matching
          'joinedRunClubIds', 'savedRunIds', 'interestedInGenders',
          'minAgePreference', 'maxAgePreference',
          // Background
          'height', 'occupation', 'company', 'education', 'religion',
          'languages',
          // Intentions
          'relationshipGoal',
          // Lifestyle
          'drinking', 'smoking', 'workout', 'diet', 'children',
          // Running
          'paceMinSecsPerKm', 'paceMaxSecsPerKm',
          'preferredDistances', 'runningReasons',
          // Notification / discovery preferences
          'prefsNewCatches', 'prefsRunReminders',
          'prefsWeeklyDigest', 'prefsShowOnMap',
          // Runtime fields
          'fcmToken', 'deleted', 'deletedAt'
        ])
        && data.keys().hasAll([
          'name', 'email', 'bio', 'phoneNumber', 'dateOfBirth',
          'gender', 'sexualOrientation', 'profileComplete',
          'photoUrls', 'joinedRunClubIds', 'savedRunIds',
          'interestedInGenders', 'minAgePreference', 'maxAgePreference',
          'languages', 'paceMinSecsPerKm', 'paceMaxSecsPerKm',
          'preferredDistances', 'runningReasons',
          'prefsNewCatches', 'prefsRunReminders',
          'prefsWeeklyDigest', 'prefsShowOnMap'
        ])
        // Core
        && data.name is string
        && data.email is string
        && data.bio is string
        && data.phoneNumber is string
        && data.dateOfBirth is timestamp
        && data.gender in ['man', 'woman', 'nonBinary', 'other']
        && data.sexualOrientation in [
          'straight', 'gay', 'bisexual', 'pansexual', 'asexual', 'other'
        ]
        && data.profileComplete is bool
        // Photos
        && data.photoUrls is list
        // Location
        && (data.city == null || data.city in [
          'mumbai', 'delhi', 'bangalore', 'hyderabad',
          'chennai', 'kolkata', 'pune', 'ahmedabad', 'indore'
        ])
        // Matching
        && data.joinedRunClubIds is list
        && data.savedRunIds is list
        && data.interestedInGenders is list
        && data.minAgePreference is number
        && data.maxAgePreference is number
        // Background
        && (data.height == null || data.height is number)
        && (data.occupation == null || data.occupation is string)
        && (data.company == null || data.company is string)
        && (data.education == null || data.education in [
          'highSchool', 'someCollege', 'bachelors', 'masters', 'phd',
          'tradeSchool', 'other'
        ])
        && (data.religion == null || data.religion in [
          'hindu', 'muslim', 'christian', 'sikh', 'jain', 'buddhist',
          'other', 'nonReligious'
        ])
        && data.languages is list
        // Intentions
        && (data.relationshipGoal == null || data.relationshipGoal in [
          'relationship', 'casual', 'marriage', 'friendship', 'unsure'
        ])
        // Lifestyle
        && (data.drinking == null || data.drinking in [
          'never', 'socially', 'often'
        ])
        && (data.smoking == null || data.smoking in [
          'never', 'occasionally', 'often'
        ])
        && (data.workout == null || data.workout in [
          'never', 'sometimes', 'often', 'everyday'
        ])
        && (data.diet == null || data.diet in [
          'omnivore', 'vegetarian', 'vegan', 'jain', 'other'
        ])
        && (data.children == null || data.children in [
          'dontHave', 'haveWantMore', 'haveNoMore', 'wantSomeday', 'dontWant'
        ])
        // Running
        && data.paceMinSecsPerKm is number
        && data.paceMinSecsPerKm > 0
        && data.paceMaxSecsPerKm is number
        && data.paceMaxSecsPerKm > 0
        && data.preferredDistances is list
        && data.runningReasons is list
        // Notification / discovery preferences
        && data.prefsNewCatches is bool
        && data.prefsRunReminders is bool
        && data.prefsWeeklyDigest is bool
        && data.prefsShowOnMap is bool
        // Runtime fields (optional)
        && (data.fcmToken == null || data.fcmToken is string)
        && (data.deleted == null || data.deleted is bool)
        && (data.deletedAt == null || data.deletedAt is timestamp);
    }

    // Any authenticated user can read profiles (needed for chat, matches).
    // Only the owner can write their own document.
    match /users/{uid} {
      allow read: if isAuthed()
        && !isDeletedUser(uid)
        && !hasBlockBetween(request.auth.uid, uid);
      allow write: if request.auth.uid == uid
        && hasValidUserShape(request.resource.data);
    }

    // ── Blocks ───────────────────────────────────────────────────────────────
    // Clients can read only block edges involving themselves. Mutations go
    // through Cloud Functions so existing matches can be closed atomically.
    match /blocks/{blockId} {
      allow read: if isAuthed() && (
        resource.data.blockerUserId == request.auth.uid
        || resource.data.blockedUserId == request.auth.uid
      );
      allow write: if false;
    }

    // Written exclusively by the reportUser Cloud Function.
    match /reports/{reportId} {
      allow read, write: if false;
    }

    // Written exclusively by the account-deletion Cloud Function.
    match /deletedUsers/{uid} {
      allow read, write: if false;
    }

    // ── Public profiles ───────────────────────────────────────────────────────
    // Synced by the syncPublicProfile Cloud Function trigger. No client writes.
    match /publicProfiles/{uid} {
      allow read: if isAuthed()
        && !isDeletedUser(uid)
        && !hasBlockBetween(request.auth.uid, uid);
      allow write: if false;
    }

    // ── Run clubs ─────────────────────────────────────────────────────────────
    match /runClubs/{clubId} {
      allow read: if isAuthed();

      // Any authenticated user can create a club; they must be its host.
      allow create: if isAuthed()
        && isValidRunClubCreate();

      allow update: if isAuthed() && (
        // Host can edit club profile fields only.
        isValidRunClubHostUpdate()

        // Members can only join/leave themselves and keep memberCount aligned.
        || isValidRunClubMembershipUpdate()
      );

      allow delete: if isAuthed()
        && resource.data.hostUserId == request.auth.uid;
    }

    // ── Runs ──────────────────────────────────────────────────────────────────
    function hasValidRunShape(data) {
      return data.keys().hasOnly([
          'runClubId',
          'startTime',
          'endTime',
          'meetingPoint',
          'startingPointLat',
          'startingPointLng',
          'locationDetails',
          'distanceKm',
          'pace',
          'capacityLimit',
          'description',
          'priceInPaise',
          'signedUpUserIds',
          'attendedUserIds',
          'waitlistUserIds',
          'constraints',
          'genderCounts'
        ])
        && data.keys().hasAll([
          'runClubId',
          'startTime',
          'endTime',
          'meetingPoint',
          'distanceKm',
          'pace',
          'capacityLimit',
          'description',
          'priceInPaise'
        ])
        && data.runClubId is string
        && data.startTime is timestamp
        && data.endTime is timestamp
        && data.startTime < data.endTime
        && data.meetingPoint is string
        && (data.startingPointLat == null || data.startingPointLat is number)
        && (data.startingPointLng == null || data.startingPointLng is number)
        && (data.locationDetails == null || data.locationDetails is string)
        && data.distanceKm is number
        && data.distanceKm > 0
        && data.pace in ['easy', 'moderate', 'fast', 'competitive']
        && data.capacityLimit is int
        && data.capacityLimit > 0
        && data.description is string
        && data.priceInPaise is int
        && data.priceInPaise >= 0
        && data.signedUpUserIds == []
        && data.attendedUserIds == []
        && data.waitlistUserIds == []
        && data.constraints is map
        && data.genderCounts == {};
    }

    match /runs/{runId} {
      allow read: if isAuthed();

      // Only the club host can create a run for their club.
      allow create: if isAuthed()
        && hasValidRunShape(request.resource.data)
        && get(/databases/$(database)/documents/runClubs/$(request.resource.data.runClubId))
            .data.hostUserId == request.auth.uid;

      allow update: if isAuthed() && (
        // Host can edit run details but NOT the booking lists or gender counts
        // — those are managed exclusively by Cloud Functions.
        (
          get(/databases/$(database)/documents/runClubs/$(resource.data.runClubId))
              .data.hostUserId == request.auth.uid
          && !request.resource.data.diff(resource.data).affectedKeys()
              .hasAny(['signedUpUserIds', 'attendedUserIds', 'genderCounts'])
        )

        // Users can leave the waitlist directly. Joining goes through the
        // joinRunWaitlist Cloud Function so block checks stay server-side.
        || (
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['waitlistUserIds'])
          && (
            request.resource.data.waitlistUserIds.size()
              == resource.data.waitlistUserIds.size() - 1
            && resource.data.waitlistUserIds
                .hasAll(request.resource.data.waitlistUserIds)
            && resource.data.waitlistUserIds.hasAll([request.auth.uid])
            && !request.resource.data.waitlistUserIds.hasAll([request.auth.uid])
          )
        )
      );

      allow delete: if isAuthed()
        && get(/databases/$(database)/documents/runClubs/$(resource.data.runClubId))
            .data.hostUserId == request.auth.uid;
    }

    // ── Payments ──────────────────────────────────────────────────────────────
    // Written exclusively by Cloud Functions (verifyRazorpayPayment).
    // Users can only read their own payment records.
    match /payments/{paymentId} {
      allow read: if isAuthed() && resource.data.userId == request.auth.uid;
      allow write: if false;
    }

    // ── Reviews ───────────────────────────────────────────────────────────────
    match /reviews/{reviewId} {
      allow read: if isAuthed();
      allow create: if isAuthed()
        && reviewId == expectedReviewId()
        && isValidReviewPayload(request.resource.data);
      allow update: if isAuthed()
        && resource.data.reviewerUserId == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['rating', 'comment', 'updatedAt'])
        && request.resource.data.rating is int
        && request.resource.data.rating >= 1
        && request.resource.data.rating <= 5
        && request.resource.data.comment is string
        && request.resource.data.updatedAt is timestamp;
      allow delete: if isAuthed()
        && resource.data.reviewerUserId == request.auth.uid;
    }

    // ── Swipes ────────────────────────────────────────────────────────────────
    // Each user owns their outgoing swipes subcollection.
    match /swipes/{userId}/outgoing/{targetId} {
      allow read: if request.auth.uid == userId;
      allow create: if request.auth.uid == userId
        && !isDeletedUser(targetId)
        && !hasBlockBetween(userId, targetId);
    }

    // ── Matches ───────────────────────────────────────────────────────────────
    // Created by the onSwipeCreated Cloud Function. Participants can read.
    match /matches/{matchId} {
      allow get: if isAuthed()
        && isMatchParticipant(resource.data, request.auth.uid)
        && resource.data.status != 'blocked'
        && !hasBlockBetween(resource.data.user1Id, resource.data.user2Id);
      allow list: if isAuthed()
        && resource.data.user1Id == request.auth.uid
        && resource.data.status == 'active';
      allow list: if isAuthed()
        && resource.data.user2Id == request.auth.uid
        && resource.data.status == 'active';
      allow write: if false;
    }

    // ── Chat messages ─────────────────────────────────────────────────────────
    match /chats/{matchId}/messages/{messageId} {
      allow read: if isAuthed()
        && isMatchParticipant(
          get(/databases/$(database)/documents/matches/$(matchId)).data,
          request.auth.uid
        )
        && get(/databases/$(database)/documents/matches/$(matchId))
            .data.status != 'blocked';
      allow create: if isAuthed()
        && request.resource.data.senderId == request.auth.uid
        && isMatchParticipant(
          get(/databases/$(database)/documents/matches/$(matchId)).data,
          request.auth.uid
        )
        && get(/databases/$(database)/documents/matches/$(matchId))
            .data.status != 'blocked';
    }

    // ── App config (force-update gate) ────────────────────────────────────────
    match /config/app_config {
      allow read: if true;
      allow write: if false;
    }
  }
}
