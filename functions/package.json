{
  "name": "functions",
  "scripts": {
    "lint": "eslint --ext .js,.ts src",
    "prebuild": "node scripts/clean-lib.cjs",
    "build": "tsc",
    "test": "npm run build && node --test lib/matching/*.test.js lib/marketplace/*.test.js lib/moderation/*.test.js lib/payments/*.test.js lib/places/*.test.js lib/profiles/*.test.js lib/reviews/*.test.js lib/clubs/*.test.js lib/events/*.test.js lib/eventSuccess/*.test.js lib/safety/*.test.js lib/demoOps/*.test.js lib/shared/*.test.js lib/waitlist/*.test.js test/callable-app-check.test.cjs",
    "test:rules": "node --test --test-concurrency=1 test/firestore.rules.test.cjs test/storage.rules.test.cjs",
    "build:watch": "tsc --watch",
    "serve": "npm run build && firebase emulators:start --only functions",
    "shell": "npm run build && firebase functions:shell",
    "start": "npm run shell",
    "generate:types": "dart ../tool/contracts/generate_firestore_types.dart",
    "sync:callable-invokers": "node scripts/set-callable-invokers-public.cjs",
    "backfill:profile-thumbnails": "node scripts/backfill-profile-thumbnails.cjs",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log"
  },
  "engines": {
    "node": "24"
  },
  "main": "lib/index.js",
  "dependencies": {
    "@google-cloud/vision": "^5.3.6",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "date-fns": "^4.0.0",
    "firebase-admin": "^13.6.0",
    "firebase-functions": "^7.0.0",
    "razorpay": "^2.9.6",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^5.0.0",
    "@typescript-eslint/eslint-plugin": "^5.12.0",
    "@typescript-eslint/parser": "^5.12.0",
    "eslint": "^8.9.0",
    "eslint-config-google": "^0.14.0",
    "eslint-plugin-import": "^2.25.4",
    "firebase-functions-test": "^3.4.1",
    "json-schema-to-typescript": "^15.0.4",
    "typescript": "^5.7.3"
  },
  "private": true
}
