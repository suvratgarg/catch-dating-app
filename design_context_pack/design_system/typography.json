  "rules": {
    "familyRoles": "Archivo is display/brand voice; platform system is prose, user content, and UI; IBM Plex Mono is data.",
    "tracking": "Zero by default. Caps-only mono roles own 0.08-0.18em; welcomeReelHeadline owns the -0.5px display exception.",
    "uppercase": "Use uppercase-enforcing owners with kicker, monoCapsLabel, and badgeCaps.",
    "displayVoice": "Archivo is roman-only at the locked 78% width and is centralized through CatchFonts.",
    "color": "Base UI is paper and ink; chroma is reserved for activity meaning."
  },
  "registry": {
    "publicStaticTextStyleMethods": 57,
    "covered": 56,
    "excluded": 1
  },
  "excluded": {
    "transparentInput": "Utility style for hidden platform input; excluded from design typography."
