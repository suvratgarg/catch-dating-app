{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://catch.local/design-parity/state-matrix.schema.json",
  "title": "Catch Design Parity State Matrix",
  "type": "object",
  "required": ["version", "updated", "features"],
  "properties": {
    "version": { "const": 1 },
    "updated": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
    "requiredStateKinds": {
      "type": "array",
      "items": { "type": "string" },
      "uniqueItems": true
    },
    "features": {
      "type": "array",
      "items": { "$ref": "#/$defs/feature" },
      "minItems": 1
    }
  },
  "$defs": {
    "feature": {
      "type": "object",
      "required": ["id", "name", "priority", "status", "screens"],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9_]+$" },
        "name": { "type": "string", "minLength": 1 },
        "priority": { "enum": ["P1", "P2", "P3", "P4"] },
        "status": { "enum": ["planned", "in_progress", "ready", "blocked"] },
        "nextPass": { "type": "string" },
        "screens": {
          "type": "array",
          "items": { "$ref": "#/$defs/screen" },
          "minItems": 1
        },
        "lintCandidates": {
          "type": "array",
          "items": { "$ref": "#/$defs/gap" }
        },
        "previewPlan": {
          "type": "array",
          "items": { "$ref": "#/$defs/gap" }
        }
      }
    },
    "screen": {
      "type": "object",
      "required": ["id", "routeId", "implementationPaths", "states"],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9_.-]+$" },
        "routeId": { "type": "string" },
        "routeIds": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1,
          "uniqueItems": true
        },
        "implementationPaths": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1,
          "uniqueItems": true
        },
        "componentIds": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        },
        "captureIds": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        },
        "designRefs": {
          "type": "array",
          "items": { "$ref": "#/$defs/designRef" }
        },
        "states": {
          "type": "array",
          "items": { "$ref": "#/$defs/state" },
          "minItems": 1
        },
        "gaps": {
          "type": "array",
          "items": { "$ref": "#/$defs/gap" }
        }
      }
    },
    "state": {
      "type": "object",
      "required": ["id", "kind", "status"],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9_.-]+$" },
        "kind": { "type": "string" },
        "status": {
          "enum": ["planned", "implemented", "captured", "tested", "ready", "blocked"]
        },
        "captureIds": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        },
        "previewIds": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        },
        "tests": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        },
        "notes": { "type": "string" }
      }
    },
    "designRef": {
      "type": "object",
      "required": ["id", "kind", "status"],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9_.-]+$" },
        "kind": { "enum": ["repo", "external", "figma", "generated"] },
        "status": { "enum": ["available", "needs_export", "planned", "blocked"] },
        "path": { "type": "string" },
        "notes": { "type": "string" }
      }
    },
    "gap": {
      "type": "object",
      "required": ["id", "status", "nextAction"],
      "properties": {
        "id": { "type": "string", "pattern": "^[A-Z0-9-]+$" },
        "status": { "enum": ["open", "in_progress", "blocked", "closed"] },
        "nextAction": { "type": "string", "minLength": 1 }
      }
    }
  }
}
