DATASET_LOCATION=asia-south1
BIGQUERY_PROJECT_ID=${param:PROJECT_ID}
DATABASE=(default)
DATABASE_REGION=asia-south1
COLLECTION_PATH=participantMomentum
WILDCARD_IDS=false
DATASET_ID=catch_marketplace_metrics
TABLE_ID=participant_momentum
TABLE_PARTITIONING=DAY
MAX_DISPATCHES_PER_SECOND=25
VIEW_TYPE=view
BACKUP_COLLECTION=bigQueryExportFailures
USE_NEW_SNAPSHOT_QUERY_SYNTAX=yes
EXCLUDE_OLD_DATA=yes
MAX_ENQUEUE_ATTEMPTS=3
LOG_LEVEL=info
