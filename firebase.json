{
  "flutter": {
    "platforms": {
      "android": {
        "default": {
          "projectId": "catch-dating-app-64e51",
          "appId": "1:574779808785:android:81edbfa0d4aba7c48ea5b0",
          "fileOutput": "android/app/google-services.json"
        }
      },
      "ios": {
        "default": {
          "projectId": "catch-dating-app-64e51",
          "appId": "1:574779808785:ios:49b1ce51418604b78ea5b0",
          "uploadDebugSymbols": false,
          "fileOutput": "ios/Runner/GoogleService-Info.plist"
        }
      },
      "macos": {
        "default": {
          "projectId": "catch-dating-app-64e51",
          "appId": "1:574779808785:ios:49b1ce51418604b78ea5b0",
          "uploadDebugSymbols": false,
          "fileOutput": "macos/Runner/GoogleService-Info.plist"
        }
      },
      "dart": {
        "lib/firebase_options.dart": {
          "projectId": "catch-dating-app-64e51",
          "configurations": {
            "android": "1:574779808785:android:81edbfa0d4aba7c48ea5b0",
            "ios": "1:574779808785:ios:49b1ce51418604b78ea5b0",
            "macos": "1:574779808785:ios:49b1ce51418604b78ea5b0",
            "web": "1:574779808785:web:0c3bd6aa7d98590f8ea5b0"
          }
        }
      }
    }
  },
  "extensions": {
    "bq-event-success-feedback": "firebase/firestore-bigquery-export@0.3.2",
    "bq-event-success-scorecards": "firebase/firestore-bigquery-export@0.3.2",
    "bq-host-clubs": "firebase/firestore-bigquery-export@0.3.2",
    "bq-host-event-invite-links": "firebase/firestore-bigquery-export@0.3.2",
    "bq-host-event-participations": "firebase/firestore-bigquery-export@0.3.2",
    "bq-host-events": "firebase/firestore-bigquery-export@0.3.2",
    "bq-host-matches": "firebase/firestore-bigquery-export@0.3.2",
    "bq-host-payments": "firebase/firestore-bigquery-export@0.3.2",
    "bq-host-reviews": "firebase/firestore-bigquery-export@0.3.2",
    "bq-host-saved-events": "firebase/firestore-bigquery-export@0.3.2",
    "bq-participant-marketplace-metrics": "firebase/firestore-bigquery-export@0.3.2",
    "bq-participant-metric-counters": "firebase/firestore-bigquery-export@0.3.2",
    "bq-participant-momentum": "firebase/firestore-bigquery-export@0.3.2",
    "bq-participant-signal-facts": "firebase/firestore-bigquery-export@0.3.2"
  },
  "hosting": [
    {
      "target": "marketing",
      "public": "website/dist",
      "ignore": [
        "firebase.json",
        "**/.git/**",
        "**/.DS_Store",
        "**/node_modules/**"
      ],
      "predeploy": [
        "node tool/env/check_web_hosting_env.mjs marketing",
        "npm run web:marketing:build"
      ],
      "headers": [
        {
          "source": "/.well-known/apple-app-site-association",
          "headers": [
            {
              "key": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        {
          "source": "/.well-known/assetlinks.json",
          "headers": [
            {
              "key": "Content-Type",
              "value": "application/json"
            }
          ]
        }
      ],
      "rewrites": [
        {
          "source": "/api/join-waitlist",
          "function": {
            "functionId": "joinWaitlist",
            "region": "asia-south1"
          }
        },
        {
          "source": "/host",
          "destination": "/host/index.html"
        },
        {
          "source": "/host/**",
          "destination": "/host/index.html"
        },
        {
          "source": "**",
          "destination": "/index.html"
        }
      ]
    },
    {
      "target": "app",
      "public": "build/web",
      "ignore": [
        "firebase.json",
        "**/.git/**",
        "**/.DS_Store"
      ],
      "rewrites": [
        {
          "source": "**",
          "destination": "/index.html"
        }
      ]
    },
    {
      "target": "admin",
      "public": "admin/dist",
      "ignore": [
        "firebase.json",
        "**/.git/**",
        "**/.DS_Store",
        "**/node_modules/**"
      ],
      "predeploy": [
        "node tool/env/check_web_hosting_env.mjs admin",
        "npm run web:admin:build"
      ],
      "headers": [
        {
          "source": "**",
          "headers": [
            {
              "key": "X-Robots-Tag",
              "value": "noindex, nofollow"
            }
          ]
        }
      ],
      "rewrites": [
        {
          "source": "**",
          "destination": "/index.html"
        }
      ]
    }
  ],
  "firestore": {
    "database": "(default)",
    "location": "asia-south1",
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json",
    "predeploy": [
      "npm --prefix functions ci",
      "npm --prefix functions test",
      "firebase emulators:exec --project demo-catch-rules --only firestore,storage \"npm --prefix functions run test:rules\""
    ]
  },
  "emulators": {
    "auth": {
      "port": 9099
    },
    "functions": {
      "port": 5001
    },
    "firestore": {
      "port": 8080
    },
    "storage": {
      "port": 9199
    },
    "ui": {
      "enabled": true,
      "port": 4000
    },
    "singleProjectMode": true,
    "hosting": {
      "port": 5000
    }
  },
  "functions": {
    "codebase": "default",
    "disallowLegacyRuntimeConfig": true,
    "ignore": [
      "node_modules",
      ".git",
      "firebase-debug.log",
      "firebase-debug.*.log",
      "*.local"
    ],
    "predeploy": [
      "npm --prefix \"$RESOURCE_DIR\" run lint",
      "npm --prefix \"$RESOURCE_DIR\" run build"
    ],
    "source": "functions"
  },
  "storage": {
    "rules": "storage.rules"
  },
  "remoteconfig": {
    "template": "firebase/remote_config.template.json"
  }
}
