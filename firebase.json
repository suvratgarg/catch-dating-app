      "dart": {
        "lib/firebase_options.dart": {
          "projectId": "catch-dating-app-64e51",
          "configurations": {
            "android": "1:574779808785:android:8d7b61e9d54592f68ea5b0",
            "ios": "1:574779808785:ios:ee42e89efaf280f78ea5b0",
