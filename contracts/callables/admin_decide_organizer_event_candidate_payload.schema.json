{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://catch.app/contracts/callables/admin_decide_organizer_event_candidate_payload.schema.json",
  "title": "AdminDecideOrganizerEventCandidateCallablePayload",
  "description": "Callable payload accepted by adminDecideOrganizerEventCandidate. This records a manual admin review decision for a private external event candidate without importing the event.",
  "type": "object",
  "additionalProperties": false,
  "required": ["candidateId", "decision", "checklist", "note"],
  "properties": {
    "candidateId": {"type": "string", "minLength": 1, "maxLength": 240},
    "decision": {"type": "string", "enum": ["approve_for_import", "hold", "reject"]},
    "checklist": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "identityReviewed",
        "sourceEventReviewed",
        "timeReviewed",
        "locationReviewed",
        "dedupeReviewed",
        "ownerSafeCopyReviewed",
        "importPolicyAcknowledged"
      ],
      "properties": {
        "identityReviewed": {"type": "boolean"},
        "sourceEventReviewed": {"type": "boolean"},
        "timeReviewed": {"type": "boolean"},
        "locationReviewed": {"type": "boolean"},
        "dedupeReviewed": {"type": "boolean"},
        "ownerSafeCopyReviewed": {"type": "boolean"},
        "importPolicyAcknowledged": {"type": "boolean"}
      }
    },
    "note": {"type": "string", "minLength": 1, "maxLength": 1000}
  }
}
