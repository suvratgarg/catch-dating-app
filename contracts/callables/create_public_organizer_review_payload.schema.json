{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://catch.app/contracts/callables/create_public_organizer_review_payload.schema.json",
  "title": "CreatePublicOrganizerReviewCallablePayload",
  "description": "Callable payload accepted by createPublicOrganizerReview for unverified public organizer listing reviews.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "organizerId",
    "rating",
    "comment",
    "reviewerName",
    "isAnonymous",
    "submittedFromPath"
  ],
  "properties": {
    "organizerId": {"$ref": "../shared/event_common.schema.json#/definitions/documentId"},
    "rating": {"type": "integer", "minimum": 1, "maximum": 5},
    "comment": {"type": "string", "minLength": 1, "maxLength": 1000},
    "reviewerName": {"type": "string", "maxLength": 120},
    "isAnonymous": {"type": "boolean"},
    "submittedFromPath": {"type": "string", "minLength": 1, "maxLength": 240}
  }
}
