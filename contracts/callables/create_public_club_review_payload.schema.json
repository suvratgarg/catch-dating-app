{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://catch.app/contracts/callables/create_public_club_review_payload.schema.json",
  "title": "CreatePublicClubReviewCallablePayload",
  "description": "Callable payload accepted by createPublicClubReview for unverified public organizer listing reviews.",
  "type": "object",
  "additionalProperties": false,
  "required": ["clubId", "rating", "comment", "reviewerName", "isAnonymous"],
  "properties": {
    "clubId": {"$ref": "../shared/event_common.schema.json#/definitions/documentId"},
    "rating": {"type": "integer", "minimum": 1, "maximum": 5},
    "comment": {"type": "string", "minLength": 1, "maxLength": 1000},
    "reviewerName": {"type": "string", "maxLength": 120},
    "isAnonymous": {"type": "boolean"},
    "submittedFromPath": {"type": ["string", "null"], "maxLength": 240}
  }
}
