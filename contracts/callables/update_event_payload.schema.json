{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://catch.app/contracts/callables/update_event_payload.schema.json",
  "title": "UpdateEventCallablePayload",
  "description": "Callable payload accepted by updateEvent.",
  "type": "object",
  "additionalProperties": false,
  "required": ["eventId", "fields"],
  "properties": {
    "eventId": {"$ref": "../shared/event_common.schema.json#/definitions/documentId"},
    "fields": {
      "type": "object",
      "additionalProperties": false,
      "minProperties": 1,
      "properties": {
        "startTimeMillis": {"type": "integer"},
        "endTimeMillis": {"type": "integer"},
        "meetingPoint": {"type": "string", "minLength": 1, "maxLength": 240},
        "meetingLocation": {
          "$ref": "../shared/event_common.schema.json#/definitions/eventMeetingLocation"
        },
        "startingPointLat": {
          "anyOf": [
            {"$ref": "../shared/event_common.schema.json#/definitions/latitude"},
            {"type": "null"}
          ]
        },
        "startingPointLng": {
          "anyOf": [
            {"$ref": "../shared/event_common.schema.json#/definitions/longitude"},
            {"type": "null"}
          ]
        },
        "locationDetails": {"type": ["string", "null"], "maxLength": 1000},
        "photoUrl": {"$ref": "../shared/event_common.schema.json#/definitions/urlOrNull"},
        "eventPhotos": {
          "type": "array",
          "maxItems": 12,
          "items": {"$ref": "../embedded/uploaded_photo.schema.json"}
        },
        "distanceKm": {"type": "number", "minimum": 0, "maximum": 100},
        "pace": {"$ref": "../shared/event_common.schema.json#/definitions/paceLevel"},
        "description": {"type": "string", "maxLength": 2000},
        "capacityLimit": {"type": "integer", "minimum": 1, "maximum": 1000},
        "priceInPaise": {"type": "integer", "minimum": 0, "maximum": 100000000},
        "constraints": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "minAge": {"type": "integer", "minimum": 0, "maximum": 120},
            "maxAge": {"type": "integer", "minimum": 0, "maximum": 120},
            "maxMen": {"type": ["integer", "null"], "minimum": 0},
            "maxWomen": {"type": ["integer", "null"], "minimum": 0}
          }
        },
        "eventPolicy": {
          "$ref": "../shared/event_common.schema.json#/definitions/eventPolicyBundle"
        },
        "privateAccess": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "inviteCode": {
              "type": ["string", "null"],
              "minLength": 4,
              "maxLength": 64,
              "pattern": "^[A-Za-z0-9_-]+$"
            }
          }
        }
      }
    }
  }
}
