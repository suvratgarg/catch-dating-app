{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://catch.app/contracts/operations/decision.schema.json",
  "title": "OperationDecision",
  "description": "Append-only decision over a particular work-item revision.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "decisionId",
    "runId",
    "workItemId",
    "workItemRevision",
    "decision",
    "status",
    "actor",
    "reasonCodes",
    "rationale",
    "evidenceRefs",
    "rulesetVersion",
    "modelVersion",
    "calibratedConfidence",
    "auditRequired",
    "createdAt",
    "effectiveAt",
    "supersedesDecisionId"
  ],
  "properties": {
    "schemaVersion": {"type": "integer", "const": 1},
    "decisionId": {"$ref": "common.schema.json#/definitions/id"},
    "runId": {"$ref": "common.schema.json#/definitions/id"},
    "workItemId": {"$ref": "common.schema.json#/definitions/id"},
    "workItemRevision": {"type": "integer", "minimum": 0},
    "decision": {
      "type": "string",
      "enum": ["approve", "reject", "escalate", "hold"]
    },
    "status": {
      "type": "string",
      "enum": ["proposed", "accepted", "superseded", "revoked"]
    },
    "actor": {"$ref": "common.schema.json#/definitions/actor"},
    "reasonCodes": {
      "type": "array",
      "minItems": 1,
      "maxItems": 40,
      "uniqueItems": true,
      "items": {"$ref": "common.schema.json#/definitions/code"}
    },
    "rationale": {"type": ["string", "null"], "maxLength": 4000},
    "evidenceRefs": {
      "type": "array",
      "maxItems": 100,
      "items": {"$ref": "common.schema.json#/definitions/evidenceRef"}
    },
    "rulesetVersion": {"type": "string", "minLength": 1, "maxLength": 120},
    "modelVersion": {"type": ["string", "null"], "maxLength": 160},
    "calibratedConfidence": {
      "type": ["number", "null"],
      "minimum": 0,
      "maximum": 1
    },
    "auditRequired": {"type": "boolean"},
    "createdAt": {"$ref": "common.schema.json#/definitions/isoDateTime"},
    "effectiveAt": {"$ref": "common.schema.json#/definitions/nullableIsoDateTime"},
    "supersedesDecisionId": {
      "anyOf": [
        {"$ref": "common.schema.json#/definitions/id"},
        {"type": "null"}
      ]
    }
  }
}
