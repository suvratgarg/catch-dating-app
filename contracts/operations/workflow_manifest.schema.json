{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://catch.app/contracts/operations/workflow_manifest.schema.json",
  "title": "OperationWorkflowManifest",
  "description": "Enforced inventory for a durable operations workflow, its CLI surface, queue model, source profiles, capacity, and disabled capabilities.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "workflowId",
    "version",
    "executionModes",
    "capabilities",
    "commands",
    "primaryStages",
    "entityKinds",
    "allowedTransitions",
    "lifecycleStatuses",
    "lifecycleSemantics",
    "maxWorkItemsPerRun",
    "sourceProfiles"
  ],
  "properties": {
    "schemaVersion": {"type": "integer", "const": 1},
    "workflowId": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]{1,99}$"
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "executionModes": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": ["shadow", "assisted", "autonomous"]
      }
    },
    "capabilities": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "network",
        "modelCalls",
        "publicWrites",
        "ruleDeployment"
      ],
      "properties": {
        "network": {"type": "boolean"},
        "modelCalls": {"type": "boolean"},
        "publicWrites": {"type": "boolean"},
        "ruleDeployment": {"type": "boolean"}
      }
    },
    "commands": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^[a-z][a-z0-9-]{0,63}$"
      }
    },
    "primaryStages": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^[a-z][a-z0-9_]{0,63}$"
      }
    },
    "entityKinds": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^[a-z][a-z0-9_]{0,79}$"
      }
    },
    "allowedTransitions": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "array",
        "uniqueItems": true,
        "items": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]{0,63}$"
        }
      }
    },
    "lifecycleStatuses": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^[a-z][a-z0-9_]{0,63}$"
      }
    },
    "lifecycleSemantics": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "activeStatuses",
        "publishedStatuses",
        "expiredStatuses"
      ],
      "properties": {
        "activeStatuses": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_]{0,63}$"
          }
        },
        "publishedStatuses": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_]{0,63}$"
          }
        },
        "expiredStatuses": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_]{0,63}$"
          }
        }
      }
    },
    "maxWorkItemsPerRun": {
      "type": "integer",
      "minimum": 1,
      "maximum": 10000
    },
    "sourceProfiles": {
      "type": "array",
      "minItems": 0,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^[a-z][a-z0-9-]{0,99}$"
      }
    }
  }
}
