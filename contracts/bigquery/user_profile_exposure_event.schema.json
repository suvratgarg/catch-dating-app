{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://catch.app/contracts/bigquery/user_profile_exposure_event.schema.json",
  "title": "UserProfileExposureEvent",
  "description": "Raw BigQuery event for profile impression, dwell, and photo performance analytics. This table is the denominator for user-safe profile analytics and internal composition models.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "analytics_event_id",
    "occurred_at",
    "event_date",
    "subject_uid",
    "event_name",
    "ingested_at"
  ],
  "properties": {
    "analytics_event_id": {"type": "string", "minLength": 1, "maxLength": 160},
    "occurred_at": {"type": "string", "format": "date-time"},
    "event_date": {"type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$"},
    "viewer_uid": {
      "anyOf": [
        {"$ref": "../shared/event_common.schema.json#/definitions/documentId"},
        {"type": "null"}
      ]
    },
    "subject_uid": {"$ref": "../shared/event_common.schema.json#/definitions/documentId"},
    "event_id": {
      "anyOf": [
        {"$ref": "../shared/event_common.schema.json#/definitions/documentId"},
        {"type": "null"}
      ]
    },
    "club_id": {
      "anyOf": [
        {"$ref": "../shared/event_common.schema.json#/definitions/documentId"},
        {"type": "null"}
      ]
    },
    "event_name": {
      "type": "string",
      "enum": [
        "profileImpression",
        "profileView",
        "profileDwell",
        "photoImpression",
        "photoDwell"
      ]
    },
    "surface": {"type": ["string", "null"], "maxLength": 80},
    "photo_id": {"type": ["string", "null"], "maxLength": 180},
    "photo_slot": {"type": ["integer", "null"], "minimum": 0, "maximum": 24},
    "dwell_ms": {"type": ["integer", "null"], "minimum": 0, "maximum": 3600000},
    "session_hash": {"type": ["string", "null"], "maxLength": 128},
    "platform": {"type": ["string", "null"], "maxLength": 40},
    "ingested_at": {"type": "string", "format": "date-time"}
  }
}
