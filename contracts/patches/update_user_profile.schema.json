{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://catch.app/contracts/patches/update_user_profile.schema.json",
  "title": "UpdateUserProfileCallablePayload",
  "description": "Callable request body for updateUserProfile. Values are normalized before Firestore writes.",
  "type": "object",
  "additionalProperties": false,
  "required": ["fields"],
  "properties": {
    "fields": {
      "type": "object",
      "additionalProperties": false,
      "minProperties": 1,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 120
        },
        "displayName": {
          "type": "string",
          "minLength": 1,
          "maxLength": 80,
          "pattern": ".*\\S.*"
        },
        "email": {
          "anyOf": [
            {
              "const": ""
            },
            {
              "type": "string",
              "format": "email",
              "maxLength": 320
            }
          ]
        },
        "instagramHandle": {
          "anyOf": [
            {
              "type": "string",
              "minLength": 1,
              "maxLength": 30,
              "pattern": "^[A-Za-z0-9._]{1,30}$"
            },
            {"type": "null"}
          ]
        },
        "profilePrompts": {
          "type": "array",
          "maxItems": 3,
          "items": {
            "$ref": "../embedded/profile_prompt_answer.schema.json"
          }
        },
        "phoneNumber": {
          "type": "string",
          "minLength": 1,
          "maxLength": 32
        },
        "dateOfBirth": {
          "type": "integer",
          "minimum": 0,
          "description": "Milliseconds since epoch before conversion to Firestore Timestamp."
        },
        "gender": {
          "$ref": "../shared/profile_common.schema.json#/definitions/gender"
        },
        "profileComplete": {
          "type": "boolean"
        },
        "photoUrls": {
          "$ref": "../shared/profile_common.schema.json#/definitions/photoUrlList"
        },
        "photoPrompts": {
          "type": "array",
          "maxItems": 6,
          "items": {
            "$ref": "../embedded/photo_prompt_answer.schema.json"
          }
        },
        "city": {
          "$ref": "../shared/profile_common.schema.json#/definitions/citySlug"
        },
        "latitude": {
          "$ref": "../shared/profile_common.schema.json#/definitions/latitude"
        },
        "longitude": {
          "$ref": "../shared/profile_common.schema.json#/definitions/longitude"
        },
        "interestedInGenders": {
          "type": "array",
          "minItems": 1,
          "maxItems": 8,
          "uniqueItems": true,
          "items": {
            "$ref": "../shared/profile_common.schema.json#/definitions/gender"
          }
        },
        "minAgePreference": {
          "type": "integer",
          "minimum": 18,
          "maximum": 99
        },
        "maxAgePreference": {
          "type": "integer",
          "minimum": 18,
          "maximum": 99
        },
        "height": {
          "$ref": "../shared/profile_common.schema.json#/definitions/heightCm"
        },
        "occupation": {
          "$ref": "../shared/profile_common.schema.json#/definitions/nullableString"
        },
        "company": {
          "$ref": "../shared/profile_common.schema.json#/definitions/nullableString"
        },
        "education": {
          "$ref": "../shared/profile_common.schema.json#/definitions/educationLevel"
        },
        "religion": {
          "$ref": "../shared/profile_common.schema.json#/definitions/religion"
        },
        "languages": {
          "type": "array",
          "maxItems": 20,
          "uniqueItems": true,
          "items": {
            "$ref": "../shared/profile_common.schema.json#/definitions/language"
          }
        },
        "relationshipGoal": {
          "$ref": "../shared/profile_common.schema.json#/definitions/relationshipGoal"
        },
        "drinking": {
          "$ref": "../shared/profile_common.schema.json#/definitions/drinkingHabit"
        },
        "smoking": {
          "$ref": "../shared/profile_common.schema.json#/definitions/smokingHabit"
        },
        "workout": {
          "$ref": "../shared/profile_common.schema.json#/definitions/workoutFrequency"
        },
        "diet": {
          "$ref": "../shared/profile_common.schema.json#/definitions/dietaryPreference"
        },
        "children": {
          "$ref": "../shared/profile_common.schema.json#/definitions/childrenStatus"
        },
        "paceMinSecsPerKm": {
          "$ref": "../shared/profile_common.schema.json#/definitions/paceSecsPerKm"
        },
        "paceMaxSecsPerKm": {
          "$ref": "../shared/profile_common.schema.json#/definitions/paceSecsPerKm"
        },
        "preferredDistances": {
          "type": "array",
          "maxItems": 12,
          "uniqueItems": true,
          "items": {
            "$ref": "../shared/profile_common.schema.json#/definitions/preferredDistance"
          }
        },
        "runningReasons": {
          "type": "array",
          "maxItems": 12,
          "uniqueItems": true,
          "items": {
            "$ref": "../shared/profile_common.schema.json#/definitions/runReason"
          }
        },
        "preferredRunTimes": {
          "type": "array",
          "maxItems": 8,
          "uniqueItems": true,
          "items": {
            "$ref": "../shared/profile_common.schema.json#/definitions/preferredRunTime"
          }
        },
        "prefsNewCatches": {
          "type": "boolean"
        },
        "prefsMessages": {
          "type": "boolean"
        },
        "prefsRunReminders": {
          "type": "boolean"
        },
        "prefsRunStatusUpdates": {
          "type": "boolean"
        },
        "prefsClubUpdates": {
          "type": "boolean"
        },
        "prefsWeeklyDigest": {
          "type": "boolean"
        },
        "prefsShowOnMap": {
          "type": "boolean"
        }
      }
    }
  },
  "x-normalization": [
    "trim prompt ids and display prompt titles",
    "collapse stacked blank lines in prompt answers and captions",
    "drop empty prompt answers and empty photo captions",
    "convert dateOfBirth millis to Firestore Timestamp"
  ],
  "x-intentionally-excluded-fields": [
    "firstName",
    "lastName",
    "photoThumbnailUrls",
    "fcmToken",
    "deleted",
    "deletedAt",
    "sexualOrientation",
    "bio"
  ]
}
