{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://catch.app/contracts/storage/club_photos.schema.json",
  "title": "ClubPhotosStoragePath",
  "description": "Club gallery and cover photos stored at clubs/{clubId}/photos/{fileName}. Host writes require club ownership or host membership.",
  "type": "object",
  "x-storage-rules-match": "match /clubs/{clubId}/photos/{fileName}",
  "x-storage-read": "public (download URLs are used for public club media)",
  "x-storage-write": "club host or owner",
  "x-storage-content-type-pattern": "image/.*",
  "x-storage-file-name-pattern": "[0-5]_[0-9]+\\.(jpg|jpeg|png)",
  "x-storage-max-bytes": 8388608,
  "x-storage-rules-test-file": "functions/test/storage.rules.test.cjs",
  "x-storage-related-collection": "clubs",
  "x-storage-known-consumers": [
    "lib/clubs/presentation/create/create_club_controller.dart"
  ],
  "properties": {
    "clubId": {
      "type": "string",
      "description": "Club document id; path segment."
    },
    "fileName": {
      "type": "string",
      "description": "Required pattern: {position}_{timestamp}.{ext}, with position 0-5 and ext jpg/jpeg/png."
    }
  }
}
