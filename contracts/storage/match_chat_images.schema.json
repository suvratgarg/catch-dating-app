{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://catch.app/contracts/storage/match_chat_images.schema.json",
  "title": "MatchChatImagesStoragePath",
  "description": "Chat images uploaded inside a match conversation. Stored at matches/{matchId}/images/{fileName}. Read and write require active match participation.",
  "type": "object",
  "x-storage-rules-match": "match /matches/{matchId}/images/{fileName}",
  "x-storage-read": "active match participant",
  "x-storage-write": "active match participant (uploader)",
  "x-storage-content-type-pattern": "image/.*",
  "x-storage-max-bytes": 8388608,
  "x-storage-rules-test-file": "functions/test/storage.rules.test.cjs",
  "x-storage-related-collection": "matches",
  "x-storage-known-consumers": [
    "lib/chats/presentation/chat_screen.dart",
    "lib/chats/data/chat_repository.dart",
    "functions/src/safety/moderateChatMessage.ts"
  ],
  "properties": {
    "matchId": {
      "type": "string",
      "description": "Match document id; path segment."
    },
    "fileName": {
      "type": "string",
      "description": "Conventional pattern: {senderId}_{timestamp}.{ext}"
    }
  }
}
