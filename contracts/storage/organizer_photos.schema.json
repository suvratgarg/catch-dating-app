{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://catch.app/contracts/storage/organizer_photos.schema.json",
  "title": "OrganizerPhotosStoragePath",
  "description": "Organizer gallery and cover photos stored at organizers/{organizerId}/photos/{fileName}.",
  "type": "object",
  "x-storage-rules-match": "match /organizers/{organizerId}/photos/{fileName}",
  "x-storage-read": "public",
  "x-storage-write": "organizer owner or manager",
  "x-storage-content-type-pattern": "image/.*",
  "x-storage-file-name-pattern": "[0-5]_[0-9]+\\.(jpg|jpeg|png)",
  "x-storage-max-bytes": 8388608,
  "x-storage-rules-test-file": "functions/test/storage.rules.test.cjs",
  "x-storage-related-collection": "organizers",
  "x-storage-known-consumers": ["lib/organizers/data/organizers_repository.dart"],
  "properties": {
    "organizerId": {"type": "string", "description": "Organizer document id; path segment."},
    "fileName": {"type": "string", "description": "Required pattern: {position}_{timestamp}.{ext}."}
  }
}
