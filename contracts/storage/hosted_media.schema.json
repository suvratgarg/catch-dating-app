{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://catch.app/contracts/storage/hosted_media.schema.json",
  "title": "HostedMediaStoragePath",
  "description": "Retired user-owned club and event media staging path at users/{uid}/hostedMedia/{fileName}. Existing objects remain public-readable for compatibility; new client writes are denied.",
  "type": "object",
  "x-storage-rules-match": "match /users/{uid}/hostedMedia/{fileName}",
  "x-storage-read": "public (download URLs are used for public club/event media)",
  "x-storage-write": "legacy read-only (client writes denied)",
  "x-storage-content-type-pattern": "image/.*",
  "x-storage-max-bytes": 8388608,
  "x-storage-rules-test-file": "functions/test/storage.rules.test.cjs",
  "x-storage-related-collection": "users",
  "x-storage-known-consumers": [
    "functions/src/moderation/moderatePhoto.ts"
  ],
  "properties": {
    "uid": {
      "type": "string",
      "description": "Firebase Auth uid of the uploading host; path segment."
    },
    "fileName": {
      "type": "string",
      "description": "Conventional patterns: club_{clubId}_cover_{timestamp}.{ext}, club_{clubId}_profile_{timestamp}.{ext}, event_{clubId}_{eventId}_{timestamp}.{ext}"
    }
  }
}
