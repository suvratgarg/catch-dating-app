{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://catch.app/contracts/storage/event_images.schema.json",
  "title": "EventImagesStoragePath",
  "description": "Public event photos stored at clubs/{clubId}/events/{eventId}/{fileName}. Writes restricted to host/owner/co-host of the parent club.",
  "type": "object",
  "x-storage-rules-match": "match /clubs/{clubId}/events/{eventId}/{fileName}",
  "x-storage-read": "public (any user, authenticated or not)",
  "x-storage-write": "club hostUserId, ownerUserId, or any uid in parent club's hostUserIds",
  "x-storage-content-type-pattern": "image/.*",
  "x-storage-max-bytes": 8388608,
  "x-storage-rules-test-file": "functions/test/storage.rules.test.cjs",
  "x-storage-related-collection": "events",
  "x-storage-known-consumers": [
    "lib/events/presentation/create_event_screen.dart",
    "lib/events/data/event_repository.dart"
  ],
  "properties": {
    "clubId": {
      "type": "string",
      "description": "Parent club document id; path segment."
    },
    "eventId": {
      "type": "string",
      "description": "Event document id; path segment."
    },
    "fileName": {
      "type": "string",
      "description": "Conventional pattern: cover.{ext} or {timestamp}.{ext}"
    }
  }
}
