{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://catch.app/contracts/firestore/users.schema.json",
  "title": "UserProfileDocument",
  "description": "Canonical private profile document stored at users/{uid}. The uid is the document id and is not stored in document data.",
  "type": "object",
  "additionalProperties": false,
  "x-firestore-collection": "users",
  "x-firestore-path": "users/{uid}",
  "x-document-id-field": "uid",
  "x-owner": "owner initial create, callable-owned profile edits, server-owned projections",
  "required": [
    "name",
    "firstName",
    "lastName",
    "displayName",
    "dateOfBirth",
    "gender",
    "phoneNumber",
    "profileComplete",
    "email",
    "profilePrompts",
    "photoUrls",
    "photoThumbnailUrls",
    "photoPrompts",
    "interestedInGenders",
    "minAgePreference",
    "maxAgePreference",
    "languages",
    "paceMinSecsPerKm",
    "paceMaxSecsPerKm",
    "preferredDistances",
    "runningReasons",
    "preferredRunTimes",
    "prefsNewCatches",
    "prefsMessages",
    "prefsEventReminders",
    "prefsRunStatusUpdates",
    "prefsClubUpdates",
    "prefsWeeklyDigest",
    "prefsShowOnMap"
  ],
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120
    },
    "firstName": {
      "type": "string",
      "maxLength": 80
    },
    "lastName": {
      "type": "string",
      "maxLength": 80
    },
    "displayName": {
      "type": "string",
      "minLength": 1,
      "maxLength": 80,
      "pattern": ".*\\S.*"
    },
    "dateOfBirth": {
      "$ref": "../shared/profile_common.schema.json#/definitions/timestamp"
    },
    "gender": {
      "$ref": "../shared/profile_common.schema.json#/definitions/gender"
    },
    "phoneNumber": {
      "type": "string",
      "minLength": 1,
      "maxLength": 32
    },
    "profileComplete": {
      "type": "boolean"
    },
    "synthetic": {
      "type": "boolean",
      "description": "Internal demo seed marker used for cleanup and diagnostics."
    },
    "seedPrefix": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120,
      "description": "Internal demo seed prefix used for cleanup and diagnostics."
    },
    "scenario": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120,
      "description": "Internal demo seed scenario name used for cleanup and diagnostics."
    },
    "demoOps": {
      "type": "boolean",
      "description": "Internal demo-operations marker used for cleanup and diagnostics."
    },
    "demoOpsId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 180,
      "description": "Internal demo-operations id used for cleanup and diagnostics."
    },
    "demoOpsCommand": {
      "type": "string",
      "minLength": 1,
      "maxLength": 80,
      "description": "Internal demo-operations command name used for cleanup and diagnostics."
    },
    "email": {
      "anyOf": [
        {
          "const": ""
        },
        {
          "type": "string",
          "format": "email",
          "maxLength": 320
        }
      ]
    },
    "instagramHandle": {
      "anyOf": [
        {
          "type": "string",
          "minLength": 1,
          "maxLength": 30,
          "pattern": "^[A-Za-z0-9._]{1,30}$"
        },
        {"type": "null"}
      ]
    },
    "profilePrompts": {
      "type": "array",
      "maxItems": 3,
      "items": {
        "$ref": "../embedded/profile_prompt_answer.schema.json"
      }
    },
    "photoUrls": {
      "$ref": "../shared/profile_common.schema.json#/definitions/photoUrlList"
    },
    "photoThumbnailUrls": {
      "$ref": "../shared/profile_common.schema.json#/definitions/photoUrlList"
    },
    "photoPrompts": {
      "type": "array",
      "maxItems": 6,
      "items": {
        "$ref": "../embedded/photo_prompt_answer.schema.json"
      }
    },
    "profilePhotos": {
      "type": "array",
      "maxItems": 6,
      "items": {
        "$ref": "../embedded/profile_photo.schema.json"
      }
    },
    "city": {
      "$ref": "../shared/profile_common.schema.json#/definitions/citySlug"
    },
    "latitude": {
      "$ref": "../shared/profile_common.schema.json#/definitions/latitude"
    },
    "longitude": {
      "$ref": "../shared/profile_common.schema.json#/definitions/longitude"
    },
    "interestedInGenders": {
      "type": "array",
      "minItems": 1,
      "maxItems": 8,
      "uniqueItems": true,
      "items": {
        "$ref": "../shared/profile_common.schema.json#/definitions/gender"
      }
    },
    "minAgePreference": {
      "type": "integer",
      "minimum": 18,
      "maximum": 99
    },
    "maxAgePreference": {
      "type": "integer",
      "minimum": 18,
      "maximum": 99
    },
    "height": {
      "$ref": "../shared/profile_common.schema.json#/definitions/heightCm"
    },
    "occupation": {
      "$ref": "../shared/profile_common.schema.json#/definitions/nullableString"
    },
    "company": {
      "$ref": "../shared/profile_common.schema.json#/definitions/nullableString"
    },
    "education": {
      "$ref": "../shared/profile_common.schema.json#/definitions/educationLevel"
    },
    "religion": {
      "$ref": "../shared/profile_common.schema.json#/definitions/religion"
    },
    "languages": {
      "type": "array",
      "maxItems": 20,
      "uniqueItems": true,
      "items": {
        "$ref": "../shared/profile_common.schema.json#/definitions/language"
      }
    },
    "relationshipGoal": {
      "$ref": "../shared/profile_common.schema.json#/definitions/relationshipGoal"
    },
    "drinking": {
      "$ref": "../shared/profile_common.schema.json#/definitions/drinkingHabit"
    },
    "smoking": {
      "$ref": "../shared/profile_common.schema.json#/definitions/smokingHabit"
    },
    "workout": {
      "$ref": "../shared/profile_common.schema.json#/definitions/workoutFrequency"
    },
    "diet": {
      "$ref": "../shared/profile_common.schema.json#/definitions/dietaryPreference"
    },
    "children": {
      "$ref": "../shared/profile_common.schema.json#/definitions/childrenStatus"
    },
    "paceMinSecsPerKm": {
      "$ref": "../shared/profile_common.schema.json#/definitions/paceSecsPerKm"
    },
    "paceMaxSecsPerKm": {
      "$ref": "../shared/profile_common.schema.json#/definitions/paceSecsPerKm"
    },
    "preferredDistances": {
      "type": "array",
      "maxItems": 12,
      "uniqueItems": true,
      "items": {
        "$ref": "../shared/profile_common.schema.json#/definitions/preferredDistance"
      }
    },
    "runningReasons": {
      "type": "array",
      "maxItems": 12,
      "uniqueItems": true,
      "items": {
        "$ref": "../shared/profile_common.schema.json#/definitions/runReason"
      }
    },
    "preferredRunTimes": {
      "type": "array",
      "maxItems": 8,
      "uniqueItems": true,
      "items": {
        "$ref": "../shared/profile_common.schema.json#/definitions/preferredRunTime"
      }
    },
    "prefsNewCatches": {
      "type": "boolean"
    },
    "prefsMessages": {
      "type": "boolean"
    },
    "prefsEventReminders": {
      "type": "boolean"
    },
    "prefsRunStatusUpdates": {
      "type": "boolean"
    },
    "prefsClubUpdates": {
      "type": "boolean"
    },
    "prefsWeeklyDigest": {
      "type": "boolean"
    },
    "prefsShowOnMap": {
      "type": "boolean"
    },
    "fcmToken": {
      "type": "string"
    },
    "deleted": {
      "type": "boolean"
    },
    "deletedAt": {
      "$ref": "../shared/profile_common.schema.json#/definitions/nullableTimestamp"
    }
  },
  "x-internal-demo-fields": [
    "synthetic",
    "seedPrefix",
    "scenario",
    "demoOps",
    "demoOpsId",
    "demoOpsCommand"
  ],
  "x-legacy-tolerated-fields": ["bio"],
  "x-denormalized-to": ["publicProfiles/{uid}"]
}
