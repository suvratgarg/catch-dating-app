{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://catch.app/contracts/firestore/run_participations.schema.json",
  "title": "RunParticipationDocument",
  "description": "Canonical run roster edge stored at runParticipations/{participationId}.",
  "type": "object",
  "additionalProperties": false,
  "x-firestore-collection": "runParticipations",
  "x-firestore-path": "runParticipations/{participationId}",
  "x-document-id-field": "id",
  "x-owner": "booking, waitlist, attendance, cancellation, and account-deletion callables",
  "x-internal-demo-fields": [
    "synthetic",
    "seedPrefix",
    "scenario",
    "demoOps",
    "demoOpsId",
    "demoOpsCommand"
  ],
  "required": [
    "runId",
    "runClubId",
    "uid",
    "status",
    "createdAt",
    "updatedAt",
    "signedUpAt",
    "waitlistedAt",
    "attendedAt",
    "cancelledAt",
    "deletedAt",
    "genderAtSignup",
    "paymentId"
  ],
  "properties": {
    "runId": {
      "$ref": "../shared/run_common.schema.json#/definitions/documentId"
    },
    "runClubId": {
      "$ref": "../shared/run_common.schema.json#/definitions/documentId"
    },
    "uid": {
      "$ref": "../shared/run_common.schema.json#/definitions/documentId"
    },
    "status": {
      "$ref": "../shared/run_common.schema.json#/definitions/runParticipationStatus"
    },
    "createdAt": {
      "$ref": "../shared/run_common.schema.json#/definitions/timestamp"
    },
    "updatedAt": {
      "$ref": "../shared/run_common.schema.json#/definitions/timestamp"
    },
    "signedUpAt": {
      "$ref": "../shared/run_common.schema.json#/definitions/nullableTimestamp"
    },
    "waitlistedAt": {
      "$ref": "../shared/run_common.schema.json#/definitions/nullableTimestamp"
    },
    "attendedAt": {
      "$ref": "../shared/run_common.schema.json#/definitions/nullableTimestamp"
    },
    "cancelledAt": {
      "$ref": "../shared/run_common.schema.json#/definitions/nullableTimestamp"
    },
    "deletedAt": {
      "$ref": "../shared/run_common.schema.json#/definitions/nullableTimestamp"
    },
    "genderAtSignup": {
      "$ref": "../shared/run_common.schema.json#/definitions/genderAtSignup"
    },
    "cohortAtSignup": {
      "type": ["string", "null"],
      "minLength": 1,
      "maxLength": 120
    },
    "paymentId": {
      "type": ["string", "null"],
      "minLength": 1,
      "maxLength": 180
    },
    "synthetic": {
      "$ref": "../shared/run_common.schema.json#/definitions/demoMetadataFields/synthetic"
    },
    "seedPrefix": {
      "$ref": "../shared/run_common.schema.json#/definitions/demoMetadataFields/seedPrefix"
    },
    "scenario": {
      "$ref": "../shared/run_common.schema.json#/definitions/demoMetadataFields/scenario"
    },
    "demoOps": {
      "$ref": "../shared/run_common.schema.json#/definitions/demoMetadataFields/demoOps"
    },
    "demoOpsId": {
      "$ref": "../shared/run_common.schema.json#/definitions/demoMetadataFields/demoOpsId"
    },
    "demoOpsCommand": {
      "$ref": "../shared/run_common.schema.json#/definitions/demoMetadataFields/demoOpsCommand"
    }
  }
}
