{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://catch.app/contracts/firestore/event_waitlist_offers.schema.json",
  "title": "EventWaitlistOfferDocument",
  "description": "Server-owned waitlist offer stored at eventWaitlistOffers/{eventId_uid}. Offers reserve a waitlist slot until accepted, declined, expired, or cancelled.",
  "type": "object",
  "additionalProperties": false,
  "x-firestore-collection": "eventWaitlistOffers",
  "x-firestore-path": "eventWaitlistOffers/{offerId}",
  "x-document-id-field": "id",
  "x-owner": "waitlist offer callables and expiry scheduler",
  "x-internal-demo-fields": [
    "synthetic",
    "seedPrefix",
    "scenario",
    "demoOps",
    "demoOpsId",
    "demoOpsCommand"
  ],
  "required": [
    "eventId",
    "clubId",
    "uid",
    "cohortAtOffer",
    "status",
    "source",
    "offeredBy",
    "offeredAt",
    "expiresAt",
    "decidedAt",
    "createdAt",
    "updatedAt"
  ],
  "properties": {
    "eventId": {
      "$ref": "../shared/event_common.schema.json#/definitions/documentId",
      "x-catch-ownership": "callable-owned"
    },
    "clubId": {
      "$ref": "../shared/event_common.schema.json#/definitions/documentId",
      "x-catch-ownership": "callable-owned"
    },
    "organizerId": {
      "$ref": "../shared/event_common.schema.json#/definitions/documentId",
      "x-catch-ownership": "callable-owned"
    },
    "uid": {
      "$ref": "../shared/event_common.schema.json#/definitions/documentId",
      "x-catch-ownership": "callable-owned"
    },
    "cohortAtOffer": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120,
      "x-catch-ownership": "callable-owned"
    },
    "status": {
      "$ref": "../shared/event_common.schema.json#/definitions/eventWaitlistOfferStatus",
      "x-catch-ownership": "callable-owned"
    },
    "source": {
      "$ref": "../shared/event_common.schema.json#/definitions/eventWaitlistOfferSource",
      "x-catch-ownership": "callable-owned"
    },
    "offeredBy": {
      "type": ["string", "null"],
      "minLength": 1,
      "maxLength": 180,
      "x-catch-ownership": "callable-owned"
    },
    "offeredAt": {
      "$ref": "../shared/event_common.schema.json#/definitions/timestamp",
      "x-catch-ownership": "callable-owned"
    },
    "expiresAt": {
      "$ref": "../shared/event_common.schema.json#/definitions/timestamp",
      "x-catch-ownership": "callable-owned"
    },
    "decidedAt": {
      "$ref": "../shared/event_common.schema.json#/definitions/nullableTimestamp",
      "x-catch-ownership": "callable-owned"
    },
    "expiringNotifiedAt": {
      "$ref": "../shared/event_common.schema.json#/definitions/nullableTimestamp",
      "x-catch-ownership": "callable-owned"
    },
    "inviteLinkId": {
      "type": ["string", "null"],
      "minLength": 1,
      "maxLength": 180,
      "x-catch-ownership": "callable-owned"
    },
    "createdAt": {
      "$ref": "../shared/event_common.schema.json#/definitions/timestamp",
      "x-catch-ownership": "callable-owned"
    },
    "updatedAt": {
      "$ref": "../shared/event_common.schema.json#/definitions/timestamp",
      "x-catch-ownership": "callable-owned"
    },
    "synthetic": {
      "$ref": "../shared/event_common.schema.json#/definitions/demoMetadataFields/synthetic"
    },
    "seedPrefix": {
      "$ref": "../shared/event_common.schema.json#/definitions/demoMetadataFields/seedPrefix"
    },
    "scenario": {
      "$ref": "../shared/event_common.schema.json#/definitions/demoMetadataFields/scenario"
    },
    "demoOps": {
      "$ref": "../shared/event_common.schema.json#/definitions/demoMetadataFields/demoOps"
    },
    "demoOpsId": {
      "$ref": "../shared/event_common.schema.json#/definitions/demoMetadataFields/demoOpsId"
    },
    "demoOpsCommand": {
      "$ref": "../shared/event_common.schema.json#/definitions/demoMetadataFields/demoOpsCommand"
    }
  }
}
