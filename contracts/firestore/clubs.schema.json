{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://catch.app/contracts/firestore/clubs.schema.json",
  "title": "ClubDocument",
  "description": "Canonical club document stored at clubs/{clubId}. The club id is the document id and is not stored in document data.",
  "type": "object",
  "additionalProperties": false,
  "x-firestore-collection": "clubs",
  "x-firestore-path": "clubs/{clubId}",
  "x-document-id-field": "id",
  "x-owner": "create/update/archive/delete club callables; aggregate projections are trigger-owned",
  "x-internal-demo-fields": [
    "synthetic",
    "seedPrefix",
    "scenario",
    "demoOps",
    "demoOpsId",
    "demoOpsCommand"
  ],
  "required": [
    "name",
    "description",
    "location",
    "area",
    "hostUserId",
    "hostName",
    "hostAvatarUrl",
    "ownerUserId",
    "hostUserIds",
    "hostProfiles",
    "createdAt",
    "imageUrl",
    "profileImageUrl",
    "tags",
    "memberCount",
    "rating",
    "reviewCount",
    "nextEventAt",
    "nextEventLabel",
    "instagramHandle",
    "phoneNumber",
    "email",
    "status",
    "archived",
    "archivedAt",
    "archiveReason"
  ],
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120,
      "x-catch-ownership": "callable-owned"
    },
    "description": {
      "type": "string",
      "minLength": 1,
      "maxLength": 2000,
      "x-catch-ownership": "callable-owned"
    },
    "location": {
      "$ref": "../shared/event_common.schema.json#/definitions/citySlug",
      "x-catch-ownership": "callable-owned"
    },
    "area": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120,
      "x-catch-ownership": "callable-owned"
    },
    "hostUserId": {
      "$ref": "../shared/event_common.schema.json#/definitions/documentId",
      "x-catch-ownership": "callable-owned"
    },
    "hostName": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120,
      "x-catch-ownership": "callable-owned"
    },
    "hostAvatarUrl": {
      "$ref": "../shared/event_common.schema.json#/definitions/urlOrNull",
      "x-catch-ownership": "callable-owned"
    },
    "ownerUserId": {
      "$ref": "../shared/event_common.schema.json#/definitions/documentId",
      "x-catch-ownership": "callable-owned"
    },
    "hostUserIds": {
      "type": "array",
      "minItems": 1,
      "maxItems": 20,
      "uniqueItems": true,
      "items": {
        "$ref": "../shared/event_common.schema.json#/definitions/documentId"
      },
      "x-catch-ownership": "callable-owned"
    },
    "hostProfiles": {
      "type": "array",
      "minItems": 1,
      "maxItems": 20,
      "items": {
        "$ref": "../shared/event_common.schema.json#/definitions/clubHostProfile"
      },
      "x-catch-ownership": "callable-owned"
    },
    "createdAt": {
      "$ref": "../shared/event_common.schema.json#/definitions/timestamp",
      "x-catch-ownership": "callable-owned"
    },
    "imageUrl": {
      "$ref": "../shared/event_common.schema.json#/definitions/urlOrNull",
      "x-catch-ownership": "callable-owned"
    },
    "profileImageUrl": {
      "$ref": "../shared/event_common.schema.json#/definitions/urlOrNull",
      "x-catch-ownership": "callable-owned"
    },
    "clubPhotos": {
      "type": "array",
      "maxItems": 12,
      "items": {
        "$ref": "../embedded/uploaded_photo.schema.json"
      },
      "x-catch-ownership": "callable-owned"
    },
    "logoPhoto": {
      "anyOf": [
        {"$ref": "../embedded/uploaded_photo.schema.json"},
        {"type": "null"}
      ],
      "x-catch-ownership": "callable-owned"
    },
    "tags": {
      "type": "array",
      "maxItems": 20,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 80
      },
      "x-catch-ownership": "callable-owned"
    },
    "memberCount": {
      "$ref": "../shared/event_common.schema.json#/definitions/nonNegativeInteger",
      "x-catch-ownership": "trigger-owned"
    },
    "rating": {
      "type": "number",
      "minimum": 0,
      "maximum": 5,
      "x-catch-ownership": "trigger-owned"
    },
    "reviewCount": {
      "$ref": "../shared/event_common.schema.json#/definitions/nonNegativeInteger",
      "x-catch-ownership": "trigger-owned"
    },
    "nextEventAt": {
      "$ref": "../shared/event_common.schema.json#/definitions/nullableTimestamp",
      "x-catch-ownership": "trigger-owned"
    },
    "nextEventLabel": {
      "type": [
        "string",
        "null"
      ],
      "maxLength": 240,
      "x-catch-ownership": "trigger-owned"
    },
    "instagramHandle": {
      "$ref": "../shared/event_common.schema.json#/definitions/contactString",
      "x-catch-ownership": "callable-owned"
    },
    "phoneNumber": {
      "$ref": "../shared/event_common.schema.json#/definitions/contactString",
      "x-catch-ownership": "callable-owned"
    },
    "email": {
      "$ref": "../shared/event_common.schema.json#/definitions/contactString",
      "x-catch-ownership": "callable-owned"
    },
    "status": {
      "$ref": "../shared/event_common.schema.json#/definitions/clubLifecycleStatus",
      "x-catch-ownership": "callable-owned"
    },
    "archived": {
      "type": "boolean",
      "x-catch-ownership": "callable-owned"
    },
    "archivedAt": {
      "$ref": "../shared/event_common.schema.json#/definitions/nullableTimestamp",
      "x-catch-ownership": "callable-owned"
    },
    "archiveReason": {
      "type": [
        "string",
        "null"
      ],
      "maxLength": 500,
      "x-catch-ownership": "callable-owned"
    },
    "hostDefaults": {
      "$ref": "../shared/event_common.schema.json#/definitions/clubHostDefaults",
      "x-catch-ownership": "callable-owned"
    },
    "synthetic": {
      "$ref": "../shared/event_common.schema.json#/definitions/demoMetadataFields/synthetic"
    },
    "seedPrefix": {
      "$ref": "../shared/event_common.schema.json#/definitions/demoMetadataFields/seedPrefix"
    },
    "scenario": {
      "$ref": "../shared/event_common.schema.json#/definitions/demoMetadataFields/scenario"
    },
    "demoOps": {
      "$ref": "../shared/event_common.schema.json#/definitions/demoMetadataFields/demoOps"
    },
    "demoOpsId": {
      "$ref": "../shared/event_common.schema.json#/definitions/demoMetadataFields/demoOpsId"
    },
    "demoOpsCommand": {
      "$ref": "../shared/event_common.schema.json#/definitions/demoMetadataFields/demoOpsCommand"
    }
  }
}
