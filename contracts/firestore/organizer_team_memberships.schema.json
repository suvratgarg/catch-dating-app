{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://catch.app/contracts/firestore/organizer_team_memberships.schema.json",
  "title": "OrganizerTeamMembershipDocument",
  "description": "Canonical owner or manager edge stored at organizerTeamMemberships/{organizerId_uid}.",
  "type": "object",
  "additionalProperties": false,
  "x-firestore-collection": "organizerTeamMemberships",
  "x-firestore-path": "organizerTeamMemberships/{membershipId}",
  "x-document-id-field": "id",
  "x-owner": "organizer team callables",
  "required": ["organizerId", "uid", "role", "status", "createdAt", "removedAt"],
  "properties": {
    "organizerId": {"$ref": "../shared/event_common.schema.json#/definitions/documentId", "x-catch-ownership": "callable-owned"},
    "uid": {"$ref": "../shared/event_common.schema.json#/definitions/documentId", "x-catch-ownership": "callable-owned"},
    "role": {"type": "string", "enum": ["owner", "manager"], "x-catch-ownership": "callable-owned"},
    "status": {"type": "string", "enum": ["active", "removed"], "x-catch-ownership": "callable-owned"},
    "createdAt": {"$ref": "../shared/event_common.schema.json#/definitions/timestamp", "x-catch-ownership": "callable-owned"},
    "removedAt": {"$ref": "../shared/event_common.schema.json#/definitions/nullableTimestamp", "x-catch-ownership": "callable-owned"}
  }
}
