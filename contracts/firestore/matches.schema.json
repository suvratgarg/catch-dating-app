{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://catch.app/contracts/firestore/matches.schema.json",
  "title": "MatchDocument",
  "description": "Canonical match document stored at matches/{matchId}.",
  "type": "object",
  "additionalProperties": false,
  "x-firestore-collection": "matches",
  "x-firestore-path": "matches/{matchId}",
  "x-document-id-field": "id",
  "x-owner": "matching triggers own lifecycle; participants may reset only their unread count",
  "x-internal-demo-fields": [
    "synthetic",
    "seedPrefix",
    "scenario",
    "demoOps",
    "demoOpsId",
    "demoOpsCommand"
  ],
  "required": [
    "user1Id",
    "user2Id",
    "eventIds",
    "createdAt",
    "lastMessageAt",
    "lastMessagePreview",
    "lastMessageSenderId",
    "unreadCounts",
    "status",
    "blockedBy",
    "blockedAt",
    "participantIds"
  ],
  "properties": {
    "user1Id": {
      "$ref": "../shared/event_common.schema.json#/definitions/documentId",
      "x-catch-ownership": "trigger-owned"
    },
    "user2Id": {
      "$ref": "../shared/event_common.schema.json#/definitions/documentId",
      "x-catch-ownership": "trigger-owned"
    },
    "eventIds": {
      "type": "array",
      "minItems": 0,
      "uniqueItems": true,
      "items": {
        "$ref": "../shared/event_common.schema.json#/definitions/documentId"
      },
      "x-catch-ownership": "trigger-owned"
    },
    "createdAt": {
      "$ref": "../shared/event_common.schema.json#/definitions/timestamp",
      "x-catch-ownership": "trigger-owned"
    },
    "lastMessageAt": {
      "$ref": "../shared/event_common.schema.json#/definitions/nullableTimestamp",
      "x-catch-ownership": "trigger-owned"
    },
    "lastMessagePreview": {
      "type": [
        "string",
        "null"
      ],
      "maxLength": 300,
      "x-catch-ownership": "trigger-owned"
    },
    "lastMessageSenderId": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1,
      "maxLength": 180,
      "x-catch-ownership": "trigger-owned"
    },
    "unreadCounts": {
      "type": "object",
      "additionalProperties": {
        "$ref": "../shared/event_common.schema.json#/definitions/nonNegativeInteger"
      },
      "x-catch-ownership": "client-runtime-writable"
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "blocked"
      ],
      "x-catch-ownership": "trigger-owned"
    },
    "blockedBy": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1,
      "maxLength": 180,
      "x-catch-ownership": "trigger-owned"
    },
    "blockedAt": {
      "$ref": "../shared/event_common.schema.json#/definitions/nullableTimestamp",
      "x-catch-ownership": "trigger-owned"
    },
    "participantIds": {
      "type": "array",
      "minItems": 2,
      "maxItems": 2,
      "uniqueItems": true,
      "items": {
        "$ref": "../shared/event_common.schema.json#/definitions/documentId"
      },
      "x-catch-ownership": "trigger-owned"
    },
    "conversationType": {
      "type": "string",
      "enum": [
        "match",
        "clubHostInquiry"
      ],
      "x-catch-ownership": "trigger-owned"
    },
    "clubId": {
      "$ref": "../shared/event_common.schema.json#/definitions/documentId",
      "x-catch-ownership": "trigger-owned"
    },
    "organizerId": {
      "$ref": "../shared/event_common.schema.json#/definitions/documentId",
      "x-catch-ownership": "trigger-owned"
    },
    "synthetic": {
      "$ref": "../shared/event_common.schema.json#/definitions/demoMetadataFields/synthetic"
    },
    "seedPrefix": {
      "$ref": "../shared/event_common.schema.json#/definitions/demoMetadataFields/seedPrefix"
    },
    "scenario": {
      "$ref": "../shared/event_common.schema.json#/definitions/demoMetadataFields/scenario"
    },
    "demoOps": {
      "$ref": "../shared/event_common.schema.json#/definitions/demoMetadataFields/demoOps"
    },
    "demoOpsId": {
      "$ref": "../shared/event_common.schema.json#/definitions/demoMetadataFields/demoOpsId"
    },
    "demoOpsCommand": {
      "$ref": "../shared/event_common.schema.json#/definitions/demoMetadataFields/demoOpsCommand"
    }
  }
}
