{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://catch.app/contracts/firestore/organizer_schedule_locks.schema.json",
  "title": "OrganizerScheduleLockDocument",
  "description": "Server-owned time-slot claim stored at organizerScheduleLocks/{organizerId_slot}.",
  "type": "object",
  "additionalProperties": false,
  "x-firestore-collection": "organizerScheduleLocks",
  "x-firestore-path": "organizerScheduleLocks/{lockId}",
  "x-document-id-field": "lockId",
  "x-owner": "event schedule conflict callables",
  "required": ["ownerType", "ownerId", "slot", "eventId", "organizerId", "startTimeMillis", "endTimeMillis"],
  "properties": {
    "ownerType": {"type": "string", "const": "organizer", "x-catch-ownership": "callable-owned"},
    "ownerId": {"$ref": "../shared/event_common.schema.json#/definitions/documentId", "x-catch-ownership": "callable-owned"},
    "slot": {"type": "integer", "minimum": 0, "x-catch-ownership": "callable-owned"},
    "eventId": {"$ref": "../shared/event_common.schema.json#/definitions/documentId", "x-catch-ownership": "callable-owned"},
    "organizerId": {"$ref": "../shared/event_common.schema.json#/definitions/documentId", "x-catch-ownership": "callable-owned"},
    "startTimeMillis": {"type": "integer", "minimum": 0, "x-catch-ownership": "callable-owned"},
    "endTimeMillis": {"type": "integer", "minimum": 0, "x-catch-ownership": "callable-owned"}
  }
}
