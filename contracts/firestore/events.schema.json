{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://catch.app/contracts/firestore/events.schema.json",
  "title": "EventDocument",
  "description": "Canonical event document stored at events/{eventId}. The event id is the document id and is not stored in document data.",
  "type": "object",
  "additionalProperties": false,
  "x-firestore-collection": "events",
  "x-firestore-path": "events/{eventId}",
  "x-document-id-field": "id",
  "x-owner": "host create/update/cancel/delete callables; booking and attendance aggregates are callable-owned",
  "x-internal-demo-fields": [
    "synthetic",
    "seedPrefix",
    "scenario",
    "demoOps",
    "demoOpsId",
    "demoOpsCommand"
  ],
  "required": [
    "clubId",
    "startTime",
    "endTime",
    "meetingPoint",
    "meetingLocation",
    "startingPointLat",
    "startingPointLng",
    "locationDetails",
    "eventFormat",
    "distanceKm",
    "pace",
    "capacityLimit",
    "description",
    "priceInPaise",
    "bookedCount",
    "checkedInCount",
    "waitlistedCount",
    "status",
    "cancelledAt",
    "cancellationReason",
    "constraints",
    "genderCounts",
    "cohortCounts",
    "waitlistedCohortCounts",
    "discoveryMarketId",
    "discoveryCityName",
    "discoveryActivityKind",
    "discoveryGeoCell",
    "discoveryHasOpenSpots",
    "discoveryAvailability",
    "discoveryOpenCohorts",
    "discoveryWaitlistCohorts",
    "discoveryInviteRequired",
    "discoveryMembershipRequired",
    "discoveryManualApprovalRequired",
    "discoveryMinAge",
    "discoveryMaxAge"
  ],
  "properties": {
    "clubId": {
      "$ref": "../shared/event_common.schema.json#/definitions/documentId",
      "x-catch-ownership": "callable-owned"
    },
    "startTime": {
      "$ref": "../shared/event_common.schema.json#/definitions/timestamp",
      "x-catch-ownership": "callable-owned"
    },
    "endTime": {
      "$ref": "../shared/event_common.schema.json#/definitions/timestamp",
      "x-catch-ownership": "callable-owned"
    },
    "meetingPoint": {
      "type": "string",
      "minLength": 1,
      "maxLength": 240,
      "x-catch-ownership": "callable-owned"
    },
    "meetingLocation": {
      "$ref": "../shared/event_common.schema.json#/definitions/eventMeetingLocation",
      "x-catch-ownership": "callable-owned"
    },
    "startingPointLat": {
      "$ref": "../shared/profile_common.schema.json#/definitions/strictLatitude",
      "x-catch-ownership": "callable-owned"
    },
    "startingPointLng": {
      "$ref": "../shared/profile_common.schema.json#/definitions/strictLongitude",
      "x-catch-ownership": "callable-owned"
    },
    "locationDetails": {
      "type": [
        "string",
        "null"
      ],
      "maxLength": 1000,
      "x-catch-ownership": "callable-owned"
    },
    "photoUrl": {
      "$ref": "../shared/event_common.schema.json#/definitions/urlOrNull",
      "x-catch-ownership": "callable-owned"
    },
    "eventPhotos": {
      "type": "array",
      "maxItems": 12,
      "items": {
        "$ref": "../embedded/uploaded_photo.schema.json"
      },
      "x-catch-ownership": "callable-owned"
    },
    "distanceKm": {
      "type": "number",
      "minimum": 0,
      "maximum": 100,
      "x-catch-ownership": "callable-owned"
    },
    "eventFormat": {
      "$ref": "../shared/event_common.schema.json#/definitions/eventFormatSnapshot",
      "x-catch-ownership": "callable-owned"
    },
    "pace": {
      "$ref": "../shared/event_common.schema.json#/definitions/paceLevel",
      "x-catch-ownership": "callable-owned"
    },
    "capacityLimit": {
      "type": "integer",
      "minimum": 1,
      "maximum": 1000,
      "x-catch-ownership": "callable-owned"
    },
    "description": {
      "type": "string",
      "maxLength": 2000,
      "x-catch-ownership": "callable-owned"
    },
    "priceInPaise": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100000000,
      "x-catch-ownership": "callable-owned"
    },
    "currency": {
      "type": "string",
      "pattern": "^[A-Z]{3}$",
      "x-catch-ownership": "callable-owned"
    },
    "bookedCount": {
      "$ref": "../shared/event_common.schema.json#/definitions/nonNegativeInteger",
      "x-catch-ownership": "callable-owned"
    },
    "checkedInCount": {
      "$ref": "../shared/event_common.schema.json#/definitions/nonNegativeInteger",
      "x-catch-ownership": "callable-owned"
    },
    "waitlistedCount": {
      "$ref": "../shared/event_common.schema.json#/definitions/nonNegativeInteger",
      "x-catch-ownership": "callable-owned"
    },
    "status": {
      "$ref": "../shared/event_common.schema.json#/definitions/eventLifecycleStatus",
      "x-catch-ownership": "callable-owned"
    },
    "cancelledAt": {
      "$ref": "../shared/event_common.schema.json#/definitions/nullableTimestamp",
      "x-catch-ownership": "callable-owned"
    },
    "cancellationReason": {
      "type": [
        "string",
        "null"
      ],
      "maxLength": 500,
      "x-catch-ownership": "callable-owned"
    },
    "constraints": {
      "$ref": "../shared/event_common.schema.json#/definitions/eventConstraints",
      "x-catch-ownership": "callable-owned"
    },
    "eventPolicy": {
      "$ref": "../shared/event_common.schema.json#/definitions/eventPolicyBundle",
      "x-catch-ownership": "callable-owned"
    },
    "genderCounts": {
      "type": "object",
      "additionalProperties": {
        "$ref": "../shared/event_common.schema.json#/definitions/nonNegativeInteger"
      },
      "x-catch-ownership": "callable-owned"
    },
    "cohortCounts": {
      "type": "object",
      "additionalProperties": {
        "$ref": "../shared/event_common.schema.json#/definitions/nonNegativeInteger"
      },
      "x-catch-ownership": "callable-owned"
    },
    "waitlistedCohortCounts": {
      "type": "object",
      "additionalProperties": {
        "$ref": "../shared/event_common.schema.json#/definitions/nonNegativeInteger"
      },
      "x-catch-ownership": "callable-owned"
    },
    "discoveryMarketId": {
      "$ref": "../shared/event_common.schema.json#/definitions/marketId",
      "x-catch-ownership": "callable-owned"
    },
    "discoveryCityName": {
      "$ref": "../shared/event_common.schema.json#/definitions/strictCitySlug",
      "x-catch-ownership": "callable-owned"
    },
    "discoveryActivityKind": {
      "$ref": "../shared/event_common.schema.json#/definitions/activityKind",
      "x-catch-ownership": "callable-owned"
    },
    "discoveryGeoCell": {
      "type": [
        "string",
        "null"
      ],
      "pattern": "^-?\\d+:-?\\d+$",
      "x-catch-ownership": "callable-owned"
    },
    "discoveryHasOpenSpots": {
      "type": "boolean",
      "x-catch-ownership": "callable-owned"
    },
    "discoveryAvailability": {
      "type": "string",
      "enum": [
        "open",
        "waitlist",
        "gated",
        "full",
        "cancelled"
      ],
      "x-catch-ownership": "callable-owned"
    },
    "discoveryOpenCohorts": {
      "type": "array",
      "maxItems": 4,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": [
          "menInterestedInWomen",
          "womenInterestedInMen",
          "queerOrOpen",
          "nonBinaryOrOther"
        ]
      },
      "x-catch-ownership": "callable-owned"
    },
    "discoveryWaitlistCohorts": {
      "type": "array",
      "maxItems": 4,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": [
          "menInterestedInWomen",
          "womenInterestedInMen",
          "queerOrOpen",
          "nonBinaryOrOther"
        ]
      },
      "x-catch-ownership": "callable-owned"
    },
    "discoveryInviteRequired": {
      "type": "boolean",
      "x-catch-ownership": "callable-owned"
    },
    "discoveryMembershipRequired": {
      "type": "boolean",
      "x-catch-ownership": "callable-owned"
    },
    "discoveryManualApprovalRequired": {
      "type": "boolean",
      "x-catch-ownership": "callable-owned"
    },
    "discoveryMinAge": {
      "type": "integer",
      "minimum": 0,
      "maximum": 120,
      "x-catch-ownership": "callable-owned"
    },
    "discoveryMaxAge": {
      "type": "integer",
      "minimum": 0,
      "maximum": 120,
      "x-catch-ownership": "callable-owned"
    },
    "adminSearch": {
      "type": "object",
      "additionalProperties": false,
      "description": "Server-owned deterministic search projection used by admin event publishing. Rebuildable from canonical event and organizer fields; not consumed by the app.",
      "required": [
        "tokens",
        "sortKey",
        "updatedAt",
        "updatedBySource"
      ],
      "properties": {
        "tokens": {
          "type": "array",
          "maxItems": 120,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 2,
            "maxLength": 80,
            "pattern": "^[a-z0-9-]+$"
          }
        },
        "sortKey": {
          "type": "string",
          "minLength": 1,
          "maxLength": 160,
          "pattern": "^[a-z0-9-]+(?:-[a-z0-9-]+)*$"
        },
        "updatedAt": {
          "$ref": "../shared/event_common.schema.json#/definitions/timestamp"
        },
        "updatedBySource": {
          "type": "string",
          "enum": [
            "adminUpdateEventDetails",
            "adminEventSearchBackfill"
          ]
        }
      },
      "x-catch-ownership": "server-only"
    },
    "synthetic": {
      "$ref": "../shared/event_common.schema.json#/definitions/demoMetadataFields/synthetic"
    },
    "seedPrefix": {
      "$ref": "../shared/event_common.schema.json#/definitions/demoMetadataFields/seedPrefix"
    },
    "scenario": {
      "$ref": "../shared/event_common.schema.json#/definitions/demoMetadataFields/scenario"
    },
    "demoOps": {
      "$ref": "../shared/event_common.schema.json#/definitions/demoMetadataFields/demoOps"
    },
    "demoOpsId": {
      "$ref": "../shared/event_common.schema.json#/definitions/demoMetadataFields/demoOpsId"
    },
    "demoOpsCommand": {
      "$ref": "../shared/event_common.schema.json#/definitions/demoMetadataFields/demoOpsCommand"
    }
  }
}
