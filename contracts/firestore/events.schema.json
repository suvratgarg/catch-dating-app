{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://catch.app/contracts/firestore/events.schema.json",
  "title": "EventDocument",
  "description": "Canonical event document stored at events/{eventId}. The event id is the document id and is not stored in document data.",
  "type": "object",
  "additionalProperties": false,
  "x-firestore-collection": "events",
  "x-firestore-path": "events/{eventId}",
  "x-document-id-field": "id",
  "x-owner": "host create/update/cancel/delete callables; booking and attendance aggregates are callable-owned",
  "x-internal-demo-fields": [
    "synthetic",
    "seedPrefix",
    "scenario",
    "demoOps",
    "demoOpsId",
    "demoOpsCommand"
  ],
  "required": [
    "clubId",
    "startTime",
    "endTime",
    "meetingPoint",
    "startingPointLat",
    "startingPointLng",
    "locationDetails",
    "eventFormat",
    "distanceKm",
    "pace",
    "capacityLimit",
    "description",
    "priceInPaise",
    "bookedCount",
    "checkedInCount",
    "waitlistedCount",
    "status",
    "cancelledAt",
    "cancellationReason",
    "constraints",
    "genderCounts",
    "cohortCounts",
    "waitlistedCohortCounts"
  ],
  "properties": {
    "clubId": {
      "$ref": "../shared/event_common.schema.json#/definitions/documentId"
    },
    "startTime": {
      "$ref": "../shared/event_common.schema.json#/definitions/timestamp"
    },
    "endTime": {
      "$ref": "../shared/event_common.schema.json#/definitions/timestamp"
    },
    "meetingPoint": {
      "type": "string",
      "minLength": 1,
      "maxLength": 240
    },
    "startingPointLat": {
      "$ref": "../shared/event_common.schema.json#/definitions/latitude"
    },
    "startingPointLng": {
      "$ref": "../shared/event_common.schema.json#/definitions/longitude"
    },
    "locationDetails": {
      "type": ["string", "null"],
      "maxLength": 1000
    },
    "photoUrl": {
      "$ref": "../shared/event_common.schema.json#/definitions/urlOrNull"
    },
    "distanceKm": {
      "type": "number",
      "minimum": 0,
      "maximum": 100
    },
    "eventFormat": {
      "$ref": "../shared/event_common.schema.json#/definitions/eventFormatSnapshot"
    },
    "pace": {
      "$ref": "../shared/event_common.schema.json#/definitions/paceLevel"
    },
    "capacityLimit": {
      "type": "integer",
      "minimum": 1,
      "maximum": 1000
    },
    "description": {
      "type": "string",
      "maxLength": 2000
    },
    "priceInPaise": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100000000
    },
    "bookedCount": {
      "$ref": "../shared/event_common.schema.json#/definitions/nonNegativeInteger"
    },
    "checkedInCount": {
      "$ref": "../shared/event_common.schema.json#/definitions/nonNegativeInteger"
    },
    "waitlistedCount": {
      "$ref": "../shared/event_common.schema.json#/definitions/nonNegativeInteger"
    },
    "status": {
      "$ref": "../shared/event_common.schema.json#/definitions/eventLifecycleStatus"
    },
    "cancelledAt": {
      "$ref": "../shared/event_common.schema.json#/definitions/nullableTimestamp"
    },
    "cancellationReason": {
      "type": ["string", "null"],
      "maxLength": 500
    },
    "constraints": {
      "$ref": "../shared/event_common.schema.json#/definitions/eventConstraints"
    },
    "eventPolicy": {
      "$ref": "../shared/event_common.schema.json#/definitions/eventPolicyBundle"
    },
    "genderCounts": {
      "type": "object",
      "additionalProperties": {
        "$ref": "../shared/event_common.schema.json#/definitions/nonNegativeInteger"
      }
    },
    "cohortCounts": {
      "type": "object",
      "additionalProperties": {
        "$ref": "../shared/event_common.schema.json#/definitions/nonNegativeInteger"
      }
    },
    "waitlistedCohortCounts": {
      "type": "object",
      "additionalProperties": {
        "$ref": "../shared/event_common.schema.json#/definitions/nonNegativeInteger"
      }
    },
    "synthetic": {
      "$ref": "../shared/event_common.schema.json#/definitions/demoMetadataFields/synthetic"
    },
    "seedPrefix": {
      "$ref": "../shared/event_common.schema.json#/definitions/demoMetadataFields/seedPrefix"
    },
    "scenario": {
      "$ref": "../shared/event_common.schema.json#/definitions/demoMetadataFields/scenario"
    },
    "demoOps": {
      "$ref": "../shared/event_common.schema.json#/definitions/demoMetadataFields/demoOps"
    },
    "demoOpsId": {
      "$ref": "../shared/event_common.schema.json#/definitions/demoMetadataFields/demoOpsId"
    },
    "demoOpsCommand": {
      "$ref": "../shared/event_common.schema.json#/definitions/demoMetadataFields/demoOpsCommand"
    }
  }
}
