{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://catch.app/contracts/firestore/public_profiles.schema.json",
  "title": "PublicProfileDocument",
  "description": "Backend-owned public profile projection stored at publicProfiles/{uid}. The uid is the document id and is not stored in document data.",
  "type": "object",
  "additionalProperties": false,
  "x-firestore-collection": "publicProfiles",
  "x-firestore-path": "publicProfiles/{uid}",
  "x-document-id-field": "uid",
  "x-owner": "syncPublicProfile trigger",
  "x-source": "users/{uid}",
  "required": [
    "name",
    "age",
    "gender",
    "profilePrompts",
    "profilePhotos",
    "activityPreferences"
  ],
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 80,
      "x-catch-ownership": "trigger-owned"
    },
    "age": {
      "$ref": "../shared/profile_common.schema.json#/definitions/age",
      "x-catch-ownership": "trigger-owned"
    },
    "gender": {
      "$ref": "../shared/profile_common.schema.json#/definitions/gender",
      "x-catch-ownership": "trigger-owned"
    },
    "synthetic": {
      "type": "boolean",
      "description": "Internal demo seed marker used for cleanup and diagnostics."
    },
    "seedPrefix": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120,
      "description": "Internal demo seed prefix used for cleanup and diagnostics."
    },
    "scenario": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120,
      "description": "Internal demo seed scenario name used for cleanup and diagnostics."
    },
    "demoOps": {
      "type": "boolean",
      "description": "Internal demo-operations marker used for cleanup and diagnostics."
    },
    "demoOpsId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 180,
      "description": "Internal demo-operations id used for cleanup and diagnostics."
    },
    "demoOpsCommand": {
      "type": "string",
      "minLength": 1,
      "maxLength": 80,
      "description": "Internal demo-operations command name used for cleanup and diagnostics."
    },
    "profilePrompts": {
      "type": "array",
      "maxItems": 3,
      "items": {
        "$ref": "../embedded/profile_prompt_answer.schema.json"
      },
      "x-catch-ownership": "trigger-owned"
    },
    "profilePhotos": {
      "type": "array",
      "maxItems": 6,
      "items": {
        "$ref": "../embedded/profile_photo.schema.json"
      },
      "x-catch-ownership": "trigger-owned"
    },
    "city": {
      "$ref": "../shared/profile_common.schema.json#/definitions/citySlug",
      "x-catch-ownership": "trigger-owned"
    },
    "height": {
      "$ref": "../shared/profile_common.schema.json#/definitions/heightCm",
      "x-catch-ownership": "trigger-owned"
    },
    "occupation": {
      "$ref": "../shared/profile_common.schema.json#/definitions/nullableString",
      "x-catch-ownership": "trigger-owned"
    },
    "company": {
      "$ref": "../shared/profile_common.schema.json#/definitions/nullableString",
      "x-catch-ownership": "trigger-owned"
    },
    "education": {
      "$ref": "../shared/profile_common.schema.json#/definitions/educationLevel",
      "x-catch-ownership": "trigger-owned"
    },
    "religion": {
      "$ref": "../shared/profile_common.schema.json#/definitions/religion",
      "x-catch-ownership": "trigger-owned"
    },
    "languages": {
      "type": "array",
      "maxItems": 20,
      "uniqueItems": true,
      "items": {
        "$ref": "../shared/profile_common.schema.json#/definitions/language"
      },
      "x-catch-ownership": "trigger-owned"
    },
    "relationshipGoal": {
      "$ref": "../shared/profile_common.schema.json#/definitions/relationshipGoal",
      "x-catch-ownership": "trigger-owned"
    },
    "drinking": {
      "$ref": "../shared/profile_common.schema.json#/definitions/drinkingHabit",
      "x-catch-ownership": "trigger-owned"
    },
    "smoking": {
      "$ref": "../shared/profile_common.schema.json#/definitions/smokingHabit",
      "x-catch-ownership": "trigger-owned"
    },
    "workout": {
      "$ref": "../shared/profile_common.schema.json#/definitions/workoutFrequency",
      "x-catch-ownership": "trigger-owned"
    },
    "diet": {
      "$ref": "../shared/profile_common.schema.json#/definitions/dietaryPreference",
      "x-catch-ownership": "trigger-owned"
    },
    "children": {
      "$ref": "../shared/profile_common.schema.json#/definitions/childrenStatus",
      "x-catch-ownership": "trigger-owned"
    },
    "activityPreferences": {
      "$ref": "../embedded/activity_preferences.schema.json",
      "x-catch-ownership": "trigger-owned"
    }
  },
  "x-internal-demo-fields": [
    "synthetic",
    "seedPrefix",
    "scenario",
    "demoOps",
    "demoOpsId",
    "demoOpsCommand"
  ],
  "x-legacy-tolerated-fields": [
    "bio"
  ],
  "x-hidden-fields": [
    "phoneNumber",
    "email",
    "instagramHandle",
    "latitude",
    "longitude",
    "interestedInGenders",
    "preferences"
  ]
}
